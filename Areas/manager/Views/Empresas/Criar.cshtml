<div>
    @Html.ActionLink("Voltar", "Index")
</div>



@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
<script src="~/Assets/js/custom.js"></script>

    <script>
        $("#EmpresaCnpj").mask("99.999.999/9999-99");
        $("#sAgendaHoraIni").mask("99:99");
        $("#sAgendaHoraFim").mask("99:99");

    </script>

