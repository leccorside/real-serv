            </div>
            <div class="span4">
                <label>Token</label>
                @Html.TextBoxFor(model => model.EmpresaTrelloToken, new { @class = "span12", maxlength = "150" })
            </div>
            <div class="span4">
                <label>Organização</label>
                @Html.TextBoxFor(model => model.EmpresaTrelloOrganization, new { @class = "span12", maxlength = "150" })
            </div>

