@model Models.Empresa

@{
    
    var acao = "Cadastrar";
    if (Model.EmpresaId > 0)
    {
        acao = "Alterar";
    }


    ViewBag.Title = acao + " Empresa";
    Layout = "~/Areas/manager/Views/Shared/_Layout.cshtml";


    var logotipo = "~/Assets/img/logotipos/" + Model.EmpresaId + ".png?" + DateTime.Now.Second;

    var bgHome = "~/Assets/img/bg/" + Model.EmpresaId + "Home.jpg?" + DateTime.Now.Second;
    var bgInterna = "~/Assets/img/bg/" + Model.EmpresaId + "Interna.jpg?" + DateTime.Now.Second;
    
}


@section Breadcrumb{
    <li class="active"><span class="divider">/</span>    @Html.ActionLink("Empresas", "Index", new { id = 0 })</li>
}



@using (Html.BeginForm("Criar", "Empresas", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.ValidationSummary(true)

    if (Model.EmpresaId > 0)
    {
    @Html.Hidden("EmpresaId", Model.EmpresaId);
                                              acao = "Alterar";
    }
    <legende>Dados</legende>
    
    
    
    <div class="row-fluid">
