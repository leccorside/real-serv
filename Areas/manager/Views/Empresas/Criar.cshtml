    </div>
    if (Model.EmpresaId > 0)
    {
    <div class="row-fluid">
        <div class="span4"><img src="@VirtualPathUtility.ToAbsolute(logotipo)" /></div>
        <div class="span4"><div style="width:300px;height:200px;background-image:url(@VirtualPathUtility.ToAbsolute(bgHome)) ;background-size: 100% 100%;"></div></div>
        <div class="span4"><div style="width:300px;height:200px;background-image:url(@VirtualPathUtility.ToAbsolute(bgInterna)) ;background-size: 100% 100%;"></div></div>
    </div>
