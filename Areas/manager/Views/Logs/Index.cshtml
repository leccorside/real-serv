@model IEnumerable<Models.Log>

@{
    ViewBag.Title = "Últimas 200 operações realizadas no sistema";
    Layout = "~/Areas/manager/Views/Shared/_Layout.cshtml";
}

@section Breadcrumb{

}


<div class="row-fluid">

    <div class="span12">
        <table class="footable table table-bordered table-striped">
            <thead>
                <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Controle)
                </th>
                <th data-hide="phone,tablet">
                    @Html.DisplayNameFor(model => model.Acao)
                </th>
                <th data-hide="phone,tablet">
                    @Html.DisplayNameFor(model => model.Historico)
                </th>
                <th data-hide="phone,tablet">
                    @Html.DisplayNameFor(model => model.EmpresaId)
                </th>
                <th data-hide="phone,tablet">
                    @Html.DisplayNameFor(model => model.RegIdInicio)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.RegDtInicio)
                </th>

            </tr>
            </thead>
            

            @foreach (var item in Model)
            {
                <tr>
                    <td><small>
                        @Html.DisplayFor(modelItem => item.Controle)</small>
                    </td>
                    <td><small>
                        @Html.DisplayFor(modelItem => item.Acao)</small>
                    </td>
                    <td>
                        <small>
                            @item.Historico.Replace(",", Environment.NewLine)
                        </small>
                    </td>
                    <td><small>
                        @Html.DisplayFor(modelItem => item.EmpresaId)</small>
                    </td>
                    <td><small>
                        @Html.DisplayFor(modelItem => item.RegIdInicio)</small>
                    </td>
                    <td><small>
                        @Html.DisplayFor(modelItem => item.RegDtInicio)</small>
                    </td>

                </tr>
            }

        </table>
    </div>
</div>



@section Scripts {
    <script src="http://ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js" type="text/javascript"></script>
    <script src="~/Assets/themes/metro/js/footable.js"></script>
    <script type="text/javascript">
        $(function () {
            $('.footable').footable({
                breakpoints: {
                    phone: 400,
                    tablet: 800
                }
            });
        });
    </script>



}