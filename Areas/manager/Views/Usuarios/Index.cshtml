@model IEnumerable<Models.Usuario>


@{
    ViewBag.Title = "Usuários";
    Layout = "~/Areas/manager/Views/Shared/_Layout.cshtml";
    var idEmpresa = Url.RequestContext.RouteData.Values["id"];
    
}


@section Breadcrumb{
    <li class="active"><span class="divider">/</span>    @Html.ActionLink("Empresas", "Index", "Empresas")</li>

}


<div class="row-fluid">
    <div class="span12">
        @Html.ActionLink("+ Criar", "Criar", new { id = 0, @idEmpresa=idEmpresa }, new { @class = "btn btn-primary" })
    </div>
</div>




<div class="row-fluid">

    <div class="span12">
        <table class="footable table table-bordered table-striped">
                    <thead>
                        <tr>

                            <th>
                                Nome
                            </th>

                            <th data-hide="phone,tablet">
                                E-Mail
                            </th>

                            <th data-hide="phone,tablet">
                                Login
                            </th>

                            <th data-hide="phone,tablet">
                                Perfil
                            </th>
                              <th data-hide="phone,tablet">
                                @Html.DisplayNameFor(model => model.RegDtInicio)
                            </th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td width="100%">
                                    @Html.DisplayFor(modelItem => item.UsuarioNome)
                                </td>
                                <td nowrap>
                                    @Html.DisplayFor(modelItem => item.UsuarioEmail)
                                </td>
                                <td nowrap>
                                    @Html.DisplayFor(modelItem => item.UsuarioLogin)
                                </td>
                                <td nowrap>
                                    @Html.DisplayFor(modelItem => item.PerfilNome)
                                </td>
                                 <td nowrap>
                                    @Html.DisplayFor(modelItem => item.RegDtInicio)
                                </td>
                                <td nowrap>
                                    @Html.ActionLink("Alterar", "Criar", new { id = item.UsuarioId , @idEmpresa=idEmpresa}, new { @class = "btn btn-mini" }) |
                                    @Html.ActionLink("Redefinir Senha", "RedefinirSenha", new { id = item.UsuarioId, @idEmpresa=idEmpresa }, new { @class = "btn btn-mini" }) |
            @Html.ActionLink("Excluir", "Deletar", new { id = item.UsuarioId }, new { @class = "btn btn-mini" })
                                </td>
                            </tr>
                        }

                    </tbody>



                </table>
    </div>
</div>



@section Scripts {
    <script src="http://ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js" type="text/javascript"></script>
    <script src="~/Assets/themes/metro/js/footable.js"></script>
    <script type="text/javascript">
        $(function () {
            $('.footable').footable({
                breakpoints: {
                    phone: 400,
                    tablet: 800
                }
            });
        });
    </script>



}