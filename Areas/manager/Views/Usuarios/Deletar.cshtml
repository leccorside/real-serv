

@model Models.Usuario

@{
    ViewBag.Title = "Excluíndo Usuários";
    Layout = "~/Areas/manager/Views/Shared/_Layout.cshtml";
}


@section Breadcrumb{
    <li class="active"><span class="divider">/</span> @Html.ActionLink("Empresas", "Index", "Empresas")</li>
    <li class="active"><span class="divider">/</span>    @Html.ActionLink("Usuários", "Index", new { @id = Model.EmpresaId })</li>
}




<div class="alert">
    <button type="button" class="close" data-dismiss="alert">&times;</button>
    <h2>Atencão!</h2>
    Você tem certeza que deseja apagar esse Usuário?
</div>


<div class="cwell">
    <fieldset>

        <legend>Usuário</legend>
        
        <div class="row-fluid">

            <div class="span4">
                <div class="display-label">

                    <label>Nome</label>



                </div>
                <div class="display-field">
                    @Html.DisplayFor(model => model.UsuarioNome)
                </div>

            </div>
            <div class="span4">
                <div class="display-label">

                    <label>Perfil</label>



                </div>
                <div class="display-field">
                    @Html.DisplayFor(model => model.UsuarioLogin)
                </div>

            </div>

             <div class="span4">
                <div class="display-label">

                    <label>Criado em</label>



                </div>
                <div class="display-field">
                    @Html.DisplayFor(model => model.UsuarioEmail)
                </div>

        </div>

            </div>

        
        <div class="row-fluid">

           
            <div class="span6">
                <div class="display-label">

                    <label>Perfil</label>



                </div>
                <div class="display-field">
                    @Html.DisplayFor(model => model.PerfilNome)
                </div>

            </div>

             <div class="span6">
                <div class="display-label">

                    <label>Criado em</label>



                </div>
                <div class="display-field">
                    @Html.DisplayFor(model => model.RegDtInicio)
                </div>

        </div>

            </div>
    </fieldset>
    <br />

    @using (Html.BeginForm())
    {
        <div class="row-fluid">
            <div class="span12">
                @Html.HiddenFor(model => model.UsuarioId)
                @Html.HiddenFor(model => model.EmpresaId)
                <p class="pull-right">
                    <input type="submit" value="Apagar" class="btn btn-large btn-danger" />
                </p>

                <p class="pull-left">
                    @Html.ActionLink("Voltar", "Index", new { @id = Model.EmpresaId })
                </p>
            </div>
        </div>    
    }



</div>
