
@model Models.ChangePasswordModel



@{
    

    

    var acao = "Alterar";


    ViewBag.Title = acao + " Senha";
    Layout = "~/Areas/manager/Views/Shared/_Layout.cshtml";
}





@section Breadcrumb{
    <li class="active"><span class="divider">/</span> @Html.ActionLink("Empresas", "Index", "Empresas")</li>
    <li class="active"><span class="divider">/</span>    @Html.ActionLink("Usuários", "Index", new { @id = Model.EmpresaId })</li>
}


<div class="cwell">
    @using (Html.BeginForm("RedefinirSenha", "Usuarios", FormMethod.Post))
    {
        @Html.ValidationSummary(true)

        @Html.HiddenFor(model => model.EmpresaId);
            @Html.HiddenFor(model => model.UsuarioId);

                                                     @Html.Hidden("oldPassword", Guid.NewGuid());
     
        
    
        <div class="control-group">
            <label>@Html.LabelFor(model=>model.newPassword)</label>
            @Html.EditorFor(model => model.newPassword)
            @Html.ValidationMessageFor(model => model.newPassword)
        </div>
        
        
        <div class="control-group">
            <label>@Html.LabelFor(model=>model.ConfirmPassword)</label>
            @Html.EditorFor(model => model.ConfirmPassword)
            @Html.ValidationMessageFor(model => model.ConfirmPassword)
        </div>
        
        
        
      

        <div class="form-actions">


            <input type="submit" value="@acao" class="btn btn-primary  btn-large"  TabIndex=10 />

        </div>
            
    }
    <div>
        @Html.ActionLink("Voltar", "Index", new { @id = Model.EmpresaId })
    </div>
</div>





@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
