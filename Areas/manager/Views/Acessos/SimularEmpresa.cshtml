@{
    ViewBag.Title = "Simular Acesso";
    Layout = "~/Areas/manager/Views/Shared/_Layout.cshtml";
}



@section Breadcrumb{


}


<div class="cwell">
    @using (Html.BeginForm())
    {
        <div class="row-fluid">
            <div class="span12">
                <label>Selecione o usuário que deseja simular</label>
            @Html.DropDownList("UsuarioId", (SelectList)ViewBag.DdlEmpresas, new { @class="chosen-select span6" })
            </div>

        </div>
        
        <div class="form-actions">

            <button type="submit" value="Simular" class="btn btn-primary  btn-large" >Simular <i class="fa fa-space-shuttle "></i></button>


        </div>
    }


</div>


@section Scripts {
   <script>
        jQuery(function () {
            
            $('#UsuarioId').trigger('chosen:activate');

        });
    </script>
    }