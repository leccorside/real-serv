@model IEnumerable<Models.Acesso>


@{
    ViewBag.Title = "Acessos";
    Layout = "~/Areas/manager/Views/Shared/_Layout.cshtml";
}


@section Breadcrumb{


}


<div class="row-fluid">
    <div class="span12">
        @Html.ActionLink("+ Criar", "Criar", new { id = 0 }, new { @class = "btn btn-primary" })
    </div>
</div>




<div class="row-fluid">

    <div class="span12">
            <table class="footable table table-bordered table-striped">
            <thead>
                <tr>

                    <th>
                        @Html.DisplayNameFor(model => model.AcessoId)
                    </th>
                    <th data-hide="phone,tablet">
                        @Html.DisplayNameFor(model => model.Controle)
                    </th>
                    <th data-hide="phone,tablet">
                        @Html.DisplayNameFor(model => model.Acao)
                    </th>
                    <th data-hide="phone,tablet">
                        @Html.DisplayNameFor(model => model.Descricao)
                    </th>
                    <th></th>
                </tr>
            </thead>
            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            @Html.DisplayFor(modelItem => item.AcessoId)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Controle)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Acao)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Descricao)
                        </td>
                        <td nowrap>
                            @Html.ActionLink("Alterar", "Alterar", new { id = item.AcessoId }, new { @class = "btn btn-mini" }) |
            @Html.ActionLink("Excluir", "Deletar", new { id = item.AcessoId }, new { @class = "btn btn-mini" })
                        </td>
                    </tr>
                }

            </tbody>



        </table>
    </div>
</div>




@section Scripts {
    <script src="http://ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js" type="text/javascript"></script>
    <script src="~/Assets/themes/metro/js/footable.js"></script>
    <script type="text/javascript">
        $(function () {
            $('.footable').footable({
                breakpoints: {
                    phone: 400,
                    tablet: 800
                }
            });
        });
    </script>



}