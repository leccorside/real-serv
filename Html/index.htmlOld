<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title></title>
    <!--JQuery-->
    <script type="text/javascript" src="https://code.jquery.com/jquery-2.2.4.min.js"></script>
    <script type="text/javascript" src="https://code.jquery.com/ui/1.10.3/jquery-ui.min.js"></script>
    <script src="/Scripts/pesquisa-cliente.js"></script>
    <link rel="stylesheet" href="../Content/bootstrap-theme.css">
    <link rel="stylesheet" href="../Content/bootstrap.min.css">
    <link rel="stylesheet" href="../Content/AdminLTE.css">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.4.1/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gasparesganga-jquery-loading-overlay@2.1.6/dist/loadingoverlay.min.js"></script>
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/gasparesganga-jquery-loading-overlay@1.5.4/src/loadingoverlay.min.js"></script>
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/gasparesganga-jquery-loading-overlay@1.5.4/extras/loadingoverlay_progress/loadingoverlay_progress.min.js"></script>
    <script src="/Html/js/UrlsDeRequisicao.js" type="text/javascript"></script>

</head>
<body>
    <div class="container-fluid">
        <div class="animated fadeIn">
            <div class="row">
                <div class="col-xs-12 col-md-12">
                    <div class="card">
                        <div class="card-header">
                            <div align="center">
                                <img class="ant-menu-item" src="https://rdacrm.blob.core.windows.net/imagens/GrupoReal.jpeg" width="500" height="131" border="0">
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-lg-4 col-md-4 col-sm-4">
                                    <div class="form-group">
                                        <label for="condominio" class="">Condomínio</label>
                                        <input id="condominio" disabled="" placeholder="Condomínio: " type="text" class="form-control">
                                    </div>
                                </div>
                                <div class="col-lg-4 col-md-4 col-sm-4">
                                    <div class="form-group">
                                        <label for="endereco" class="">Endereço</label>
                                        <input id="endereco" disabled="" placeholder="Endereço: " type="text" class="form-control">
                                    </div>
                                </div>
                                <div class="col-lg-4 col-md-4 col-sm-4">
                                    <div class="form-group">
                                        <label for="cidade" class="">Cidade</label>
                                        <input id="cidade" disabled="" placeholder="Cidade: " type="text" class="form-control">
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <!--<div class="col-lg-4 col-md-4 col-sm-4">
                                    <div class="form-group">
                                        <label for="nome" class="">Nome </label>
                                        <input id="nome" disabled="" placeholder="Nome" type="text" class="form-control">
                                    </div>
                                </div>
                                <div class="col-lg-4 col-md-4 col-sm-4">
                                    <div class="form-group">
                                        <label for="perfil" class="">Perfil </label>
                                        <input id="perfil" disabled="" placeholder="Perfil " type="text" class="form-control">
                                    </div>
                                </div>-->
                                <div class="col-lg-4 col-md-4 col-sm-4">
                                    <div class="form-group">
                                        <label for="email" class="">E-mail </label>
                                        <input id="email" disabled="" placeholder="E-mail " type="email" class="form-control">
                                    </div>
                                </div>
                            </div>
                            <hr>
                            <div class="row">
                                <div class="col-lg-12 col-md-12 col-sm-12">
                                    <div class="form-group">
                                        <div align="center">Sua resposta é muito importante para nós, por isso gostariámos que respondesse com os seguintes critérios:</div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-lg-12 col-md-12 col-sm-12">
                                    <div class="form-group">
                                        <div align="center">
                                            <img class="ant-menu-item" src="https://rdacrm.blob.core.windows.net/imagens/PesquisaImg.png" width="600" height="142" border="0">
                                        </div>
                                    </div>
                                </div>
                            </div>
                             
                            <hr>
                            <div class="row" >
                                <div class="col-lg-12 col-md-12 col-sm-12" >
                                    <div class="form-group" align="center">
                                        <h4>1) Serviço de portaria.</h4>
                                        
                                        <label class="radio-inline">
                                            <input type="radio" value="1" id="1" name="optradio1" checked>Péssimo 
                                        </label>
                                        <label class="radio-inline">
                                            <input type="radio" value="2" id="2" name="optradio1">Ruim
                                        </label>
                                        <label class="radio-inline">
                                            <input type="radio" value="3" id="3" name="optradio1">Regular
                                        </label>
                                        <label class="radio-inline">
                                            <input type="radio" value="4" id="4" name="optradio1">Bom
                                        </label>
                                        <label class="radio-inline">
                                            <input type="radio" value="5" id="5" name="optradio1">Excelente
                                        </label>
                                    </div>
                                </div>
                                <div class="col-lg-12 col-md-4 col-sm-4">
                                    <div class="form-group">
                                        <div align="center">
                                            <img name="pergunta1" src="https://rdacrm.blob.core.windows.net/imagens/PesqSatisfacao.png" width="80" height="80" border="0">
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <hr>
                            <div class="row">
                                <div class="col-lg-12 col-md-12 col-sm-12">
                                    <div class="form-group" align="center">
                                        <h4>2) Serviço de limpeza.</h4>

                                        <label class="radio-inline">
                                            <input type="radio" value="1" id="1" name="optradio2" checked>Péssimo
                                        </label>
                                        <label class="radio-inline">
                                            <input type="radio" value="2" id="2" name="optradio2">Ruim
                                        </label>
                                        <label class="radio-inline">
                                            <input type="radio" value="3" id="3" name="optradio2">Regular
                                        </label>
                                        <label class="radio-inline">
                                            <input type="radio" value="4" id="4" name="optradio2">Bom
                                        </label>
                                        <label class="radio-inline">
                                            <input type="radio" value="5" id="5" name="optradio2">Excelente
                                        </label>
                                    </div>
                                </div>
                                <div class="col-lg-12 col-md-4 col-sm-4">
                                    <div class="form-group">
                                        <div align="center">
                                            <img name="pergunta2" src="https://rdacrm.blob.core.windows.net/imagens/PesqSatisfacao.png" width="80" height="80" border="0">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <hr>
                            
                            
                            <div class="row">
                                <div class="col-lg-12 col-md-12 col-sm-12">
                                    <div class="form-group" align="center">
                                        <h4>3) Serviço de zeladoria.</h4>

                                        <label class="radio-inline">
                                            <input type="radio" value="1" id="1" name="optradio3" checked>Péssimo
                                        </label>
                                        <label class="radio-inline">
                                            <input type="radio" value="2" id="2" name="optradio3">Ruim
                                        </label>
                                        <label class="radio-inline">
                                            <input type="radio" value="3" id="3" name="optradio3">Regular
                                        </label>
                                        <label class="radio-inline">
                                            <input type="radio" value="4" id="4"  name="optradio3">Bom
                                        </label>
                                        <label class="radio-inline">
                                            <input type="radio" value="5" id="5" name="optradio3">Excelente
                                        </label>
                                    </div>
                                </div>
                                <div class="col-lg-12 col-md-4 col-sm-4">
                                    <div class="form-group">
                                        <div align="center">
                                            <img name="pergunta3" src="https://rdacrm.blob.core.windows.net/imagens/PesqSatisfacao.png" width="80" height="80" border="0">
                                        </div>
                                    </div>
                                </div>
                            </div> 
                            
                            <hr>

                            <div class="row">
                                <div class="col-lg-12 col-md-12 col-sm-12">
                                    <div class="form-group" align="center">
                                        <h4>4) Serviço de supervisão (atendimento da empresa por parte dos supervisores).</h4>

                                        <label class="radio-inline">
                                            <input type="radio" value="1" id="1" name="optradio4" checked>Péssimo
                                        </label>
                                        <label class="radio-inline">
                                            <input type="radio" value="2" id="2" name="optradio4">Ruim
                                        </label>
                                        <label class="radio-inline">
                                            <input type="radio" value="3" id="3" name="optradio4">Regular
                                        </label>
                                        <label class="radio-inline">
                                            <input type="radio" value="4" id="4" name="optradio4">Bom
                                        </label>
                                        <label class="radio-inline">
                                            <input type="radio" value="5" id="5" name="optradio4">Excelente
                                        </label>
                                    </div>
                                </div>
                                <div class="col-lg-12 col-md-4 col-sm-4">
                                    <div class="form-group">
                                        <div align="center">
                                            <img name="pergunta3" src="https://rdacrm.blob.core.windows.net/imagens/PesqSatisfacao.png" width="80" height="80" border="0">
                                        </div>
                                    </div>
                                </div>
                            </div>  
                            <hr>
                            <div class="row">
                                <div class="col-lg-12 col-md-12 col-sm-12">
                                    <div class="form-group" align="center">
                                        <label for="obs" class="">Observação</label>
                                        <textarea name="obs" id="obs" rows="4" placeholder="Por favor nos informe a sua crítica e ou sugestão" class="form-control"></textarea>
                                    </div>
                                </div>
                            </div>
                            <hr>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-lg-12" align="center">
                    <button id="upload-button" class="btn btn-lg btn-primary" onclick="enviarFileFromStream()">
                    <i class="fas fa-cloud-upload-alt"></i> Enviar</button>
                </div>
            </div>
            <hr/>
        </div>

    </div>
</body>
</html>