    <div class="col-lg-12">
        <div class="col-lg-12" style="background-color: white">
            <form class='form-horizontal' id='formFiltrosTela' role='form' action=''>
                <div class="col-lg-12">

                    <h2>
                        Dashboard pesquisa
                        <span class="glyphicon glyphicon-dashboard"></span>
                    </h2>
                     
                  
                    <div class="row">
                        <div class="col-form col-lg-4 col-md-4 col-sm-8">

                            <div class="form-group">
                                <div align="right">
                                    <select class="form-control" id="cbCliente" onchange="AtualizarPesquisaPorPosto();"></select>
                                </div>
                            </div>

                        </div>
                    </div>


                        <div id="loading"></div>



                        <div class="row">
                            <div class="col-form col-lg-6 col-md-4 col-sm-8">


                                <div class="form-group">
                                    <div align="right">
                                        <div id="chart_div" style="width: 900px; height: 500px;"></div> <!--Portaria-->
                                    </div>
                                </div>

                            </div>
                            <div class="col-form col-lg-6 col-md-4 col-sm-4">
                                <div class="form-group">
                                    <div align="left">
                                        <div id="chart_div2" style="width: 900px; height: 500px;"></div>  <!--Limpeza-->
                                    </div>
                                </div>
                            </div>
                        </div>
                        <hr>
                        <div class="row">
                            <div class="col-form col-lg-6 col-md-4 col-sm-8">


                                <div class="form-group">
                                    <div align="right">
                                        <div id="chart_div3" style="width: 900px; height: 500px;"></div>  <!--Zeladoria-->
                                    </div>
                                </div>

                            </div>
                            <div class="col-form col-lg-6 col-md-4 col-sm-4">
                                <div class="form-group">
                                    <div align="left">
                                        <div id="chart_div4" style="width: 900px; height: 500px;"></div>  <!--Supervisão-->
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr>

                    <div id="piechart" style="width: 900px; height: 500px;"> </div>

                    </div>
            </form>

            

        </div>  
