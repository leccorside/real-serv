@model PetaPoco.Page<Models.Convenio>

@{
    ViewBag.Title = "Convênios";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";


    var user = new BLL.Usuarios();
    var ConveniosFaixasFatoresFiliais_index = user.ControleAcesso("index", "ConveniosFaixasFatoresFiliais");
}




@section Breadcrumb{

    <li class="active">@Html.ActionLink("Configurações", "Configuracoes", "Principal")</li>


}



<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">
            <div class="hpanel">
                <div class="panel-heading hbuilt">
                    <div class=" p-xs font-normal">
                        <div class="row">
                            <div class="col-lg-6">
                                @Html.ActionLink("+ Criar", "Criar", new { id = 0 }, new { @class = "btn btn-primary" })
                            </div>
                            <div class="col-lg-6">
                                @if (ConveniosFaixasFatoresFiliais_index)
                                {
                                    <a href="@Url.Content("~/ConveniosFaixasFatoresFiliais/index")" class="btn btn-outline btn-primary pull-right"><i class="fa fa-check-square-o"></i>Definição de Fatores por @BLL.Usuarios.GetEntidadeFilial()</a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="panel-body">
                    <!-- tirei daqui-->

                    <div class="table-responsive">
                        <table cellpadding="1" cellspacing="1" class="table" id="table_produtos">
                            <thead>
                                <tr style="font-size: 12px;">
                                    <th></th>
                                    <th>
                                        @Html.DisplayNameFor(model => model.Items[0].ConvenioNome)
                                    </th>
                                    <th data-hide="phone,tablet">
                                        @Html.DisplayNameFor(model => model.Items[0].RegDtInicio)
                                    </th>
                                    <th data-hide="phone,tablet">Alterar / Excluir</th>
                                </tr>
                            </thead>
                            <tbody>

                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>
                                            <div class="input-group">
                                                <div class="input-group-btn">
                                                    <button class=" btn btn-outline btn-primary dropdown-toggle" data-toggle="dropdown" type="button" aria-expanded="true"><i class="pe-7s-tools fa-x"></i><span class="caretx"></span></button>
                                                    <ul class="dropdown-menu ">

                                                        <li><a href="@Url.Content("~/ConveniosPlanos/Index/?ConvenioId=" + item.ConvenioId)" class=""><i class="fa fa-medkit"></i>Planos</a></li>
                                                        <li><a href="@Url.Content("~/Convenios/Produtos/" + item.ConvenioId)" class=""><i class="fa fa-heartbeat"></i>Produtos</a></li>
                                                        <li class="divider"></li>
                                                        <li><a href="@Url.Content("~/Convenios/ProdutosCopiarValor/" + item.ConvenioId + "/?")" class="fancybox.iframe fancybox" data-toggle="tooltip" data-original-title="Copiar valor de tabela de outro convênio"  title="Copiar valor de tabela de outro convênio" data-placement="top"><i class="fa fa-calculator"></i>Copiar valor de outro convênio</a></li>
                                                    </ul>
                                                </div>
                                            </div>
                                        </td>
                                        <td width="100%">
                                            @Html.DisplayFor(modelItem => item.ConvenioNome)<br />

                                        </td>
                                        <td nowrap data-hide="phone,tablet" style="display: table-cell">
                                            @Html.DisplayFor(modelItem => item.RegDtInicio)
                                        </td>
                                        <td nowrap data-hide="phone,tablet" style="display: table-cell">

                                            @Html.ActionLink("Alterar", "Criar", new { id = item.ConvenioId }, new { @class = "btn btn-outline btn-primary btn-xs" })&nbsp;
                                    @Html.ActionLink("Excluir", "Deletar", new { id = item.ConvenioId }, new { @class = "btn btn-outline btn-danger btn-xs" })
                                        </td>
                                    </tr>
                                }

                            </tbody>



                        </table>


                    </div>

                    @Html.FortunaPaginacao(Convert.ToInt16(Model.TotalPages))


                    <!-- ./tirei daqui-->
                </div>
            </div>
        </div>
    </div>
</div>



















@section Styles{
    @Styles.Render("~/bundles/fancybox/css")
}


@section Scripts {
    @Scripts.Render("~/bundles/fancybox/js")
    
    <script>
        $(".fancybox_recarrega").fancybox({
            fitToView: false,
            width: '98%',
            autoSize: false,
            padding: 0,
            helpers: {
                overlay: {
                    locked: true
                }
            },
            beforeClose: function () {
                RecarregaPagina();
            },
        });
        $(".fancybox").fancybox({
            toolbar: false,
            padding: 0,
            fitToView: false,
            width: '80%',
            autoSize: true,
            helpers: {
                overlay: {
                    locked: true
                }
            }
        });

        function RecarregaPagina() {
            window.location.reload(true);
        }
    </script>

}



