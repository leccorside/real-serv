@model Models.Convenio


@{
    

    
    var acao = "Cadastrar";
    if (Model.ConvenioId > 0)
    {
        acao = "Alterar";
    }


    ViewBag.Title = acao + " Convênio";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";   
}





@section Breadcrumb{
    <li class="active">@Html.ActionLink("Configurações", "Configuracoes", "Principal")</li>
    <li class="active">@Html.ActionLink("Convênios", "Index", new { id = 0 })</li>
}



<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">

            <div class="hpanel">

                <div class="panel-body">
                    <!-- conteudo aqui -->


                    @using (Html.BeginForm("Criar", "Convenios", FormMethod.Post, new { @class = "form-horizontal" }))
                    {
                        @Html.ValidationSummary(true)

                        if (Model.ConvenioId > 0)
                        {
                        @Html.Hidden("ConvenioId", Model.ConvenioId);
                                                                    acao = "Alterar";
                        }
    
       
                        <div class="row">
                            <div class="col-lg-12">
                                @Html.LabelFor(model => model.ConvenioNome)
                                @Html.TextBoxFor(model => model.ConvenioNome, new { @class = "form-control" })
                            </div>
                        </div>                  
        
            
         
                        <br />

                        <div class="row">
                            <div class="col-lg-12">
                                <input type="submit" value="Salvar" class="btn btn-primary btn-large" tabindex="11" />
                                @Html.ActionLink("Voltar", "Index", null, new { @class = "btn btn-outline btn-primary " })
                            </div>

                        </div>
            
                    }

                    <!-- ./conteudo aqui -->
                </div>

            </div>
        </div>
    </div>
</div>













@section Scripts {
    <script>
        $("#ConvenioNome").focus();
    </script>
}
