@model IEnumerable<Models.UsuarioFuncao>

@{
    ViewBag.Title = "Fun&ccedil;&otilde;es";
}

@section Breadcrumb{


}

<p>
    @Html.ActionLink("+ Criar", "Criar", new { id = 0 }, new { @class = "btn btn-primary" })
</p>
<table class="table table-bordered table-striped table-highlight table-hover table-condensed ">
    <thead>
        <tr>
            <th>#</th>
            <th>
                @Html.DisplayNameFor(model => model.UsuarioFuncaoNome)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RegDtInicio)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.UsuarioFuncaoId)</td>
                <td>
                    @Html.DisplayFor(modelItem => item.UsuarioFuncaoNome)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.RegDtInicio)
                </td>
                <td>
                    <a href="~/UsuariosFuncoes/Criar/@item.UsuarioFuncaoId" class="btn btn-mini"><i class="fa fa-pencil-square-o"></i>Alterar</a> | 
            <a href="~/UsuariosFuncoes/Deletar/@item.UsuarioFuncaoId" class="btn btn-mini"><i class="icon-trash"></i>Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@{
    //Controles de pagina&ccedil;&atilde;o
    int qtdPaginas = Convert.ToInt16(ViewBag.qtdPaginas);   
}
@Html.Paginacao(qtdPaginas)
