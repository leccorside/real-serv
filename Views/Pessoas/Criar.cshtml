@model Models.Pessoa

@{
    var user = new BLL.Usuarios();
    //var vtipo = (string)ViewBag.tipo.ToString();
    var vtipo = Model.PessoaCategoria;

    var bllProdutos = new BLL.Produtos();
    var bllPessoasDependentes = new BLL.PessoasDependentes();
    var bllPessoasDadosClinicos = new BLL.PessoasDadosClinicos();

    var bllMedGuias = new BLL.MedGuias();

    var bllContratos = new BLL.Contratos();

    var listaDadosClinicos = bllPessoasDadosClinicos.ListarPorPessoaId(Model.PessoaID);

    var listaGuias = bllMedGuias.ListarPorPessoaId(Model.PessoaID);


    var bllPessoasTermosAceite = new BLL.PessoasTermosAceite();

    var listaAceites = bllPessoasTermosAceite.ListarPorPessoaId(Model.PessoaID);
    var _PessoasTermosAceite = BLL.Usuarios.VerificaAcesso("TermosAceite", "Pessoas");

    //IEnumerable<Models.Produto> ddlProdutos = new List<Models.Produto>();

    //IEnumerable<int> ProdutosSelecionados = new List<int>();

    var vname = "";
    switch (vtipo)
    {
        case "C":
            vname = BLL.Usuarios.GetEntidadeCliente();
            break;
        case "F":
            vname = BLL.Usuarios.GetEntidadeFornecedor();
            break;
        case "O":
            vname = BLL.Usuarios.GetEntidadeFuncionario();

            //ddlProdutos = bllProdutos.Listar();
            //ProdutosSelecionados = bllProdutos.PessoasProdutosListar((int)Model.PessoaID);

            break;
        case "A":
            vname = BLL.Usuarios.GetEntidade4();
            break;
        default:
            vname = "Indefinido";

            break;
    }
    var acao = "Cadastrar";

    if (Model.PessoaID > 0)
    {
        acao = "Alterar";
    }

    var bllPessoasAnexos = new BLL.PessoasAnexos();
    var listaAnexos = bllPessoasAnexos.Listar(Model.PessoaID);

    var PostosDeServicos_Index = user.ControleAcesso("Index", "PostosDeServicos");

    var _MedGuiasAdministrador = BLL.Usuarios.VerificaAcesso("Administrador", "MedGuias");

    var _FinanceiroLancamento = BLL.Usuarios.VerificaAcesso("Lancamento", "Financeiro");

    var _MedGuiasGuiaNF = BLL.Usuarios.VerificaAcesso("GuiaNF", "MedGuias");

    var _MedGuiasCriar = BLL.Usuarios.VerificaAcesso("Criar", "MedGuias");

    var _PessoasDeletar = BLL.Usuarios.VerificaAcesso("Deletar", "Pessoas");


    var _MedGuiasAnexos = BLL.Usuarios.VerificaAcesso("Anexos", "MedGuias");

    var _ContratosPreparar = BLL.Usuarios.VerificaAcesso("Preparar", "Contratos");

    var _PessoasPlanosInscricoes_index = BLL.Usuarios.VerificaAcesso("index", "PessoasPlanosInscricoes");


    var _Regras_pessoas_cliente_formacao = user.ControleAcesso("pessoas_cliente_formacao", "Regras");

    var _PRCPropostas_Index = BLL.Usuarios.VerificaAcesso("Index", "PRCPropostas");



    bool exibeDadosBancarios = (vtipo != "C") ? true : false;

    var registrarvalores_fichacadastral = user.ControleAcesso("registrarvalores", "fichacadastral");
    var medguias_criar = user.ControleAcesso("Criar", "MedGuias");

    var listaDependentes = bllPessoasDependentes.ListarTudoPorPessoaId(Model.PessoaID);

    var associe_seusdados_maxlen_pessoa_nome = BLL.Configuracoes.CarregarPorEmpresaId("associe_seusdados_maxlen_pessoa_nome", Model.EmpresaId) ?? "";
    associe_seusdados_maxlen_pessoa_nome = (associe_seusdados_maxlen_pessoa_nome == "" ? "200" : associe_seusdados_maxlen_pessoa_nome);

    var pessoas_f_docs_padrao = BLL.Configuracoes.CarregarPorEmpresaId("pessoas_f.documentos.padrao", Model.EmpresaId) ?? "";
    var pessoas_f_docs_obrigatorio = BLL.Configuracoes.CarregarPorEmpresaId("pessoas_f.documentos.obrigatorio", Model.EmpresaId) ?? "";
    
}

@{
    ViewBag.Title = acao + " " + vname;

    if (Model.ExibirModal)
    {
        Layout = "~/Views/Shared/_FortunaLayoutModal.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_FortunaLayout.cshtml";
    }
    
    
}





@section Breadcrumb{
    <li class="active"> @Html.ActionLink(vname, "Index", new { id = 0, tipo = vtipo })</li>
}

<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">
             @if (user.ControleAcesso("pessoas_documento_duplicados", "Regras"))
             {
                <div class="alert alert-warning">
                    <i class="fa fa-exclamation-triangle" aria-hidden="true"></i><strong>Atenção</strong> Seu perfil está habilitado para cadastro de @vname duplicados.
                </div>
             }
            
              @if (vtipo == "F" && _PRCPropostas_Index)
            {
                var bllPRCPropostas = new BLL.PRCPropostas();
                  var listaIndices = bllPRCPropostas.ListaQtdPorAdvogadoId(Model.PessoaID);
                  
                <br />               
                  <a href="#" onclick="javascript:$('#tab_20').click()">
                  <div class="row">
                      @foreach (var item in listaIndices)
                      {
                          var classe = "";
                          switch (item.result_B)
                          {
                              case "Total Realizado":
                                  classe = "text-success";
                                  break;
                              case "Total Não Realizado":
                                  classe = "text-danger";
                                  break;
                              case "Total Andamento":
                                  classe = "text-warning";
                                  break;
                              default:
                                  break;
                          }
                              
                              
                      <div class="col-lg-3" style="">
                          <div class="hpanel">
                              <div class="panel-body text-center h-180">
                                  

                                  
                                  <h4 class="font-extra-bold no-margins @classe">@item.result_B</h4>
                                  <br />
                                  <div class="row">
                                <div class="col-xs-3" style="">
                                    <small class="stats-label">Propostas</small>
                                    <h5>@item.result_D</h5>
                                </div>

                                <div class="col-xs-9" style="">
                                    <small class="stats-label">Total Bruto</small>
                                    <h5>@decimal.Parse(item.result_C).ToString("C")</h5>
                                </div>
                            </div>
                              </div>

                          </div>
                      </div>    
                      }
                      
                  </div>                                                 
                      </a>         
                <br />
            }

            
            
            
        

            <div class="hpanel">
                <!-- tab aqui_-->
                @if (vtipo == "O" && Model.PessoaID > 0)
                {
                    <ul class="nav nav-tabs">
                        <li class="active">
                            <a href="#">Dados Cadastrais</a>
                        </li>
                        
                        @if (vtipo.ToString() == "O" && user.ControleAcesso("pessoas_funcionario_completo", "Regras"))
                        {
                            <li>@Html.ActionLink("Produtos", "Produtos", new { id = Model.PessoaID, tipo = vtipo }, new { @class = "" })</li>
                        }
                        @if (user.ControleAcesso("pessoas_servicos_prestados", "Regras"))
                        {
                            <li>@Html.ActionLink("Valores do Serviços prestados", "DefinirValores", new { id = Model.PessoaID, tipo = Model.PessoaCategoria }, new { @class = "" })</li>  
                        }
                        @if (user.ControleAcesso("pessoas_indicacoes", "Regras"))
                        {
                            <li>@Html.ActionLink("Indicações", "Indicacoes", new { id = Model.PessoaID, tipo = Model.PessoaCategoria }, new { @class = "" })</li>                
                        }

                    </ul>
                }
                else
                {
                    <ul class="nav nav-tabs">

                        <li class="active"><a data-toggle="tab" href="#tab-1" aria-expanded="true">Dados Cadastrais</a></li>
                        @if (Model.PessoaID > 0 && _PRCPropostas_Index)
                        {
                            <li class=""><a data-toggle="tab" href="#tab-20" id="tab_20" aria-expanded="false">Propostas</a></li>
                            <li class=""><a data-toggle="tab" href="#tab-30" aria-expanded="false">Status</a></li>
                            <li class=""><a data-toggle="tab" href="#tab-40" aria-expanded="false">Documentos</a></li>
                        }
                    </ul>
                }
                <!-- tab aqui-->
                <div class="tab-content">
                    
                    
                    <div id="tab-1" class="tab-pane active">
                        <div class="panel-body">
                            <!-- conteudo aqui -->
                            @using (Html.BeginForm("Criar", "Pessoas", FormMethod.Post, new { enctype = "multipart/form-data", @id = "form_principal" }))
                            {
                                if (Model.PessoaID > 0)
                                {
                                @Html.HiddenFor(m => m.PessoaID);
                                @Html.HiddenFor(m => m.PessoaCount);
                                }
                                @Html.HiddenFor(m => m.NomeHash)
                                @Html.HiddenFor(m => m.ExibirModal)
                                @Html.HiddenFor(m => m.PessoaGUID)
                                @Html.HiddenFor(m => m.PessoaIntegrado)
                            <!-- DADOS BASICOS -->
                            <legend>Dados Básicos</legend>
                                <div class="row">
                                    <div class="col-lg-9 col-md-9 col-sm-9">
                                        <div class="row">
                                            <div class="col-form col-lg-2 col-md-2 col-sm-2">
                                                <label>Número </label><br />
                                                <p class="form-control-static">@Model.PessoaID</p>
                                            </div>

                                            <div class="col-form col-lg-2 col-md-2 col-sm-2">
                                                <label>Código</label> <a href="#" class="btn btn-xs btn-primary btn-outline" id="btnGerarNovoCodigo"><i class="fa fa-refresh" ></i> Novo</a><br />
                                                @Html.TextBoxFor(model => model.PessoaCodigo, new { @class = "form-control" })
                                            </div>

                                                <div class="col-form col-lg-4 col-md-4 col-sm-4">
                                                <label>@BLL.Usuarios.GetEntidadeFilial():</label><br />
                                                @Html.DropDownListFiliais(Model.PessoaID, "FilialID", Model.FilialID.ToString(), false, "chosen-select form-control ", false)
                                            </div>
                                
                                            <input type="hidden" id="xsx" name="xxx" value="xxx" />
                                            <div class="col-form col-lg-4 col-md-4 col-sm-4">
                                                <label>Tipo:</label><br />
                                                @Html.DropDownListFor(m => m.PessoaTipo, new[] {
                           new SelectListItem() {Text = "PF", Value = "PF"},
                           new SelectListItem() {Text = "PJ", Value = "PJ"},
                           new SelectListItem() {Text = "Estrangeiro", Value = "OU"},
                           }, null, new { onchange = "Select(this.value);", @class = "chosen-select form-control" })
                                            </div>

                                            <div class="col-form col-lg-4 col-md-4 col-sm-4">
                                                <label id="tpDocumento"></label><br />

                                                <div class="input-group">
                                                    @Html.TextBoxFor(model => model.Documento, new { @class = "form-control" })
                                                    <span class="input-group-btn">
                                                         @if (Model.CpfValido == true)
                                                         {
                                                        <button class="btn btn-success " type="submit" name="btnSubmit" value="validar"><i class="fa fa-check"></i></button>    
                                            
                                                         }
                                                         else
                                                         {
                                                        <button class="btn btn-outline btn-primary" type="submit" name="btnSubmit" value="validar"><i class="fa fa-search"></i></button>    
                                                         }
                                                    </span>
                                                </div>

                                            </div>

                                              <div class="col-form col-lg-8 col-md-8 col-sm-8">
                                                <label>Nome Completo</label><br />
                                                  @Html.TextBox("Nome", Model.Nome, new { @class = "form-control max", maxlength = associe_seusdados_maxlen_pessoa_nome })<br />@Html.ValidationMessageFor(model => model.Nome)
                                            </div>

                                            @if (user.ControleAcesso("pessoas_campo_apelido", "Regras"))
                                            {
                                                <div class="col-form col-lg-6 col-md-6 col-sm-6">
                                                    <label>Apelido</label><br />
                                                    @Html.TextBoxFor(model => model.Apelido, new { @class = "form-control" })
                                                    <br />@Html.ValidationMessageFor(model => model.Apelido)
                                                </div>}

                                            <div class="col-form col-lg-6 col-md-6 col-sm-6">
                                                <label style="width:100%">Celular   @if (Model.PessoaID > 0 && Model.Celular != null)
                                                                                    {
                                        
                                                    
                                                    <a href="@Url.Content("~/TemplatesMensagens/Enviar/?PessoaId=" + Model.PessoaID)" class="fancybox_full fancybox.iframe btn btn-outline btn-success btn-xs"><i class="fa fa-whatsapp"></i></a>    
                                                    
                                                                                    } <small class="pull-right" style="font-size: 11px">@Model.Celular</small></label><br />
                                                <div class="input-group m-b"><span class="input-group-addon">
                                                    <label>@Html.CheckBoxFor(model => model.CelularInternacional) cel. inter.</label>
                                                </span>
                                                    @Html.TextBoxFor(model => model.Celular, new { @class = "form-control" })</div>
                                            </div>

                                            @if (vtipo == "C" && user.ControleAcesso("pessoas_clientes_empresa", "Regras"))
                                            {
                                                <div class="col-form col-lg-6 col-md-6 col-sm-6">
                                                    <label>Empresa</label><br />
                                                    @Html.DropDownListFor(model => model.CompanhiaId, (SelectList)ViewBag.DdlCompanhias, "--Nenhuma--", new { @class = "chosen-select form-control" })
                                                </div>
                                            }


                                            @if (vtipo == "O" && user.ControleAcesso("pessoas_funcionario_completo", "Regras"))
                                            {
                                                <div class="col-form col-lg-3 col-md-3 col-sm-3">
                                                    <label>RE</label><br />
                                                    @Html.TextBoxFor(model => model.RE, new { @class = "form-control" })
                                                </div>
                                            }



                                            @if (user.ControleAcesso("pessoas_alterar_tipo ", "Regras") && (int)Model.PessoaID > 0)
                                            {
                                                <div class="col-form col-lg-3 col-md-3 col-sm-3">
                                                    <label>Categoria da Pessoa</label><br />
                                                    <select name="PessoaCategoria" id="PessoaCategoria", class="form-control chosen-select">
                                                        <option value="C" @(vtipo == "C" ? " SELECTED " : "")>@BLL.Usuarios.GetEntidadeCliente()</option>
                                                        <option value="F" @(vtipo == "F" ? " SELECTED " : "")>@BLL.Usuarios.GetEntidadeFornecedor()</option>
                                                        <option value="O" @(vtipo == "O" ? " SELECTED " : "")>@BLL.Usuarios.GetEntidadeFuncionario()</option>
                                                        @if (BLL.Usuarios.GetEmpresaTipoId() == 1)
                                                        {
                                                            <option value="A" @(vtipo == "A" ? " SELECTED " : "")>@BLL.Usuarios.GetEntidade4()</option>    
                                                        }
                                                    </select>
                                                </div>
                                            }
                                            else
                                            {
                                                @Html.Hidden("PessoaCategoria", vtipo)    
                                            }


                                            

                                            @if (vtipo == "C")
                                            {
                                                <div class="col-form col-lg-4 col-md-4 col-sm-4">
                                                <label>Perfil:</label><br />
                                                @Html.DropDownListFor(model => model.PessoaCategoriaSubId, (SelectList)ViewBag.DdlPessoasCategoriasSubs, null, new { @class = "chosen-select form-control" })
                                            
                                                </div>
                                                
                                                <div class="col-form col-lg-4 col-md-4 col-sm-4">
                                                <label>Indicado por:</label><br />
                                                @Html.DropDownListFor(model => model.PessoaIDIndicacao, (SelectList)ViewBag.DdlApresentadoPor, "--Ninguém--", new { @class = "chosen-select form-control" })
                                            
                                                </div>
                                                
                                                
                                                
                                                @*<div class="col-form col-lg-4 col-md-4 col-sm-4">
                                                <label>Formação:</label><br />
                                                @Html.DropDownListPessoasTabelasAux("","",true," form-control ", "selecione", "FormacaoTipo")
                                            
                                                </div>*@
                                                
                                            }

                                            @if (vtipo == "C" && user.ControleAcesso("index", "turmas"))
                                            {<div class="col-form col-lg-3 col-md-3 col-sm-3">
                                                <label>Turma:</label><br />
                                                @Html.DropDownListFor(model => model.TurmaId, (SelectList)ViewBag.DdlTurmas, "--Nenhuma--", new { @class = "chosen-select form-control" })
                                            </div>
                                            }
                                            else
                                            {
                                                @Html.HiddenFor(x => x.TurmaId)
                                            }

                                             @if (user.ControleAcesso("pessoas_campo_exibiragenda", "Regras"))
                                             {<div class="col-form col-lg-2 col-md-2 col-sm-2">
                                                <label>Exibir na agenda</label><br />
                                                <div class="checkbox">
                                                   <label>@Html.CheckBoxFor(model => model.ExibirAgenda) Sim</label>
                                                </div>
                                            </div>
                                                 if (Model.PessoaCategoria == "O")
                                                 {
                                                <div class="col-form col-lg-2 col-md-2 col-sm-2" id="div_exibiragenda_ordem">
                                                    <label>Ordem de Exibição</label><br />
                                                    @Html.TextBoxFor(model => model.ExibirAgendaOrdem, new { @class = "form-control" })
                                                </div>
                                                 }
                                             }
                                             else
                                             {
                                                 @Html.HiddenFor(x => x.ExibirAgenda)
                                                 @Html.HiddenFor(x => x.ExibirAgendaOrdem)
                                             }


                                            @if ((int)Model.PessoaID > 0)
                                            {<div class="col-form col-lg-2 col-md-2 col-sm-2">
                                                <label>Ativo</label><br />
                                                <div class="checkbox">
                                                    <label>@Html.CheckBoxFor(model => model.Ativo) Sim</label>
                                                </div>
                                            </div>
                                            }
                                            else
                                            {
                                                @Html.Hidden("Ativo", true)
                                            }

                                            @if (Model.PessoaIntegrado)
                                            {
                                                <div class="col-form col-lg-2 col-md-2 col-sm-2">
                                                <label>Integrado</label><br />
                                                <p class="form-control-static">CUBEE <i class="fa fa-cube" aria-hidden="true"></i></p>
                                            </div>

                                                
                                            }

                                            @if (user.ControleAcesso("pessoas_campo_favorito", "Regras"))
                                            {
                                            <div class="col-form col-lg-2 col-md-2 col-sm-2">
                                                <label>Favorito</label>
                                                <div class="checkbox">
                                                   <label>@Html.CheckBoxFor(model => model.Favorito) <i id="labelFavorito" class="fa text-warning fa-heart"></i> sim</label>
                                                </div>
                                            </div>}
                                            else
                                            {
                                                @Html.HiddenFor(x => x.Favorito)
                                            }

                                             @if (user.ControleAcesso("pessoas_campo_obito", "Regras"))
                                             {
                                            <div class="col-form col-lg-2 col-md-2 col-sm-2">
                                                <label>Óbito</label>
                                                <div class="checkbox">
                                                   <label>@Html.CheckBoxFor(model => model.Obito) sim</label>
                                                </div>
                                            </div>
                                             }
                                             else
                                             {
                                                @Html.HiddenFor(x => x.Obito)
                                             }

                                            <div class="form-group col-lg-3 col-md-3 col-sm-3 @(Model.NaoPermiteEmail ? " alert-warning " : "")">
                                <label>E-Mail</label>
                                <div class="checkbox">
                                    <label>@Html.CheckBoxFor(model => model.NaoPermiteEmail, new { @class = "atualiza" }) <small>Não permite</small></label>
                                </div>
                            </div>

                            <div class="form-group col-lg-3 col-md-3 col-sm-3 @(Model.NaoPermiteSMS ? " alert-warning " : "")">
                                <label>SMS</label>
                                <div class="checkbox">
                                    <label>@Html.CheckBoxFor(model => model.NaoPermiteSMS, new { @class = "atualiza" }) <small>Não permite</small></label>
                                </div>
                            </div>

                            <div class="form-group col-lg-3 col-md-3 col-sm-3 @(Model.NaoPermiteLigacao ? " alert-warning " : "")">
                                <label>Ligação</label>
                                <div class="checkbox">
                                    <label>@Html.CheckBoxFor(model => model.NaoPermiteLigacao, new { @class = "atualiza" }) <small>Não permite</small></label>
                                </div>
                            </div>


                                        </div>

                                        <div class="col-lg-3 col-md-3 col-sm-3">
                                            <label>Contra Senha</label><br />
                                            @Html.PasswordFor(model => model.ContraSenha, new { @class = "form-control" })
                                        </div>

                                        <div class="col-lg-3 col-md-3 col-sm-3">
                                            <label>Confirmar Senha</label><br />
                                            <input type="password" id="ConfirmSenha" class="form-control" />
                                        </div>

                                    </div>
                                    <div class="col-lg-3 col-md-3 col-sm-3">
                                        <div class="control-group">
                                            @if (Model.FotoPessoa != null && Model.FotoPessoa != "")
                                            {
              
                                                <div class="thumbnails">
                                                    <div class="col-lg-12 col-md-12 col-sm-12">
                                                        <div class="thumbnail">
                                                            <img src="@Url.Content(Model.FotoPessoa.Replace(".jpg", "thumb.jpg"))?@DateTime.Now.Second" alt="Foto">
                                                            <div class="caption">
                                                                <label>Foto</label><br />
                                                                <p>JPEG ou PNG</p>
                                                                <a href="@Url.Content("~/Pessoas/RemoveFoto/" + @Model.PessoaID)" class="btn btn-outline btn-danger btn-xs remove" onclick="return confirm('Deseja realmente excluir essa foto?')"><i class="fa fa-trash "></i></a>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {  
                                                <div class="thumbnails">
                                                    <div class="col-lg-12 col-md-12 col-sm-12">
                                                        <div class="thumbnail">
                                                            <img src="~/Content/images/YourPhotoHere.png" alt="Foto" width="100" height="100" />
                                                            <div class="caption">
                                                                <label>Foto</label><br />
                                                                <p>JPEG ou PNG</p>
                                                                <input type="file" name="Arquivo" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>

                                    </div>
                                </div>
                            <!-- ./ DADOS BASICOS -->
                                
                                
                                
                                <legend>Dados Complementares</legend>
                                <div class="row">
                                    <div class="col-form col-lg-3 col-md-3 col-sm-3">
                                        <label>@(vtipo == "O" ? "Data de Admissão" : BLL.Usuarios.GetEntidadeClienteSingular() + " desde")</label>
                                        @Html.TextBox("DataInicio", @String.Format("{0:dd/MM/yyyy}", Model.DataInicio), new { @class = "form-control datepicker", value = @DateTime.Now })
                                    </div>

                                    @if (vtipo == "C" && (user.ControleAcesso("pessoas_funcionario_completo", "Regras") || user.ControleAcesso("pessoas_C_DesligadoDt", "Pessoas")))
                                    {

                                        <div class="col-form col-lg-2 col-md-2 col-sm-2">
                                            <label>Desligamento?</label><br />
                                            <div class="checkbox">
                                                <label>@Html.CheckBoxFor(model => model.Desligado) sim</label>
