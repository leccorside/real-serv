        $("#sHoraDe").mask("99:99");
        $("#sHoraAte").mask("99:99");
        $("#sIntervaloDe").mask("99:99");
        $("#sIntervaloAte").mask("99:99");
        $("#DataNascimento").mask("99/99/9999");
        $("#DataInicio").mask("99/99/9999");
        $("#DesligadoDt").mask("99/99/9999");

        $("#MedCarteiraTitularCpf").mask("999.999.999-99");
        $("#PacienteDataNascimento").mask("99/99/9999");

        $("#MedCarteiraTitularDataNascimento").mask("99/99/9999");
        $("#MedCarteiraValidade").mask("99/99/9999");


        $(function () {
            @if (Model.PessoaID == 0)
            {


                if (Model.CpfValido == true)
                {
         @:$('#Nome').focus();               
                }
                else
                {
         @:$('#Documento').focus();               
                }
            }

        });

        function Select(jtipo) {


            $("#Telefone").mask(maskBehavior, options);
            //$("#Celular").mask("(99)9999-9999?9");
            habilitaMaskCelular($("#CelularInternacional").is(':checked'));

            $("#AdmTelefone").mask(maskBehavior, options);
            $("#RespTelefone").mask(maskBehavior, options);


            if (jtipo == "PJ") {
                $("#painelPJ").slideDown();
                $("#Documento").mask("99.999.999/9999-99");

                $("#dataNascimento").html("Data de Fundação");
                $("#tpDocumento").html("CNPJ");
                $("#div_sexo").hide("slow");
                $("#div_ecivil").hide("slow");
                $("#div_rg").hide("slow");
                $("#div_profissao").hide("slow");
            } else if (jtipo == "OU") {
                $("#painelPJ").slideToggle();
                $("#Documento").unmask();
                $("#dataNascimento").html("Data de Nascimento");
                $("#tpDocumento").html("Outros");
                $("#div_sexo").show("slow");
                $("#div_ecivil").show("slow");
                $("#div_rg").hide("slow");
                $("#div_profissao").show("slow");
            } else {
                $("#painelPJ").slideToggle();

                $("#Documento").mask("999.999.999-99");
                $("#dataNascimento").html("Data de Nascimento");
                $("#tpDocumento").html("CPF");
                $("#div_sexo").show("slow");
                $("#div_ecivil").show("slow");
                $("#div_rg").show("slow");
                $("#div_profissao").show("slow");
            }


            $("#div_funcoes").toggle($("#AcumulaFuncao").is(':checked'));
            $("#div_desligamento").toggle($("#Desligado").is(':checked'));
            $("#div_exibiragenda_ordem").toggle($("#ExibirAgenda").is(':checked'));

        }



        function habilitaMaskCelular(vlr) {
            if (vlr == true) {
                $("#Celular").unmask();
            } else {
                $("#Celular").mask(maskBehavior, options);
            }

        }

        $('#CelularInternacional').click(function () {
            habilitaMaskCelular(this.checked);
        });


        $('#AcumulaFuncao').click(function () {
            $("#div_funcoes").toggle(this.checked);
        });

        $('#Desligado').click(function () {
            $("#div_desligamento").toggle(this.checked);
        });

        $('#ExibirAgenda').click(function () {
            $("#div_exibiragenda_ordem").toggle(this.checked);
        });


        Select($('#PessoaTipo').val());


        $('#Favorito').click(function () {
            if (this.checked) {

                $("#labelFavorito").attr('class', 'fa fa-heart text-warning');
            } else {
                $("#labelFavorito").attr('class', 'fa fa-heart-o text-warning');
            }

        });





        $("input[data-val-length-max]").each(function (index, element) {
            var length = parseInt($(this).attr("data-val-length-max"));
            $(this).prop("maxlength", length);
        });


        $("body").tooltip({ selector: '[data-toggle=tooltip]' });


        jQuery(function () {

            $('#buscar-cep').click(function () {
                $('#Cep').cep({
                    load: function () {
                        //Exibe a div loading
                        $('#loading').css('display', 'inline');
                    },
                    complete: function () {
                        //Esconde a div loading
                        $('#loading').css('display', 'none');
                    },
                    error: function (msg) {
                        //Exibe em alert a mensagem de erro retornada
                        alert(msg);
                    },
                    success: function (data) {
                        $('#Endereco').val(data.tipoLogradouro + ' ' + data.logradouro);
                        $('#Bairro').val(data.bairro);
                        $('#Estado').val(data.estado);
                        $('#Cidade').val(data.cidade);
                        $('#Pais').val('Brasil');
                        $('#Numero').focus();
                    }
                });
            });

        });


        $('#btnGerarNovoCodigo').click(function (e) {
            var guid = @Model.PessoaID;//$(this).attr('data-val');

            e.preventDefault();

            swal({
                title: "Confirma geração de um novo código?",
                text: "Será gerado um novo código e o atual será inutilizado.",
                type: "warning",
                showCancelButton: true,
                confirmButtonColor: "#DD6B55",
                confirmButtonText: "Sim, gerar código!",
                cancelButtonText: "Cancelar geração.",
                closeOnConfirm: false,
                closeOnCancel: false
            },
                function (isConfirm) {
                    if (isConfirm) {
                    
                        $.ajax({
                            url: '/ApiIntegracao/GeraPessoaCodigo/' + guid,
                            error: function (data) {
                                console.log(data);
                                swal("Ops...", " Ocorreu um erro na geração.\n" + data.mensagem, "error");                               

                            },
                            success: function (data) {
                                console.log(data);
                                if (data.codigo == 200) {
                                    $("#PessoaCodigo").val(data.Objeto.PessoaCodigo);
                                    swal("Gerado: " + data.Objeto.PessoaCodigo + "!", "O novo código já está no campo.", "success");
                                    //location.reload();
                                } else {
                                    swal("Ops...", " Ocorreu um erro na geração.\n" + data.mensagem, "error");
                                }

                            },
                            type: 'GET'
                        });

                    } else {
                        swal("Cancelado", "Não foi gerado ou alterado código", "error");
                    }
                });

           


        });
        
        $('.btn-reenviar').click(function (e) {
            var guid = $(this).attr('data-val');

            e.preventDefault();

            //var l = $(this).ladda();
            //l.ladda('start');
            //l.ladda('setProgress', 0.5);


            $.ajax({
                url: '/Pessoas/ReenviaTermoAceite/' + guid,
                error: function (data) {
                    console.log(data);
                    window.alert("Oops... Ocorreu um erro ao reenviar\n" + data.mensagem);

                },
                success: function (data) {
                    console.log(data);
                    if (data.codigo == 200) {
                        window.alert("SMS reenviado");
                        location.reload();
                    } else {
                        window.alert("Oops... Ocorreu um erro ao reenviar\n" + data.mensagem);
                    }

                },
                type: 'GET'
            });


        });

        $('#PacienteNome').keyup(function () {
            this.value = this.value.toLocaleUpperCase();
        });

        $('#ConvenioId').on('change', function () {
            carregaPlanos($(this).val(), null);
        });


        function carregaPlanos(ConvenioId, ConvenioPlanoId) {

            $.getJSON("@Url.Content("~/ApiIntegracao/GetConveniosPlanos/")", { id: ConvenioId, FilialId: "@BLL.Usuarios.GetFilialId()" }, function (result) {
                data = $.map(result.ListConvenioPlano, function (item, a) {
                    var select = (ConvenioPlanoId == item.ConvenioPlanoId) ? " selected='selected' " : "";
                    return "<option value=" + item.ConvenioPlanoId + " " + select + ">" + item.ConvenioPlanoNome + "</option>";
                });
                $("#ConvenioPlanoId").empty();
                $('#ConvenioPlanoId').append($('<option>', {
                    value: 0,
                    text: '--Selecione--'
                }));
                $("#ConvenioPlanoId").append(data.join(""));
                $("#ConvenioPlanoId").val(ConvenioPlanoId).trigger('chosen:updated');
                $("#ConvenioPlanoId").val(ConvenioPlanoId).trigger('change.select2');

            });

        }



        //inicializador
        carregaPlanos('@Model.ConvenioId', '@Model.ConvenioPlanoId');

        @if (Model.FilialID == 0)
        {
		 @:$("#FilialID").val("@BLL.Usuarios.GetFilialId()").trigger('chosen:updated');
                                    @:$("#FilialID").val("@BLL.Usuarios.GetFilialId()").trigger('change.select2');        
	}
        else
        {
        @:$("#FilialID").val("@Model.FilialID").trigger('chosen:updated');
                            @:$("#FilialID").val("@Model.FilialID").trigger('change.select2');        
                	}
        
        
    </script>
