                        swal({ title: "Atencão!", text: result.MENSAGEM, type: "error", showCancelButton: false, cancelButtonText: "Não", confirmButtonColor: "#DD6B55", confirmButtonText: "Ok", closeOnConfirm: true }, function () { });
                    }

                },
                error: function (result) {
                    swal({ title: "Atencão!", text: "Ocorreu um erro ao tentar salvar os dados", type: "error", showCancelButton: false, cancelButtonText: "Não", confirmButtonColor: "#DD6B55", confirmButtonText: "Ok", closeOnConfirm: true }, function () { });
                }
            });


        }


        $("input[type=text], textarea, select, :checkbox").change(function () {
            atualiza();

        });

        // Validação de senha
        $('form').submit(function (e) {
            var senha = $('#ContraSenha').val();
            var confirma = $('#ConfirmSenha').val();

            if (senha != confirma) {
                swal({ title: "Atenção!", text: "As senhas não coincidem", type: "error", confirmButtonText: "Ok" });
                e.preventDefault();
                return false;
            }
            return true;
        });

    </script>

}
