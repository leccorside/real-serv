@model Models.Api.NewExpositor
@{
    ViewBag.Title = "CubeeIntegra";
    Layout = "~/Views/Shared/_FortunaLayoutModal.cshtml";
}


<div class="content animate-panel">


    <div class="row">
        <div class="col-lg-12" style="">
            <h2>Integração CUBEE</h2>
            @if (Model.Response.code != 200)
            {
                <div class="alert alert-warning">
                    <i class="fa fa-exclamation-triangle" aria-hidden="true"></i><strong>Atenção</strong> @Model.Response.message
                </div>
            }
            else
            {
                <div class="alert alert-success">
                    <i class="fa fa-check" aria-hidden="true"></i><strong>Tudo certo!</strong> Integrado CUBEE
                </div>            
            }

            <br />
            <h2>@Model.ContatoNome</h2>

            @if (Model.Response.code == 200)
            {
                <p>Email de primeiro acesso enviado para @Model.Email</p>
            }

        </div>
    </div>
</div>
