        $('.imprimir').on('click', function () {
            var $this = $(this);
            $this.button('loading');
            setTimeout(function () {
                $this.button('reset');
            }, 6000);
        });
    </script>
    <script>
        $('.btn-reenviar').click(function (e) {
            var guid = $(this).attr('data-val');

            e.preventDefault();




            $.ajax({
                url: '/Pessoas/ReenviaTermoAceite/' + guid,
                error: function (data) {
                    console.log(data);
                    window.alert("Oops... Ocorreu um erro ao reenviar\n" + data.mensagem);

                },
                success: function (data) {
                    console.log(data);
                    if (data.codigo == 200) {
                        window.alert("SMS reenviado");
                        location.reload();
                    } else {
                        window.alert("Oops... Ocorreu um erro ao reenviar\n" + data.mensagem);
                    }

                },
                type: 'GET'
            });


        });
    </script>

}


