       @if (Model.PessoaID > 0 && vtipo == "C" && _PessoasPlanosInscricoes_index)
    {

        var bllPessoasPlanosInscricoes = new BLL.PessoasPlanosInscricoes();
        var listaInscricoes = bllPessoasPlanosInscricoes.ListarPorPessoaID(Model.PessoaID);
        
        <div class="row">
        <div class="col-lg-12" style="">

            

            <div class="hpanel">
                <div class="panel-heading">
                    <div class="panel-tools">
                        <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                    </div>
                    Inscrições
                </div>
                <div class="panel-body">
                    <!-- dados aqui-->
                    <div class="row">
                        <div class="col-lg-12">
                            
                         
                                <div class="table-responsive">
                                    <table class="table table-striped">
                                        <thead>
                                            <tr>
                                                <th>#</th>
                                                <th>Tipo</th>
                                                <th>Dt. Validade </th>
                                                <th>Tipo Pagto. </th>
                                                <th>Status Pagto</th>
                                                <th>Dt. Pagto. </th>
                                                <th>Total</th>
                                                <th>Status Doc.</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in listaInscricoes.Items.OrderByDescending(x=>x.PessoaPlanoInscricaoDtValidade))
                                            {
                                                var icon_status = "";
                                                var class_status = "";
                                                var panelColor = "hred";
                                                bool statusPagto = false;
                                                switch (item.PessoaPlanoPagtoStatus)
                                                {
                                                    case "Paga":
                                                    case "Gratuito":
                                                        class_status = " text-success ";
                                                        icon_status = "fa fa-check";
                                                        statusPagto = true;
                                                        break;
                                                    case "AguardandoPagamento":
                                                        class_status = " text-warning ";
                                                        icon_status = "fa fa-pause";
                                                        break;
                                                    default:
                                                        class_status = "  ";
                                                        break;
                                                }

                                                if (statusPagto && Model.CubeeAnexosStatusOk)
                                                {
                                                    panelColor = "hgreen";
                                                }
                                                else if (statusPagto || Model.CubeeAnexosStatusOk)
                                                {
                                                    panelColor = "hyellow";
                                                }

                                                var isPlano = (item.PessoaPlanoGrupoTipoId == 0 ? true : false);

                                                
                                                
                                                <tr>
                                                    <td>@item.PessoaPlanoInscricaoId</td>
                                                    <td><small>@item.PessoaPlanoGrupoNome</small><br />@item.PessoaPlanoTitulo</td>
                                                    <td>

                                                        @if (item.PessoaPlanoGrupoTipoId==0)   {
                                                            if (item.PessoaPlanoPagtoStatus=="AguardandoPagamento")
                                                        {
                                                            <small>Válido até @DateTime.Now.AddMonths(12).ToShortDateString() se pago em @DateTime.Now.ToShortDateString().</small>
                                                        }
                                                        else
                                                        {
                                                        
                                                            if (item.PessoaPlanoInscricaoDtValidade != null)
                                                            {
                                                            <span>@Convert.ToDateTime(item.PessoaPlanoInscricaoDtValidade).ToShortDateString()</span>
                                                            }
                                                        
                                                        }
                                                        }else
                                                        {
                                                            <span>-</span>
                                                        }

                                                    </td>
                                                    <td>@item.GatewayTipoPagamento</td>
                                                    <td>
                                                        @if (item.PessoaPlanoPagtoStatus == "AguardandoPagamento")
                                                        {
                                                            <a class="btn btn-outline btn-primary btn-xs" target="_blank" href="@Url.Content("~/Associados/GateWayPagamento/" + Model.EmpresaId + "/" + item.PessoaPlanoGUID)"> Realizar Pagamento</a>
                                                        }
                                                        else
                                                        {
                                                        <span class="@class_status">@item.PessoaPlanoPagtoStatus <i class="@icon_status"></i></span>
                                                        }
                                                        
                                                        
                                                    </td>
                                                    <td>
                                                        @if (item.PessoaPlanoInscricaoDtPagto != null)
                                                        {
                                                                <span>@Convert.ToDateTime(item.PessoaPlanoInscricaoDtPagto).ToShortDateString()</span>
                                                        }
                                                    </td>
                                                    <td>@string.Format("{0:c}", item.PessoaPlanoVlrTotal) <i class=" @icon_status"></i></td>
                                                    <td>
                                                     <span class="@(Model.CubeeAnexosStatusOk ? "  text-success " : " text-warning ")">@(Model.CubeeAnexosStatusOk ? "Ok" : "Pendente") <i class="@(Model.CubeeAnexosStatusOk ? "fa fa-check" : " fa fa-pause ")"></i></span></td>
                                                    <td>
                                                        @if (item.PlanoAtivo)
                                                        {
                                                            <i class="fa fa-check text-success"></i>    
                                                        }


                                                    </td>
                                                </tr>
                                            }


                                        </tbody>
                                    </table>
                                </div>
                                
                              
                        @*            
                            <a class="fancybox_recarrega fancybox.iframe" href="@Url.Content("~/PessoasPlanosInscricoes/Criar/" + item.PessoaPlanoInscricaoId + "/" + item.PessoaPlanoGUID)">
                                    @Html.Partial("~/Views/PessoasPlanosInscricoes/_detalheInscricao.cshtml", item)
                                </a>
                            *@
                         
                           
                        </div>
                    </div>
                    
                    
                    <!-- ./ dados aqui-->
                </div>

            </div>
        </div>
    </div>
        
    }

</div>






