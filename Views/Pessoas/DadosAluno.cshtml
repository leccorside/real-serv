    @if (PostosDeServicos_Index)
    {
    <div class="row">
        <div class="col-lg-12">
            <div class="hpanel">
                <div class="panel-heading">
                    <div class="panel-tools">
                        <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                    </div>
                    Espelho de Ponto
                </div>
                <div class="panel-body">
                    <div id="espelhoPontoContainer">
                        <div style="text-align:center;padding:20px;"><i class="fa fa-spinner fa-spin"></i> Carregando...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script>
    (function() {
        var pessoaId = @Model.PessoaID;
        var apiUrl = '@Url.Content("~/Handlers/PontoHandler_vFinal.ashx")';
        var hoje = new Date();
        var de = new Date(hoje.getFullYear(), hoje.getMonth(), 1);
        function fmt(d) { return d.getFullYear() + '-' + ('0'+(d.getMonth()+1)).slice(-2) + '-' + ('0'+d.getDate()).slice(-2); }

        fetch(apiUrl + '?busca=P' + pessoaId + '&dataInicial=' + fmt(de) + '&dataFinal=' + fmt(hoje))
            .then(function(r){ return r.json(); })
            .then(function(registros) {
                var container = document.getElementById('espelhoPontoContainer');
                if (!registros || registros.length === 0) {
                    container.innerHTML = '<p class="text-muted" style="padding:10px;">Nenhum registro de ponto encontrado para o m&ecirc;s atual.</p>';
                    return;
                }
                var html = '<div class="table-responsive"><table class="table table-condensed table-striped" style="font-size:13px;">';
                html += '<thead><tr><th>Data</th><th style="color:#059669;">Prev. Entrada</th><th style="color:#059669;">Prev. Sa&iacute;da</th><th>Entrada</th><th>Sa&iacute;da</th><th>Posto</th><th>Situa&ccedil;&atilde;o</th></tr></thead><tbody>';
                registros.forEach(function(r) {
                    var dt = r.DataRegistro ? r.DataRegistro.substring(0, 10) : '';
                    var dtFmt = dt ? dt.split('-').reverse().join('/') : '-';
                    var prevEnt = r.PrevEntrada ? r.PrevEntrada.substring(11,16) : '--:--';
                    var prevSai = r.PrevSaida   ? r.PrevSaida.substring(11,16)   : '--:--';
                    var ent  = r.Entrada  || '--:--';
                    var sai  = r.Saida    || '--:--';
                    var sit  = r.Situacao || '';
                    var sitClass = sit === 'Falta' ? 'text-danger' : (sit === 'Normal' ? 'text-success' : '');
                    html += '<tr>';
                    html += '<td>' + dtFmt + '</td>';
                    html += '<td style="color:#059669;">' + prevEnt + '</td>';
                    html += '<td style="color:#059669;">' + prevSai + '</td>';
                    html += '<td>' + ent + '</td>';
                    html += '<td>' + sai + '</td>';
                    html += '<td>' + (r.PostoTrabalho || '') + '</td>';
                    html += '<td class="' + sitClass + '">' + sit + '</td>';
                    html += '</tr>';
                });
                html += '</tbody></table></div>';
                container.innerHTML = html;
            })
            .catch(function(e) {
                document.getElementById('espelhoPontoContainer').innerHTML = '<p class="text-danger">Erro ao carregar espelho de ponto.</p>';
            });
    })();
    </script>
    }

