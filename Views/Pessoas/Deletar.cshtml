@model Models.Pessoa

@{
    var vtipo = (string)Model.PessoaCategoria;
    var vname = "";
    var vlista = "";
    switch (vtipo)
    {
        case "C":
            vname = BLL.Usuarios.GetEntidadeCliente();
            break;
        case "F":
            vname = BLL.Usuarios.GetEntidadeFornecedor();

            break;

        default:
            vname = "Indefinido";

            break;
    }
    
    
    
}


@{
    ViewBag.Title = "Excluir " + vname;
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";  
}




@section Breadcrumb{
    <li class="active"><span class="divider">/</span>  @Html.ActionLink(vname, "Index", new { id = 0, tipo = vtipo })</li>
}


<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">
            <div class="alert alert-warning">
                <i class="fa fa-exclamation-triangle" aria-hidden="true"></i><strong>Atenção</strong> Você tem certeza que deseja apagar esse registro?
            </div>

            <div class="hpanel">
                <div class="panel-body">
                    <!-- conteudo aqui -->
                    <div class="row">
                        <div class="col-lg-3 col-md-3 col-ms-3">
                            <div class="display-label">
                                @Html.DisplayNameFor(model => model.PessoaID)
                            </div>
                            <div class="display-field">
                                @Html.DisplayFor(model => model.PessoaID)
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-3 col-ms-3">
                            <div class="display-label">
                                @Html.DisplayNameFor(model => model.Nome)
                            </div>
                            <div class="display-field">
                                @Html.DisplayFor(model => model.Nome)
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-3 col-ms-3">

                            <div class="display-label">
                                @Html.DisplayNameFor(model => model.Documento)
                            </div>
                            <div class="display-field">
                                @Html.DisplayFor(model => model.Documento)
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-3 col-ms-3">
                            <div class="display-label">
                                @Html.DisplayNameFor(model => model.DataNascimento)
                            </div>
