                <div class="panel-footer">

                    @using (Html.BeginForm())
                    {
                        <div class="row">
                            <div class="col-lg-12">
                                @Html.HiddenFor(model => model.PessoaID)
                                @Html.HiddenFor(model => model.PessoaCategoria)
                                <input type="submit" value="Apagar" class="btn btn-danger pull-right" />

                                @Html.ActionLink("Voltar", "Index", new { @class = "btn btn-outline btn-primary " })


                            </div>
                        </div>    
