@model Models.DocumentoLayout

@{
    ViewBag.Title = "Excluíndo Layouts";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";
}


@section Breadcrumb{
    <li> @Html.ActionLink("Configurações", "Configuracoes", "Principal")</li>
    
 <li>   @Html.ActionLink("Layouts", "Index", new { id = 0 })</li>
}




<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">
            <div class="alert alert-warning">
                <i class="fa fa-exclamation-triangle" aria-hidden="true"></i><strong>Atenção</strong> Você tem certeza que deseja apagar esse registro?
            </div>

            <div class="hpanel">
                <div class="panel-body">
                    <!-- conteudo aqui -->
                    <div class="row">
                <div class="col-lg-3 col-md-3 col-sm-3">
                    <div class="display-label">

                        @Html.DisplayNameFor(model => model.DocumentoLayoutId)



                    </div>
                    <div class="display-field">
                        @Html.DisplayFor(model => model.DocumentoLayoutId)
                    </div>

                </div>
                <div class="col-lg-9 col-md-9 col-sm-9">
                    <div class="display-label">

                        @Html.DisplayNameFor(model => model.DocumentoLayoutNome)



                    </div>
                    <div class="display-field">
                        @Html.DisplayFor(model => model.DocumentoLayoutNome)
                    </div>

                </div>



            </div>
                    <!-- ./conteudo aqui -->
                </div>
                <div class="panel-footer">

                    @using (Html.BeginForm())
                    {
                        <div class="row">
                            <div class="col-lg-12">
                                @Html.HiddenFor(model => model.DocumentoLayoutId)
                                
                                    <input type="submit" value="Apagar" class="btn btn-danger" />
                                
                                    @Html.ActionLink("Voltar", "Index", null, new { @class = "btn btn-outline btn-primary" })
                                
                            </div>
                        </div>    
                    }

                </div>
            </div>

        </div>
    </div>
</div>



