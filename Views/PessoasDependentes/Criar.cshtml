@model Models.PessoaDependente

@{
    
    ViewBag.Title = "Criar Dependente";


    Layout = "~/Views/Shared/_FortunaLayoutModal.cshtml";


}



<div class="content animate-panel">


    <div class="row">
        <div class="col-lg-12" style="">
            <div class="hpanel ">
                <div class="panel-heading">
                    <div class="panel-tools">
                        <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                    </div>
                    Cadastro de Dependente
                </div>
                <div class="panel-body">
                    <!-- dados aqui-->
                    <div class="row">
                        <div class="col-lg-2 col-md-2 col-sm-2">
                            <label>CPF Responsável</label>
                            @Model.ResponsavelDocumento
                        </div>

                      

                        <div class="col-lg-10 col-md-10 col-sm-10">
                            <label>Responsável Nome</label><br />
                            @Model.ResponsavelNome
                        </div>

                    </div>
                    
                    <br />
                    @using (Html.BeginForm("Criar", "PessoasDependentes", FormMethod.Post))
                    {
                        @Html.ValidationSummary(true)

                        @Html.HiddenFor(m => m.PessoaID)

                        if (Model.PessoaDependenteId > 0)
                        {
                        @Html.HiddenFor(m => m.PessoaDependenteId);
                        }
                        
                            

        
                        <div class="row">

                            <div class="form-group col-lg-6">
                                <label>Nome</label>
                                @Html.TextBoxFor(m => m.PessoaDependenteNome, new {@class="form-control" })
                            </div>

                            <div class="form-group col-lg-2">
                                <label>Grau Parentesco</label>
                                @Html.DropDownListFor(model => model.GrauParentescoId, (SelectList)ViewBag.ddlGrausParentescos, "--Selecione--", new { @class = "chosen-select form-control " })    
                            </div>


                            <div class="form-group col-lg-2">
                                <label>Data Nascimento</label>
                                @Html.TextBox("DataNascimento", String.Format("{0:dd/MM/yyyy}", Model.DataNascimento), new { @class = "datepicker form-control", value = DateTime.Now })
                            </div>

                            <div class="form-group col-lg-2">
                                <label>Sexo</label>
                                @Html.DropDownListSexo("Sexo", Model.Sexo, false, "form-control")
                            </div>


                            
                            






                        </div>
                        <div class="row">
                            <div class="col-lg-12">
                                <button type="submit" class="btn btn-primary">Salvar</button> <a href="@Url.Content("~/PessoasDependentes/Index/" + Model.PessoaID)" class="btn btn-outline btn-primary ">Voltar</a>
                            </div>
                        </div>
                    }

                    <!-- ./ dados aqui-->
                </div>

            </div>
        </div>
    </div>
</div>





@section Styles{
    @Styles.Render("~/bundles/select2/css")
    @Styles.Render("~/bundles/fancybox/css")
    @Styles.Render("~/bundles/datepicker/css")
}



@section Scripts {
    @Scripts.Render("~/bundles/select2/js")
    @Scripts.Render("~/bundles/fancybox/js")
    @Scripts.Render("~/bundles/clipboard/js")
    @Scripts.Render("~/bundles/datepicker/js")
    @Scripts.Render("~/bundles/mask/js")
    @Scripts.Render("~/bundles/maxlenght/js")


    <script>
        $(document).ready(function () {
            $("#MedGuia_TotalProdutosCusto").focus();
        });

        $('.max').maxlength();
        $("#DataNascimento").mask("99/99/9999");

        $(document).ready(function () {

            $(".fancybox").fancybox({ fitToView: false, width: '80%', autoSize: true });
            $(".fancybox_full").fancybox({
                fitToView: false,
                width: '100%',
                autoSize: false,
                closeClick: false,
                openEffect: 'none',
                closeEffect: 'none'
            });
        });

    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('.chosen-select').select2();
            $('.datepicker').datepicker({ language: 'pt-BR', format: 'dd/mm/yyyy', todayHighlight: true, todayBtn: true });
            $('.moeda').mask('000000000000000,00', { reverse: true });
        });
    </script>
}

