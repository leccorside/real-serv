@model IEnumerable<Models.PagamentoTipo>

@{
    ViewBag.Title = "Tipos de pagamento";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";      
}




@section Breadcrumb{

    <li class="active"><span class="divider">/</span> @Html.ActionLink("Configurações", "Configuracoes", "Principal")</li>


}


<div class="row-fluid">
    <div class="span12">
        @Html.ActionLink("+ Criar", "Criar", new { id = 0 }, new { @class = "btn btn-primary" })
    </div>
</div>




<div class="row-fluid">

    <div class="span12">
        <table class="table table-bordered table-striped">
            <thead>
                <tr>

                    <th>
                        @Html.DisplayNameFor(model => model.PagamentoNome)
                    </th>

                    <th>
                        @Html.DisplayNameFor(model => model.RegDtInicio)
                    </th>
                    <th></th>
                </tr>
            </thead>
            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td width="100%">
                            @Html.DisplayFor(modelItem => item.PagamentoNome)
                        </td>

                        <td nowrap>
                            @Html.DisplayFor(modelItem => item.RegDtInicio)
                        </td>
                        <td nowrap>
                            @Html.ActionLink("Alterar", "Criar", new { id = item.PagamentoTipoId }, new { @class = "btn btn-mini" }) |
            @Html.ActionLink("Excluir", "Deletar", new { id = item.PagamentoTipoId }, new { @class = "btn btn-mini" })
                        </td>
                    </tr>
                }

            </tbody>



        </table>



    </div>
</div>


