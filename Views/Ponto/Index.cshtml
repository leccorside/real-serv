@model Models.ConsultarPonto

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_LayoutOpen.cshtml";
    var agora = DateTime.Now;

    
}

@section Styles{

}

<br />
<br />
<br />
@using (Html.BeginForm("Index", "Ponto", FormMethod.Post, new { @autocomplete = "off" }))
{
    @Html.ValidationSummary(true)
    <div class="row-fluid">
        <div class="span2"></div>
        <div class="span8">
            <h2 class="pull-right"><i class="fa fa-clock-o"></i><span id="clock"></span></h2>
            <h2 class="pull-left">Registro de Ponto</h2>

        </div>
        <div class="span2"></div>
    </div>
    
    <div class="row-fluid">
        <div class="span4"></div>
        @*<div class="span4">
            <label>Empresa</label>
            @Html.DropDownListFor(model => model.CompanhiaId, (SelectList)ViewBag.DdlCompanhias, "--Nenhuma--", new { @class = "chosen-select form-control span12" })
        </div>*@
        <div class="span4">
            <label>Seu RE</label>

            <div class="input-append">
                @Html.TextBoxFor(m => m.RE, new { @class = "span12 form-control ", @placeholder = "Seu RE" })
                <button type="submit" class="btn btn-primary">Próximo</button>
            </div>




        </div>
        <div class="span4"></div>
    </div>
}
@section scripts{
    <script src="~/Assets/js/jquery.js"></script>



    <script>
        $(function () {

            function updateTime() {
                $.getJSON("@Url.Content("~/Ponto/DataHora")", function (result) {
                    $("#clock").text(result);
                });
            }


            setInterval(function () {
                updateTime();
            }, 30000);

            updateTime();

        });
    </script>
}