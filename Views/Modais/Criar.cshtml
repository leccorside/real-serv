@model Models.Modal



@{
    

    
    var acao = "Cadastrar";
    if (Model.ModalId > 0)
    {
        acao = "Alterar";
    }


    ViewBag.Title = acao + " Modal";
    
}





@section Breadcrumb{

    <li class="active"><span class="divider">/</span>    @Html.ActionLink("Modais", "Index", new { id = 0 })</li>
}



@using (Html.BeginForm("Criar", "Modais", FormMethod.Post, new { @class = "form-horizontal" }))
{
    @Html.ValidationSummary(true)

    if (Model.ModalId > 0)
    {
    @Html.Hidden("ModalId", Model.ModalId);
    @Html.Hidden("Ativo", Model.Ativo);
    @Html.Hidden("Language", Model.Language);
                                            acao = "Alterar";
    }
       
            
     
    <div class="control-group">
        @Html.LabelFor(model => model.Titulo, new { @class = "control-label" })
        <div class="controls">
            @Html.EditorFor(model => model.Titulo) 
            @*@Html.ValidationMessageFor(model => model.Titulo)*@
        </div>
    </div>
        
    <div class="control-group">
        @Html.LabelFor(model => model.Conteudo, new { @class = "control-label" })
        <div class="controls">
            @Html.TextAreaFor(m => m.Conteudo)
        </div>
    </div>
    

    <div class="form-actions">


        <input type="submit" value="@acao" class="btn btn-primary  btn-large"  TabIndex=10 />

    </div>
            
}

@Html.ActionLink("Voltar", "Index")







@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")


    @Styles.Render("~/redactor/redactor.css")
    @Scripts.Render("~/redactor/redactor.min.js")
    <script type="text/javascript">
        $(function () {
            $('#Conteudo').redactor({
                focus: true,
                imageUpload: '@Url.Content("~/Redactor/ImageUpload")'
            });



        });

    </script>
}
