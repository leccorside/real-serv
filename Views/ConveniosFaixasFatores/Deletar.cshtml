@model Models.ConvenioFaixaFator

@{
    ViewBag.Title = "Excluíndo Fator";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";
}


@section Breadcrumb{
    <li class="active">@Html.ActionLink("Configurações", "Configuracoes", "Principal")</li>
    <li class="active">@Html.ActionLink("Convênios", "Index", "Convenios", new { id = 0 }, null)</li>
    <li class="active"><span class="divider">/</span>@Model.ConvenioPlano.ConvenioNome</li>
    <li class="active">@Html.ActionLink("Planos", "Index", new { id = 0, ConvenioPlanoId = Model.ConvenioPlanoId }, null)</li>
}



<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">
            <div class="alert alert-warning">
                <i class="fa fa-exclamation-triangle" aria-hidden="true"></i><strong>Atenção</strong> Você tem certeza que deseja apagar esse registro?
            </div>

            <div class="hpanel">
                <div class="panel-body">
                    <!-- conteudo aqui -->


                    <div class="row">

                        <div class="col-lg-2">
                            <div class="display-label">
                                @Html.DisplayNameFor(model => model.ConvenioFaixaFatorId)
                            </div>
                            <div class="display-field">
                                @Html.DisplayFor(model => model.ConvenioFaixaFatorId)
                            </div>

                        </div>
                        <div class="col-lg-5">

                            <div class="display-label">
                                Faixa
                            </div>
                            <div class="display-field">
                                @string.Format("{0:n2}", Model.ValorDe) até @string.Format("{0:n2}", Model.ValorAte)
                            </div>

                        </div>
                        
                        <div class="col-lg-3">

                            <div class="display-label">
                                Fator
                            </div>
                            <div class="display-field">
                                % @string.Format("{0:n2}", Model.Fator)
                            </div>

                        </div>
                    </div>




                    <!-- ./conteudo aqui -->
                </div>
                <div class="panel-footer">

                    @using (Html.BeginForm())
                    {
                        <div class="row">
                            <div class="col-lg-12">
                                @Html.HiddenFor(m => m.ConvenioPlanoId)
                @Html.HiddenFor(model => model.ConvenioFaixaFatorId)
                                    <input type="submit" value="Apagar" class="btn btn-danger" />
                                
                                    @Html.ActionLink("Voltar", "Index", null, new { @class = "btn btn-outline btn-primary" })
                                
                            </div>
                        </div>    
                    }

                </div>
            </div>

        </div>
    </div>
</div>




