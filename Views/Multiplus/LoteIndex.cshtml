@model PetaPoco.Page<Models.Lote>


@{
    var user = new BLL.Usuarios();
    ViewBag.Title = "Lotes";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";  

 
 
       
}


@section Breadcrumb{

}

<div class="row-fluid">
    <div class="span12">
        <a href="@Url.Content("~/Multiplus/LoteGerar/" + BLL.Usuarios.GetEmpresaId() + "?lightbox[iframe]=true&lightbox[width]=770&lightbox[height]=460")" class="ui-lightbox btn btn-primary " data-toggle="tooltip" data-original-title="Gerar Lote"  title="Gerar Lote" data-placement="top"><i class="fa fa-list-ul" aria-hidden="true"></i> Gerar Lote</a>      
    </div>
</div>
<br />    


<div class="row-fluid">

    <div class="span12">

        <table class="footable table-bordered table-striped table-pequeno">
                    <thead>
                        <tr>
                            <th>
                                @Html.CampoOrdenacao("Lote", "LoteId")
                            </th>
                            <th>
                                @Html.CampoOrdenacao("Data", "RegDtInicio")
                            </th>
                            <th>Qtd. Registros</th>
                            <th>Status Multiplus</th>
                            <th data-hide="phone,tablet"></th>
                        </tr>
                    </thead>
                    <tbody>

                        @foreach (var item in Model.Items)
                        {
                            bool loteErro = (item.ErrCode > 0) ? true : false;
                            bool loteEnviado = (item.RtnIdLote > 0) ? true : false;
                            var tr_class = (loteErro) ? " error text-error " : "";
                            
                            <tr class="@tr_class">
                                <td class="text-center">@item.LoteId</td>
                                <td>@item.RegDtInicio </td>
                                <td>@item.QtdRegistros</td>
                                <td>
                                    @if (loteEnviado)
                                    {
                                        <span class="span2">Situação:<br /><i class="fa fa-check-square-o"></i> Lote enviado</span>
                                        <span class="span2">Data envio:<br />@item.RtnDataRecebimento</span>
                                        <span class="span8">Num. Lote:<br />@item.RtnIdLote</span>
                                    }else if (loteErro)
	                                {
		                                <span class="span2">Situação:<br /><i class="fa fa-bug"></i> Erro no envio</span>
                                        <span class="span2">Código:<br />@item.ErrCode</span>
                                        <span class="span8">Mensagem:<br />@item.ErrString</span>
                                    }
                                    else
                                    {
                                        <span class="span2">Situação:<br /><i class="fa fa-square-o"></i> Lote não enviado</span>
                                        <span class="span2">Data envio:<br />n/r</span>
                                        <span class="span8">Num. Lote:<br />n/r</span>
                                    }
                                </td>
                                
                                
                                <td nowrap data-hide="phone,tablet" style="display: table-cell">
                                    @if (loteEnviado)
                                    {
                                        <a href="#" class="btn btn-mini disabled " data-toggle="tooltip" data-original-title="Enviar Lote"  title="Enviar Lote" data-placement="top"><i class="fa fa-upload" aria-hidden="true"></i> Enviar Lote</a>
                                        
                                        <a href="@Url.Content("~/Multiplus/LoteConsultar/" + BLL.Usuarios.GetEmpresaId() + "?LoteId=" + item.LoteId + "&lightbox[iframe]=true&lightbox[width]=770&lightbox[height]=460")" class="ui-lightbox btn btn-mini " data-toggle="tooltip" data-original-title="Consultar Lote"  title="Consultar Lote" data-placement="top"><i class="fa fa-search" aria-hidden="true"></i> Consultar Lote</a>
                                    }
                                    else
                                    {
                                    <a href="@Url.Content("~/Multiplus/LoteEnviar/" + BLL.Usuarios.GetEmpresaId() + "?LoteId=" + item.LoteId + "&lightbox[iframe]=true&lightbox[width]=770&lightbox[height]=460")" class="ui-lightbox btn btn-mini " data-toggle="tooltip" data-original-title="Enviar Lote"  title="Enviar Lote" data-placement="top"><i class="fa fa-upload" aria-hidden="true"></i> Enviar Lote</a>          
                                        
                                        <a href="#" class="btn btn-mini disabled " data-toggle="tooltip" data-original-title="Consultar Lote"  title="Consultar Lote" data-placement="top"><i class="fa fa-search" aria-hidden="true"></i> Consultar Lote</a>
                                    }
                                    
                                    <a href="@Url.Content("~/Multiplus/LoteViewXml/" + BLL.Usuarios.GetEmpresaId() + "?LoteId=" + item.LoteId + "&lightbox[iframe]=true&lightbox[width]=770&lightbox[height]=460")" class="ui-lightbox btn btn-mini " data-toggle="tooltip" data-original-title="Visualizar XML"  title="Visualizar XML" data-placement="top"><i class="fa fa-code" aria-hidden="true"></i> Visualizar XML</a>      
                                </td>
                            </tr>
                        }

                    </tbody>



                </table>

        @Html.Paginacao(Convert.ToInt16(Model.TotalPages))

    </div>
</div>




@section Scripts {
    <script src="http://ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js" type="text/javascript"></script>
    <script src="~/Content/themes/base/js/plugins/lightbox/jquery.lightbox.min.js"></script>
    <script src="~/Content/themes/base/js/Application.js"></script>
    
    <script src="~/Assets/themes/metro/js/footable.js"></script>
    <script type="text/javascript">
        $(function () {
            $('.footable').footable({
                breakpoints: {
                    phone: 400,
                    tablet: 800
                }
            });


            $("body").on("click", ".jquery-lightbox-overlay", function () {
                window.location.reload(true);
            });

            $("body").on("click", ".jquery-lightbox-button-close", function () {
                window.location.reload(true);
            });



        });
    </script>



}