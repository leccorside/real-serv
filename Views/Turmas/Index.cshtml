@model IEnumerable<Models.Turma>


@{
    ViewBag.Title = "Turmas";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";  
    var user = new BLL.Usuarios();

    var pagina = Request["pagina"];
    var paginaAtual = (pagina == "" || pagina == null) ? 1 : int.Parse(pagina);
    var qtdPaginas = ViewBag.qtdPaginas;

    var ordenacao = Request["tipoordenacao"];
    var tipoordenacao = (ordenacao == "" || pagina == null) ? "asc" : ordenacao;
    tipoordenacao = (tipoordenacao == "asc") ? "desc" : "asc";
}


@section Breadcrumb{
    <li class="active"><span class="divider">/</span> @Html.ActionLink("Configurações", "Configuracoes", "Principal")</li>
}


<div class="row-fluid">
    <div class="span12">
        @if (user.ControleAcesso("criar", "turmas"))
        { 
            @Html.ActionLink("+ Criar", "Criar", new { id = 0 }, new { @class = "btn btn-primary" })
        }
    </div>
</div>




<div class="row-fluid">

    <div class="span12">
        <table class="table table-bordered table-striped">
            <thead>
                <tr>

                    <th>
                        <a href="@Url.Content("~/Turmas/Index/0/" )?pagina=@paginaAtual&ordenacao=Turmas.TurmaNome&tipoordenacao=@tipoordenacao">@Html.DisplayNameFor(model => model.TurmaNome)</a>
                    </th>
                    <th>Coaches</th>
                    <th>Horário</th>
                    <th>Dias</th>
                    <th nowrap>Qtd. de @BLL.Usuarios.GetEntidadeCliente()</th>
                    <th nowrap>
                        @Html.DisplayNameFor(model => model.RegDtInicio)
                    </th>
                    @if (user.ControleAcesso("criar", "alterar"))
                    {
                        <th></th>}
                </tr>
            </thead>
            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td width="100%">
                            <a href="@Url.Content("~/Turmas/Alunos/" + item.TurmaId)?lightbox[iframe]=true&lightbox[width]=770&lightbox[height]=460" class="ui-lightbox">@Html.DisplayFor(modelItem => item.TurmaNome)</a>
                        </td>

                        @{
                                    
                    BLL.Turmas t = new BLL.Turmas();
                    var coaches = t.GetCoaches(item.TurmaId);
                            
                        }

                        <td>
                            @{
                    foreach (var item2 in coaches)
                    {

                                
                                <small>@item2.Apelido</small><br>
                                

                    } }
                        </td>
                        <td nowrap><small>@item.Inicio.ToString("hh:mm") ~ @item.Fim.ToString("hh:mm")</small></td>
                        <td nowrap><small>
                            @(item.Domingo == true ? "Domingo" + Html.Raw(" - ") : "")
                            @(item.Segunda == true ? "Segunda" + Html.Raw(" - ") : "")
                            @(item.Terca == true ? "Terça" + Html.Raw(" - ") : "")
                            @(item.Quarta == true ? "Quarta" + Html.Raw(" - ") : "")
                            @(item.Quinta == true ? "Quinta" + Html.Raw(" - ") : "")
                            @(item.Sexta == true ? "Sexta" + Html.Raw(" - ") : "")
                            @(item.Sabado == true ? "Sábado" + Html.Raw(" - ") : "")</small>
                        </td>
                        <td>@Html.DisplayFor(modelItem => item.QtdAlunos)</td>
                        <td nowrap>
                            @Html.DisplayFor(modelItem => item.RegDtInicio)
                        </td>
                        @if (user.ControleAcesso("criar", "turmas"))
                        {
                            <td nowrap>
                                @Html.ActionLink("Alterar", "Criar", new { id = item.TurmaId }, new { @class = "btn btn-mini" }) |
            @Html.ActionLink("Excluir", "Deletar", new { id = item.TurmaId }, new { @class = "btn btn-mini" })
                            </td> }
                    </tr>
                        
                }
            </tbody>



        </table>
    </div>
</div>

<div class="row-fluid">
    <div class="span12">
        <div class="pagination">
            <ul>

                <li class="@(paginaAtual == 1 ? " disabled " : "")"><a href="@Url.Content("~/Turmas/Index/0/" )?pagina=@(paginaAtual > 1 ? paginaAtual - 1 : paginaAtual)">«</a></li>
                @for (int i = 1; i < qtdPaginas + 1; i++)
                {
                    <li class="@(paginaAtual == i ? " active " : "")"><a href="@Url.Content("~/Turmas/Index/0/" )?pagina=@i">@i</a></li>      
                      
                }


                <li class="@(paginaAtual >= qtdPaginas ? " disabled " : "")"><a href="@Url.Content("~/Turmas/Index/0/" )?pagina=@(paginaAtual < qtdPaginas ? paginaAtual + 1 : paginaAtual)">»</a></li>
            </ul>
        </div>
    </div>

</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")


    <script src="~/Content/themes/base/js/plugins/lightbox/jquery.lightbox.min.js"></script>
    <script src="~/Content/themes/base/js/Application.js"></script>
    @*<script src="~/Content/themes/base/js/Gallery.js"></script>*@

}