@model Models.Midia



@{
    

    
    var acao = "Cadastrar";
    if (Model.MidiaId > 0)
    {
        acao = "Alterar";
    }


    ViewBag.Title = acao + " Midia";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";     
}





@section Breadcrumb{
      <li class="active"><span class="divider">/</span> @Html.ActionLink("Configurações", "Configuracoes", "Principal")</li>
<li class="active"><span class="divider">/</span>    @Html.ActionLink("Midias", "Index", new { id = 0 })</li>
}


<div class="cwell">
        @using (Html.BeginForm("Criar", "Midias", FormMethod.Post, new { @class = "form-horizontal" }))
        {
            @Html.ValidationSummary(true)

            if (Model.MidiaId > 0)
            {
            @Html.Hidden("MidiaId", Model.MidiaId);
                                                          acao = "Alterar";
            }
       
            
if (BLL.Usuarios.GetUtilizaFilial() == true && BLL.Usuarios.GetFilialIDMaster() == 0)
            { 
            <div class="control-group">
                <label class="control-label" for="ContaTipoId">@BLL.Usuarios.GetEntidadeFilial():</label>
                <div class="controls">
                    @Html.DropDownListFor(model => model.FilialID, (SelectList)ViewBag.DdlFiliais, "--Nenhuma--", new { @class = "chosen-select" })
                </div>
            </div>
            } else
                    {
                        <input type="hidden" name="FilialID" value="@BLL.Usuarios.GetFilialIDMaster()"/>
                    }
     
            <div class="control-group">
                @Html.LabelFor(model => model.MidiaNome, new { @class = "control-label" })
                <div class="controls">
                    @Html.EditorFor(model => model.MidiaNome)
                    @Html.ValidationMessageFor(model => model.MidiaNome)
                </div>
            </div>
        
        <div class="control-group">
                @Html.LabelFor(model => model.MidiaNomeEN_US, new { @class = "control-label" })
                <div class="controls">
                    @Html.EditorFor(model => model.MidiaNomeEN_US)
                    @Html.ValidationMessageFor(model => model.MidiaNomeEN_US)
                </div>
            </div>
        
      

            <div class="form-actions">


                <input type="submit" value="@acao" class="btn btn-primary  btn-large"  TabIndex=10 />

            </div>
            
        }
    <div>
    @Html.ActionLink("Voltar", "Index")
</div>
    </div>





@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
