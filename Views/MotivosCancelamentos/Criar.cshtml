@model Models.MotivoCancelamento

@{
    
    
    var acao = "Cadastrar";
    if (Model.MotivoCancelamentoId > 0)
    {
        acao = "Alterar";
    }



    ViewBag.Title = acao + " " + "Motivos de Cancelamento";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section Breadcrumb{

    <li class="active"><span class="divider">/</span>    @Html.ActionLink("Motivos de Cancelamento", "Index")</li>

}




@using (Html.BeginForm())
{
    @Html.ValidationSummary(true)
    
    if (Model.MotivoCancelamentoId > 0)
    {
    @Html.Hidden("MotivoCancelamentoId", Model.MotivoCancelamentoId);
    }
    <legend>Dados do Motivo de Cancelamento</legend>
    
    <div class="row-fluid">
        <div class="span12">
            <div class="editor-label">
                @Html.LabelFor(model => model.MotivoCancelamentoNome)
            </div>
            <div class="editor-field">
                @Html.TextBoxFor(model => model.MotivoCancelamentoNome, new { @class = "span12" })
                @*@Html.ValidationMessageFor(model => model.MotivoCancelamentoNome)*@
            </div>
        </div>

    </div>
    
    <div class="form-actions">
        <input type="submit" value="@acao" class="btn btn-primary  btn-large"  TabIndex=10 />
    </div>
}




<div>
    @Html.ActionLink("Voltar", "Index")
</div>


@section Scripts {



}
