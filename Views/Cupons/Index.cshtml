@model PetaPoco.Page<Models.Cupom>


@{
    var user = new BLL.Usuarios();
    ViewBag.Title = "Cupons";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";  

    var bllCuponsTipos = new BLL.CuponsTipos();
    var cuponsTipos = bllCuponsTipos.Listar();

    var bllCuponsCabecalhos = new BLL.CuponsCabecalhos();
    var lotes = bllCuponsCabecalhos.Listar();

    var criar_cupons = user.ControleAcesso("Criar", "Cupons");
}


@section Breadcrumb{

}


<div class="row-fluid">
    <div class="span12">
        @if (criar_cupons)
        {
        @Html.ActionLink("+ Criar", "Criar", new { id = 0 }, new { @class = "btn btn-primary" })    
        }
        

    </div>
</div>
<br />
@using (Html.BeginForm("Index", "Cupons", FormMethod.Post, new { @class = "form-inline cwell " }))
{
    <div class="row-fluid">
        <div class="span3">
            <small>Documento ou Cupom</small><br />
            <input type="text" name="pesquisar" title="Pesquisar" class="span12" placeholder="Documento ou Cupom..." value="@Request["pesquisar"]">
        </div>

        <div class="span3">
            <small>Programa</small><br />
            <select name="CupomTipoId" id="CupomTipoId" class = "chosen-select span12 ">
                <option>--Selecione--</option>
                @foreach (var item in cuponsTipos)
                {
                    <option value="@item.CupomTipoId" @(item.CupomTipoId.ToString()==Request["CupomTipoId"]?" SELECTED ":"") >@item.CupomTipoNome / @item.CupomCodigoComplementar</option>
                }
            </select>
        </div>

        <div class="span3">
            <small>Lote</small><br />
            <select name="CupomCabecalhoId" id="CupomCabecalhoId" class = "chosen-select span12 ">
                <option>--Selecione--</option>
                @foreach (var item in lotes)
                {
                    <option value="@item.CupomCabecalhoId"  @(item.CupomCabecalhoId.ToString()==Request["CupomCabecalhoId"]?" SELECTED ":"")  >@item.CupomTipoCodigoComplementar @item.CupomCodigoComplementar</option>
                }
            </select>
            
        </div>

        <div class="span3">
            <br />
        <button class="btn" type="submit">Pesquisar</button><button class="btn" type="button" onclick="parent.location='@Request.Url.AbsoluteUri'">Limpar</button>
        </div>
    </div>
    
    
}


@using (Html.BeginForm("Export", "Cupons", FormMethod.Post, new { @class = "form-inline " }))
{
    <div class="row-fluid">
        <div class="span12">
            <input type="hidden" name="pesquisar" value="@Request["pesquisar"]">
            <input type="hidden" name="CupomTipoId" value="@Request["CupomTipoId"]">
            <input type="hidden" name="CupomCabecalhoId" value="@Request["CupomCabecalhoId"]">
            <button class="btn pull-right" type="submit" onclick="return confirm('Esse processo pode demorar alguns segundos?')" >Exportar</button>
        </div>
    </div>
        }

<div class="row-fluid">
    <div class="span12">
        <table class="footable table-bordered table-striped table-pequeno">
                    <thead>
                        <tr>
                            <th>@Html.CampoOrdenacao("Programa", "CuponsTipos.CupomTipoNome")</th>
                            <th>@Html.CampoOrdenacao("Cupom", "CupomNumber")</th>
                            <th>@Html.CampoOrdenacao("Valor", "CupomValor")</th>
                            <th data-hide="phone,tablet">
                                @Html.CampoOrdenacao("Cliente", "Pessoas.Nome")
                            </th>
                            <th>
                                @Html.CampoOrdenacao("Gerado", "Cupons.RegDtInicio")
                            </th>
                            <th>
                                @Html.CampoOrdenacao("Vencimento", "Cupons.CupomVencimento")
                            </th>
                            <th>
                                @Html.CampoOrdenacao("Utilizado", "Cupons.UtilizadoData")
                            </th>
                            <th>Excluir</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr class="">
                                <td>@item.CupomTipoNome</td>
                                <td class="text-center">@item.CupomNumber</td>
                                
                                <td class="text-center">
                                    @if (item.CupomTipo==0)
                                    {
                                        <span>@item.CupomValor.ToString("C")</span>
                                    }
                                    else
                                    {
                                        <span>@item.CupomValor.ToString("P")</span>
                                    }
                                    
                                </td>

                                <td nowrap data-hide="phone,tablet" style="display: table-cell">
                                    @item.Nome
                                </td>
                                <td>@string.Format("{0:dd/MM/yyyy}",item.RegDtInicio)</td>
                                <td>@string.Format("{0:dd/MM/yyyy}",item.CupomVencimento)</td>
                                <td>
                                    @if (item.Utilizado)
                                    {
                                        <span>Sim - @item.UtilizadoData</span>
                                    }
                                    else
                                    {
                                        <span>Não</span>
                                    }
                                    

                                </td>
                                <td>
                                    @if (!item.Utilizado)
                                    {
                                        @Html.ActionLink("Excluir", "Deletar", new { id = item.CupomId }, new { @class = "btn btn-mini" });    
                                    }
                                    
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
        @Html.Paginacao(Convert.ToInt16(Model.TotalPages))
    </div>
</div>


@section Scripts {
    <script src="http://ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js" type="text/javascript"></script>
    <script src="~/Assets/themes/metro/js/footable.js"></script>
    <script type="text/javascript">
        $(function () {
            $('.footable').footable({
                breakpoints: {
                    phone: 400,
                    tablet: 800
                }
            });

            @*$("#CupomTipoId").val("@Request["CupomTipoId"]");*@

        });
    </script>



}