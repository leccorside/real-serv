@model List<Models.PessoaPlanoGrupoParticipante>

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_FortunaLayoutModal.cshtml";
    var currentId = ViewContext.RouteData.Values["id"] as string ?? "0";
}


<div class="content ">

    <div class="row">
        <div class="col-lg-12" style="">
            <div class="hpanel">
                <div class="panel-heading">
                    <div class="panel-tools">
                        <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                    </div>
                    Participantes
                </div>
                <div class="panel-body">
                    <!-- dados aqui-->
                    <div class="row">
                        <div class="col-lg-12">
                            <a href="@Url.Content("~/PessoasPlanosGruposParticipantes/Criar/0/?PessoaPlanoGrupoId=" + currentId)" class="btn btn-primary"><i class="fa fa-plus"></i>Criar</a>
                            <div class="table-responsive">
                                <table class="data table table-condensed table-striped">
                                    <tr>
                                        <th></th>
                                        <th>Tipo
                                        </th>
                                        <th>Nome
                                        </th>
                                        <th></th>
                                        <th></th>
                                    </tr>

                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>@item.PessoaPlanoGrupoParticipanteTipoNome</td>
                                            <td>
                                                @item.PessoaPlanoGrupoParticipanteNome
                                            </td>
                                           
                                            <td><a href="@Url.Content("~/PessoasPlanosGruposParticipantes/Criar/" + item.PessoaPlanoGrupoParticipanteId + "/?PessoaPlanoGrupoId=" + item.PessoaPlanoGrupoId)" class="btn btn-outline btn-primary btn-xs ">Editar</a>    </td>
                                            <td>
                                                <a href="@Url.Content("~/PessoasPlanosGruposParticipantes/Deletar/" + item.PessoaPlanoGrupoParticipanteId + "/?PessoaPlanoGrupoId=" + item.PessoaPlanoGrupoId)" class="btn btn-outline btn-danger btn-xs ">Excluir</a>
                                            </td>
                                        </tr>
                                    }

                                </table>
                            </div>

                        </div>
                    </div>

                </div>

            </div>
        </div>
    </div>

</div>





@section Scripts {
    @Scripts.Render("~/bundles/fancybox/js")
    @Scripts.Render("~/bundles/select2/js")

    <script>
        function selecionado(id) {
            this.parent.UpdateElementOfParent(id);
        }


    </script>


}