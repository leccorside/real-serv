@model Models.ProdutoStatus


@{
    

    
    var acao = "Cadastrar";
    if (Model.ProdutoStatusId > 0)
    {
        acao = "Alterar";
    }


    ViewBag.Title = acao + " Status de Produto";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";     
}





@section Breadcrumb{
    <li class="active"><span class="divider">/</span> @Html.ActionLink("Produtos", "Produtos", "Principal")</li>
    <li class="active"><span class="divider">/</span> @Html.ActionLink("Status de Produto", "Index", new { id = 0 })</li>
}


<div class="cwell">
    @using (Html.BeginForm("Criar", "ProdutosStatus", FormMethod.Post, new { @class = "form-horizontal" }))
    {
        @Html.ValidationSummary(true)

        if (Model.ProdutoStatusId > 0)
        {
        @Html.Hidden("ProdutoStatusId", Model.ProdutoStatusId);
                                            acao = "Alterar";
        }
    
        if (BLL.Usuarios.GetUtilizaFilial() == true && BLL.Usuarios.GetFilialIDMaster() == 0)
            { 
            <div class="control-group">
                <label class="control-label" for="FilialID">@BLL.Usuarios.GetEntidadeFilial():</label>
                <div class="controls">
                    @Html.DropDownListFor(model => model.FilialID, (SelectList)ViewBag.DdlFiliais, "--Nenhuma--", new { @class = "chosen-select" })
                </div>
            </div>
            } else
                    {
                        <input type="hidden" name="FilialID" value="@BLL.Usuarios.GetFilialIDMaster()"/>
                    }
            
        <div class="control-group">
            @Html.LabelFor(model => model.ProdutoStatusNome, new { @class = "control-label" })
            <div class="controls">
                @Html.EditorFor(model => model.ProdutoStatusNome)
                @Html.ValidationMessageFor(model => model.ProdutoStatusNome)
            </div>
        </div>
        
        
         
            
            
                       
            

        <div class="form-actions">


            <input type="submit" value="@acao" class="btn btn-primary  btn-large"  />

        </div>
            
    }
    <div>
        @Html.ActionLink("Voltar", "Index")
    </div>
</div>






@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
