@model Models.PRCPropostaIndiceTipo


@{
    

    
    var acao = "Cadastrar";
    if (Model.PRCPropostaIndiceTipoId > 0)
    {
        acao = "Alterar";
    }


    ViewBag.Title = acao + " Tipo de Índice";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";   
}





@section Breadcrumb{
    <li class="active">@Html.ActionLink("Configurações", "Configuracoes", "Principal")</li>
    <li class="active">@Html.ActionLink("Tipos de Índices", "Index", new { id = 0 })</li>
}



<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">

            <div class="hpanel">

                <div class="panel-body">
                    <!-- conteudo aqui -->


                    @using (Html.BeginForm("Criar", "PRCPropostasIndicesTipos", FormMethod.Post, new { @id = "form-criar", @class = "alertChanges" }))
                    {
                        @Html.ValidationSummary(true)

                        if (Model.PRCPropostaIndiceTipoId > 0)
                        {
                        @Html.Hidden("PRCPropostaIndiceTipoId", Model.PRCPropostaIndiceTipoId);
                                                                                      acao = "Alterar";
                        }
    
       
                        <div class="row">
                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>Tipo</label>
                                @Html.TextBoxFor(model => model.PRCPropostaIndiceTipoNome, new { @class = "form-control select-all" })
                            </div>

                            
                        </div>
         
                        <br />

                        <div class="row-fluid">
                            <div class="col-lg-12">
                                <input type="submit" value="Salvar" class="btn btn-primary btn-large" tabindex="11" />
                                @Html.ActionLink("Voltar", "Index", null, new { @class = "btn btn-outline btn-primary " })
                            </div>

                        </div>
            
                    }

                    <!-- ./conteudo aqui -->
                </div>

            </div>
        </div>
    </div>
</div>




@section Scripts {
    @Scripts.Render("~/bundles/fancybox/js")
    @Scripts.Render("~/bundles/select2/js")
    @Scripts.Render("~/bundles/datepicker/js")
    @Scripts.Render("~/bundles/mask/js")
    @Scripts.Render("~/bundles/jquery-cep/js")
    <script>


        $(".select-all").click(function () {
            $(this).select();
        });




        $(document).ready(function () {
            $('.chosen-select').select2();
            $('.number').mask('0000', { reverse: true });
            $('.moeda').mask('000000000000000,00', { reverse: true });
            $('.indice').mask('00,000000000', { reverse: false });

        });
    </script>
}
