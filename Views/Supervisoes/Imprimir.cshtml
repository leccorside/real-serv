    <span class="text-center">Ref. @Model.MedGuia.MedGuiaId<center>@medico.Endereco, @medico.Numero @medico.Complemento - @medico.Cep - @medico.Bairro - @medico.Cidade / @medico.Estado</center></span>
</div>*@
