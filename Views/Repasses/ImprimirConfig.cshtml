@model Models.RepasseView

@{
    ViewBag.Title = "ImprimirConfig";
    Layout = "~/Views/Shared/_FortunaLayoutModal.cshtml";
}


<div class="content animate-panel">
    <div class="row">
        <div class="col-lg-12" style="">

            <div class="hpanel">
                <div class="panel-heading">
                    <div class="panel-tools">
                        <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                    </div>
                    <h4>Selecione os campos para impressão</h4>
                </div>
                <div class="panel-body">
                    <!-- dados aqui-->
                    @using (Html.BeginForm("Imprimir", "Repasses", FormMethod.Post, new { @class = "" }))
                    {
                        @Html.ValidationSummary(true)
        
                        @Html.HiddenFor(m => m.Repasse.RepasseId);
                        
                        
                        <div class="row">
                            <div class="col-lg-12">
                                <ul>
                                    <li>
                                        <div class="checkbox">
                                            <label>
                                                @Html.CheckBoxFor(model => model.ExibeValorReal) Exibir valores reais?
                                            </label>
                                        </div>
                                    </li>
                                    <li>
                                        <div class="checkbox">
                                            <label>
                                                @Html.CheckBoxFor(model => model.ExibeDetalhamento) Exibir detalhamento?
                                            </label>
                                        </div>
                                        <ul>
                                            <li>
                                                <div class="checkbox">
                                                    <label>
                                                        @Html.CheckBoxFor(model => model.ExibeValorPorGuia) Exibir valores por guia (no detalhamento)?
                                                    </label>
                                                </div>
                                            </li>
                                        </ul>
                                    </li>
                                </ul>

                            </div>
                        </div>
                        
                        <div class="row">


                            <div class="col-lg-12">
                                <input type="submit" value="Imprimir" class="btn btn-primary btn-large" tabindex="11" />
                            </div>

                        </div>
                        
                        
                        
                    }


                    <!-- ./ dados aqui-->
                </div>

            </div>
        </div>
    </div>
    <br />


</div>


