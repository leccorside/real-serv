@model IEnumerable<Models.RepassePreview>

@{
    ViewBag.Title = "Repasses";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";
    var user = new BLL.Usuarios();
    var config_filiais_index = user.ControleAcesso("index", "Filiais");
       
}




@section Breadcrumb{



}



<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">
            <div class="hpanel">
                <div class="panel-body">
                    <!-- tirei daqui-->

                    <div class="table-responsive">
                        <table cellpadding="1" cellspacing="1" class="table" id="table_produtos">
                            <thead>
                                <tr style="font-size: 12px;">
                                    <th>#</th>
                                    <th>@BLL.Usuarios.GetEntidadeFilial()</th>
                                    <th class="text-right">Total</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>

                                @foreach (var item in Model)
                                {
                                    var repasse_config = (item.FilialRepasse == 0 || item.FilialRepasseTeto == 0) ? false : true;
                                           
                                    <tr class="@(repasse_config?"  ":" active ")">
                                        <td>@item.FilialID</td>
                                        <td>@item.FilialNome <i class="fa @(repasse_config?"":" fa-exclamation-triangle text-warning ")" aria-hidden="true"></i> 
                                                @if (!repasse_config)
                                                {
                                                    <small><br /><strong>Atenção:</strong> Parâmetros de repasse não configurados.</small>
                                                    if (config_filiais_index)
                                                    {
                                                        <small><a href="@Url.Content("~/Filiais/Index")">Clique aqui para acessar Filiais</a></small>
                                                    }
                                                }

                                        </td>
                                        <td class="text-right">R$ @string.Format("{0:F2}", item.Total)</td>
                                        <td><a class="btn btn-outline btn-primary btn-xs" href="@Url.Content("~/Repasses/Preparar/" + item.FilialID)" >Gerar Repasse</a></td>
                                    </tr>
                                }

                            </tbody>

                            <tfoot>
                                    <tr>
                                        <th colspan="3" class="text-right">R$ @string.Format("{0:F2}", Model.Sum(m => m.Total))</th>
                                        <th></th>
                                    </tr>
                                </tfoot>

                        </table>


                    </div>


                    <!-- ./tirei daqui-->
                </div>
            </div>
        </div>
    </div>
</div>










