@model Models.RepasseView

@{
    ViewBag.Title = "Demonstrativo " + Model.Repasse.RepasseId;
    Layout = "~/Views/Shared/_WindowPrint.cshtml";
    decimal total = 0;
    var colunas = 2;
    if (Model.ExibeValorPorGuia)
    {
        colunas = 3;
    }
    
}
@section Styles{

    <style>
        body
        {
            font-size: 12px;
        }


        pre
        {
            background-color: transparent !important;
            border: none !important;
            font-size: 12px;
            margin: 0px;
            padding: 0px;
        }


        @@media screen
        {
            div.divFooter
            {
                display: none;
            }
        }

        @@media print
        {
            div.divFooter
            {
                position: fixed;
                bottom: 0;
                text-align: center;
                width: 100%;
                border-top: 1px solid #808080;
            }
        }
    </style>



}
<h3>Demonstrativo</h3>
<table border="1" width="100%" cellpadding="5">
    <tr>
        <td valign="top" nowrap><small>Ref n<sup>o</sup>.:</small><br />@Model.Repasse.RepasseId</td>

        <td valign="top" width="100%"><small>Guias n<sup>o</sup>.:</small><br />
            @String.Join(", ", Model.ListMedGuias.OrderBy(x => x.MedGuiaId).Select(x => x.MedGuiaId))</td>
        <td valign="top" nowrap><small>Qtd. Guias</small><br />@Model.ListMedGuias.Count()</td>
    </tr>
</table>

<h5>Dados Bancários</h5>
<table border="1" width="100%" cellpadding="5" style="border-bottom: 0px none">
    <tr>
        <td valign="top"><small>Para:</small><br />@Model.Filial.FilialNome</td>
        <td valign="top"><small>Endereço:</small><br />@Model.Filial.FilialEndereco @Model.Filial.FilialNumero @Model.Filial.FilialComplemento\<br />
            @Model.Filial.FilialCidade @Model.Filial.FilialEstado, @Model.Filial.FilialCep<br />
        </td>
        <td valign="top"><small>Telefone:</small><br />@Model.Filial.FilialTelefone</td>
    </tr>
</table>
<table border="1" width="100%" cellpadding="5">
    <tr>
        <td valign="top"><small>Banco:</small><br />@Model.Filial.FilialBancoCod - @Model.Filial.FilialBancoNome</td>
        <td valign="top"><small>Agência:</small><br />@Model.Filial.FilialBancoAgencia</td>
        <td valign="top"><small>Conta:</small><br />@Model.Filial.FilialBancoConta</td>
        @if (Model.ExibeValorReal)
        {
            <td valign="top"><small>Total:</small><br />
                R$ @string.Format("{0:F2}", Model.Repasse.RepasseTotal)</td>            
        }
        else
        {
            <td valign="top"><small>Total:</small><br />
                R$ @string.Format("{0:F2}", Model.Repasse.RepasseTotalReal)</td>
        }

        <td valign="top"><small>Observações:</small><br />@Model.Filial.FilialBancoObservacoes</td>
    </tr>
</table>


<h5>Autorização</h5>
<table border="1" width="100%" cellpadding="5">
    <tr>
        <td valign="top"><small>Visto:</small><br />
            <br />
            <br />
            <br />
            <small>Nome:</small><br />
            <small>RG:</small></td>
        <td valign="top"><small>Visto:</small><br />
            <br />
            <br />
            <br />
            <small>Nome:</small><br />
            <small>RG:</small></td>
    </tr>
</table>
@if (Model.ExibeDetalhamento)
{
    <h4>Detalhamento</h4>
    <table border="1" width="100%" cellpadding="5">
        <thead>
            <tr>
                <th colspan="@colunas">Dados Guia</th>
                <th colspan="2">Médico</th>
                <th colspan="2">Paciente</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <th>Guia n<sup>o</sup></th>
                <th>Data Exame</th>
                @if (Model.ExibeValorPorGuia)
                {
                    <th>Vlr. Guia</th>
                }
                <th>CRM</th>
                <th>Nome</th>
                <th>CPF</th>
                <th>Nome</th>
            </tr>
        </tbody>
        @foreach (var item in Model.ListMedGuias.OrderBy(x => x.MedGuiaId))
        {
            total = total + (decimal)item.TotalRepasse;
            <tbody>
                <tr>
                    <td>@item.MedGuiaId</td>
                    <td>@string.Format("{0:dd/MM/yyyy}", item.MedGuiaData)</td>
                    @if (Model.ExibeValorPorGuia)
                    {
                        <td>R$ @string.Format("{0:F2}", item.TotalReembolso)</td>    
                    }
                    <td>@item.MedicoCRM</td>
                    <td>@item.MedicoNome</td>
                    <td>@item.PacienteCpf</td>
                    <td>@item.PacienteNome</td>

                </tr>
            </tbody>    
        }
    </table>
}else {
    <hr style="border-bottom: 1px dotted black" />
}