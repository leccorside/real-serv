@model List<Models.GaleriaArquivo>

@{
    ViewBag.Title = "Base de Conhecimento";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";
    
    
}

@section Breadcrumb{

}





<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">
            <div class="hpanel">
                <div class="panel-body">
                    <!-- tirei daqui-->




                    <ul style="list-style: none; margin: 0px !important; padding: 0px !important;">
                        @foreach (var item in Model)
                        {
                            var urldownload = Url.Content("~/apiintegracao/galeriaarquivosdownload/?guid=" + item.GaleriaArquivoGuid + "");
                                    
                            <li class="col-lg-3" style="">
                                <div class="hpanel">
                                    <div class="panel-body file-body">
                                        <a href="@urldownload">
                                            <i class="fa @BLL.GaleriasArquivos.TipoIcone(item.GaleriaArquivoContentType)"></i>
                                            <br />
                                            @item.GaleriaArquivoFileName
                                            <br />
                                            <small>@item.GaleriaArquivoContentType</small>
                                            <br /><br />
                                            @if (BLL.Utils.Validacoes.ToStringNullSafe(item.GaleriaArquivoBadges) != "")
                                                                    {
                                                                        List<string> badges = item.GaleriaArquivoBadges.Split(',').ToList();
                                                                        foreach (var badge in badges)
                                                                        {
                                                                        <span class="label label-info">@badge</span>
                                                                        }
                                                                    }
                                        </a>
                                    </div>
                                    <div class="panel-footer">
                                        <a href="@urldownload">@item.GaleriaArquivoNome</a>
                                    </div>
                                </div>


                            </li>
                        }
                    </ul>

                    <!-- ./tirei daqui-->
                </div>
            </div>
        </div>
    </div>
</div>