    <script>
        $(document).ready(function () {
            GetListaQtdNegociadorStatus();
        });

        function GetListaQtdNegociadorStatus() {
            $.getJSON('@Url.Content("~/ApiIntegracao/GetListaQtdNegociadorStatus/")', { id: "@BLL.Usuarios.GetUsuarioId()", visualizarTodas: "@PRCPropostas_ViewAll", visualizarTriagem: "@PRCPropostas_ViewTriagem", empresaid: "@BLL.Usuarios.GetEmpresaId()" }, function (result) {
                  $('#loading_table_negociadores_propostas').css('display', 'inline');
                  data = $.map(result, function (item, a) {

                      $("#" + item.Descricao).html(item.Quantidade);

                  });
                  $('#loading_table_negociadores_propostas').css('display', 'none');

              });
          }

    </script>




