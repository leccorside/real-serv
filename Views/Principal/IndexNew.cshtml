@{
    ViewBag.Title = "Home";
    ViewBag.nobreadcrumb = "true";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";
    var user = new BLL.Usuarios();

    var lista = new List<Models.Menu>();
    var contador = 0;
    var contadorMaster = 1;
    var orientacao = "col-l";
    var click = "";
    var xx = 0;
    var yy =0;

    var config_filiais_index = user.ControleAcesso("index", "Filiais");
    var PRCPropostas_ViewAll = user.ControleAcesso("ViewAll", "PRCPropostas");
    var PRCPropostas_ViewTriagem = user.ControleAcesso("ViewTriagem", "PRCPropostas");

    var bllOcorrencias = new BLL.Ocorrencias();
    var bllMedGuias = new BLL.MedGuias();
    var bllRepasses = new BLL.Repasses();
    var bllPropostas = new BLL.PRCPropostas();
    var bllUsuarios = new BLL.Usuarios();
    var bllStatus = new BLL.EntidadesStatus();

    var bllMetas = new BLL.Metas();
    var listarMetas = bllMetas.ListarPorPerfilEUsuario(BLL.Usuarios.GetPerfilId(), BLL.Usuarios.GetUsuarioId(), "PRCPropostas");


    var hoje = DateTime.Now;
    DateTime ontem = DateTime.Now.AddDays(-1);

    var labelOntem = "ONTEM";
    if ((int)ontem.DayOfWeek == 6)
    {
        // se sabado volta 2
        ontem = DateTime.Now.AddDays(-2);
        labelOntem = "SEXTA";
    }
    if ((int)ontem.DayOfWeek == 0)
    {
        // se domingo, volta e
        ontem = DateTime.Now.AddDays(-3);
        labelOntem = "SEXTA";
    }


    var listarPropostasComTarefasHoje = bllPropostas.ListarTODO(0);
    var listarPropostasComTarefasOntem = bllPropostas.ListarTODO(-1);
    var listarHistorico7dias = bllPropostas.ListaQtdPorNegociador(BLL.Usuarios.GetUsuarioId(), -7, "0,1");

    var retornoQtd = listarPropostasComTarefasHoje.Count();
    var retornoTotal = listarPropostasComTarefasHoje.Sum(x => x.PRCPropostaValorBruto);

    var retornoOntemQtd = listarPropostasComTarefasOntem.Count();
    var retornoOntemTotal = listarPropostasComTarefasOntem.Sum(x => x.PRCPropostaValorBruto);

    var pensandoQtd = listarHistorico7dias.result_D;
    var pensandoTotal = listarHistorico7dias.result_C;

    var metaMesVolume = listarMetas.Where(m => m.PeriodicidadeTipo == "M").Sum(x => x.MetaVolume);
    var metaMesQtd = listarMetas.Where(m => m.PeriodicidadeTipo == "M").Sum(x => x.PeriodicidadeValor);

    //0 e 1 - fluxo
    //2-sucesso
    //3-erro
    var resultMeta = bllMetas.CalcularMetaUnitaria("PRCPropostas", "M", "2", BLL.Usuarios.GetPerfilId(), BLL.Usuarios.GetUsuarioId(), metaMesQtd, metaMesVolume);
    var mapaStatus = bllPropostas.ListaParaMapa(BLL.Usuarios.GetUsuarioId()).ToList();
    var mapaStatusLegenda = mapaStatus.GroupBy(x => x.Descricao)
                   .Select(grp => grp.First())
                   .ToList();
    var teste = "";
    var count = 0;
    mapaStatusLegenda.ForEach(item =>
    {
        count++;
        teste += "\"" + item.Descricao + ":\'data" + count.ToString()+"_x\',";
    });
    if (teste!=null && teste!="")
    {
        teste = teste.Substring(0, teste.Length - 1);    
    }
    
}
<div class="content">
    
    
    
    
    
        <div class="row">
            <div class="col-lg-6 welcome-header">
                <h1>Olá @BLL.Utils.Funcoes.GetPrimeiroNome(BLL.Usuarios.GetUsuarioNome())!</h1>
                <br />
                @if (resultMeta.Volume >= metaMesVolume)
                {
                    <h2>Você está com uma ótima performance, veja os índices abaixo. </h2>
                }
                else
                {
                <h2>Falta somente <strong> @metaMesVolume.ToString("C") </strong>para bater a META desse mês. Dê uma olhada nos índices abaixo, dá pra chegar!     </h2>
                }

                
                
            </div>
            <div class="col-lg-6">
                <div class="hpanel">
                    <div class="panel-heading">
                        <div class="panel-tools">
                            <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                            <a class="closebox"><i class="fa fa-times"></i></a>
                        </div>
                        Propostas aceitas
                    </div>
                    <div class="panel-body">
                        <div>
                            <div id="gauge"></div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
        <div class="row">
            <div class="col-lg-3">
                <div class="hpanel stats">
                    <div class="panel-body h-200">
                        <div class="stats-title pull-left">
                            <h4>Retornos</h4>
                        </div>
                        <div class="stats-icon pull-right">
                            <i class="pe-7s-back fa-4x"></i>
                        </div>
                        <div class="m-t-xl">
                            <h1 class="text-success">@retornoQtd</h1>
                            <span class="font-bold no-margins">Retornos para hoje
                            </span>
                            <br />
                            <small>Somados eles somam <strong>@retornoTotal.ToString("C")</strong>. 
                            </small>
                        </div>
                    </div>
                    <div class="panel-footer">
                        Clique para ver seus retornos
                    </div>
                </div>
            </div>
            <div class="col-lg-3">
                <div class="hpanel stats">
                    <div class="panel-body h-200">
                        <div class="stats-title pull-left">
                            <h4>@labelOntem ( @String.Format("{0:ddd-dd/MM}", ontem) )</h4>
                        </div>
                        <div class="stats-icon pull-right">
                            <i class="pe-7s-browser fa-4x"></i>
                        </div>
                        <div class="m-t-xl">
                            <h1 class="text-success">@retornoOntemQtd</h1>
                            <span class="font-bold no-margins">Atendimentos
                            </span>
                            <br />
                            <small>Você falou <strong>menos</strong> que a sua média. Faltaram 5 contatos para alcançar.
                            </small>
                        </div>
                    </div>
                    <div class="panel-footer">
                        Se quiser ver essas propostas, clique aqui
                    </div>
                </div>
            </div>
            <div class="col-lg-3">
                <div class="hpanel stats">
                    <div class="panel-body h-200">
                        <div class="stats-title pull-left">
                            <h4>Favoritos</h4>
                        </div>
                        <div class="stats-icon pull-right">
                            <i class="pe-7s-star fa-4x"></i>
                        </div>
                        <div class="m-t-xl">
                            <h1 class="text-success">22</h1>
                            <span class="font-bold no-margins">Pessoas favoritas
                            </span>
                            <br />
                            <small>Com essas pessoas você já falou <strong>5x ou mais</strong>. Vamos fechar ou tirar esses da frente!
                            </small>
                        </div>
                    </div>
                    <div class="panel-footer">
                        Não atendeu e Deixei recado não entram aqui.
                    </div>
                </div>
            </div>
            <div class="col-lg-3">
                <div class="hpanel stats">
                    <div class="panel-body h-200">
                        <div class="stats-title pull-left">
                            <h4>Pensando</h4>
                        </div>
                        <div class="stats-icon pull-right">
                            <i class="pe-7s-monitor fa-4x"></i>
                        </div>
                        <div class="m-t-xl">
                            <h1 class="text-success">@pensandoQtd</h1>
                            <span class="font-bold no-margins">Pensando na sua proposta
                            </span>
                            <br />
                            <small>Essas propostas somam <strong>@decimal.Parse(pensandoTotal).ToString("C")</strong>.
                            </small>
                        </div>
                    </div>
                    <div class="panel-footer">
                        Temos só 7 dias nesse status.
                    </div>
                </div>
            </div>
        </div>
        <div class="row">

            <div class="col-lg-12">
                <div class="hpanel">
                    <div class="panel-heading">
                        <div class="panel-tools">
                            <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                            <a class="closebox"><i class="fa fa-times"></i></a>
                        </div>
                        Propostas por status
                    </div>
                    <div class="panel-body">
                        <div>
                            <div id="scatter"></div>
                            <div id="chartteste"></div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
        <div class="row">
            <div class="col-lg-12">
                <div class="hpanel">
                    <div class="panel-heading">
                        <div class="panel-tools">
                            <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                            <a class="closebox"><i class="fa fa-times"></i></a>
                        </div>
                        Última semana
                    </div>
                    <div class="panel-body">
                        <div>
                            <div id="stocked"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

@section css{
    @Styles.Render("~/bundles/datatables/css")<link href="~/Assets/_fortuna/vendor/c3/c3.css" rel="stylesheet" />
    <style>
        li.col-lg-3
        {
            min-height: 265px !important;
        }
    </style>
}


@section Scripts{
  
    
<!-- Vendor scripts -->
<script src="~/Assets/_fortuna/vendor/jquery/dist/jquery.min.js"></script>
<script src="~/Assets/_fortuna/vendor/jquery-ui/jquery-ui.min.js"></script>
<script src="~/Assets/_fortuna/vendor/slimScroll/jquery.slimscroll.min.js"></script>
<script src="~/Assets/_fortuna/vendor/bootstrap/dist/js/bootstrap.min.js"></script>
<script src="~/Assets/_fortuna/vendor/metisMenu/dist/metisMenu.min.js"></script>
<script src="~/Assets/_fortuna/vendor/iCheck/icheck.min.js"></script>
<script src="~/Assets/_fortuna/vendor/sparkline/index.js"></script>
<script src="~/Assets/_fortuna/vendor/d3/d3.min.js"></script>
<script src="~/Assets/_fortuna/vendor/c3/c3.min.js"></script>

<!-- App scripts -->
<script src="~/Assets/_fotuna/scripts/homer.js"></script>


<script>

    $(function () {

        // Wait until all panels will be render
        // Remove setTimeout if you don't use animate-panel effect

        c3.generate({
            bindto: '#lineChart',
            data: {
                columns: [
                    ['Novas', 32, 28, 65, 40, 35, 25],
                    ['Retorno', 5, 2, 10, 4, 1, 25]
                ],
                colors: {
                    data1: '#62cb31',
                    data2: '#BABABA'
                }
            }
        });

        c3.generate({
            bindto: '#areaChart',
            data: {
                columns: [
                    ['data1', 300, 350, 300, 0, 0, 0],
                    ['data2', 130, 100, 140, 200, 150, 50]
                ],
                types: {
                    data1: 'area',
                    data2: 'area-spline'
                },
                colors: {
                    data1: '#62cb31',
                    data2: '#BABABA'
                }
            }
        });

        var mapa = c3.generate({
            bindto: '#scatter',
            data: {
                xs: { 'Mapa':'Mapa_x' },//data1:'data1_x', data2:'data2_x'    },
                columns: [
                    ["Mapa_x", 21, 3.2, 3.1, 2.3, 2.8, 2.8, 3.3, 2.4, 2.9, 2.7, 2.0, 3.0, 2.2, 2.9, 2.9, 3.1, 3.0, 2.7, 2.2, 2.5, 3.2, 2.8, 2.5, 2.8, 2.9, 3.0, 2.8, 3.0, 2.9, 2.6, 2.4, 2.4, 2.7, 2.7, 3.0, 3.4, 3.1, 2.3, 3.0, 2.5, 2.6, 3.0, 2.6, 2.3, 2.7, 3.0, 2.9, 2.9, 2.5, 2.8],
                    ["Mapa", 2.5, 1.9, 2.1, 1.8, 2.2, 2.1, 1.7, 1.8, 1.8, 2.5, 2.0, 1.9, 2.1, 2.0, 2.4, 2.3, 1.8, 2.2, 2.3, 1.5, 2.3, 2.0, 2.0, 1.8, 2.1, 1.8, 1.8, 1.8, 2.1, 1.6, 1.9, 2.0, 2.2, 1.5, 1.4, 2.3, 2.4, 1.8, 1.8, 2.1, 2.4, 2.3, 1.9, 2.3, 2.5, 2.3, 1.9, 2.0, 2.3, 1.8]
                ],
                type: 'scatter'
            },
            axis: {
                y: {
                    label: 'R$ Valor Bruto x 1000',
                    tick: {
                        fit: false
                    }
                },
                x: {
                    label: 'Dias no status'
                }
            }
        });
        

        c3.generate({
            bindto: '#stocked',
            data: {
                columns: [
                    ['Novas', 32, 28, 65, 40, 35, 25],
                    ['Retorno', 5, 2, 10, 4, 1, 25]
                ],
                colors: {
                    Novas: '#62cb31',
                    Retorno: '#BABABA'
                },
                type: 'bar',
                groups: [
                    ['Novas', 'Retorno']
                ]
            }
        });

        c3.generate({
            bindto: '#gauge',
            data: {
                columns: [
                    ['Propostas aceitas', @resultMeta.ResultPercentVolume]
                ],

                type: 'gauge'
            },
            color: {
                pattern: ['#ff7514', '#BABABA']

            }
        });


        mapa.unload({
            ids: 'Mapa'
        });
    @foreach (var item in mapaStatusLegenda)
    {
    @:setTimeout(function() {
                        @:mapa.load({
                        @:xs:
                            @:{
                            @:'@Html.Raw(item.Descricao)': '@Html.Raw(item.Descricao + "_x")'
                            @:},
        @:columns: [
            @:['@Html.Raw(item.Descricao + "_x")', @String.Join(",", mapaStatus.Where(x => x.Descricao==item.Descricao).Select(x=>(x.data_x)))],
            @:['@Html.Raw(item.Descricao)', @String.Join(",", mapaStatus.Where(x => x.Descricao==item.Descricao).Select(x=>(x.data)))],
      @:  ]
    @:});
    @:}, 3500);

    }


    });


</script>



}