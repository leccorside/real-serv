@model Models.ProdutoSecao

@{
    ViewBag.Title = "Excluíndo Tipos de Seções";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


@section Breadcrumb{

    <li class="active"><span class="divider">/</span>    @Html.ActionLink("Tipos de Seções", "Index")</li>
}


<div class="alert">

    <h2>Atencão!</h2>
    Você tem certeza que deseja apagar esse registro?
</div>

<table class="table table-bordered table-striped table-highlight">
    <thead>
        <tr>
            <th>Seção</th>
            <th nowrap>Criado em</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td width="100%">@Html.DisplayFor(model => model.ProdutoSecaoNome)</td>
            <td nowrap>@Model.RegDtInicio</td>
        </tr>
    </tbody>
</table>

@using (Html.BeginForm())
{
    
    @Html.HiddenFor(model => model.ProdutoSecaoId)

    <p class="pull-right">
        <input type="submit" value="Apagar" class="btn btn-large btn-danger" />
    </p>

    <p class="pull-left">
        @Html.ActionLink("Voltar", "Index")
    </p>
}


