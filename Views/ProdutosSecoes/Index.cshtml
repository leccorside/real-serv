@model IEnumerable<Models.ProdutoSecao>


@{
    ViewBag.Title = "Tipos de Seções";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    
}


@section Breadcrumb{

}




@Html.ActionLink("+ Criar", "Criar", new { id = 0 }, new { @class = "btn btn-primary" })


<table class="table table-bordered table-striped table-highlight">
    <thead>
        <tr>

            <th>Seção</th>

            
            <th nowrap>
                @Html.DisplayNameFor(model => model.RegDtInicio)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Count() == 0)
        {
            <tr class="info">
                <td colspan="20"><small class="muted">Nenhum registro localizado</small></td>
            </tr>
        }
        @foreach (var item in Model)
        {
            <tr>

                <td width="100%">
                    @item.ProdutoSecaoNome
                </td>
                
                <td nowrap>
                    @item.RegDtInicio
                </td>
                <td nowrap>
                    <a href="~/ProdutosSecoes/Criar/@item.ProdutoSecaoId" class="btn btn-mini"><i class="fa fa-pencil"></i>Alterar</a> | 
                    <a href="~/ProdutosSecoes/Deletar/@item.ProdutoSecaoId" class="btn btn-mini"><i class="fa fa-times"></i>Excluir</a>
                </td>
            </tr>
        }

    </tbody>
</table>




@{
    //Controles de paginação
    int qtdPaginas = Convert.ToInt16(ViewBag.qtdPaginas);   
}
@Html.Paginacao(qtdPaginas)
