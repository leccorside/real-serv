@model PetaPoco.Page<Models.PRCProposta>

@{
    ViewBag.Title = "Propostas";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";

    String strPathAndQuery = HttpContext.Current.Request.Url.PathAndQuery;
    String strUrl = HttpContext.Current.Request.Url.AbsoluteUri.Replace(strPathAndQuery, "/");
    strUrl = strUrl + "PRCPropostas/Find";

    ViewBag.SearchAction = strUrl;
    ViewBag.SearchPlaceHolder = "Pesquisar por Precatório ";
    ViewBag.SearchMethod = "get";

    var _visualizarTodas = BLL.Usuarios.VerificaAcesso("ViewAll", "PRCPropostas");
    var _PrcPropsotas_Deletar = BLL.Usuarios.VerificaAcesso("Deletar", "PRCPropostas");
    var _PrcPropsotas_Criar = BLL.Usuarios.VerificaAcesso("Criar", "PRCPropostas");
    var _PrcPropsotas_CriarPorId = BLL.Usuarios.VerificaAcesso("CriarPorId", "PRCPropostas");

    var _regraVisualizaOutras = true;

    string outrosCampos = Convert.ToString(ViewBag.Campos);
    if (outrosCampos == null)
    {
        outrosCampos = "";
    }

   
}




@section Breadcrumb{


}



<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">
            <div class="hpanel">
                
                <div class="panel-heading hbuilt">
                    <div class=" p-xs font-normal">

                        @using (Html.BeginForm("Find", "PRCPropostas", FormMethod.Get, new { @class = "  " }))
                        {
                            if (_regraVisualizaOutras)
                            {
                            <input type="hidden" name="pesquisartudo" value="true" />
                            }
                            
                            <div class="row">
                                <div class="form-group col-lg-4">
                                    <label>Proposta</label>
                                    <input type="text" name="PRCPropostaId" id="PRCPropostaId" title="Pesquisar" class="form-control select-all" placeholder="Proposta..." value="@Request["PRCPropostaId"]">
                                </div>

                                <div class="form-group col-lg-4">
                                    <label>Precatório</label>
                                    <input type="text" name="pesquisar" id="pesquisar" title="Pesquisar" class="form-control select-all" placeholder="Precatório..." value="@Request["pesquisar"]">
                                </div>

                                <div class="form-group col-lg-4">
                                    <label>Advogado</label>
                                    <input type="text" name="Advogados_Nome" id="Advogados_Nome" title="Pesquisar" class="form-control select-all" placeholder="Advogado..." value="@Request["Advogados_Nome"]">
                                </div>

                                <div class="form-group col-lg-4">
                                    <label>CPF</label>
                                    <input type="text" name="Requerentes_Documento" id="Requerentes_Documento" title="Pesquisar" class="form-control select-all" placeholder="Documento..." value="@Request["Requerentes_Documento"]">
                                </div>

                                <div class="form-group col-lg-4">
                                    <label>Nome</label>
                                    <input type="text" name="Requerentes_Nome" id="Requerentes_Nome" title="Pesquisar select-all" class="form-control" placeholder="Requerente..." value="@Request["Requerentes_Nome"]">
                                </div>

                                <div class="form-group col-lg-4">
                                    <label>Telefone</label>
                                    <input type="text" name="telefone" id="telefone" title="Pesquisar" class="form-control select-all" placeholder="Telefone..." value="@Request["telefone"]">
                                </div>

                            </div>
                                
                                    <div class="row">

                                        <div class="col-lg-12" style="">
                                            <button class="btn btn-primary" type="submit"><i class="fa fa-search"></i> Pesquisar</button>
                                                <button class="btn btn-xs btn-outline btn-danger pull-right" type="button" onclick="parent.location='@strUrl'"><i class="fa fa-eraser"></i> Limpar pesquisa</button>
                                        </div>
                                    </div>
                                
                        }
                    </div>
                </div>

                <div class="panel-body">
                    <!-- tirei daqui-->

                    <div class="table-responsive">
                        

                        <table cellpadding="1" cellspacing="1" class="table" id="table_produtos">
    <thead>
        <tr style="font-size: 12px;">
            <th>@Html.CampoOrdenacao("Proposta", "PRCPropostaId")</th>
            <th>@Html.CampoOrdenacao("Precatório", "PRCPropostaPrecatorio")</th>
            
            <th>@Html.CampoOrdenacao("Status", "StatusNome")</th>
            
            <th>@Html.CampoOrdenacao("Valor", "PRCPropostaValorBruto")</th>
            <th>@Html.CampoOrdenacao("Negociador", "Negociadores.UsuarioNome")</th>

            <th></th>



            @if (_PrcPropsotas_Deletar)
            {
                <th></th>    
            }

        </tr>
    </thead>
    <tbody>

        @foreach (var item in Model.Items)
        {

            var tr_status = "";



            var icon = "";
            var tempoPassado = "";
            if (item.StatusTempoMaximo > 0 && item.StatusTempoPassado >= item.StatusTempoMaximo)
            {
                tr_status = "warning";
                icon = "fa fa-bell-o";
                tempoPassado = "<i class='fa fa-clock-o'></i> " + item.StatusTempoPassado + " hrs";
            }
            
                                    
            <tr class=" @tr_status">
                <td><i class="@icon"></i>@item.PRCPropostaId </td>
               
                <td>
                    <span class="badge @item.Fonte">@item.Fonte</span><br />
                    @item.PRCPropostaPrecatorio
                        <br />
                        <br /><small>Requerente:<strong></small><br />
                        <h5>@item.RequerenteNome</h5>
               
                </td>
                
                
                <td>@item.StatusNome @Html.Raw(tempoPassado)

                    @if (item.EntidadeStatusSubStatus != null && item.EntidadeStatusSubStatus != "")
                    {
                        List<string> badges = item.EntidadeStatusSubStatus.Split(',').ToList();
                        foreach (var badge in badges)
                        {
                        <span class="label label-info">@badge</span>
                        }
                    }

                    @if (item.TriagemRetorno)
                    {
                    <br /><span class="label label-success">Retorno Triagem</span>
                    }

                    @if (item.Triagem)
                    {
                    <br /><span class="label label-warning">Em triagem</span>
                    }


                    <br /><br /><label>Última ação:</label>
                     @if (item.EntidadeStatusDtAtualiza != null)
                    {
                        <br /><span>@String.Format("{0:dd/MM/yyyy}", (DateTime)item.EntidadeStatusDtAtualiza)</span>
                    }
                     else
                     {
                         <br /><span>-</span>
                     }

                    <br /><br /><label>Próxima ação:</label>
                     @if (item.EntidadeStatusHistoricoData != null)
                     {
                        <br /><span>@String.Format("{0:dd/MM/yyyy}", (DateTime)item.EntidadeStatusHistoricoData)</span>
                     }
                     else
                     {
                         <br /><span>-</span>
                     }

                </td>
                <td>
                    <label>Valor Bruto</label><br />
                    R$ @string.Format("{0:N2}", item.PRCPropostaValorBruto)
                    <br /><br />
                    <label>Valor Proposta</label><br />
                    R$ @string.Format("{0:N2}", item.PRCPropostaFinalValor)
                    <br />

                </td>
                
               <td>@item.NegociadorNome</td>
                

                @if (!item.Triagem || _visualizarTodas)
                {


                    if (_visualizarTodas == false && _regraVisualizaOutras == true && item.NegociadorId != BLL.Usuarios.GetUsuarioId())
                    {
                    <td></td>
                    }
                    else
                    {
                    <td><a href="@Url.Content("~/PRCPropostas/Editar/" + item.PRCPropostaId + "/" + item.PRCPropostaGUID)" class="btn btn-outline btn-primary btn-xs" >Editar</a></td>    
                        
                    }




                }
                else
                {
                    <td colspan="2"></td>
                }

            </tr>    
                                  

        }

    </tbody>



</table>

                    </div>

                    @Html.FortunaPaginacao(Convert.ToInt16(Model.TotalPages), outrosCampos)


                    <!-- ./tirei daqui-->
                </div>
            </div>
        </div>
    </div>
</div>







@section Styles{
    @Styles.Render("~/bundles/datatables/css")
    @Styles.Render("~/bundles/fancybox/css") @Styles.Render("~/bundles/select2/css")

}




@section Scripts {
    @Scripts.Render("~/bundles/datatables/js")@Scripts.Render("~/bundles/select2/js")
    @Scripts.Render("~/bundles/datatablesBootstrap/js")
    @Scripts.Render("~/bundles/datatablesPlugins/js")
    @Scripts.Render("~/bundles/fancybox/js")

    <script type="text/javascript">
        $(".fancybox").fancybox({
            toolbar: false,
            padding: 0,
            fitToView: false,
            width: '80%',
            autoSize: true,
            helpers: {
                overlay: {
                    locked: true
                }
            }
        });
    </script>
    <script>

        // Initialize Example 2
        $('.dataTable').dataTable({
            "pageLength": 50,
            "paging": true,
            "ordering": true,
            "bLengthChange": true,
            "bFilter": true,
            "info": true,
            "language": {
                "sEmptyTable": "Nenhum registro encontrado",
                "sInfo": "Mostrando de _START_ até _END_ de _TOTAL_ registros",
                "sInfoEmpty": "Mostrando 0 até 0 de 0 registros",
                "sInfoFiltered": "(Filtrados de _MAX_ registros)",
                "sInfoPostFix": "",
                "sInfoThousands": ".",
                "sLengthMenu": "_MENU_ resultados por página",
                "sLoadingRecords": "Carregando...",
                "sProcessing": "Processando...",
                "sZeroRecords": "Nenhum registro encontrado",
                "sSearch": "Pesquisar ",
                "oPaginate": {
                    "sNext": "Próximo",
                    "sPrevious": "Anterior",
                    "sFirst": "Primeiro",
                    "sLast": "Último"
                },
                "oAria": {
                    "sSortAscending": ": Ordenar colunas de forma ascendente",
                    "sSortDescending": ": Ordenar colunas de forma descendente"
                }
            }
        });






    </script>

    <script>
        $("#de").mask("99/99/9999");
        $("#ate").mask("99/99/9999");
        $("#Requerentes_Documento").mask("999.999.999-99");
        $('#telefone').mask(maskBehavior, options);
        $(".select-all").click(function () {
            $(this).select();
        });
        $("#StatusNome").val('@Request["StatusNome"]').trigger('chosen:updated');
        $("#StatusNome").val('@Request["StatusNome"]').trigger('change.select2');

        $("#TipoConversaoId").val('@Request["TipoConversaoId"]').trigger('chosen:updated');
        $("#TipoConversaoId").val('@Request["TipoConversaoId"]').trigger('change.select2');
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('.chosen-select').select2();
            $('.datepicker').datepicker({ language: 'pt-BR', format: 'dd/mm/yyyy', todayHighlight: true, todayBtn: true });
            $('.moeda').mask('000000000000000,00', { reverse: true });
        });
    </script>


}














