@model Models.PRCPropostaView

@{
    string nome = "Proposta";



    ViewBag.Title = nome;


    Layout = "~/Views/Shared/_FortunaLayout.cshtml";




    var bllDocumentosArquivos = new BLL.DocumentosArquivos();

    var listaDocumentos = bllDocumentosArquivos.Listar(null, "", "", "", "prcpropostas", Model.PRCProposta.PRCPropostaId);
}


@section Breadcrumb{
    <li>@Html.ActionLink("Propostas", "Index", new { id = 0 })</li>
    <li class="active">Histórico</li>
}




<div class="content ">

    <div class="row">
        <div class="col-lg-12">
            <div class="alert alert-warning">
                <i class="fa fa-exclamation-triangle" aria-hidden="true"></i><strong>Atenção</strong> Você tem certeza que deseja apagar esse registro?
            </div>

            <div class="hpanel">
                <div class="tab-content">
                    <div id="tab-1" class="tab-pane active">
                        <div class="panel-body">
                            <!-- conteuod aqui -->
                            <div class="row">
                                <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                    <label>Proposta</label>
                                    <p class="form-control-static">@Model.PRCProposta.PRCPropostaId</p>
                                </div>
                                <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                    <label>Valor Bruto</label>
                                    <p class="form-control-static">R$ @string.Format("{0:N2}", Model.PRCProposta.PRCPropostaValorBruto)</p>
                                </div>
                                <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                    <label>Proposta Inicial</label>
                                    <p class="form-control-static">R$ @string.Format("{0:N2}", Model.PRCProposta.PRCPropostaInicialValor)</p>
                                </div>
                                <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                    <label>Proposta Inicial</label>
                                    <p class="form-control-static">R$ @string.Format("{0:N2}", Model.PRCProposta.PRCPropostaFinalValor)</p>
                                </div>
                            </div>
                            @Html.Partial("~/Views/PRCPropostas/_ResumoProposta.cshtml", Model)
                            <!-- ./conteudo aqui -->
                        </div>
                    </div>
                </div>
            </div>


        </div>
    </div>





    @using (Html.BeginForm())
    {
        <div class="row">
            <div class="col-lg-12">
                @Html.HiddenFor(model => model.PRCProposta.PRCPropostaId)
                @Html.HiddenFor(model => model.PRCProposta.PRCPropostaGUID)
                <p class="pull-right">
                    <input type="submit" value="Apagar" class="btn btn-danger" />
                </p>

                <p class="pull-left">


                    <div>
                        <a href="~/PRCPropostas/Index" class="btn btn-default">Voltar</a>
                    </div>

                </p>
            </div>
        </div>    
    }





</div>

@section Styles{
    @Styles.Render("~/bundles/fancybox/css")
    @Styles.Render("~/bundles/select2/css")
}





@section Scripts {

    @Scripts.Render("~/bundles/fancybox/js")
    @Scripts.Render("~/bundles/select2/js")

    <script type="text/javascript">

        $(document).ready(function () {
            $('.chosen-select').select2();
            $(".fancybox").fancybox({
                fitToView: false,
                width: '80%',
                autoSize: false
            });
            $(".fancybox_recarrega").fancybox({
                fitToView: false,
                width: '80%',
                autoSize: false,
                beforeClose: function () {
                    RecarregaPagina();
                },
            });
            $(".fancybox_full").fancybox({
                fitToView: false,
                width: '100%',
                autoSize: false,
                closeClick: false,
                openEffect: 'none',
                closeEffect: 'none'
            });
        });



        function RecarregaPagina() {
            window.location.reload(true);
        }

    </script>



}

