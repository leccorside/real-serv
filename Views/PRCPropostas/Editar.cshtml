@model Models.PRCPropostaView

@{
    ViewBag.Title = "Proposta n. " + Model.PRCProposta.PRCPropostaId;

    ViewBag.InfoAdicional = "<h3>" + Model.Requerente.Nome + "<small> / "+BLL.Utils.Funcoes.CalculaIdade(Model.Requerente.DataNascimento)+" anos</small></h3>";
    
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";

    var _PrcPropsotas_Index = BLL.Usuarios.VerificaAcesso("Index", "PRCPropostas");
    var _PrcPropsotas_Find = BLL.Usuarios.VerificaAcesso("Find", "PRCPropostas");

    var _PrcPropsotas_EditarNegociador = BLL.Usuarios.VerificaAcesso("EditarNegociador", "PRCPropostas");


    var _possuiParentes = (Model.ListPessoaDependente.Count > 0);
}



@section Breadcrumb{
    @if (_PrcPropsotas_Find)
    {
        <li>@Html.ActionLink("Propostas", "Find", new { id = 0 })</li>
    }
    else
    {
        <li>@Html.ActionLink("Propostas", "Index", new { id = 0 })</li>    
    }


}



@using (Html.BeginForm("Editar", "PRCPropostas", FormMethod.Post, new { @id = "form-criar", @class = "alertChanges" }))
{
    @Html.ValidationSummary(true)

    @Html.HiddenFor(m => m.PRCProposta.PRCPropostaId);
    @Html.HiddenFor(m => m.PRCProposta.PRCPropostaGUID);
    
    @Html.HiddenFor(m => m.Requerente.PessoaID);
    @Html.HiddenFor(m => m.Advogado.PessoaID);
    @Html.HiddenFor(m => m.PRCProposta.RegStatus);
    @Html.HiddenFor(m => m.PRCProposta.NotificacaoNotificado);    
    




      
    <div class="content ">
        <div class="row">
            <div class="col-lg-12">
                <div class="hpanel">
                    @Html.Partial("~/Views/PRCPropostas/_tabs.cshtml", Model)
                    <div class="tab-content">
                        <div id="tab-1" class="tab-pane active">
                            <div class="panel-body">
                                <!-- conteuod aqui -->

                                <div class="row">
                                    <div class="col-md-3 m-b-md" style="">
                                        <div class="btn-group">
                                            <button type="submit" class="btn btn-default btn-sm"><i class="fa fa-floppy-o" aria-hidden="true"></i>Salvar</button>
                                             @if (_PrcPropsotas_Find)
                                            {
                                                <a class="btn btn-default btn-sm" href="@Url.Content("~/PRCPropostas/Find/0")"><i class="fa fa-chevron-left" aria-hidden="true"></i>Sair</a>
                                            }
                                            else
                                            {
                                                <a class="btn btn-default btn-sm" href="@Url.Content("~/PRCPropostas/Index/0")"><i class="fa fa-chevron-left" aria-hidden="true"></i>Sair</a>    
                                            }

                                        </div>
                                    </div>
                                    <div class="col-md-9 mailbox-pagination m-b-md" style="">
                                        <div class="btn-group">
                                            
                                            @if (Model.Precatorio.Fonte == "TRF4")
                                            {
                                                if (Model.Precatorio.TrjReqPagLink != null && Model.Precatorio.TrjReqPagLink != "")
                                                {
                                                <a href="@Url.Content("~/Content/Uploads/Precatorios/" + BLL.Utils.Formatacoes.ApenasNumeros(Model.Precatorio.TrjReqPagNumero) + ".pdf")"  class="btn btn-default btn-sm fancybox_recarrega fancybox.iframe" ><i class="fa fa-file" aria-hidden="true"></i> Precatório</a>
                                                }
                                            }

                                            @if (Model.PRCProposta.PRCPropostaParenteBusca)
                                            {
                                                <div class="btn btn-default btn-sm">
                                                    <div class="checkbox" style="margin-top: 4px !important;">
                                                        <label><i class="fa fa-map-signs " aria-hidden="true"></i> @Html.CheckBoxFor(model => model.PRCProposta.Triagem) Triagem</label>
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <a href="#!" class="btn btn-default btn-sm disabled " type="button"><i class="fa fa-map-signs " aria-hidden="true"></i> Triagem Enviar</a>
                                            }

                                            @if ((Model.Requerente.Cep != null && Model.Requerente.Cep != "") && (Model.Requerente.Endereco != null && Model.Requerente.Endereco != ""))
                                            {
                                                <a class="btn btn-default btn-sm fancybox_recarrega fancybox.iframe" type="button" aria-expanded="true" href="@Url.Content("~/DocumentosArquivos/SelecionarECriar/0?entidade=prcpropostas&entidadeid=" + Model.PRCProposta.PRCPropostaId + "&templateid=" + BLL.Configuracoes.CarregarPorEmpresaId("prcpropostas.documentotemplate.default", Model.PRCProposta.EmpresaId) + "&FilaImpressao=S")"><i class="fa fa-file-text " aria-hidden="true"></i> Gerar Mala Direta</a>
                                            }
                                            else
                                            {
                                                <a class="btn btn-default btn-sm disabled " type="button" aria-expanded="true" href="#!"><i class="fa fa-file-text " aria-hidden="true"></i> Gerar Mala Direta</a>
                                            }

                                            <a class="btn btn-default btn-sm " type="button" aria-expanded="true" href="@Url.Content("~/PRCPropostas/AtualizaPropostaProcob/" + Model.PRCProposta.PRCPropostaId + "/" + Model.PRCProposta.PRCPropostaGUID + "/?rota=Triagem")" ><i class="fa fa-user-circle " aria-hidden="true"></i> Buscar Dados PROCOB</a>

                                            @if (_possuiParentes)
                                            {
                                                <a class="btn btn-default btn-sm disabled " type="button" aria-expanded="true" href="#!"><i class="fa fa-users " aria-hidden="true"></i><i class="fa fa-check text-success" aria-hidden="true"></i>Buscar Parentes</a>
                                            }
                                            else
                                            {
                                                <a class="btn btn-default btn-sm" type="button" aria-expanded="true" href="@Url.Content("~/PRCPropostas/CapturaParentes/" + Model.PRCProposta.PRCPropostaId + "/" + Model.PRCProposta.PRCPropostaGUID)" ><i class="fa fa-users " aria-hidden="true"></i> Buscar Parentes</a>
                                            }

                                           
                                        </div>
                                    </div>
                                </div>

                                <div class="btn-group">
                                </div>


                                <!-- ./conteudo aqui -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-7" style="">
                <div class="hpanel">

                    <div class="panel-heading ">
                        <div class="panel-tools">
                            <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                        </div>
                        <i class="fa fa-user-circle-o" aria-hidden="true"></i>Dados Requerente
                    </div>
                    @if (Model.Requerente.NaoPermiteEmail || Model.Requerente.NaoPermiteLigacao || Model.Requerente.NaoPermiteSMS)
                    {                               
                        <div class="alert alert-warning" role="alert">
                            <h4><i class="fa fa-exclamation-triangle" aria-hidden="true"></i><strong>Atenção</strong> Requerente não permite:</h4>
                            @if (Model.Requerente.NaoPermiteEmail)
                            {
                                <span>- Envio de emails<br />
                                </span>
                            }
                            @if (Model.Requerente.NaoPermiteSMS)
                            {
                                <span>- SMS<br />
                                </span>
                            }
                            @if (Model.Requerente.NaoPermiteLigacao)
                            {
                                <span>- Ligações<br />
                                </span>
                            }
                        </div>
                    }
                    <div class="panel-body">


                        <div class="row">
                            <div class="form-group col-lg-7 col-md-7 col-sm-7">
                                <label>Nome</label>
                                @Html.TextBoxFor(m => m.Requerente.Nome, new { @class = "form-control" })
                            </div>
                            <div class="form-group col-lg-5 col-md-5 col-sm-5">
                                <label>CPF/CNPJ</label>


                                <div class="input-group">
                                    @Html.TextBoxFor(m => m.Requerente.Documento, new { @class = "form-control" })
                                    <span class="input-group-btn">
                                        <a id="btnProcobResult" href="@Url.Content("~/PRCPropostas/ProcobResult/" + Model.PRCProposta.PRCPropostaId + "/" + Model.PRCProposta.PRCPropostaGUID)" class="btn btn-outline btn-primary fancybox_recarrega fancybox.iframe" type="button"><i class="fa fa-users" aria-hidden="true"></i><small>(@Model.PRCProposta.JsonResult_Rootobject.content.cpf.Count())</small></a>
                                    </span>
                                </div>


                            </div>
                            <div class="form-group col-lg-6 col-md-6 col-sm-6">
                                <label>E-Mail</label>
                                <i class="fa fa-commenting" aria-hidden="true"></i><small>recebe notificações</small>
                                @Html.TextBoxFor(m => m.Requerente.Email, new { @class = "form-control importante" })
                            </div>
                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>Sexo</label>
                                @Html.DropDownListSexo("Requerente.Sexo", Model.Requerente.Sexo, true, " form-control chosen-select ")
                            </div>
                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>
                                    <abbr title="Data de Nascimento">Dt.Nasc.</abbr></label>
                                @Html.TextBoxFor(m => m.Requerente.DataNascimento, new { @class = "form-control" })
                            </div>
                            <div class="form-group col-lg-6 col-md-6 col-sm-6">
                                <label>Celular</label>
                                <i class="fa fa-commenting" aria-hidden="true"></i><small>recebe notificações</small>
                                @Html.TextBoxFor(m => m.Requerente.Celular, new { @class = "form-control importante" })
                            </div>
                            <div class="form-group col-lg-6 col-md-6 col-sm-6">
                                <label>Telefone</label>
                                @Html.TextBoxFor(m => m.Requerente.Telefone, new { @class = "form-control" })
                            </div>

                            <div class="form-group col-lg-12 col-md-12 col-sm-12">
                                <label>Perfil</label>
                                @Html.TextAreaFor(m => m.Requerente.PessoaPerfil, new { @class = "form-control" })
                            </div>

                            <div class="form-group col-lg-3 col-md-3 col-sm-3 @(Model.Requerente.Obito ? " alert-danger " : "")">
                                <label>Óbito</label>
                                <div class="checkbox">
                                    <label>@Html.CheckBoxFor(model => model.Requerente.Obito) Sim</label>
                                </div>
                            </div>

                            <div class="form-group col-lg-3 col-md-3 col-sm-3 @(Model.Requerente.NaoPermiteEmail ? " alert-warning " : "")">
                                <label>E-Mail</label>
                                <div class="checkbox">
                                    <label>@Html.CheckBoxFor(model => model.Requerente.NaoPermiteEmail, new { @class = "atualiza" }) <small>Não permite</small></label>
                                </div>
                            </div>

                            <div class="form-group col-lg-3 col-md-3 col-sm-3 @(Model.Requerente.NaoPermiteSMS ? " alert-warning " : "")">
                                <label>SMS</label>
                                <div class="checkbox">
                                    <label>@Html.CheckBoxFor(model => model.Requerente.NaoPermiteSMS, new { @class = "atualiza" }) <small>Não permite</small></label>
                                </div>
                            </div>

                            <div class="form-group col-lg-3 col-md-3 col-sm-3 @(Model.Requerente.NaoPermiteLigacao ? " alert-warning " : "")">
                                <label>Ligação</label>
                                <div class="checkbox">
                                    <label>@Html.CheckBoxFor(model => model.Requerente.NaoPermiteLigacao, new { @class = "atualiza" }) <small>Não permite</small></label>
                                </div>
                            </div>

                        </div>
                        <div class="row">
                            <div class="col-lg-12 col-md-12 col-sm-12">



                                <table id="tableContatos" cellpadding="1" cellspacing="1" class="table table-condensed table-striped">
                                    <caption class="">
                                        <button type="button" onclick="callFancyBoxContatos()" class="pull-left btn btn-outline btn-primary btn-xs">
                                            <i class="fa fa-plus-square-o" aria-hidden="true"></i>
                                        </button>
                                        <a id="hiddenclickerContatos" class="fancybox_reload fancybox.iframe"></a><strong>&nbsp;<a href="@Url.Content("~/PessoasContatos/Index/" + Model.Requerente.PessoaID + "")" class="fancybox fancybox.iframe ">Outros meios de contato</a></strong></caption>
                                    <tbody>
                                    </tbody>
                                </table>



                                <table id="tableEnderecos" cellpadding="1" cellspacing="1" class="table table-condensed table-striped">
                                    <caption class="">
                                        <button type="button" onclick="callFancyBoxEnderecos()" class="pull-left btn btn-outline btn-primary btn-xs">
                                            <i class="fa fa-plus-square-o" aria-hidden="true"></i>
                                        </button>
                                        <a id="hiddenclickerEnderecos" class="fancybox_reload fancybox.iframe"></a><strong>&nbsp;<a href="@Url.Content("~/PessoasEnderecos/Index/" + Model.Requerente.PessoaID + "")" class="fancybox fancybox.iframe ">Endereços</a></strong></caption>
                                    <tbody>
                                    </tbody>
                                </table>

                                @if (_possuiParentes)
                                {
                                    <table id="tableParentes" cellpadding="1" cellspacing="1" class="table table-condensed table-striped">
                                        <thead>
                                            <tr>
                                                <th></th>
                                                <th>Parentes</th>
                                                <th>Grau</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in Model.ListPessoaDependente)
                                            {
                                                int parenteLocalizado = -1;
                                                parenteLocalizado = Model.ListPessoaContato.FindIndex(f => f.PessoaDependenteId == item.PessoaDependenteId);
                                                if (parenteLocalizado < 0)
                                                {
                                                    parenteLocalizado = Model.ListPessoaEndereco.FindIndex(f => f.PessoaDependenteId == item.PessoaDependenteId);
                                                }
                                                <tr>
                                                    @if (parenteLocalizado < 0)
                                                    {
                                                        <td><a class="btn btn-outline btn-primary btn-xs" href="@Url.Content("~/PRCPropostas/CapturaParentesTelefones/" + Model.PRCProposta.PRCPropostaId + "/" + Model.PRCProposta.PRCPropostaGUID + "/?pdid=" + item.PessoaDependenteId)">Buscar Contatos</a></td>
                                                    }
                                                    else
                                                    {
                                                        <td><a class="btn btn-default btn-xs disabled"><i class="fa fa-check text-success" aria-hidden="true"></i>Capturado</a></td>
                                                    }
                                                    <td>

                                                        @item.PessoaDependenteNome</td>
                                                    <td>@item.GrauParentescoNome</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                    
                                }
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-lg-12">
                                <br />
                                <div class="panel panel-default">
                                    <div class="panel-heading" role="tab" id="headingOne">
                                        <h4 class="panel-title">
                                            <a data-toggle="collapse" data-parent="#accordion" href="#collapseOne" aria-expanded="false" aria-controls="collapseOne" class="collapsed">Dados Complementares e Endereço
                                            </a>
                                        </h4>
                                    </div>
                                    <div id="collapseOne" class="panel-collapse collapse" role="tabpanel" aria-labelledby="headingOne" aria-expanded="false" style="height: 0px;">
                                        <div class="panel-body">

                                            <div class="row-fluid">
                                                <legend>Dados complementares</legend>
                                                <div class="form-group col-lg-6 col-md-6 col-sm-6">
                                                    <label>RG</label>
                                                    @Html.TextBox("Requerente.Rg", Model.Requerente.Rg, new { @class = "  form-control ", maxlength = "40" })
                                                </div>

                                                <div class="form-group col-lg-6 col-md-6 col-sm-6">
                                                    <label>Estado Civil</label>
                                                    @Html.DropDownListEstadoCivil("Requerente.EstadoCivl", Model.Requerente.EstadoCivl, true, " form-control ", "")
                                                </div>
                                            </div>

                                            <div class="row-fluid">
                                                <legend>Endereço</legend>
                                                <div class="form-group col-lg-4">
                                                    <label>CEP</label><label id="loading_cep" style="display: none"><i class="fa fa-spinner fa-spin"></i></label>

                                                    <div class="input-group">
                                                        @Html.TextBoxFor(model => model.Requerente.Cep, new { @class = "form-control" })
                                                        <span class="input-group-btn">
                                                            <button type="button" id="buscar-cep" class="btn btn-default"><i class="fa fa-search"></i></button>
                                                        </span>
                                                    </div>


                                                </div>
                                                <div class="form-group col-lg-5">
                                                    <label>Endereço</label>
                                                    @Html.TextBoxFor(model => model.Requerente.Endereco, new { @class = "  form-control " })
                                                </div>
                                                <div class="form-group col-lg-3">
                                                    <label>Número</label>
                                                    @Html.TextBoxFor(model => model.Requerente.Numero, new { @class = "  form-control " })
                                                </div>
                                                <div class="form-group col-lg-6">
                                                    <label>Complemento</label>
                                                    @Html.TextBoxFor(model => model.Requerente.Complemento, new { @class = "  form-control " })
                                                </div>

                                                <div class="form-group col-lg-6">
                                                    <label>Bairro</label>
                                                    @Html.TextBoxFor(model => model.Requerente.Bairro, new { @class = "  form-control " })
                                                </div>
                                                <div class="form-group col-lg-6">
                                                    <label>Cidade</label>
                                                    @Html.TextBoxFor(model => model.Requerente.Cidade, new { @class = "  form-control " })
                                                </div>
                                                <div class="form-group col-lg-6">
                                                    <label>Estado</label>
                                                    @Html.TextBoxFor(model => model.Requerente.Estado, new { @class = "  form-control " })
                                                </div>

                                            </div>


                                            <div class="row-fluid">
                                                <legend>Dados bancários</legend>
                                                <div class="form-group col-lg-4">
                                                    <label>Código do Banco</label>
                                                    @Html.TextBoxFor(model => model.Requerente.BancoCod, new { @class = "form-control", maxlength = "10" })
                                                </div>
                                                <div class="form-group col-lg-4">
                                                    <label>Nome do Banco</label>
                                                    @Html.TextBoxFor(model => model.Requerente.BancoNome, new { @class = "form-control", maxlength = "50" })
                                                </div>
                                                <div class="form-group col-lg-4">
                                                    <label>Agência</label>
                                                    @Html.TextBoxFor(model => model.Requerente.BancoAgencia, new { @class = "form-control", maxlength = "20" })
                                                </div>
                                                <div class="form-group col-lg-4">
                                                    <label>Conta</label>
                                                    @Html.TextBoxFor(model => model.Requerente.BancoConta, new { @class = "form-control", maxlength = "20" })
                                                </div>
                                                <div class="form-group col-lg-8">
                                                    <label>Observações</label>
                                                    @Html.TextBoxFor(model => model.Requerente.BancoObservacoes, new { @class = "form-control", maxlength = "20" })
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                </div>
            </div>

            <div class="col-lg-5" style="">

                @Html.Partial("~/Views/PRCPropostas/_ResumoPropostaInfoPRC.cshtml", Model)

                <div class="hpanel">
                    <div class="panel-heading ">
                        <div class="panel-tools">
                            <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                        </div>
                        <i class="fa fa-user-secret" aria-hidden="true"></i>Dados Negociador
                    </div>
                    <div class="panel-body">
                        <div class="row">
                            <div class="form-group col-lg-12 col-md-12 col-sm-12">
                                <label>
                                    <abbr title="Procedimento">Nome</abbr></label>
                                <p class="form-control-static">@Model.Negociador.UsuarioNome</p>
                            </div>
                            <div class="form-group col-lg-12 col-md-12 col-sm-12">
                                <label>
                                    <abbr title="Procedimento">E-Mail</abbr></label>
                                <p class="form-control-static">@Model.Negociador.UsuarioEmail</p>
                            </div>



                        </div>
                    </div>

                </div>

                @if (_PrcPropsotas_EditarNegociador)
                {
                    <div class="hpanel">
                        <div class="panel-heading ">
                            <div class="panel-tools">
                                <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                            </div>
                            <i class="fa fa-user-secret" aria-hidden="true"></i>Alterar Negociador
                        </div>
                        <div class="panel-body">
                            <div class="row">
                                <div class="form-group col-lg-12 col-md-12 col-sm-12">
                                    <label>
                                        Alterar negociador</label><br />
                                    @Html.DropDownListFor(model => model.PRCProposta.NegociadorId, (SelectList)ViewBag.ddlUsuarios, null, new { @class = "chosen-select-add form-control atualiza" })
                                </div>

                            </div>

                            <div class="row">
                                <div class="form-group col-lg-12 col-md-12 col-sm-12">
                                    <label>
                                        Alterar negociador aleatórioamente</label>
                                    <a onclick="return confirm('Confirma a alteração aleatória de negociador?')" class="btn btn-outline btn-warning2" href="@Url.Content("~/PrcPropostas/EditarNegociadorRandom/" + Model.PRCProposta.PRCPropostaId + "/" + Model.PRCProposta.PRCPropostaGUID + "/?uid=" + Model.PRCProposta.NegociadorId)"><i class="fa fa-random"></i>Executar Alteração </a>
                                </div>
                            </div>
                        </div>

                    </div>    
                }
                else
                {
                    @Html.HiddenFor(m => m.PRCProposta.NegociadorId);
                }

            </div>

        </div>


        @if (Model.PRCProposta.Fonte == "TJ-SP")
        {
            @Html.Partial("~/Views/PRCPropostas/_DadosInfoPropostaTRSP.cshtml", Model)
        }
        else
        {
            @Html.Partial("~/Views/PRCPropostas/_DadosInfoPropostaTRF.cshtml", Model)    
        }





        <div class="row">
            <div class="col-lg-4" style="">
                <div class="hpanel">
                    <div class="panel-heading ">
                        <div class="panel-tools">
                            <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                        </div>
                        <i class="fa fa-thumbs-o-up" aria-hidden="true"></i>Proposta Inicial
                    </div>
                    <div class="panel-body">
                        <div class="row">
                            <div class="form-group col-lg-12 col-md-12 col-sm-12 text-center">
                                <div class="input-group m-b">
                                    <span class="input-group-addon">%</span>
                                    @Html.TextBox("PRCProposta.PRCPropostaInicialPercentual", string.Format("{0:F2}", Model.PRCProposta.PRCPropostaInicialPercentual), new { @class = "moeda form-control select-all" })
                                    @Html.Hidden("PRCProposta.PRCPropostaInicialValor", string.Format("{0:F2}", Model.PRCProposta.PRCPropostaInicialValor))
                                </div>
                                <h2 id="lblPRCPropostaInicialValor">R$ @string.Format("{0:F2}", Model.PRCProposta.PRCPropostaInicialValor)</h2>
                            </div>
                        </div>
                    </div>


                </div>
            </div>

            <div class="col-lg-4" style="">
                <div class="hpanel">
                    <div class="panel-heading ">
                        <div class="panel-tools">
                            <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                        </div>
                        <i class="fa fa-user-circle-o" aria-hidden="true"></i>Proposta Cliente
                    </div>
                    <div class="panel-body">
                        <div class="row">
                            @*<div class="form-group col-lg-12 col-md-12 col-sm-12 text-center">
                                <div class="input-group m-b">
                                    <span class="input-group-addon">%</span>
