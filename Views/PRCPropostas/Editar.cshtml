    <script>

        function atualiza(reload) {
            var url = "@Url.Content("~/PRCPropostas/EditarJSON")"; // the script where you handle the form input.
            calculaVlLiq();



            $.ajax({
                type: "POST",
                url: url,
                data: $("#form-criar").serialize(),
                success: function (result) {
                    if (result.NUMERO == 999) {
                        swal({ title: "Atencão!", text: result.MENSAGEM, type: "error", showCancelButton: false, cancelButtonText: "Não", confirmButtonColor: "#DD6B55", confirmButtonText: "Ok", closeOnConfirm: true }, function () { });
                    } else if (result.NUMERO == 10) {

                        toastr.options = {
                            "debug": false,
                            "newestOnTop": false,
                            "positionClass": "toast-bottom-right",
                            "closeButton": true,
                            "toastClass": "animated fadeInDown",
                        };



                        toastr.warning(result.MENSAGEM)

                        if (reload) {
                            RecarregaPagina();
                        }


                    }

                },
                error: function (result) {
                    swal({ title: "Atencão!", text: "Ocorreu um erro ao tentar salvar os dados da proposta", type: "error", showCancelButton: false, cancelButtonText: "Não", confirmButtonColor: "#DD6B55", confirmButtonText: "Ok", closeOnConfirm: true }, function () { });
                }
            });


        }


        $("input[type=text], textarea, select, :checkbox").change(function () {

            var isReload = $(this).hasClass('atualiza');

            atualiza(isReload);

        });

        $("input[type=text], select").keyup(function () {
            calculaVlLiq();
        });




    </script>
    <script>
        function moedaParaNumero(valor) {
            return isNaN(valor) == false ? parseFloat(valor) : parseFloat(valor.replace("R$", "").replace(".", "").replace(",", "."));
        }
        function numeroParaMoeda(n, c, d, t) {
            c = isNaN(c = Math.abs(c)) ? 2 : c, d = d == undefined ? "," : d, t = t == undefined ? "." : t, s = n < 0 ? "-" : "", i = parseInt(n = Math.abs(+n || 0).toFixed(c)) + "", j = (j = i.length) > 3 ? j % 3 : 0;
            return s + (j ? i.substr(0, j) + t : "") + i.substr(j).replace(/(\d{3})(?=\d)/g, "$1" + t) + (c ? d + Math.abs(n - i).toFixed(c).slice(2) : "");
        }



        function calculaVlLiq() {
            //var vlrBruto = @Model.Precatorio.TrjReqPagValorSolicitado.ToString().Replace(",", ".");

            var vlrBruto = moedaParaNumero($("#PRCProposta_PRCPropostaValorBruto").val());
            var vlrHonorarios = moedaParaNumero($("#PRCProposta_PRCPropostaAdvHon").val());
            var vlrIRRA = moedaParaNumero($("#PRCProposta_PRCPropostaIRRA").val());
            var vlrIR = moedaParaNumero($("#PRCProposta_PRCPropostaIR").val());
            var vlrPSS = moedaParaNumero($("#PRCProposta_PRCPropostaPSS").val());



            var tpIR = $("#PRCProposta\\.PRCPropostaIRTipoValor").find(":selected").text();
            var tpIRRA = $("#PRCProposta\\.PRCPropostaIRRATipoValor").find("option:selected").text();
            var tpPSS = $("#PRCProposta\\.PRCPropostaPSSTipoValor").find(":selected").text();

            if (tpIRRA == '%') { vlrIRRA = vlrBruto * (vlrIRRA / 100) };
            if (tpIR == '%') { vlrIR = vlrBruto * (vlrIR / 100) };
            if (tpPSS == '%') { vlrPSS = vlrBruto * (vlrPSS / 100) };


            var vlrHonorarios2 = (vlrBruto * (vlrHonorarios / 100));

            var vlrLiq = vlrBruto - vlrHonorarios2 - vlrIR - vlrIRRA - vlrPSS;

            $("#PRCProposta_PRCPropostaValorLiquido").val(numeroParaMoeda(vlrLiq));
            $("#lblVlLiquido").text('R$ ' + numeroParaMoeda(vlrLiq));


            //proposta inicial
            var PropostaInicialPercentual = moedaParaNumero($("#PRCProposta_PRCPropostaInicialPercentual").val());
            $("#PRCProposta_PRCPropostaInicialValor").val(numeroParaMoeda(vlrLiq * (PropostaInicialPercentual / 100)));
            $("#lblPRCPropostaInicialValor").text('R$ ' + numeroParaMoeda(vlrLiq * (PropostaInicialPercentual / 100)));

            //proposta cliente valor
            //var PropostaClientePercentual = moedaParaNumero($("#PRCProposta_PRCPropostaClientePercentual").val());
            //$("#PRCProposta_PRCPropostaClienteValor").val(numeroParaMoeda(vlrLiq * (PropostaClientePercentual/100)));
            //$("#lblPRCPropostaClienteValor").text('R$ ' + numeroParaMoeda(vlrLiq * (PropostaClientePercentual/100)));


            //proposta cliente percentual
            var PropostaClienteValor = moedaParaNumero($("#PRCProposta_PRCPropostaClienteValor").val());
            $("#PRCProposta_PRCPropostaClientePercentual").val(numeroParaMoeda((PropostaClienteValor * 100) / vlrLiq));
            $("#lblPRCPropostaClientePercentual").text('% ' + numeroParaMoeda((PropostaClienteValor * 100) / vlrLiq));

            //proposta final
            //var PropostaFinalPercentual = moedaParaNumero($("#PRCProposta_PRCPropostaFinalPercentual").val());
            //$("#PRCProposta_PRCPropostaFinalValor").val(numeroParaMoeda(vlrLiq * (PropostaFinalPercentual/100)));
            //$("#lblPRCPropostaFinalValor").text('R$ ' + numeroParaMoeda(vlrLiq * (PropostaFinalPercentual/100)));

            //proposta final percentual
            var PropostaFinalValor = moedaParaNumero($("#PRCProposta_PRCPropostaFinalValor").val());
            $("#PRCProposta_PRCPropostaFinalPercentual").val(numeroParaMoeda((PropostaFinalValor * 100) / vlrLiq));
            $("#lblPRCPropostaFinalPercentual").text('% ' + numeroParaMoeda((PropostaFinalValor * 100) / vlrLiq));

        }

        calculaVlLiq();
    </script>


    <script>

        $('#PRCProposta_PRCPropostaPrioridade').change(function () {
            verificaPrioridade(this.checked);
        });

        verificaPrioridade($("#PRCProposta_PRCPropostaPrioridade").is(':checked'));


        function verificaPrioridade(checado) {
            if (checado) {
                $("#div_Prioridade").slideDown();
            } else {
                $("#div_Prioridade").slideUp();
            }
        }

    </script>

