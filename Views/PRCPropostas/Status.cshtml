@model Models.PRCPropostaView

@{
    string nome = "Proposta";


    ViewBag.Title = "Proposta n. " + Model.PRCProposta.PRCPropostaId;

    ViewBag.InfoAdicional = "<h3>" + Model.Requerente.Nome + "<small> / " + BLL.Utils.Funcoes.CalculaIdade(Model.Requerente.DataNascimento) + " anos</small></h3>";
    
    
    var _PrcPropsotas_Find = BLL.Usuarios.VerificaAcesso("Find", "PRCPropostas");


    Layout = "~/Views/Shared/_FortunaLayout.cshtml";


    var _EntidadeStatus_ViewAll = BLL.Usuarios.VerificaAcesso("ViewAll", "EntidadesStatus");

    
}


@section Breadcrumb{
    @if (_PrcPropsotas_Find)
    {
        <li>@Html.ActionLink("Propostas", "Find", new { id = 0 })</li>
    }
    else
    {
        <li>@Html.ActionLink("Propostas", "Index", new { id = 0 })</li>    
    }
    <li class="active">Status</li>
}




<div class="content ">

    <div class="row">
        <div class="col-lg-12">
            <div class="hpanel">
                @Html.Partial("~/Views/PRCPropostas/_tabs.cshtml", Model)
                <div class="tab-content">
                    <div id="tab-1" class="tab-pane active">
                        <div class="panel-body">
                            <!-- conteuod aqui -->

                            @Html.Partial("~/Views/PRCPropostas/_ResumoProposta.cshtml", Model)
                            <!-- ./conteudo aqui -->
                        </div>
                    </div>
                </div>
            </div>


        </div>
    </div>


    <div class="row">
        <div class="col-lg-12">
                <h4>Status</h4>
                <div class="hpanel">
                    <div class="panel-body">
                        @Html.CubeeStatus("PRCPropostas", Model.PRCProposta.PRCPropostaId, "chosen-select form-control", BLL.Usuarios.GetUsuarioId(), _EntidadeStatus_ViewAll, 0, true, -1, "", false, true)
                    </div>
                </div>
            </div>
    </div>

    



</div>

@section Styles{
    @Styles.Render("~/bundles/fancybox/css")
    @Styles.Render("~/bundles/select2/css")
@Styles.Render("~/bundles/datepicker/css")
}





@section Scripts {

    @Scripts.Render("~/bundles/fancybox/js")
    @Scripts.Render("~/bundles/select2/js")
    @Scripts.Render("~/bundles/clipboard/js")
    @Scripts.Render("~/bundles/datepicker/js")
    @Scripts.Render("~/bundles/mask/js")

    <script type="text/javascript">


        $(document).ready(function () {
            $('.chosen-select').select2();
            $(".fancybox").fancybox({
                fitToView: false,
                width: '80%',
                autoSize: false
            });
            $(".fancybox_recarrega").fancybox({
                fitToView: false,
                width: '80%',
                autoSize: false,
                beforeClose: function () {
                    RecarregaPagina();
                },
            });
            $(".fancybox_full").fancybox({
                fitToView: false,
                width: '100%',
                autoSize: false,
                closeClick: false,
                openEffect: 'none',
                closeEffect: 'none'
            });
        });

        //$('.chosen-select').select2();
        $('.datepicker').datepicker({ language: 'pt-BR', format: 'dd/mm/yyyy', todayHighlight: true, todayBtn: true });
        
        $('.moeda').mask('000000000000000,00', { reverse: true });


        function RecarregaPagina() {
            window.location.reload(true);
        }




        
    </script>



}

