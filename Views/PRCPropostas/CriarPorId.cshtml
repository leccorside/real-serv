@model Models.PRCProposta
@{
    ViewBag.Title = "Criando Proposta";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";
}


@section Breadcrumb{
    <li>@Html.ActionLink("Propostas", "Index", new { id = 0 })</li>
}


<div class="content ">
    @using (Html.BeginForm())
    {
        @Html.HiddenFor(m => m.EmpresaId)
        <div class="row">
            <div class="col-lg-12" style="">
                <div class="hpanel">
                    <div class="panel-heading ">
                        <div class="panel-tools">
                            <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                        </div>
                        <i class="fa fa-user-circle-o" aria-hidden="true"></i>Criando Proposta
                    </div>
                    <div class="panel-body">

                        <div class="row">
                            <div class="form-group col-lg-4 col-md-4 col-sm-4">
                                <label>Negociador</label>
                                @Html.DropDownListFor(model => model.NegociadorId, (SelectList)ViewBag.ddlUsuarios, null, new { @class = "chosen-select form-control" })
                            </div>
                            <div class="form-group col-lg-2 col-md-2 col-sm-2">
                                <label>Fonte</label>
                                <select class="form-control" id="Fonte" name="Fonte">
                                    <option value="TRF1">TRF1</option>
                                    <option value="TRF2">TRF2</option>
                                    <option value="TRF3">TRF3</option>
                                    <option value="TRF4">TRF4</option>
                                    <option value="TRF5">TRF5</option>
                                    <option value="TJ-SP">TJ-SP</option>
                                </select>
                            </div>
                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>Origem</label>
                                <select class="form-control" id="Origem" name="Origem">
                                    <option value="">BASE NORMAL</option>
                                    <option value="LOA">BASE LOA</option>
                                </select>
                            </div>

                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>Proposta</label>
                                @Html.TextBoxFor(model => model.PRCPropostaPrecatorio, new { @class = "form-control" })
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-lg-12">
                                <input type="button" id="btn_processar" value="Cadastrar" class="ladda-button btn btn-primary" data-style="zoom-in" />
                            </div>
                        </div>


                        <div class="m">
                            <div class="progress m-t-xs full progress-striped active">
                                <div id="barra_progresso" style="width: 0%" aria-valuemax="100" aria-valuemin="0" aria-valuenow="0" role="progressbar" class=" progress-bar progress-bar-success">
                                    <span id="info_progresso">0%</span>
                                </div>
                            </div>
                        </div>

                    </div>

                </div>
            </div>

        </div>
    }

</div>

@section Styles {
    @Styles.Render("~/bundles/ladda/css")
    @Styles.Render("~/bundles/select2/css")

}

@section Scripts {
    @Scripts.Render("~/bundles/ladda/js")
    @Scripts.Render("~/bundles/select2/js")
    <script>


        $('.chosen-select').select2();
        $('#btn_processar').click(function () {
            var UserId = $("#NegociadorId").val();
            var TrjReqPagNumero = $("#PRCPropostaPrecatorio").val();
            var EmpresaId = $("#EmpresaId").val();
            var Origem = $("#Origem").val();
            var Fonte = $("#Fonte").val();
            CriarProposta(EmpresaId, UserId, TrjReqPagNumero, Fonte, Origem);

        });

        function CriarProposta(EmpresaId, UserId, TrjReqPagNumero, Fonte, Origem) {
            var l = $('#btn_processar').ladda();
            l.ladda('start');

            if (UserId == "0") {
                swal({ title: "Ooops!", text: "Informe o número do negociador", type: "error", showCancelButton: false, cancelButtonText: "Não", confirmButtonColor: "#DD6B55", confirmButtonText: "Ok", closeOnConfirm: true }, function () { });
                l.ladda('stop');
                return;
            }

            if (TrjReqPagNumero == "") {
                swal({ title: "Ooops!", text: "Informe o número do precatório", type: "error", showCancelButton: false, cancelButtonText: "Não", confirmButtonColor: "#DD6B55", confirmButtonText: "Ok", closeOnConfirm: true }, function () { });
                l.ladda('stop');
                return;
            }

            CarregaProgesso(30, "Carregando PRC");



            $.getJSON("@Url.Content("~/ApiIntegracao/PRCPropostaCriarReturnErro/")", { EmpresaId: EmpresaId, UserId: UserId, TrjReqPagNumero: TrjReqPagNumero, Fonte: Fonte, Origem: Origem }, function (result) {



                CarregaProgesso(50, "Consultando dados do Requerente");





            })
                .success(function (result) {

                    console.log(result);

                    if (result.NUMERO == "999") {
                        //erro
                        CarregaProgesso(0, "");
                        swal({ title: "Ooops!", text: result.MENSAGEM, type: "error", showCancelButton: false, cancelButtonText: "Não", confirmButtonColor: "#DD6B55", confirmButtonText: "Ok", closeOnConfirm: true }, function () { });
                    } else if (result.NUMERO == "10") {
                        // alerta

                        CarregaProgesso(0, "");
                        swal({ title: "Ooops!", text: result.MENSAGEM, type: "error", showCancelButton: false, cancelButtonText: "Não", confirmButtonColor: "#DD6B55", confirmButtonText: "Ok", closeOnConfirm: true }, function () { });
                    } else {
                        // Sucesso
                        CarregaProgesso(100, "Pronto!");


                        setTimeout(CarregaProgesso(0, ""), 2000);
                        swal({ title: "Tudo certo!", text: "Proposta Criada", type: "success", showCancelButton: false, cancelButtonText: "Não", confirmButtonColor: "#DD6B55", confirmButtonText: "Ok", closeOnConfirm: true }, function () { });
                    }


                    l.ladda('stop');

                })
                .error(function () {
                    swal({ title: "Tudo certo!", text: "Erro ao gerar proposta", type: "error", showCancelButton: false, cancelButtonText: "Não", confirmButtonColor: "#DD6B55", confirmButtonText: "Ok", closeOnConfirm: true }, function () { });
                    l.ladda('stop');
                });

        }




        function CarregaProgesso(valor, info) {
            $("#barra_progresso").css({ 'width': valor + "%" })
            $("#info_progresso").html(valor + "%");
            $("#info").html(info);


        }

    </script>
}