@model PetaPoco.Page<Models.PRCProposta>

@{
    ViewBag.Title = "Propostas";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";

    String strPathAndQuery = HttpContext.Current.Request.Url.PathAndQuery;
    String strUrl = HttpContext.Current.Request.Url.AbsoluteUri.Replace(strPathAndQuery, "/");
    strUrl = strUrl + "PRCPropostas/Index";

    ViewBag.SearchAction = strUrl;
    ViewBag.SearchPlaceHolder = "Pesquisar por Precatório ";
    ViewBag.SearchMethod = "get";

    var _visualizarTodas = BLL.Usuarios.VerificaAcesso("ViewAll", "PRCPropostas");
    var _PrcPropsotas_Deletar = BLL.Usuarios.VerificaAcesso("Deletar", "PRCPropostas");
    var _PrcPropsotas_Criar = BLL.Usuarios.VerificaAcesso("Criar", "PRCPropostas");
    var _PrcPropsotas_CriarPorId = BLL.Usuarios.VerificaAcesso("CriarPorId", "PRCPropostas");

    var _regraVisualizaOutras = true;

    string outrosCampos = Convert.ToString(ViewBag.Campos);
    if (outrosCampos == null)
    {
        outrosCampos = "";
    }

   
}




@section Breadcrumb{


}



<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">
            <div class="hpanel">
                <div class="panel-heading hbuilt">
                    <div class=" p-xs font-normal">
                        @using (Html.BeginForm("CriarPorFonteOrigem", "PRCPropostas", FormMethod.Get, new { @class = "  " }))
                        {
                            <input type="hidden" name="id" id="id" value="@BLL.Usuarios.GetEmpresaId()" />
                            <div class="row">
                                <div class="col-lg-10">

                                    <div class="row">
                                        <div class="form-group col-lg-4 col-md-4 col-sm-4">
                                            <label>Fonte</label>
                                            <select class="form-control" id="Fonte" name="Fonte">
                                                <option value="TRF1">TRF1</option>
                                                <option value="TRF2">TRF2</option>
                                                <option value="TRF3">TRF3</option>
                                                <option value="TRF4">TRF4</option>
                                                <option value="TRF5">TRF5</option>
                                                <option value="TJ-SP">TJ-SP</option>
                                            </select>
                                            @if (_PrcPropsotas_CriarPorId)
                                            {<br />
                                                <a href="@Url.Content("~/PRCPropostas/CriarPorId/0")" class=""><i class="fa fa-plus"></i>Criar por n. precatorio</a>    
                                            }
                                        </div>

                                        <div class="form-group col-lg-5 col-md-5 col-sm-5">
                                            <label>Origem</label>
                                            <div class="input-group">
                                                <select class="form-control" id="Origem" name="Origem">
                                                    <option value="">BASE NORMAL</option>
                                                    <option value="LOA">BASE LOA</option>
                                                </select>
                                                <span class="input-group-btn">
                                                    <button type="submit" class="btn btn-primary">
                                                        Criar
                                                    </button>


                                                </span>
                                            </div>
                                        </div>




                                    </div>




                                </div>
                                <div class="col-lg-2">
                                    <div class="btn-group pull-right">

                                        @*   @if (_PrcPropsotas_Criar)
                                        {
                                            <a href="@Url.Content("~/PRCPropostas/Criar/0/TRF3")" class="btn btn-primary"><i class="fa fa-plus"></i>Criar TRF3</a>    
                                            <a href="@Url.Content("~/PRCPropostas/Criar/0/TRF4")" class="btn btn-primary"><i class="fa fa-plus"></i>Criar TRF4</a>    
                                            <a href="@Url.Content("~/PRCPropostas/Criar/0/TJ-SP")" class="btn btn-primary"><i class="fa fa-plus"></i>Criar TJ-SP</a>    
                                        }*@

                                        @if (@BLL.Usuarios.GetManager())
                                        {
                                            <a href="@Url.Content("~/PRCPropostas/AtualizaValorPropostasTRF4")" class="btn btn-xs btn-outline btn-primary fancybox fancybox.iframe"><i class="fa fa-refresh"></i>Atualizar Propostas sem valor TRF4</a>    
                                        }

                                        @using (Html.BeginForm("Export", "PRCPropostas", FormMethod.Post, new { @class = "form-inline " }))
                                        {
                                            <input type="hidden" name="pesquisar" value="@Request["pesquisar"]">
@*<button class="btn btn-outline btn-primary btn-sm" data-toggle="tooltip" data-original-title="Exportar" title="Exportar" data-placement="top" type="submit" onclick="return confirm('Esse processo pode demorar alguns segundos?')"><i class="fa fa-download"></i></button>*@   
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="panel-heading hbuilt">
                    <div class=" p-xs font-normal">

                        @using (Html.BeginForm("Index", "PRCPropostas", FormMethod.Get, new { @class = "  " }))
                        {
                            if (_regraVisualizaOutras)
                            {
                            <input type="hidden" name="pesquisartudo" value="true" />
                            }
                            
                            <div class="row">
                                <div class="form-group col-lg-2">
                                    <label>Proposta</label>
                                    <input type="text" name="PRCPropostaId" id="PRCPropostaId" title="Pesquisar" class="form-control select-all" placeholder="Proposta..." value="@Request["PRCPropostaId"]">
                                </div>

                                <div class="form-group col-lg-3">
                                    <label>Precatório</label>
                                    <input type="text" name="pesquisar" id="pesquisar" title="Pesquisar" class="form-control select-all" placeholder="Precatório..." value="@Request["pesquisar"]">
                                </div>

                                <div class="form-group col-lg-4">
                                    <label>Requerente</label>
                                    <input type="text" name="Requerentes_Nome" id="Requerentes_Nome" title="Pesquisar select-all" class="form-control" placeholder="Requerente..." value="@Request["Requerentes_Nome"]">
                                </div>

                                <div class="form-group col-lg-3">
                                    <label>Advogado</label>
                                    <input type="text" name="Advogados_Nome" id="Advogados_Nome" title="Pesquisar" class="form-control select-all" placeholder="Advogado..." value="@Request["Advogados_Nome"]">
                                </div>



                                <div class="form-group col-lg-2">
                                    <label>Telefone</label>
                                    <input type="text" name="telefone" id="telefone" title="Pesquisar" class="form-control select-all" placeholder="Telefone..." value="@Request["telefone"]">
                                </div>

                                <div class="form-group col-lg-3">
                                    <label>Tipo Conversão</label>@Html.DropDownList("TipoConversaoId", (SelectList)ViewBag.ddlTiposConversoes, new { @class = "chosen-select form-control " })
                                </div>



                                <div class="form-group col-lg-4">
                                    <label>Status</label>@Html.DropDownList("StatusNome", (SelectList)ViewBag.ddlStatusAgrupado, new { @class = "chosen-select form-control " })
                                </div>

                                <div class="form-group col-lg-3">
                                    <label>Fonte</label>@Html.DropDownListTrjFonte("Fonte", Request["Fonte"], true, " form-control ")
                                </div>



                                <div class="form-group col-lg-6">
                                    <label>
                                        <input type="checkbox" name="chk_pesquisar_data" id="chk_pesquisar_data" @(Request["chk_pesquisar_data"] == "on" ? "checked" : "") />
                                        Pesquisar por Data Próx. Ação</label>
                                    <div class="row">

                                        <div class="col-md-4" style="">
                                            <input type="text" name="de" id="de" title="Data de" class="datepicker form-control tip-bottom select-all" value="@String.Format("{0:dd/MM/yyyy}", @BLL.Usuarios.GetDateDe())" />
                                        </div>
                                        <div class="col-md-4" style="">
                                            <input type="text" name="ate" id="ate" title="Data até" class="datepicker form-control tip-bottom select-all" value="@String.Format("{0:dd/MM/yyyy}", @BLL.Usuarios.GetDateAte())" />
                                        </div>
                                        <div class="col-md-4" style="">
                                            <div class="btn-group" role="group" aria-label="Basic example">
                                                <button class="btn btn-outline btn-primary" type="submit"><i class="fa fa-search"></i></button>
                                                <button class="btn btn-outline btn-danger" type="button" onclick="parent.location='@strUrl'"><i class="fa fa-eraser"></i></button>
                                            </div>
                                        </div>
                                    </div>
                                </div>




                            </div>
                        }
                    </div>
                </div>

                <div class="panel-body">
                    <!-- tirei daqui-->

                    <div class="table-responsive">
                        @Html.Partial("~/Views/PRCPropostas/_PropostasRegistros.cshtml", Model)
                    </div>

                    @Html.FortunaPaginacao(Convert.ToInt16(Model.TotalPages), outrosCampos)


                    <!-- ./tirei daqui-->
                </div>
            </div>
        </div>
    </div>
</div>







@section Styles{
    @Styles.Render("~/bundles/datatables/css")
    @Styles.Render("~/bundles/fancybox/css") @Styles.Render("~/bundles/select2/css")

}




@section Scripts {
    @Scripts.Render("~/bundles/datatables/js")@Scripts.Render("~/bundles/select2/js")
    @Scripts.Render("~/bundles/datatablesBootstrap/js")
    @Scripts.Render("~/bundles/datatablesPlugins/js")
    @Scripts.Render("~/bundles/fancybox/js")

    <script type="text/javascript">
        $(".fancybox").fancybox({
            toolbar: false,
            padding: 0,
            fitToView: false,
            width: '80%',
            autoSize: true,
            helpers: {
                overlay: {
                    locked: true
                }
            }
        });
    </script>
    <script>

        // Initialize Example 2
        $('.dataTable').dataTable({
            "pageLength": 50,
            "paging": true,
            "ordering": true,
            "bLengthChange": true,
            "bFilter": true,
            "info": true,
            "language": {
                "sEmptyTable": "Nenhum registro encontrado",
                "sInfo": "Mostrando de _START_ até _END_ de _TOTAL_ registros",
                "sInfoEmpty": "Mostrando 0 até 0 de 0 registros",
                "sInfoFiltered": "(Filtrados de _MAX_ registros)",
                "sInfoPostFix": "",
                "sInfoThousands": ".",
                "sLengthMenu": "_MENU_ resultados por página",
                "sLoadingRecords": "Carregando...",
                "sProcessing": "Processando...",
                "sZeroRecords": "Nenhum registro encontrado",
                "sSearch": "Pesquisar ",
                "oPaginate": {
                    "sNext": "Próximo",
                    "sPrevious": "Anterior",
                    "sFirst": "Primeiro",
                    "sLast": "Último"
                },
                "oAria": {
                    "sSortAscending": ": Ordenar colunas de forma ascendente",
                    "sSortDescending": ": Ordenar colunas de forma descendente"
                }
            }
        });






    </script>

    <script>
        $("#de").mask("99/99/9999");
        $("#ate").mask("99/99/9999");
        $('#telefone').mask(maskBehavior, options);
        $(".select-all").click(function () {
            $(this).select();
        });
        $("#StatusNome").val('@Request["StatusNome"]').trigger('chosen:updated');
        $("#StatusNome").val('@Request["StatusNome"]').trigger('change.select2');

        $("#TipoConversaoId").val('@Request["TipoConversaoId"]').trigger('chosen:updated');
        $("#TipoConversaoId").val('@Request["TipoConversaoId"]').trigger('change.select2');
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('.chosen-select').select2();
            $('.datepicker').datepicker({ language: 'pt-BR', format: 'dd/mm/yyyy', todayHighlight: true, todayBtn: true });
            $('.moeda').mask('000000000000000,00', { reverse: true });
        });
    </script>


}














