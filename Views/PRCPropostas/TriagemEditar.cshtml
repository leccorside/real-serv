@section Scripts {
    @Scripts.Render("~/bundles/fancybox/js")
    @Scripts.Render("~/bundles/select2/js")
    @Scripts.Render("~/Assets/js/chosen.jquery.js")
    @Scripts.Render("~/Assets/js/chosen.jquery.extend.js")
    @Scripts.Render("~/bundles/datepicker/js")
    @Scripts.Render("~/bundles/mask/js")
    @Scripts.Render("~/bundles/jquery-cep/js")
    @Scripts.Render("~/bundles/maxlenght/js")
    @Scripts.Render("~/bundles/ladda/js")
    <script>
        //ChosenAddNewItem("PRCProposta_CartorioId", "Cartorios", "CartorioNome");
        function UpdateElementOfParent(id) {
            carregaContatos($("#Requerente_PessoaID").val());
            carregaEnderecos($("#Requerente_PessoaID").val());
            $.fancybox.close();
        }

        function callFancyBoxContatos() {
            var Requerente_PessoaID = $("#Requerente_PessoaID").val();
            $("#hiddenclickerContatos").attr("href", "@(Url.Content("~/PessoasContatos/Criar/0?PessoaID="))" + Requerente_PessoaID)
            $('#hiddenclickerContatos').trigger('click');
        }

        function callFancyBoxEnderecos() {
            var Requerente_PessoaID = $("#Requerente_PessoaID").val();
            $("#hiddenclickerEnderecos").attr("href", "@(Url.Content("~/PessoasEnderecos/Criar/0?PessoaID="))" + Requerente_PessoaID)
            $('#hiddenclickerEnderecos').trigger('click');
        }

        $(".fancybox").fancybox({
            toolbar: false,
            padding: 0,
            fitToView: false,
            width: '80%',
            autoSize: true,
            helpers: {
                overlay: {
                    locked: true
                }
            }
        });

        $(".fancybox_reload").fancybox({
            fitToView: false,
            width: '98%',
            autoSize: false,
            padding: 0,
            helpers: {
                overlay: {
                    locked: true
                }
            },
            beforeClose: function () {
                carregaContatos($("#Requerente_PessoaID").val());
                carregaEnderecos($("#Requerente_PessoaID").val());
            },
        });


    </script>

    <script>

        $('#PRCProposta_Triagem').click(function () {
            var checked = $(this).is(':checked');
            if (checked) {
                alert("Essa proposta continua bloqueada para triagem");
            } else {
                alert("Proposta disponibilizada para negociação");
            }
        });



        $("#Requerente_Documento").focusout(function () {
            verificaMascara();
        })

        function verificaMascara() {
            $("#Requerente_Documento").unmask();

            var tamanho = $("#Requerente_Documento").val().length;

            console.log(tamanho);

            if (tamanho <= 14) {
                $("#Requerente_Documento").mask("999.999.999-99");
            } else {
                $("#Requerente_Documento").mask("99.999.999/9999-99");
            }
        }



        //$("#Requerente_Documento").mask("999.999.999-99");
        $('#Requerente_Celular').mask(maskBehavior, options);
        $('#Requerente_Telefone').mask(maskBehavior, options);
        $("#Requerente_DataNascimento").mask("99/99/9999");
        $("#Requerente_Cep").mask("99999-999");



        //cep
        $('#buscar-cep').click(function () {
            $('#Requerente_Cep').cep({
                load: function () {
                    //Exibe a div loading
                    $('#loading.cep').css('display', 'inline');
                },
                complete: function () {
                    //Esconde a div loading
                    $('#loading.cep').css('display', 'none');
                },
                error: function (msg) {
                    //Exibe em alert a mensagem de erro retornada
                    alert(msg);
                },
                success: function (data) {
                    $('#Requerente_Endereco').val(data.tipoLogradouro + ' ' + data.logradouro);
                    $('#Requerente_Bairro').val(data.bairro);
                    $('#Requerente_Estado').val(data.estado);
                    $('#Requerente_Cidade').val(data.cidade);
                    $('#Requerente_Numero').focus();
                }
            });
        });



    </script>
    <script>

        function carregaContatos(PessoaId) {
            $.getJSON("@Url.Content("~/ApiIntegracao/GetPessoasContatos/")", { id: PessoaId }, function (result) {



                var tr = [];
                for (var i = 0; i < result.length; i++) {
                    tr.push("<tr class='" + result[i].RegStatus + " " + (result[i].PessoaContatoErrado ? "errado" : "certo") + " ' >");
                    tr.push("<td><a class=\"" + (result[i].PessoaContatoFavorito ? "like" : "unlike") + "\" href=\"#/\" onclick=\"like(" + result[i].PessoaContatoId + ",'contato','" + (result[i].PessoaContatoFavorito ? "false" : "true") + "')\"></a></td>");
                    tr.push("<td><a class=\"" + (result[i].PessoaContatoErrado ? "errado" : "certo") + "\" href=\"#/\" onclick=\"errado(" + result[i].PessoaContatoId + ",'contato','" + (result[i].PessoaContatoErrado ? "false" : "true") + "')\"></a></td>");
                    tr.push("<td>");
                    if ($.trim(result[i].PessoaDependenteNome) != null) {
                        tr.push("<i class=\"fa fa-users\" ></i> ");
                    }
                    tr.push("</td>");


                    tr.push("<td>");
                    tr.push($.trim(result[i].PessoaContatoValor));
                    tr.push("<br />");
                    tr.push("<small>" + result[i].PessoaContatoCategoria + " " + result[i].PessoaContatoTipo + " " + $.trim(result[i].PessoaContatoDescricao) + "</small>");
                    if ($.trim(result[i].PessoaDependenteNome) != null) {
                        tr.push("<br />");
                        tr.push($.trim(result[i].PessoaDependenteNome) + " <small>/ " + $.trim(result[i].GrauParentescoNome) + "</small>");
                    }
                    tr.push("</td>");

                    tr.push("<td><a class='btn btn-outline btn-primary btn-xs fancybox_reload fancybox.iframe' href='@(Url.Content("~/PessoasContatos/Criar/"))" + result[i].PessoaContatoId + "'><i class=\"fa fa-pencil-square-o\" aria-hidden=\"true\"></i></a></td>");
                   tr.push("<td><a class='btn btn-outline btn-danger btn-xs fancybox_reload fancybox.iframe' href='@(Url.Content("~/PessoasContatos/Deletar/"))" + result[i].PessoaContatoId + "'><i class=\"fa fa-trash-o\" aria-hidden=\"true\"></i></a></td>");
                   tr.push('</tr>');
               }
                $("#tableContatos tbody tr").remove();
                $("#tableContatos tbody").append($(tr.join('')));


            });
       }

       carregaContatos($("#Requerente_PessoaID").val());


       function carregaEnderecos(PessoaId) {
           $.getJSON("@Url.Content("~/ApiIntegracao/GetPessoasEnderecos/")", { id: PessoaId }, function (result) {



                var tr = [];
                for (var i = 0; i < result.length; i++) {
                    tr.push("<tr class='" + result[i].RegStatus + " " + (result[i].PessoaEnderecoErrado ? "errado" : "certo") + " ' >");
                    tr.push("<td><a class=\"" + (result[i].PessoaEnderecoFavorito ? "like" : "unlike") + "\" href=\"#/\" onclick=\"like(" + result[i].PessoaEnderecoId + ",'endereco','" + (result[i].PessoaEnderecoFavorito ? "false" : "true") + "')\"></a></td>");
                    tr.push("<td><a class=\"" + (result[i].PessoaEnderecoErrado ? "errado" : "certo") + "\" href=\"#/\" onclick=\"errado(" + result[i].PessoaEnderecoId + ",'endereco','" + (result[i].PessoaEnderecoErrado ? "false" : "true") + "')\"></a></td>");
                    tr.push("<td>");
                    if ($.trim(result[i].PessoaDependenteNome) != null) {
                        tr.push("<i class=\"fa fa-users\" ></i> ");
                    }
                    tr.push("</td>");


                    tr.push("<td>");
                    tr.push($.trim(result[i].PessoaEnderecoEndereco) + " " + $.trim(result[i].PessoaEnderecoNumero) + " " + $.trim(result[i].PessoaEnderecoComplemento) + " " + $.trim(result[i].PessoaEnderecoCep) + " " + $.trim(result[i].PessoaEnderecoBairro) + " " + $.trim(result[i].PessoaEnderecoCidade) + " " + $.trim(result[i].PessoaEnderecoEstado));
                    tr.push("<br />");
                    tr.push("<small>" + $.trim(result[i].PessoaContatoDescricao) + "</small> " + $.trim(result[i].PessoaDependenteNome) + " <small> / " + $.trim(result[i].GrauParentescoNome) + "</small>");
                    tr.push("</td>");

                    tr.push("<td><a class='btn btn-outline btn-primary btn-xs fancybox_reload fancybox.iframe' href='@(Url.Content("~/PessoasEnderecos/Criar/"))" + result[i].PessoaEnderecoId + "'><i class=\"fa fa-pencil-square-o\" aria-hidden=\"true\"></i></a></td>");
                    tr.push("<td><a class='btn btn-outline btn-danger btn-xs fancybox_reload fancybox.iframe' href='@(Url.Content("~/PessoasEnderecos/Deletar/"))" + result[i].PessoaEnderecoId + "'><i class=\"fa fa-trash-o\" aria-hidden=\"true\"></i></a></td>");
                    tr.push('</tr>');
                }
                $("#tableEnderecos tbody tr").remove();
                $("#tableEnderecos tbody").append($(tr.join('')));


            });
        }

        carregaEnderecos($("#Requerente_PessoaID").val());

    </script>
    <script type="text/javascript">
        $(document).ready(function () {
            $('.chosen-select').select2();

            $('.chosen-select-add').chosen().trigger("chosen:updated");
            $('.datepicker').datepicker({ language: 'pt-BR', format: 'dd/mm/yyyy', todayHighlight: true, todayBtn: true });
            $('.moeda').mask('000000000000000,00', { reverse: true });
            $('.max').maxlength({
                alwaysShow: true,
                threshold: 10,
                warningClass: "label label-success",
                limitReachedClass: "label label-danger"
            });
        });
    </script>
    <script>

        function like(id, tipo, favorito) {
            $.getJSON('@Url.Content("~/ApiIntegracao/SetRegistraContatoEnderecoFavorito/")', { id: id, tipo: tipo, favorito: favorito }, function (data) {

                switch (tipo) {
                    case "contato":
                        carregaContatos($("#Requerente_PessoaID").val());
                        break;
                    case "endereco":
                        carregaEnderecos($("#Requerente_PessoaID").val());
                        break;
                }
                console.log(data);
            });
        }


    </script>
    <script>

        function atualiza(reload) {
            var url = "@Url.Content("~/PRCPropostas/TriagemEditarJSON")"; // the script where you handle the form input.


            $.ajax({
                type: "POST",
                url: url,
                data: $("#form-criar").serialize(),
                success: function (result) {
                    if (result.NUMERO != 0) {
                        swal({ title: "Atencão!", text: result.MENSAGEM, type: "error", showCancelButton: false, cancelButtonText: "Não", confirmButtonColor: "#DD6B55", confirmButtonText: "Ok", closeOnConfirm: true }, function () { });
                    }


                    if (reload) {
                        RecarregaPagina();
                    }



                },
                error: function (result) {
                    swal({ title: "Atencão!", text: "Ocorreu um erro ao tentar salvar os dados da proposta", type: "error", showCancelButton: false, cancelButtonText: "Não", confirmButtonColor: "#DD6B55", confirmButtonText: "Ok", closeOnConfirm: true }, function () { });
                }
            });


        }


        $("input[type=text], textarea, select, :checkbox").change(function () {
            var isReload = $(this).hasClass('atualiza');

            atualiza(isReload);


        });

        function RecarregaPagina() {
            window.location.reload(true);
        }

    </script>

}

