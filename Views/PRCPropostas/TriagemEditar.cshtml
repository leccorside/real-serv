@model Models.PRCPropostaView

@{
    ViewBag.Title = "Proposta n. " + Model.PRCProposta.PRCPropostaId;
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";

    var _possuiParentes = (Model.ListPessoaDependente.Count > 0);
    var _PrcPropsotas_EditarNegociador = BLL.Usuarios.VerificaAcesso("EditarNegociador", "PRCPropostas");

    var _possuiContatos = BLL.PessoasContatos.PossuiContatos(Model.PRCProposta.NegociadorId);


    var _dadosTruncados = (Model.Requerente.Documento == "" && _possuiContatos);
    
}



@section Breadcrumb{

}



@using (Html.BeginForm("TriagemEditar", "PRCPropostas", FormMethod.Post, new { @id = "form-criar", @class = "alertChanges" }))
{
    @Html.ValidationSummary(true)

    @Html.HiddenFor(m => m.PRCProposta.PRCPropostaId);
    @Html.HiddenFor(m => m.PRCProposta.PRCPropostaGUID);

    @Html.HiddenFor(m => m.Requerente.PessoaID);
    @Html.HiddenFor(m => m.Advogado.PessoaID);
    @Html.HiddenFor(m => m.PRCProposta.RegStatus);
    @Html.HiddenFor(m => m.PRCProposta.NotificacaoNotificado);







    <div class="content ">

        <div class="row">
            <div class="col-lg-12">
                <div class="hpanel">
                    @Html.Partial("~/Views/PRCPropostas/_tabstriagem.cshtml", Model)

                </div>

            </div>
        </div>

        <div class="row">
            <div class="col-lg-7" style="">
                <div class="hpanel">
                    <div class="panel-heading ">
                        <div class="panel-tools">
                            <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                        </div>
                        <i class="fa fa-user-circle-o" aria-hidden="true"></i>Dados Requerente
                    </div>

                    @if (Model.Requerente.NaoPermiteEmail || Model.Requerente.NaoPermiteLigacao || Model.Requerente.NaoPermiteSMS)
                                {                               
                                    <div class="alert alert-warning" role="alert">
                                        <h4><i class="fa fa-exclamation-triangle" aria-hidden="true"></i><strong>Atenção</strong> Requerente não permite:</h4>
                                        @if (Model.Requerente.NaoPermiteEmail)
	                                    {
		                                <span>- Envio de emails<br /></span>
	                                    }
                                        @if (Model.Requerente.NaoPermiteSMS)
	                                    {
		                                <span>- SMS<br /></span>
	                                    }
                                        @if (Model.Requerente.NaoPermiteLigacao)
	                                    {
		                                <span>- Ligações<br /></span>
	                                    }
                                    </div>
                                }
                    <div class="panel-body">


                        <div class="row">
                            <div class="form-group col-lg-8 col-md-8 col-sm-8">
                                <label>Nome</label>
                                @Html.TextBoxFor(m => m.Requerente.Nome, new { @class = "form-control" })
                            </div>
                            <div class="form-group col-lg-4 col-md-4 col-sm-4">
                                <label>CPF/CNPJ</label>
                                @Html.TextBoxFor(m => m.Requerente.Documento, new { @class = "form-control" })
                            </div>
                            <div class="form-group col-lg-6 col-md-6 col-sm-6">
                                <label>E-Mail</label>
                                @Html.TextBoxFor(m => m.Requerente.Email, new { @class = "form-control" })
                            </div>
                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>Sexo</label>
                                @Html.DropDownListSexo("Requerente.Sexo", Model.Requerente.Sexo, true, " form-control chosen-select ")
                            </div>
                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>
                                    <abbr title="Data de Nascimento">Dt.Nasc.</abbr>
                                </label>
                                @Html.TextBoxFor(m => m.Requerente.DataNascimento, new { @class = "form-control" })
                            </div>
                            <div class="form-group col-lg-6 col-md-6 col-sm-6">
                                <label>Celular</label>
                                @Html.TextBoxFor(m => m.Requerente.Celular, new { @class = "form-control" })
                            </div>
                            <div class="form-group col-lg-6 col-md-6 col-sm-6">
                                <label>Telefone</label>
                                @Html.TextBoxFor(m => m.Requerente.Telefone, new { @class = "form-control" })
                            </div>

                              <div class="form-group col-lg-3 col-md-3 col-sm-3 @(Model.Requerente.Obito ? " alert-danger " : "")">
                                <label>Óbito</label>
                                <div class="checkbox">
                                    <label>@Html.CheckBoxFor(model => model.Requerente.Obito) Sim</label>
                                </div>
                            </div>

                            <div class="form-group col-lg-3 col-md-3 col-sm-3 @(Model.Requerente.NaoPermiteEmail ? " alert-warning " : "")">
                                <label>E-Mail</label>
                                <div class="checkbox">
                                    <label>@Html.CheckBoxFor(model => model.Requerente.NaoPermiteEmail, new { @class = "atualiza" }) <small>Não permite</small></label>
                                </div>
                            </div>

                            <div class="form-group col-lg-3 col-md-3 col-sm-3 @(Model.Requerente.NaoPermiteSMS ? " alert-warning " : "")">
                                <label>SMS</label>
                                <div class="checkbox">
                                    <label>@Html.CheckBoxFor(model => model.Requerente.NaoPermiteSMS, new { @class = "atualiza" }) <small>Não permite</small></label>
                                </div>
                            </div>

                            <div class="form-group col-lg-3 col-md-3 col-sm-3 @(Model.Requerente.NaoPermiteLigacao ? " alert-warning " : "")">
                                <label>Ligação</label>
                                <div class="checkbox">
                                    <label>@Html.CheckBoxFor(model => model.Requerente.NaoPermiteLigacao, new { @class = "atualiza" }) <small>Não permite</small></label>
                                </div>
                            </div>

                        </div>
                        <div class="row">
                            <div class="col-lg-12 col-md-12 col-sm-12">
                                <table id="tableContatos" cellpadding="1" cellspacing="1" class="table table-condensed table-striped">
                                    <caption class="">
                                        <button type="button" onclick="callFancyBoxContatos()" class="pull-left btn btn-outline btn-primary btn-xs">
                                            <i class="fa fa-plus-square-o" aria-hidden="true"></i>
                                        </button>
                                        <a id="hiddenclickerContatos" class="fancybox_reload fancybox.iframe"></a><strong>&nbsp;<a href="@Url.Content("~/PessoasContatos/Index/" + Model.Requerente.PessoaID + "")" class="fancybox fancybox.iframe ">Outros meios de contato</a></strong>
                                    </caption>
                                    <tbody></tbody>
                                </table>

                                <table id="tableEnderecos" cellpadding="1" cellspacing="1" class="table table-condensed table-striped">
                                    <caption class="">
                                        <button type="button" onclick="callFancyBoxEnderecos()" class="pull-left btn btn-outline btn-primary btn-xs">
                                            <i class="fa fa-plus-square-o" aria-hidden="true"></i>
                                        </button>
                                        <a id="hiddenclickerEnderecos" class="fancybox_reload fancybox.iframe"></a><strong>&nbsp;<a href="@Url.Content("~/PessoasEnderecos/Index/" + Model.Requerente.PessoaID + "")" class="fancybox fancybox.iframe ">Endereços</a></strong>
                                    </caption>
                                    <tbody></tbody>
                                </table>

                                @if (_possuiParentes)
                                {
                                    <table id="tableParentes" cellpadding="1" cellspacing="1" class="table table-condensed table-striped">
                                        <thead>
                                            <tr>
                                                <th></th>
                                                <th>Parentes</th>
                                                <th>Grau</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in Model.ListPessoaDependente)
                                            {
                                                int parenteLocalizado = -1;
                                                parenteLocalizado = Model.ListPessoaContato.FindIndex(f => f.PessoaDependenteId == item.PessoaDependenteId);
                                                if (parenteLocalizado < 0)
                                                {
                                                    parenteLocalizado = Model.ListPessoaEndereco.FindIndex(f => f.PessoaDependenteId == item.PessoaDependenteId);
                                                }
                                                <tr>
                                                    @if (parenteLocalizado < 0)
                                                    {
                                                        <td><a class="btn btn-outline btn-primary btn-xs" href="@Url.Content("~/PRCPropostas/CapturaParentesTelefones/" + Model.PRCProposta.PRCPropostaId + "/" + Model.PRCProposta.PRCPropostaGUID + "/?pdid=" + item.PessoaDependenteId + "&rota=Triagem")">Buscar Contatos</a></td>
                                                    }
                                                    else
                                                    {
                                                        <td><a class="btn btn-default btn-xs disabled"><i class="fa fa-check text-success" aria-hidden="true"></i>Capturado</a></td>
                                                    }
                                                    <td>

                                                        @item.PessoaDependenteNome</td>
                                                    <td>@item.GrauParentescoNome</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                    
                                }
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-lg-12">
                                <br />
                                <div class="panel panel-default">
                                    <div class="panel-heading" role="tab" id="headingOne">
                                        <h4 class="panel-title">
                                            <a data-toggle="collapse" data-parent="#accordion" href="#collapseOne" aria-expanded="false" aria-controls="collapseOne" class="collapsed">Dados Complementares e Endereço
                                            </a>
                                        </h4>
                                    </div>
                                    <div id="collapseOne" class="panel-collapse collapse" role="tabpanel" aria-labelledby="headingOne" aria-expanded="false" style="height: 0px;">
                                        <div class="panel-body">

                                            <div class="row-fluid">
                                                <legend>Dados complementares</legend>
                                                <div class="form-group col-lg-6 col-md-6 col-sm-6">
                                                    <label>RG</label>
                                                    @Html.TextBox("Requerente.Rg", Model.Requerente.Rg, new { @class = "  form-control ", maxlength = "40" })
                                                </div>

                                                <div class="form-group col-lg-6 col-md-6 col-sm-6">
                                                    <label>Estado Civil</label>
                                                    @Html.DropDownListEstadoCivil("Requerente.EstadoCivl", Model.Requerente.EstadoCivl, true, " form-control ", "")
                                                </div>
                                            </div>

                                            <div class="row-fluid">
                                                <legend>Endereço</legend>
                                                <div class="form-group col-lg-4">
                                                    <label>CEP</label><label id="loading_cep" style="display: none"><i class="fa fa-spinner fa-spin"></i></label>

                                                    <div class="input-group">
                                                        @Html.TextBoxFor(model => model.Requerente.Cep, new { @class = "form-control" })
                                                        <span class="input-group-btn">
                                                            <button type="button" id="buscar-cep" class="btn btn-default"><i class="fa fa-search"></i></button>
                                                        </span>
                                                    </div>


                                                </div>
                                                <div class="form-group col-lg-5">
                                                    <label>Endereço</label>
                                                    @Html.TextBoxFor(model => model.Requerente.Endereco, new { @class = "  form-control " })
                                                </div>
                                                <div class="form-group col-lg-3">
                                                    <label>Número</label>
                                                    @Html.TextBoxFor(model => model.Requerente.Numero, new { @class = "  form-control " })
                                                </div>
                                                <div class="form-group col-lg-6">
                                                    <label>Complemento</label>
                                                    @Html.TextBoxFor(model => model.Requerente.Complemento, new { @class = "  form-control " })
                                                </div>

                                                <div class="form-group col-lg-6">
                                                    <label>Bairro</label>
                                                    @Html.TextBoxFor(model => model.Requerente.Bairro, new { @class = "  form-control " })
                                                </div>
                                                <div class="form-group col-lg-6">
                                                    <label>Cidade</label>
                                                    @Html.TextBoxFor(model => model.Requerente.Cidade, new { @class = "  form-control " })
                                                </div>
                                                <div class="form-group col-lg-6">
                                                    <label>Estado</label>
                                                    @Html.TextBoxFor(model => model.Requerente.Estado, new { @class = "  form-control " })
                                                </div>

                                            </div>


                                            <div class="row-fluid">
                                                <legend>Dados bancários</legend>
                                                <div class="form-group col-lg-4">
                                                    <label>Código do Banco</label>
                                                    @Html.TextBoxFor(model => model.Requerente.BancoCod, new { @class = "form-control", maxlength = "10" })
                                                </div>
                                                <div class="form-group col-lg-4">
                                                    <label>Nome do Banco</label>
                                                    @Html.TextBoxFor(model => model.Requerente.BancoNome, new { @class = "form-control", maxlength = "50" })
                                                </div>
                                                <div class="form-group col-lg-4">
                                                    <label>Agência</label>
                                                    @Html.TextBoxFor(model => model.Requerente.BancoAgencia, new { @class = "form-control", maxlength = "20" })
                                                </div>
                                                <div class="form-group col-lg-4">
                                                    <label>Conta</label>
                                                    @Html.TextBoxFor(model => model.Requerente.BancoConta, new { @class = "form-control", maxlength = "20" })
                                                </div>
                                                <div class="form-group col-lg-8">
                                                    <label>Observações</label>
                                                    @Html.TextBoxFor(model => model.Requerente.BancoObservacoes, new { @class = "form-control", maxlength = "20" })
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                </div>

            </div>
            <div class="col-lg-5" style="">

                <!--precatorio-->
                <div class="hpanel ">
                    <div class="panel-heading ">
                        <div class="panel-tools">
                            <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                        </div>
                        <i class="fa fa-diamond" aria-hidden="true"></i>Informações Precatório
                    </div>
                    <div class="panel-heading hbuilt">
                        <div class="btn-group">

                            <button type="submit" class="btn btn-default btn-sm"><i class="fa fa-floppy-o" aria-hidden="true"></i>Salvar</button>
                            <a class="btn btn-default btn-sm" href="@Url.Content("~/Principal/Index/0")"><i class="fa fa-chevron-left" aria-hidden="true"></i>Sair</a>
                        </div>
                    </div>

                    <div class="panel-body">
                        <div class="row">
                            <div class="form-group col-lg-4 col-md-4 col-sm-4">
                                <label>Número</label>
                                <p class="form-control-static"><a href="@Url.Content("~/Trj/View/0/?Protocolo=" + Model.Precatorio.TrjReqPagNumero + "")" class="fancybox fancybox.iframe "><i class="fa fa-search"></i>@Model.Precatorio.TrjReqPagNumero</a></p>
                            </div>
                            <div class="form-group col-lg-2 col-md-2 col-sm-2">
                                <label>
                                    <abbr title="Ano Proposta">Ano</abbr>
                                </label>
                                <p class="form-control-static">@Model.Precatorio.TrjReqPagMesAno</p>
                            </div>
                            <div class="form-group col-lg-6 col-md-6 col-sm-6">
                                <label>
                                    <abbr title="Data Protocolo">Dt.Protoc.</abbr>
                                </label>
                                <p class="form-control-static"><small>@Model.Precatorio.TrjReqPagDtProtocolo</small></p>
                            </div>
                            <div class="form-group col-lg-12 col-md-12 col-sm-12">
                                <label>Requerido</label>
                                <p class="form-control-static"><small>@Model.Precatorio.TrjReqPagRequerido</small></p>
                            </div>
                            <div class="form-group col-lg-12 col-md-12 col-sm-12">
                                <label>Valor Solicitado</label>
                                <h5 class="text-info">R$ @string.Format("{0:N2}", Model.Precatorio.TrjReqPagValorSolicitado)</h5>
                            </div>

                            <div class="form-group col-lg-12 col-md-12 col-sm-12">
                                <label>Motivo Triagem</label>
                                @Model.PRCProposta.TriagemObservacao

                                
                            </div>
                            



                        </div>

                        <div class="row">
                            <div class="col-lg-12">



                                    <a style="height:86px" href="@Url.Content("~/PRCPropostas/TriagemDesbloquear/" + Model.PRCProposta.PRCPropostaId + "/" + Model.PRCProposta.PRCPropostaGUID)" class="btn btn-outline btn-primary  " type="button"><i class="fa fa-map-signs fa-2x" aria-hidden="true"></i>
                                        <br>
                                        Triagem<br />
                                        <small>Desbloquear</small></a>
                                

                                
                                @if (_dadosTruncados)
                                {
                                    <a style="height: 86px" class="btn btn-default disabled " type="button" aria-expanded="true" href="#!"><i class="fa fa-user-circle fa-2x" aria-hidden="true"></i>
                                        <br />
                                        <small><i class="fa fa-check text-success" aria-hidden="true"></i>Buscar<br />
                                            Dados PROCOB</small> </a>
                                }
                                else
                                {
                                    <a style="height:86px" class="btn btn-outline btn-info " type="button" aria-expanded="true" href="@Url.Content("~/PRCPropostas/AtualizaPropostaProcob/" + Model.PRCProposta.PRCPropostaId + "/" + Model.PRCProposta.PRCPropostaGUID + "/?rota=Triagem")" ><i class="fa fa-user-circle fa-2x" aria-hidden="true"></i>
                                        <br />
                                        <small>Buscar<br />
                                            Dados PROCOB</small> </a>    
                                }


                                @if (_possuiParentes || !_dadosTruncados)
                                {
                                    
                                    <a style="height: 86px" class="btn btn-default disabled " type="button" aria-expanded="true" href="#!"><i class="fa fa-users fa-2x" aria-hidden="true"></i>
                                        <br />
                                        <small><i class="fa @(!_dadosTruncados?"":" fa-check text-success ")" aria-hidden="true"></i>Buscar<br />
                                            Parentes</small> </a>    
                                    
                                    
                                }
                                else
                                {
                                    <a style="height:86px" class="btn btn-outline btn-warning2 " type="button" aria-expanded="true" href="@Url.Content("~/PRCPropostas/CapturaParentes/" + Model.PRCProposta.PRCPropostaId + "/" + Model.PRCProposta.PRCPropostaGUID + "/?rota=Triagem")" ><i class="fa fa-users fa-2x" aria-hidden="true"></i>
                                        <br />
                                        <small>Buscar<br />
                                            Parentes</small> </a>    
                                }

                            </div>



                        </div>
                    </div>

                </div>
                <!--./precatorio-->

                <!-- negociador -->
                <div class="hpanel">
                    <div class="panel-heading ">
                        <div class="panel-tools">
                            <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                        </div>
                        <i class="fa fa-user-secret" aria-hidden="true"></i>Dados Negociador
                    </div>
                    <div class="panel-body">
                        <div class="row">
                            <div class="form-group col-lg-12 col-md-12 col-sm-12">
                                <label>
                                    <abbr title="Procedimento">Nome</abbr>
                                </label>
                                <p class="form-control-static">@Model.Negociador.UsuarioNome</p>
                            </div>
                            <div class="form-group col-lg-12 col-md-12 col-sm-12">
                                <label>
                                    <abbr title="Procedimento">E-Mail</abbr>
                                </label>
                                <p class="form-control-static">@Model.Negociador.UsuarioEmail</p>
                            </div>

                        </div>
                    </div>

                </div>
                <!-- ./negociador-->

                @if (_PrcPropsotas_EditarNegociador)
                {
                    <div class="hpanel">
                        <div class="panel-heading ">
                            <div class="panel-tools">
                                <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                            </div>
                            <i class="fa fa-user-secret" aria-hidden="true"></i>Alterar Negociador
                        </div>
                        <div class="panel-body">
                            <div class="row">
                                <div class="form-group col-lg-12 col-md-12 col-sm-12">
                                    <label>
                                        <abbr title="Procedimento">Alterar negociador</abbr></label><br />
                                    @Html.DropDownListFor(model => model.PRCProposta.NegociadorId, (SelectList)ViewBag.ddlUsuarios, null, new { @class = "chosen-select-add form-control atualiza" })
                                </div>

                            </div>
                        </div>

                    </div>    
                }
                else
                {
                    @Html.HiddenFor(m => m.PRCProposta.NegociadorId);
                }
            </div>

        </div>

        


        <div class="row">
            <div class="col-lg-12" style="">
                <div class="hpanel">
                    <div class="panel-heading ">
                        <div class="panel-tools">
                            <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                        </div>
                        <i class="fa fa-balance-scale" aria-hidden="true"></i>Dados Advogado
                    </div>
                    <div class="panel-body">
                        <div class="row">
                            <div class="form-group col-lg-8 col-md-8 col-sm-8">
                                <label>Nome</label>
                                @Html.TextBoxFor(m => m.Advogado.Nome, new { @class = "form-control" })
                            </div>
                            <div class="form-group col-lg-4 col-md-4 col-sm-4">
                                <label>CPF</label>
                                @Html.TextBoxFor(m => m.Advogado.Documento, new { @class = "form-control" })
                            </div>
                            <div class="form-group col-lg-6 col-md-6 col-sm-6">
                                <label>E-Mail</label>
                                @Html.TextBoxFor(m => m.Advogado.Email, new { @class = "form-control" })
                            </div>
                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>Sexo</label>
                                @Html.DropDownListSexo("Advogado.Sexo", Model.Requerente.Sexo, true, " form-control chosen-select ")
                            </div>
                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>
                                    <abbr title="Data de Nascimento">Dt.Nasc.</abbr>
                                </label>
                                @Html.TextBoxFor(m => m.Advogado.DataNascimento, new { @class = "form-control" })
                            </div>
                            <div class="form-group col-lg-6 col-md-6 col-sm-6">
                                <label>Celular</label>
                                @Html.TextBoxFor(m => m.Advogado.Celular, new { @class = "form-control" })
                            </div>
                            <div class="form-group col-lg-6 col-md-6 col-sm-6">
                                <label>Telefone</label>
                                @Html.TextBoxFor(m => m.Advogado.Telefone, new { @class = "form-control" })
                            </div>
                        </div>

                    </div>

                </div>
            </div>

        </div>
    </div>
}

@section Styles{
    @Styles.Render("~/Assets/css/chosen.css")
    @Styles.Render("~/bundles/select2/css")
    @Styles.Render("~/bundles/datepicker/css")
    @Styles.Render("~/bundles/fancybox/css")
    @Styles.Render("~/bundles/ladda/css")
    <style>
        .form-group-mini .checkbox
        {
            margin-top: -10px !important;
            margin-bottom: 15px !important;
        }

        .my-group .select
        {
            width: 30%;
        }

        .my-group .input
        {
            width: 70%;
        }

        tr.E
        {
            text-decoration: line-through;
            color: gray;
            font-style: italic;
        }

            tr.E a
            {
                display: none;
            }

        a.like:before
        {
            content: "\f004";
            font-family: "FontAwesome";
            font-size: 18px;
            color: red;
        }

        a.unlike:before
        {
            content: "\f08a";
            font-family: "FontAwesome";
            font-size: 18px;
            color: #cccccc;
        }


        a.errado:before
        {
            content: "\f02e";
