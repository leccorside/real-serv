@model Models.PessoaPlanoGrupoAgendamento

@{
    
    ViewBag.Title = "Excluir Programação";


    Layout = "~/Views/Shared/_FortunaLayoutModal.cshtml";


}



<div class="content animate-panel">

    <div class="row">
        <div class="col-lg-12">
            <div class="alert alert-warning">
                <i class="fa fa-exclamation-triangle" aria-hidden="true"></i><strong>Atenção</strong> Você tem certeza que deseja apagar esse registro?
            </div>
        </div>
    </div>


    <div class="row">
        <div class="col-lg-12" style="">
            <div class="hpanel ">
                <div class="panel-heading">
                    <div class="panel-tools">
                        <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                    </div>
                    Excluir Programação
                </div>
                <div class="panel-body">
                    <!-- dados aqui-->


                    

                    <br />
                    @using (Html.BeginForm("Deletar", "PessoasPlanosGruposAgendamentos", FormMethod.Post))
                    {
                        
                        @Html.HiddenFor(m => m.PessoaPlanoGrupoAgendamentoId)

                        @Html.HiddenFor(m => m.PessoaPlanoGrupoId);
                        
                            

        
                        <div class="row">

                            <div class="form-group col-lg-12">
                                <label>Titulo</label><br />
                                @Model.PessoaPlanoGrupoAgendamentoTitulo
                            </div>

                            <div class="form-group col-lg-12">
                                <label>Descrição</label><br />
                                @Model.PessoaPlanoGrupoAgendamentoDescricao
                            </div>

                             <div class="form-group col-lg-6 col-md-6 col-sm-6">
                                <label>Palestrante ou Responsável</label><br />
                                 @Model.PessoaPlanoGrupoAgendamentoNome
                            </div>

                            <div class="form-group col-lg-2 col-md-2 col-sm-2">
                                <label>Data</label><br />
                                @Model.PessoaPlanoGrupoAgendamentoDt
                            </div>

                            <div class="form-group col-lg-2 col-md-2 col-sm-2">
                                <label>Hora Início</label><br />
                                @Model.PessoaPlanoGrupoAgendamentoHrIni
                            </div>

                            <div class="form-group col-lg-2 col-md-2 col-sm-2">
                                <label>Hora Início</label><br />
                                @Model.PessoaPlanoGrupoAgendamentoHrFim
                            </div>
                            









                        </div>
                        <div class="row">
                            <div class="col-lg-12">
                                <button type="submit" class="btn btn-outline btn-danger">Excluir</button>
                                
                                <a href="@Url.Content("~/PessoasPlanosGruposAgendamentos/Index/" + Model.PessoaPlanoGrupoId)" class="btn btn-outline btn-primary ">Voltar</a>
                            </div>
                        </div>
                    }

                    <!-- ./ dados aqui-->
                </div>

            </div>
        </div>
    </div>
</div>





@section Styles{
    @Styles.Render("~/bundles/select2/css")
    @Styles.Render("~/bundles/fancybox/css")
    @Styles.Render("~/bundles/datepicker/css")
}



@section Scripts {
    @Scripts.Render("~/bundles/select2/js")
    @Scripts.Render("~/bundles/fancybox/js")
    @Scripts.Render("~/bundles/clipboard/js")
    @Scripts.Render("~/bundles/datepicker/js")
    @Scripts.Render("~/bundles/mask/js")
    @Scripts.Render("~/bundles/maxlenght/js")


    <script>
        
        $('.max').maxlength();


        $(document).ready(function () {

            $(".fancybox").fancybox({ fitToView: false, width: '80%', autoSize: true });
            $(".fancybox_full").fancybox({
                fitToView: false,
                width: '100%',
                autoSize: false,
                closeClick: false,
                openEffect: 'none',
                closeEffect: 'none'
            });
        });

    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('.chosen-select').select2();
            $('.datepicker').datepicker({ language: 'pt-BR', format: 'dd/mm/yyyy', todayHighlight: true, todayBtn: true });
            $('.moeda').mask('000000000000000,00', { reverse: true });
        });
    </script>
}

