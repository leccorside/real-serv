@model Models.ChangePasswordModel



@{
    

    

    var acao = "Alterar";


    ViewBag.Title = acao + " Senha";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";   
}





@section Breadcrumb{
    <li class="active">@Html.ActionLink("Configurações", "Configuracoes", "Principal")</li>
    <li class="active">@Html.ActionLink("Seu Perfil", "Perfil", "Principal")</li>
}



<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">

            <div class="hpanel">

                <div class="panel-body">
                    <!-- conteudo aqui -->


            @using (Html.BeginForm("SuaSenha", "Perfil", FormMethod.Post))
    {
        @Html.ValidationSummary(true)

      
            @Html.Hidden("UsuarioId", BLL.Usuarios.GetUsuarioId());
                      
            
            <div class="row">
                
             <div class="col-lg-4">
            <label>@Html.LabelFor(model=>model.oldPassword)</label>
            @Html.PasswordFor(model => model.oldPassword, new {@class="form-control"})
        </div>
        
    
        <div class="col-lg-4">
            <label>@Html.LabelFor(model=>model.newPassword)</label>
            @Html.PasswordFor(model => model.newPassword, new {@class="form-control"})
        </div>
        
        
        <div class="col-lg-4">
            <label>@Html.LabelFor(model=>model.ConfirmPassword)</label>
            @Html.PasswordFor(model => model.ConfirmPassword, new {@class="form-control"})
        </div>
        
      

            </div>
            
                        

                        <div class="row">
                            <div class="col-lg-12">
                                <input type="submit" value="Salvar" class="btn btn-primary btn-large pull-right" tabindex="11" />
                            </div>

                        </div>
            
                    }

                    <!-- ./conteudo aqui -->
                </div>

            </div>
        </div>
    </div>
</div>

