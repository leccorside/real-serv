@model Models.Perfil

@{
    ViewBag.Title = "Excluíndo Perfil";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


@section Breadcrumb{

    <li class="active"><span class="divider">/</span> @Html.ActionLink("Perfis", "Index", new { id = 0 })</li>
}




<div class="alert">
    <h2>Atencão!</h2>
    Você tem certeza que deseja apagar essa Perfil?
</div>


<table class="table table-bordered table-striped table-highlight">
    <thead>
        <tr>



            <th width="100%">Pefil
            </th>


            <th nowrap>Criado em
            </th>

        </tr>
    </thead>
    <tbody>
        <tr>


            <td>@Html.DisplayFor(model => model.PerfilNome) </td>

            <td>@Html.DisplayFor(model => model.RegDtInicio)  </td>
        </tr>



    </tbody>
</table>

@using (Html.BeginForm())
{
          
    @Html.HiddenFor(model => model.PerfilId)
                   
    <p class="pull-right">
        <input type="submit" value="Apagar" class="btn btn-large btn-danger" />
    </p>

    <p class="pull-left">
        @Html.ActionLink("Voltar", "Index")
    </p>
             
}