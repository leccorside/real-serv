@model Models.Acesso

@{
    ViewBag.Title = "Excluíndo Acesso";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


@section Breadcrumb{
    <li class="active"><span class="divider">/</span>    @Html.ActionLink("Acessos", "Index", new { id = 0 })</li>
}




<div class="alert">

    <h2>Atencão!</h2>
    Você tem certeza que deseja apagar esse Acesso?
</div>


<table class="table table-bordered table-striped table-highlight">
    <thead>
        <tr>

            <th>
                @Html.DisplayNameFor(model => model.AcessoId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Controle)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Acao)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Descricao)
            </th>
            <th>Exibir no menu</th>
            <th>Menu</th>
            <th>Ordem</th>
            <th>Id Pai</th>

        </tr>
    </thead>
    <tbody>

        <tr>

            <td>@Html.DisplayFor(model => model.AcessoId)</td>
            <td>
                @Html.DisplayFor(model => model.Controle)
            </td>
            <td>
                @Html.DisplayFor(model => model.Acao)
            </td>
            <td>
                @Html.DisplayFor(model => model.Descricao)
            </td>
            <td>@if (Model.MenuExibir)
                {
                <i class="icon-checkmark"></i>    
                }</td>
            <td>
                @Html.DisplayFor(model => model.Menu)</td>
            <td>
                @Html.DisplayFor(model => model.MenuOrdem)</td>
            <td>
                @Html.DisplayFor(model => model.AcessoIdPai)</td>

        </tr>

    </tbody>



</table>





@using (Html.BeginForm())
{
   
    @Html.HiddenFor(model => model.AcessoId)
    <p class="pull-right">
        <input type="submit" value="Apagar" class="btn btn-large btn-danger" />
    </p>

    <p class="pull-left">
        @Html.ActionLink("Voltar", "Index")
    </p>
 
}