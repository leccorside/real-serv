@model Models.MedicaoRegistroView

@{    
    
    var acao = "Cadastrar";

    ViewBag.Title = acao + " " + "Estacas Executadas";

  
        Layout = "~/Views/Shared/_LayoutBranco.cshtml";
   
    
    

    var totalLcravado = Model.ListaMedicaoRegistro.Select(c => c.LCravado).Sum();

    var totalReap1 = Model.ListaMedicaoRegistro.Select(c => c.Reap1).Sum();

    var totalCortes = Model.ListaMedicaoRegistro.Select(c => c.Cortes).Count();

    var totalCompMed = Model.ListaMedicaoRegistro.Select(c => c.CompMed).Sum();
        
}



@section Styles{
    
    <style>
        .table-executada
        {
            font-size: 8px;
        }

        .editor-label label
        {
            font-size: 9px;
        }

        .editor-field input
        {
            font-size: 10px;
        }
    </style>
}





@using (Html.BeginForm())
{
    @Html.ValidationSummary(true)

    if (Model.MedicaoRegistro.MedicaoRegistroId > 0)
    {
    @Html.Hidden("MedicaoRegistro.MedicaoRegistroId", Model.MedicaoRegistro.MedicaoRegistroId);
    }
  
    
    @Html.Hidden("MedicaoRegistro.MedicaoId", Model.Medicao.MedicaoId);
    @Html.HiddenFor(model => model.MedicaoRegistro.LCravado)
    @Html.HiddenFor(model => model.MedicaoRegistro.ComLevM)
    @Html.HiddenFor(model => model.MedicaoRegistro.Soldas)
    @Html.HiddenFor(model => model.MedicaoRegistro.CompMed)
    @Html.HiddenFor(model => model.MedicaoRegistro.Linha)
    
    
    
    <legend>Estacas Executadas</legend>
    <div class="row-fluid">
            <div class="span3">
                <div class="editor-label">
                <label>Equipamento</label></div>
                @Model.Medicao.EquipamentoNome
                
            </div>
            <div class="span3">
            <div class="editor-label">
                <label>Taxa Outros</label>
            </div>
            @Model.Medicao.TaxaOutros
        </div>
            <div class="span3">
                <div class="editor-label">
                <label>Operador</label></div>
                @Model.Medicao.OperadorNome
            </div>
            <div class="span3">
                <div class="editor-label">
                <label>Data</label></div>
                @Convert.ToDateTime(Model.Medicao.EquipamentoDtEntrada).ToShortDateString()
            </div>
        </div>
    <br />
    
    <div class="row-fluid">
        <div class="span4">
            <div class="editor-label">
                <label>Tipo</label>
            </div>
            <div class="editor-field">
                @Html.DropDownListFor(model => model.MedicaoRegistro.MedicaoTipoId, (SelectList)ViewBag.ddlMedicoesTipos, new { @class = "span12 " })
                @*@Html.ValidationMessageFor(model => model.MedicaoRegistro.MedicaoTipoId)*@
            </div>
        </div>
        <div class="span2">
            <div class="editor-label">
                @Html.LabelFor(model => model.MedicaoRegistro.Estaca)
            </div>
            <div class="editor-field">
                @Html.TextBoxFor(model => model.MedicaoRegistro.Estaca, new { @class = "span12" })
                @*@Html.ValidationMessageFor(model => model.MedicaoRegistro.Estaca)*@
            </div>
        </div>

        <div class="span2">
            <div class="editor-label">
                @Html.LabelFor(model => model.MedicaoRegistro.Etapa)
            </div>
            <div class="editor-field">
                @Html.TextBoxFor(model => model.MedicaoRegistro.Etapa, new { @class = "span12" })
                @*@Html.ValidationMessageFor(model => model.MedicaoRegistro.Etapa)*@
            </div>
        </div>
        <div class="span4">
            <div class="editor-label">
                @Html.LabelFor(model => model.MedicaoRegistro.ProdutoSecaoId)
            </div>
            <div class="editor-field">
                @Html.DropDownListFor(model => model.MedicaoRegistro.ProdutoSecaoId, (SelectList)ViewBag.ddlProdutos, new { @class = "span12 chosen-select" })
                @*@Html.ValidationMessageFor(model => model.MedicaoRegistro.ProdutoId)*@
            </div>
        </div>
    </div>

    <div class="row-fluid">
        <div class="span10">
            <div class="editor-label">
                @Html.LabelFor(model => model.MedicaoRegistro.Comp1)
            </div>
            <div class="editor-field">
                @Html.TextBoxFor(model => model.MedicaoRegistro.Comp1, new { @class = "input-mini money", @style = "display: inline" })
                @Html.TextBoxFor(model => model.MedicaoRegistro.Comp2, new { @class = "input-mini money", @style = "display: inline" })
                @Html.TextBoxFor(model => model.MedicaoRegistro.Comp3, new { @class = "input-mini money", @style = "display: inline" })
                @Html.TextBoxFor(model => model.MedicaoRegistro.Comp4, new { @class = "input-mini money", @style = "display: inline" })
                @Html.TextBoxFor(model => model.MedicaoRegistro.Comp5, new { @class = "input-mini money", @style = "display: inline" })
                @Html.TextBoxFor(model => model.MedicaoRegistro.Comp6, new { @class = "input-mini money", @style = "display: inline" })
                @if (Bll.Configuracoes.Carregar("medicoes.estacas.qtd.composicao") == "8")
                {
                @Html.TextBoxFor(model => model.MedicaoRegistro.Comp7, new { @class = "input-mini money", @style = "display: inline" })
                @Html.TextBoxFor(model => model.MedicaoRegistro.Comp8, new { @class = "input-mini money", @style = "display: inline" })
                }
            </div>
        </div>
        <div class="span2">
            <div class="editor-label">
                @Html.LabelFor(model => model.MedicaoRegistro.HoraExtra)
            </div>
            <div class="editor-field">
                <label class="checkbox">
                    @Html.CheckBoxFor(model => model.MedicaoRegistro.HoraExtra) <i class="fa fa-clock-o"></i>
                </label>
            </div>
        </div>

    </div>
    
    <div class="row-fluid">
        <div class="span2">
            <div class="editor-label">
                @Html.LabelFor(model => model.MedicaoRegistro.PreFuro)
            </div>
            <div class="editor-field">
                @Html.TextBoxFor(model => model.MedicaoRegistro.PreFuro, new { @class = "span12 money" })
                @*@Html.ValidationMessageFor(model => model.MedicaoRegistro.PreFuro)*@
            </div>
        </div>
        <div class="span2">
            <div class="editor-label">
                @Html.LabelFor(model => model.MedicaoRegistro.PontaMetalica)
            </div>
            <div class="editor-field">
                @Html.TextBoxFor(model => model.MedicaoRegistro.PontaMetalica, new { @class = "span12 money" })
                @*@Html.ValidationMessageFor(model => model.MedicaoRegistro.PontaMetalica)*@
            </div>
        </div>
        <div class="span2">
            <div class="editor-label">
                @Html.LabelFor(model => model.MedicaoRegistro.Reap1)
            </div>
            <div class="editor-field">
                @Html.TextBoxFor(model => model.MedicaoRegistro.Reap1, new { @class = "span12 money" })
                @*@Html.ValidationMessageFor(model => model.MedicaoRegistro.Reap1)*@
            </div>
        </div>
        <div class="span2">
            <div class="editor-label">
                @Html.LabelFor(model => model.MedicaoRegistro.Cortes)
            </div>
            <div class="editor-field">
                <label class="checkbox">
                    @Html.CheckBoxFor(model => model.MedicaoRegistro.Cortes) <i class="fa fa-scissors"></i>
                </label>
            </div>
        </div>
        <div class="span2">
            <div class="editor-label">
                @Html.LabelFor(model => model.MedicaoRegistro.Supl)
            </div>
            <div class="editor-field">
                @Html.TextBoxFor(model => model.MedicaoRegistro.Supl, new { @class = "span12 money" })
                @*@Html.ValidationMessageFor(model => model.MedicaoRegistro.Supl)*@
            </div>
        </div>
        <div class="span2">
            <div class="editor-label">
                @Html.LabelFor(model => model.MedicaoRegistro.Sobra)
            </div>
            <div class="editor-field">
                @Html.TextBoxFor(model => model.MedicaoRegistro.Sobra, new { @class = "span12 money" })
                @*@Html.ValidationMessageFor(model => model.MedicaoRegistro.Sobra)*@
            </div>
        </div>
        </div>
    <div class="row-fluid">
        <div class="span2">
            <div class="editor-label">
                @Html.LabelFor(model => model.MedicaoRegistro.Nega)
            </div>
            <div class="editor-field">
                @Html.TextBoxFor(model => model.MedicaoRegistro.Nega, new { @class = "span12 money" })
                @*@Html.ValidationMessageFor(model => model.MedicaoRegistro.Nega)*@
            </div>
        </div>
        <div class="span2">
            <div class="editor-label">
                @Html.LabelFor(model => model.MedicaoRegistro.QuebraQtd)
            </div>
            <div class="editor-field">
                @Html.TextBoxFor(model => model.MedicaoRegistro.QuebraQtd, new { @class = "span12 money" })
            </div>
        </div>
       <div class="span2">
            <div class="editor-label">
                <label>Cliente Paga?</label>
            </div>
            <div class="editor-field">
                    <span data-toggle='tooltip' class='tip-top pull-top' data-placement='top' title='Indica que o cliente paga a quebra'><label class="checkbox">@Html.CheckBoxFor(model => model.MedicaoRegistro.Quebra) <i class="fa fa-chain-broken"></i> <i class="fa fa-user"></i>  <i class="fa fa-usd"></i></label></span>
            </div>

        </div>
        <div class="span2">
            <div class="editor-label">
                @Html.LabelFor(model => model.MedicaoRegistro.AlturaQueda)
            </div>
            <div class="editor-field">
                @Html.TextBoxFor(model => model.MedicaoRegistro.AlturaQueda, new { @class = "span12 money" })
                @*@Html.ValidationMessageFor(model => model.MedicaoRegistro.AlturaQueda)*@
            </div>
        </div>
        <div class="span4">
            <div class="editor-label">
                @Html.LabelFor(model => model.MedicaoRegistro.Observacao)
            </div>

            <div class="editor-field">
                @Html.TextBoxFor(model => model.MedicaoRegistro.Observacao, new { @class = "span12" })
                @*@Html.ValidationMessageFor(model => model.MedicaoRegistro.Observacao)*@
            </div>



            

        </div>
    </div>
    
    <input type="submit" value="Salvar" class="btn btn-primary" />
    
}





@section Scripts {

    <script>

        $("#MedicaoRegistro_BlocoPilar").focus();
    </script>

}
