@model Models.MedicaoRegistroView

@{    
    
    var acao = "Cadastrar";

    ViewBag.Title = acao + " " + "Estacas Executadas";


    Layout = "~/Views/Shared/_LayoutFull.cshtml";




    var totalLcravado = Model.ListaMedicaoRegistro.Select(c => c.LCravado).Sum();

    var totalReap1 = Model.ListaMedicaoRegistro.Select(c => c.Reap1).Sum();

    var totalCortes = Model.ListaMedicaoRegistro.Where(c => c.Cortes==true).Count();

    var totalCompMed = Model.ListaMedicaoRegistro.Select(c => c.CompMed).Sum();

    var metaDiaria = (Model.DadosProjeto.ProjetoMetaDiaria == 0) ? 1 : Model.DadosProjeto.ProjetoMetaDiaria;

    decimal realizado = 0;

    if (Model.DadosProjeto.ProjetoMedidoTipo == "L")
    {
        realizado = (totalCompMed * 100) / metaDiaria;
    }
    else
    {
        realizado = (totalLcravado * 100) / metaDiaria;
    }


    int intRealizado = Convert.ToInt16(realizado);


    var classeRealizado = "success";

    if (realizado < 50)
    {
        classeRealizado = "danger";
    }
    else if (realizado < 90)
    {
        classeRealizado = "info";
    }
    else if (realizado <= 100)
    {
        classeRealizado = "success";
    }
    else
    {
        classeRealizado = "striped";
        intRealizado = 100;
    }
    
    
    
}



@section Styles{
    <link href="~/Assets/plugins/fancybox/jquery.fancybox.css" rel="stylesheet" />
