<table class="table table-striped table-condensed table-executada" id="table_executada">
    <thead>
        <tr>
            <th>Tipo</th>
            <th>Estaca</th>
            <th>Etapa</th>
            <th>Seção</th>
            <th>Composição</th>
            <th>Pré Furo (m)</th>
            <th>Pt. Met. (m)</th>
            <th>Reap. (m)</th>
            <th>Cortes</th>
            <th>Comp.Lev. (m)</th>
            <th>Soldas</th>
            <th>Supl. (m)</th>
            <th>Sobra (m)</th>
            <th>Nega (mm)</th>
            <th>Quebra (m)</th>
            <th>Alt.Qd. (m)</th>
            <th>Obs.</th>
            <th>LCravado (m)</th>
            <th>Comp. Med. (m)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.ListaMedicaoRegistro)
        {
            <tr>
                <td>@item.RegStatus @item.MedicaoTipoNome</td>
                <td>@item.Estaca</td>
                <td>@item.Etapa</td>
                <td>@item.ProdutoSecaoNome</td>
                <td>@item.Comp1 - @item.Comp2 - @item.Comp3 - @item.Comp4 - @item.Comp5 - @item.Comp6
                    @if (Bll.Configuracoes.Carregar("medicoes.estacas.qtd.composicao") == "8")
                    {
                        <span>- @item.Comp7 - @item.Comp8</span>
                    }
                </td>
                <td>@item.PreFuro</td>
                <td>@item.PontaMetalica</td>
                <td>@item.Reap1</td>
                <td>@Convert.ToInt16(item.Cortes)</td>
                <td>@item.ComLevM</td>
                <td>@item.Soldas</td>
                <td>@item.Supl</td>
                <td>@item.Sobra</td>
                <td>@Convert.ToInt16(item.Nega)</td>
                <td>@item.QuebraQtd</td>
                <td>@item.AlturaQueda</td>
                <td><i class="@(item.HoraExtra ? "fa fa-clock-o" : "")"></i> <i class="@(item.Quebra ? "fa fa-chain-broken" : "")"></i>@item.Observacao</td>
                <td>@item.LCravado</td>
                <td>@item.CompMed</td>
                <td>
                      @if (!Model.Medicao.Assinado)
                      {
                    <a href="~/Medicoes/EstacasAlterar/@item.MedicaoRegistroId?MedicaoId=@item.MedicaoId" class="btn btn-mini fancybox fancybox.iframe"><i class="fa fa-pencil-square-o"></i></a><a href="~/Medicoes/EstacasDeletar/@item.MedicaoRegistroId?pmd=@item.MedicaoId" class="btn btn-mini" onclick="return confirm('Deseja realmente excluir esse registro?')"><i class="fa fa-times"></i></a>
                      }
                </td>
            </tr> 
        }

    </tbody>
    <tfoot>
        <tr>
            <td colspan="4">
                <p class="pull-right">Total do dia</p>
            </td>
            <td colspan="3"></td>
            <td>@totalReap1</td>
            <td>@totalCortes</td>
            <td colspan="8"></td>
            <td>@totalLcravado</td>
            <td>@totalCompMed</td>
            <td></td>
        </tr>
    </tfoot>
</table>



<div class="progress progress-@classeRealizado active">
    <div style="width: @intRealizado%" class="bar">@realizado.ToString("0.00")%</div>
</div>
<span class="pull-right table-executada">Meta Diária: @Model.DadosProjeto.ProjetoMetaDiaria (m)</span>

<div>
    <a href="~/Medicoes/Criar/@Model.Medicao.MedicaoId?ProjetoId=@Model.DadosProjeto.ProjetoId">Voltar</a>
</div>



@section Scripts {


    <script src="~/Assets/plugins/fancybox/lib/jquery.mousewheel-3.0.6.pack.js"></script>
    <script src="~/Assets/plugins/fancybox/jquery.fancybox.js"></script>
    <script src="~/Assets/plugins/fancybox/helpers/jquery.fancybox-buttons.js"></script>
    <script src="~/Assets/bootstrap/js/jquery-cep.js"></script>

    <script type="text/javascript">
        $(document).ready(function () {



            $(".fancybox").fancybox({
                fitToView: true,
                autoSize: true,
                closeClick: false,
                openEffect: 'elastic',
                closeEffect: 'elastic',
                beforeClose: function () {
                    CarregaClientes();
                },

            });

        });


        function CarregaClientes() {
            window.location.reload(true);
        }
    </script>

    <script>

        $("#MedicaoRegistro_BlocoPilar").focus();

        //desabilida modo de edicao, pois foi assinado
        @if (Model.Medicao.Assinado)
        {
        @:$(document.body).find('input, textarea, button, select').attr('disabled', 'disabled'); 
        }
    </script>




}
