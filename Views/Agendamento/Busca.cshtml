@model Models.BuscaAgenda
@{
    ViewBag.Title = "Busca";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";  

}


@section Styles{
    <link href="~/Assets/plugins/fancybox/jquery.fancybox.css" rel="stylesheet" />
    <link href="~/Assets/plugins/fancybox/helpers/jquery.fancybox-buttons.css" rel="stylesheet" />
}

<div class="cwell">
    <legend><i class="fa fa-star"></i>Busca Ninja</legend>
    @using (Html.BeginForm())
    {
        @Html.ValidationSummary(true)
        <div class="row-fluid">
            <div class="span3">
                <strong>Celular </strong><br />
                @Html.TextBoxFor(m=>m.Celular)
            </div>
            <div class="span9">
                <strong>Nome do cliente</strong><br />
                @Html.TextBoxFor(m=>m.NomeCliente, new { @class="span9" })
            </div>
            
        </div>
        
         
        
        <div class="row-fluid">
            <div class="span3"><strong>@BLL.Usuarios.GetEntidadeFuncionario()</strong><br />@Html.DropDownList("PessoaId", (SelectList)ViewBag.DdlPessoas, new { @class = "chosen-select span12" })</div>
            <div class="span3"><span title="Espaço em horas na agenda à localizar" class="tip-top"><i class="fa fa-info-circle"></i></span><strong>Duração da Sessão (horas)</strong><br />@Html.TextBoxFor(m => m.QtdHoras, new { @class = "input-mini number" })</div>
            <div class="span2"><span title="Quantidade de resultados à localizar" class="tip-top"><i class="fa fa-info-circle"></i></span><strong>Qtd. de Sessões</strong><br />@Html.TextBoxFor(m => m.QtdRegistros, new { @class = "input-mini number" })</div>
            <div class="span2"><span title="Data inicial da pesquisa" class="tip-top"><i class="fa fa-info-circle"></i></span><strong>Data Inicial</strong><br />@Html.TextBoxFor(m => m.DataInicial, "{0:dd/MM/yyyy}", new { @class = "datepickerDe input-small" })</div>
            <div class="span2"><span title="Data final da pesquisa" class="tip-top"><i class="fa fa-info-circle"></i></span><strong>Data Final</strong><br />@Html.TextBoxFor(m => m.DataFinal, "{0:dd/MM/yyyy}", new { @class = "datepickerDe input-small" })</div>
        </div>
        <br />
        <div class="row-fluid">
            <div class="span12">
                <br />
                <button type="submit" class="btn btn-inverse  btn-large">Buscar <i class="fa fa-star"></i></button>
            </div>
        </div>
        <br />
    }

    <div class="row-fluid">

        <div class="span12">
            <table class="footable table-bordered table-striped">
                <thead>
                    <tr>
                        <th>Datas / Horários encontrados</th>
                    </tr>
                </thead>
                <tbody>

                    @foreach (var item in Model.ListaDatasDisponiveis)
                    {
                        <tr>
                            <td><input type="checkbox"> <a class=" fancybox fancybox.iframe " href="@Url.Content("~/Agendamento/Criar/0?dataInicio=" + item.HoraInicio.ToString("dd/MM/yyyy HH:mm") + "&dataFim=" + item.HoraFim.ToString("dd/MM/yyyy HH:mm") + "&modal=true&pessoaId=" + Model.PessoaId)">- @item.HoraInicio.ToString("dddd, dd/MM/yyyy") das @item.HoraInicio.ToString("HH:mm") até @item.HoraFim.ToString("HH:mm")</a></td>
                        </tr>
                    }

                    @if (Model.ListaDatasDisponiveis.Count() == 0)
                    {
                        <tr>
                            <td><small>Nenhum registro encontrado</small></td>
                        </tr>
                    }

                </tbody>
            </table>

        </div>

    </div>


</div>


@section Scripts {
    <script src="~/Assets/plugins/fancybox/lib/jquery.mousewheel-3.0.6.pack.js"></script>
    <script src="~/Assets/plugins/fancybox/jquery.fancybox.js"></script>
    <script src="~/Assets/plugins/fancybox/helpers/jquery.fancybox-buttons.js"></script>
    <script>
        jQuery(function () {
            $("#DataInicial").mask("99/99/9999");

            $('#PessoaId').trigger('chosen:activate');

            $("#Celular").mask("(99)9999-9999?9");

        });
    </script>
    <script type="text/javascript">
        $(document).ready(function () {

            $(".fancybox").fancybox({
                fitToView: true,
                autoSize: true,
                closeClick: false,
                openEffect: 'elastic',
                closeEffect: 'elastic',
                beforeClose: function () {
                    RecarregaPagina();
                },

            });

        });

        $(".fancybox").click(function () {
            $(this).css("background-color", "#fff4aa");
        });

        function RecarregaPagina() { }
    </script>
}