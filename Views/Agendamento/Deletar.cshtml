@model Models.Agendamento


@{
    ViewBag.Title = "Excluindo Agendamento";

    if (Model.Modal)
    {
        Layout = "~/Views/Shared/_LayoutBranco.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_FortunaLayout.cshtml";  
    }

    var user = new BLL.Usuarios();
    var Agendamento_AgendamentoSeguro = user.ControleAcesso("AgendamentoSeguro", "Agendamento");
}




@section Breadcrumb{
    <li class="active"><span class="divider">/</span>   @Html.ActionLink("Agenda", "Index", "Agendamento")</li>
}





<div class="cwell">
    <fieldset>

        <legend><i class="fa fa-trash"></i> Excluir Agendamento</legend>
        <div class="row-fluid">

            <div class="span4">
                <div class="display-label">
                    <label>Serviço</label>
                </div>
                <div class="display-field">
                    @Html.DisplayFor(model => model.ServicoNome)
                </div>

            </div>

            <div class="span4">


                <div class="display-label">
                    @Html.DisplayNameFor(model => model.Inicio)
                </div>
                <div class="display-field">
                    @Html.DisplayFor(model => model.Inicio) @Html.Label(@String.Format("{0:HH:mm}", Model.Inicio))
                </div>

            </div>
            <div class="span4">



                <div class="display-label">
                    @Html.DisplayNameFor(model => model.Fim)
                </div>
                <div class="display-field">
                    @Html.DisplayFor(model => model.Fim) @Html.Label(@String.Format("{0:HH:mm}", Model.Fim))


                </div>



            </div>
        </div>

        <div class="row-fluid">
            <div class="span12">
                <div class="display-label">
                    @Html.DisplayNameFor(model => model.Observacoes)
                </div>
                <div class="display-field">
                    @Html.DisplayFor(model => model.Observacoes)
                </div>
            </div>
        </div>


    </fieldset>
    <br />
 

    @using (Html.BeginForm())
    {
            
        @Html.HiddenFor(model => model.Modal)
            
           if (Agendamento_AgendamentoSeguro)
        {
            @Html.Partial("~/Views/Usuarios/_ConfirmLogin.cshtml")            
        }
            
        <div class="row-fluid">
            <div class="span12">
                @Html.HiddenFor(model => model.AgendamentoId)
                @Html.HiddenFor(model => model.RecorrenciaGUID)
                <p class="pull-right">
                    <input type="submit" value="Apagar" class="btn btn-large btn-danger" />
                </p>

                @if (Model.RecorrenciaGUID != null)
                {
                    <p class="pull-left">
                        Ooops! Esse agendamento pertence a um cadastro em lote (recorrência). O que você deseja?<br />
                        <label>@Html.RadioButtonFor(m => m.ExcluirLote, false, true) - Apagar somente essa ocorrência</label>
                        <label>@Html.RadioButtonFor(m => m.ExcluirLote, true) - Apagar todas</label>
                    </p>    
                }


            </div>
        </div>    
            
        <div class="row-fluid">
            <div class="span12">
                <a href="@Url.Content("~/Agendamento/Criar/" + Model.AgendamentoId + "?modal=" + Model.Modal)">Voltar</a>
            </div>

        </div>
          
    }


</div>









