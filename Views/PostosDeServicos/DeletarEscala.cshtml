@model Models.EscalaRegistroView

@{
    var user = new BLL.Usuarios();
    ViewBag.Title = "Postos de Serviços";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";  

    
    
}
@section Styles{
    <link href="~/Assets/plugins/fancybox/jquery.fancybox.css" rel="stylesheet" />
    <link href="~/Assets/plugins/fancybox/helpers/jquery.fancybox-buttons.css" rel="stylesheet" />

   <style>
        .table-escala
        {
            font-size: 8px !important;
        }

        .table-escala
        {
        }

          .table-escala td.X /*feriado*/
            {
                background-color: #9974aa;
            }

            .table-escala td.F /*folga*/
            {
                background-color: #ffaaaa;
            }

            .table-escala td.FF /*férias*/
            {
                background-color: #6e91a1;
            }

            .table-escala td.h1, td.h2, td.h3, td.h4, td.h5, td.h6, td.J
            {
                background-color: #d4ee9f;
            }
    </style>
}
@section Breadcrumb{
    <li class="active"><span class="divider">/</span> @Html.ActionLink("Configurações", "Configuracoes", "Principal")</li>
    <li class="active"><span class="divider">/</span> @Html.ActionLink("Posto de Serviço", "Index", new { id = 0 })</li>
    <li class="active"><span class="divider">/</span> @Html.ActionLink("Alterar Posto de Serviço", "Criar", new { id = Model.PostoDeServico.PostoDeServicoId })</li>
}

<div class="alert">
    <button type="button" class="close" data-dismiss="alert">&times;</button>
    <h2>Atencão!</h2>
    Você tem certeza que deseja apagar esse registro?
</div>

<div class="cwell">
    @Html.Partial("~/Views/PostosDeServicos/_Navtabs.cshtml", Model.PostoDeServico)

    

    @Html.Partial("~/Views/PostosDeServicos/_Escala.cshtml", Model)

    
         

    <label>Legenda</label>
    <div style="background-color: #ffaaaa; margin-right: 5px; width: 35px; height: 30px; float: left; font-size: 9px; text-align: center">Folga</div>
    <div style="background-color: #d4ee9f; margin-right: 5px; width: 35px; height: 30px; float: left; font-size: 9px; text-align: center">Jornada</div>
    <div style="background-color: #6e91a1; margin-right: 5px; width: 35px; height: 30px; float: left; font-size: 9px; text-align: center">Férias</div>
    <div style="background-color: #9974aa; margin-right: 5px; width: 35px; height: 30px; float: left; font-size: 9px; text-align: center">Feriado</div>
    <br />
    <br />
    


</div>



<div class="cwell">


    @using (Html.BeginForm())
    {
        <div class="row-fluid">
            <div class="span2">
                @Html.HiddenFor(model => model.Escala.EscalaId)
                @Html.HiddenFor(model => model.PostoDeServico.PostoDeServicoId)
                <p class="pull-left">
                    <input type="submit" value="Apagar" class="btn btn-danger btn-large" />
                </p>
                <br/>
                <br/>
                <br/>
                <p class="bottom">
                    <a href="~/PostosDeServicos/VisualizarEscala/@Model.Escala.EscalaId">Voltar</a>
                </p>
            </div>
        </div>



    }


</div>





@section Scripts {


    <script src="http://ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js" type="text/javascript"></script>

    <script src="~/Assets/plugins/fancybox/lib/jquery.mousewheel-3.0.6.pack.js"></script>
    <script src="~/Assets/plugins/fancybox/jquery.fancybox.js"></script>
    <script src="~/Assets/plugins/fancybox/helpers/jquery.fancybox-buttons.js"></script>

    <script src="~/Assets/js/bootstrap-tooltip.js"></script>
    <script src="~/Assets/themes/metro/js/footable.js"></script>
    <script type="text/javascript">
        $(function () {
            $("[data-toggle='tooltip']").tooltip();
            $('.footable').footable({
                breakpoints: {
                    phone: 400,
                    tablet: 800
                }
            });
        });


    </script>



    <script type="text/javascript">

    </script>




}