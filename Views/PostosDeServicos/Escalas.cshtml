@model Models.PostoDeServicoEscalaView

@{
    var user = new BLL.Usuarios();
    ViewBag.Title = "Postos de Serviços";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";

    var PostosDeServicos_GerarEscalaCustom = user.ControleAcesso("GerarEscalaCustom", "PostosDeServicos");
    var PostosDeServicos_VisualizarEscala = user.ControleAcesso("VisualizarEscala", "PostosDeServicos");
    var PostosDeServicos_DeletarEscala = user.ControleAcesso("DeletarEscala", "PostosDeServicos");
}

@section Breadcrumb{
    <li>@Html.ActionLink("Configurações", "Configuracoes", "Principal")</li>
    <li>@Html.ActionLink("Posto de Serviço", "Index", new { id = 0 })</li>
    <li>@Html.ActionLink("Alterar Posto de Serviço", "Criar", new { id = Model.DadosPostoDeServico.PostoDeServicoId })</li>
}


<div class="content ">


    <div class="row">
        <div class="col-lg-12">

            

            <div class="hpanel">
                @Html.Partial("~/Views/PostosDeServicos/_Navtabs.cshtml", Model.DadosPostoDeServico)
                <div class="tab-content">
                    <div id="tab-1" class="tab-pane active">
                        <div class="panel-body">
                            <!-- conteuod aqui -->

                            @if (PostosDeServicos_GerarEscalaCustom)
                            {
                                <a href="~/PostosDeServicos/GerarEscalaCustom/@Model.DadosPostoDeServico.PostoDeServicoId" class="btn btn-primary">+ Gerar nova Escala</a>    
                            }


                            <div class="table-responsive">
                                <table cellpadding="1" cellspacing="1" class="table" id="table_produtos">
                                    <thead>
                                        <tr>
                                            <th>
                                                @Html.DisplayNameFor(model => model.ListaEscalas.Items.ElementAt(0).EscalaId)
                                            </th>
                                            <th data-hide="phone,tablet">Período
                                            </th>
                                            <th data-hide="phone,tablet">
                                                @Html.DisplayNameFor(model => model.ListaEscalas.Items.ElementAt(0).Situacao)
                                            </th>
                                            <th data-hide="phone,tablet">
                                                @Html.DisplayNameFor(model => model.ListaEscalas.Items.ElementAt(0).RegDtInicio)
                                            </th>
                                            <th data-hide="phone,tablet"></th>
                                        </tr>
                                    </thead>
                                    <tbody>

                                        @foreach (var item in Model.ListaEscalas.Items)
                                        {
                                            <tr>

                                                <td>
                                                    @Html.DisplayFor(modelItem => item.EscalaId)
                                                </td>
                                                <td nowrap data-hide="phone,tablet" style="display: table-cell">
                                                    @Html.DisplayFor(modelItem => item.DataDe) até @Html.DisplayFor(modelItem => item.DataAte)
                                                </td>
                                                <td nowrap data-hide="phone,tablet" style="display: table-cell">
                                                    @switch (item.Situacao)
                                                    {
                                                        case "P":
                                                        <p>Planejamento</p>
                                                            break;
                                                        case "E":
                                                        <p>Em aprovação</p>
                                                            break;
                                                        case "A":
                                                        <p>Aprovada</p>
                                                            break;
                                                        default:
                                                        <p>-</p>
                                                            break;
                                                    }

                                                </td>
                                                <td nowrap data-hide="phone,tablet" style="display: table-cell">
                                                    @Html.DisplayFor(modelItem => item.RegDtInicio)
                                                </td>
                                                <td nowrap data-hide="phone,tablet" style="display: table-cell">
                                                    @if (PostosDeServicos_VisualizarEscala)
                                                    {
                                                        @Html.ActionLink("Visualizar", "VisualizarEscala", new { id = item.EscalaId }, new { @class = "btn btn-outline btn-primary btn-xs" }) 
                                                        @:&nbsp;    
                                    }

                                                    @if (PostosDeServicos_DeletarEscala)
                                                    {
                                                        @Html.ActionLink("Excluir", "DeletarEscala", new { id = item.EscalaId }, new { @class = "btn btn-outline btn-danger btn-xs" })    
                                                        @:&nbsp;
                                    }


                                                </td>
                                            </tr>
                                        }

                                    </tbody>



                                </table>
                            </div>
                            @Html.FortunaPaginacao(Convert.ToInt16(Model.ListaEscalas.TotalPages))
                            <!-- ./conteudo aqui -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>








</div>














@section Scripts {


}