            </div>
            <div class="span5">
                <label>Serviço</label>
                @Html.DropDownList("PostoDeServicoPessoa.ServicoId", (SelectList)ViewBag.ddlServicos, "--Selecione--", new { @class = "chosen-select span12" })
            </div>
