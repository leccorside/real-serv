@model Models.PostoDeServicoPessoaView
@{
    ViewBag.Title = "PessoasAlterar";
    Layout = "~/Views/Shared/_LayoutBranco.cshtml";
}

<div class="cwell">


    @using (Html.BeginForm("PessoasAlterar", "PostosDeServicos", FormMethod.Post))
    {
        @Html.ValidationSummary(true)

        @Html.HiddenFor(model => model.DadosPostoDeServico.PostoDeServicoId);
        
        @Html.Hidden("PostoDeServicoPessoa.PostoDeServicoId", Model.DadosPostoDeServico.PostoDeServicoId);
        
        @Html.HiddenFor(model => model.PostoDeServicoPessoa.PostoDeServicoPessoaId);
  
        <div class="row-fluid">
            <div class="span5">
