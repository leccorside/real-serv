        //            var link = $(this).prop('href') + "?dt1=" + data1 + "&dt2=" + data2;
        //            $(this).prop('href', link);
        //        });
        //    }
        //})

        
        $("p").click(function () {
            var data1 = $("#dataInicio").val();
            var data2 = $("#dataFim").val();
            if (data1 != "dd/mm/aaaa" && data1 != "undefined" && data1 != "" && data2 != "dd/mm/aaaa" && data2 != "undefined" && data2 != "") {

                $('.link_date').each(function (index, item) {
                    var link = $(this).prop('href') + "?dt1=" + data1 + "&dt2=" + data2;
                    $(this).prop('href', link);
                });
            }
        });


    </script>
    


