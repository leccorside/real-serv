<div class="span6" id="painel_mensal"><label>Informe o dia do mês</label>
        @Html.TextBoxFor(model => model.RecorrenciaObj.Dia, new { @class = "input-mini form-control"})
                @Html.ValidationMessageFor(model => model.RecorrenciaObj.Dia)</div>

    </div>



<div class="row-fluid" id="painel_semanal">

    <div class="span12">

    <table class="table table-bordered">

        <tbody>
            <td><label class="checkbox">@Html.CheckBoxFor(model => model.RecorrenciaObj.Domingo) Domingo</label></td>
            <td><label class="checkbox">@Html.CheckBoxFor(model => model.RecorrenciaObj.Segunda) Segunda</label></td>
            <td><label class="checkbox">@Html.CheckBoxFor(model => model.RecorrenciaObj.Terca) Terça</label></td>
            <td><label class="checkbox">@Html.CheckBoxFor(model => model.RecorrenciaObj.Quarta) Quarta</label></td>
            <td><label class="checkbox">@Html.CheckBoxFor(model => model.RecorrenciaObj.Quinta) Quinta</label></td>
            <td><label class="checkbox">@Html.CheckBoxFor(model => model.RecorrenciaObj.Sexta) Sexta</label></td>
            <td><label class="checkbox">@Html.CheckBoxFor(model => model.RecorrenciaObj.Sabado) Sábado</label></td>
        </tbody>

    </table>

        </div>

</div>
  

    <script>

        function TipoRecorrencia(jtipo) {


            switch (jtipo) {
                case "Diaria":
                    $("#painel_semanal").hide();
                    $("#painel_mensal").hide();
                    break;
                case "Semanal":
                    $("#painel_semanal").show();
                    $("#painel_mensal").hide();
                    break;
                case "Mensal":
                    $("#painel_semanal").hide();
                    $("#painel_mensal").show();
                    break;
                default:


            }


        }






    </script>

