@model Models.Lancamento

<div class="row-fluid">
<div class="span3">
    <label>Tipo</label>
            @Html.DropDownListFor(m => m.RecorrenciaObj.Tipo, new[] {
                           new SelectListItem() {Text = "Diário", Value = Models.Recorrencia.ETipo.Diaria.ToString()},
                           new SelectListItem() {Text = "Semanal", Value = Models.Recorrencia.ETipo.Semanal.ToString()},
                           new SelectListItem() {Text = "Mensal", Value = Models.Recorrencia.ETipo.Mensal.ToString()},
                           }, null, new { onchange = "TipoRecorrencia(this.value);", @class="form-control" })

</div>

<div class="span3">
    <label>Ocorrências</label>
        @Html.TextBoxFor(model => model.RecorrenciaObj.Ocorrencias, new { @class = "input-mini form-control"})
                @Html.ValidationMessageFor(model => model.RecorrenciaObj.Ocorrencias)
</div>

