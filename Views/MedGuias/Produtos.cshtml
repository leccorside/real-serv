@section Scripts {
    @Scripts.Render("~/bundles/fancybox/js")
    @Scripts.Render("~/bundles/select2/js")

    <script>

        $('.chosen-select').select2();
        $(".fancybox").fancybox({ fitToView: false, width: '80%', autoSize: true });
        $(".fancybox_full").fancybox({
            fitToView: false,
            width: '100%',
            autoSize: false,
            closeClick: false,
            openEffect: 'none',
            closeEffect: 'none'
        });


        $(".fancybox_recarrega").fancybox({
            fitToView: false,
            width: '98%',
            autoSize: false,
            padding: 0,
            helpers: {
                overlay: {
                    locked: true
                }
            },
            beforeClose: function () {
                RecarregaPagina();
            },
        });


        function RecarregaPagina() {
            window.location.reload(true);
        }


        //$(".data tr").click(function () {
        //    console.log('clicou');
        //    $(this).toggleClass("highlight");
        //});

        $(".marcar").click(function () {
            var id = $(this).attr("data-id");
            var classe = $(this).attr("class");
            if (classe.indexOf('highlight') >= 0) {
                //console.log('tem que apagar');
                FiltroProdutoDelPorValor(id);
            }

            $(this).toggleClass("highlight");
        });



        $(document).ready(function () {

               @if (!Model.MedGuia.LancamentoExamesParticular)
               {
		        @:$('#MedGuiaItem_ConvenioMedProdutoId').select2('open');
	            }
        });







        $("#PacienteCpf").mask("999.999.999-99");

        $('.moeda').mask('000000000000000,00', { reverse: true });
        $(".select-all").click(function () {
            $(this).select();
        });


        $("#PacienteCpf").focusout(function () {
            $.getJSON('@Url.Content("~/Pessoas/GetPessoas/")', { tipo: 'c', stype: 'Cpf', key: $(this).val() }, function (data) {
                if (data.Objeto[0] != null) {
                    $("#PacienteNome").prop("readOnly", false);
                    $("#PacienteNome").val(data.Objeto[0].Nome);
                    $("#PacienteId").val(data.Objeto[0].PessoaID);
                    $("#PacienteNome").prop("readOnly", true);
                    $("#btnerrado").attr("style", "display:show");
                } else {
                    $("#btnerrado").attr("style", "display:none");
                    $("#PacienteNome").prop("readOnly", false);
                    $("#PacienteNome").val('');
                    $("#PacienteId").val('0');
                    $("#PacienteNome").focus();
                }
            });
        });

        $("#btnerrado").click(function () {
            $("#btnerrado").attr("style", "display:none");
            $("#PacienteNome").prop("readOnly", false);
            $("#PacienteNome").val('');
            $("#PacienteId").val('0');
            $("#PacienteNome").focus();
        });


        // controle marcacao


        function FiltroProdutoSet(type, valor, descricao) {

            jQuery.ajax({
                type: 'POST',
                url: '/ApiIntegracao/FiltroProdutoSet/',
                data: "type=" + type + "&valor=" + valor + "&descricao=" + descricao,
                success: function (data) {
                    //console.log(data);
                }
            });
            return false;
        }


        function FiltroProdutoDel(guid) {

            jQuery.ajax({
                type: 'POST',
                url: '/ApiIntegracao/FiltroProdutoDel/',
                data: "guid=" + guid,
                success: function (data) {
                    //console.log(data);
                }
            });
            return false;
        }

        function FiltroProdutoDelPorValor(valor) {

            jQuery.ajax({
                type: 'POST',
                url: '/ApiIntegracao/FiltroProdutoDelPorValor/',
                data: "valor=" + valor,
                success: function (data) {
                    //console.log(data);
                }
            });
            return false;
        }

        function FiltroProdutoClear() {

            jQuery.ajax({
                type: 'POST',
                url: '/ApiIntegracao/FiltroProdutoClear/',
                data: "",
                success: function (data) {
                    //console.log(data);
                }
            });
            return false;
        }


        jQuery.ajax({
            type: 'POST',
            url: '/ApiIntegracao/GetFiltroProduto/',
            data: "",
            success: function (data) {
                $.each(data, function (index) {
                    var id = data[index].valor;
                    $("#" + id).toggleClass("highlight");
                });

            }
        });

    </script>

    <script>
        $(".normal").click(function () {
            $("#div_normal").toggleClass("highlight");
            $("#div_particular").toggleClass("highlight");

            abreFecha("#div_particular");

        });


        $(".particular").click(function () {
            abreFecha("#div_normal");

        });

        // Function for collapse hpanel
        function abreFecha(div_id) {
            event.preventDefault();
            var hpanel = $(div_id).closest('div.hpanel');
            var icon = $(div_id).find('i:first');
            var body = hpanel.find('div.panel-body');
            var footer = hpanel.find('div.panel-footer');
            body.slideToggle(300);
            footer.slideToggle(200);

            // Toggle icon from up to down
            icon.toggleClass('fa-chevron-up').toggleClass('fa-chevron-down');
            hpanel.toggleClass('').toggleClass('panel-collapse');
            setTimeout(function () {
                hpanel.resize();
                hpanel.find('[id^=map-]').resize();
            }, 50);
        };


    </script>

    <script>
        $(function () {

            //$("#my-form").submit(function () {

