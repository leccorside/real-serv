            $("#PacienteCelular").val('');
            $("#PacienteTelefone").val('');
            $("#MedCarteiraConvenio").val('');
            $("#MedCarteiraValidade").val('');
            $("#MedCarteiraTitular").val('');

            $("#ConvenioId").val('').trigger('chosen:updated');
            carregaPlanos(0, 0);
            $("#ConvenioPlanoValor").val('');

            //dados banco
            $("#BancoCod").val('');
            $("#BancoNome").val('');
            $("#BancoAgencia").val('');
            $("#BancoConta").val('');

            //outros dados
            $("#PacienteDataInicio").val('');
            $("#PacienteDataNascimento").val('');
            $("#PacienteSexo").val('');
            $("#PacienteRG").val('');
            $("#PacienteEstadoCivil").val('');
            $("#PacienteEmail").val('');
            $("#PacienteCep").val('');
            $("#PacienteEndereco").val('');
            $("#PacienteNumero").val('');
            $("#PacienteComplemento").val('');
            $("#PacienteBairro").val('');
            $("#PacienteCidade").val('');
            $("#PacienteEstado").val('');
            $("#PacientePais").val('');
            $("#div_ExibirCheckDependente").slideUp();
            $("#PacienteResponsavel").prop('checked', false);

            verifica($("#PacienteResponsavel").is(':checked'));

        }

        $('#ConvenioId').on('change', function () {
            carregaPlanos($(this).val(), null);
        });


        function carregaPlanos(ConvenioId, ConvenioPlanoId) {
            $.getJSON("@Url.Content("~/ApiIntegracao/GetConveniosPlanos/")", { id: ConvenioId, FilialId: "@BLL.Usuarios.GetFilialId()" }, function (result) {
                data = $.map(result.ListConvenioPlano, function (item, a) {
                    var select = (ConvenioPlanoId == item.ConvenioPlanoId) ? " selected='selected' " : "";
                    return "<option value=" + item.ConvenioPlanoId + " " + select + ">" + item.ConvenioPlanoNome + "</option>";
                });
                $("#ConvenioPlanoId").empty();
                $('#ConvenioPlanoId').append($('<option>', {
                    value: 0,
                    text: '--Selecione--'
                }));
                $("#ConvenioPlanoId").append(data.join(""));

                $("#ConvenioPlanoId").val(ConvenioPlanoId).trigger('chosen:updated');
                $("#ConvenioPlanoId").val(ConvenioPlanoId).trigger('change.select2');

            });
        }

        function carregaDependentes(PessoaId, PessoaDependenteId) {
            $.getJSON("@Url.Content("~/ApiIntegracao/GetDependentes/")", { id: PessoaId }, function (result) {
                data = $.map(result, function (item, a) {
                    var select = (PessoaDependenteId == item.PessoaDependenteId) ? " selected='selected' " : "";
                    return "<option value=" + item.PessoaDependenteId + " " + select + ">" + item.PessoaDependenteNome + "</option>";
                });
                $("#PessoaDependenteId").empty();
                $('#PessoaDependenteId').append($('<option>', {
                    value: 0,
                    text: '--Selecione--'
                }));
                $("#PessoaDependenteId").append(data.join(""));

                $("#PessoaDependenteId").trigger('chosen:updated');
                $("#PessoaDependenteId").trigger('change.select2');

            });
        }



         @if (Model.RegStatus == "P")
         {
		    @:$("#MedGuiaData").focus();
	     }
         else
         {
             @:$("#MedCarteiraTitular").focus();
	     }

        //inicializador
        carregaPlanos('@Model.ConvenioId', '@Model.ConvenioPlanoId');

        

    </script>
    <script type="text/javascript">
        $(document).ready(function () {
            $('.chosen-select').select2();
            $('.datepicker').datepicker({ language: 'pt-BR', format: 'dd/mm/yyyy', todayHighlight: true, todayBtn: true });
            $('.moeda').mask('000000000000000,00', { reverse: true });

            $(".datepicker_year").datepicker({
                startView: 2,
                language: 'pt-BR', format: 'dd/mm/yyyy',
                
            });

        });
    </script>

    <script>

        verifica($("#PacienteResponsavel").is(':checked'));

        //recarrega o combo de depentens
        if ($("#PacienteId").val() > 0) {
            $("#div_ExibirCheckDependente").slideDown();
            carregaDependentes($("#PacienteId").val(), "@Model.PessoaDependenteId")
        }

        function verifica(checado) {
            if (checado) {
                $("#div_PacienteResponsavel").slideDown();
                $("#lblNomePaciente").text("Responsável");
            } else {
                $("#div_PacienteResponsavel").slideUp();
                $("#lblNomePaciente").text("Nome do Paciente");
            }
        }

        $('#PacienteResponsavel').change(function () {
            verifica(this.checked);
        });

        $('#copyDadosPessoa').change(function () {
            console.log(this.checked);
            if (this.checked) {
                $("#MedCarteiraTitularCpf").val($("#PacienteCpf").val());
                $("#MedCarteiraTitularNome").val($("#PacienteNome").val());
                $("#MedCarteiraTitularDataNascimento").val($("#PacienteDataNascimento").val());
            }
        });
    </script>

