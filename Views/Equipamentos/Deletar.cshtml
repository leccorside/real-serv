@model Models.Equipamento

@{
    ViewBag.Title = "Excluíndo Equipamentos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


@section Breadcrumb{

    <li class="active"><span class="divider">/</span>    @Html.ActionLink("Equipamentos", "Index")</li>
}


<div class="alert">
    
    <h2>Atencão!</h2>
    Você tem certeza que deseja apagar esse registro?
</div>

<table class="table table-bordered table-striped table-highlight">
    <thead>
        <tr>

            <th>Nome</th>
            <th>Medida entre trilhos</th>
            <th>Torre (m)</th>
            <th>N. Martelo Principal</th>
            <th>Peso Martelo</th>
            <th>Guincho</th>
            <th nowrap>
                @Html.DisplayNameFor(model => model.RegDtInicio)
            </th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td width="100%">
                    @Model.EquipamentoNome
                </td>
                <td nowrap>@string.Format("{0:n2}", Model.EquipamentoMedidaTrilhos) m</td>
                <td nowrap>@string.Format("{0:n2}", Model.EquipamentoTorre) m</td>
                <td nowrap>@Model.EquipamentoMarteloNumero</td>
                <td nowrap>@string.Format("{0:n2}", Model.EquipamentoMarteloPeso) kg</td>
                <td nowrap>@string.Format("{0:n2}", Model.EquipamentoGuincho) kg</td>
                <td nowrap>
                    @Model.RegDtInicio
                </td>
        </tr>



    </tbody>
</table>



@using (Html.BeginForm())
{
    
    @Html.HiddenFor(model => model.EquipamentoId)

    <p class="pull-right">
        <input type="submit" value="Apagar" class="btn btn-large btn-danger" />
    </p>

    <p class="pull-left">
        @Html.ActionLink("Voltar", "Index")
    </p>
}


