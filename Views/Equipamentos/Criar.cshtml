@model Models.Equipamento

@{
    
    
    var acao = "Cadastrar";
    if (Model.EquipamentoId > 0)
    {
        acao = "Alterar";
    }



    ViewBag.Title = acao + " " + "Equipamentos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section Breadcrumb{

    <li class="active"><span class="divider">/</span>    @Html.ActionLink("Equipamentos", "Index")</li>

}




@using (Html.BeginForm())
{
    @Html.ValidationSummary(true)
    
    if (Model.EquipamentoId > 0)
    {
    @Html.Hidden("EquipamentoId", Model.EquipamentoId);
    }
    <legend>Dados do Equipamento</legend>
    
    <div class="row-fluid">
        <div class="span6">
            <div class="editor-label">
                @Html.LabelFor(model => model.EquipamentoNome)
            </div>
            <div class="editor-field">
                @Html.TextBoxFor(model => model.EquipamentoNome, new { @class = "span12" })
                @*@Html.ValidationMessageFor(model => model.EquipamentoNome)*@
            </div>
        </div>

        <div class="span6">
            <div class="editor-label ">
                @Html.LabelFor(model => model.EquipamentoDescricao)
            </div>
            <div class="editor-field ">
                @Html.TextBoxFor(model => model.EquipamentoDescricao, new { @class = "span12" })
                @*@Html.ValidationMessageFor(model => model.EquipamentoDescricao)*@
            </div>
        </div>
    </div>
    
    <div class="row-fluid">
        <div class="span3">
            <div class="editor-label">
                <label>Medida entre trilhos</label>
            </div>
            <div class="editor-field">
                @Html.TextBox("EquipamentoMedidaTrilhos", string.Format("{0:n2}", Model.EquipamentoMedidaTrilhos), new { @class = "money" })
                @*@Html.ValidationMessageFor(model => model.EquipamentoMedidaTrilhos)*@
            </div>
        </div>
        <div class="span3">
            <div class="editor-label">
                Torre (m)
            </div>
            <div class="editor-field">
                @Html.TextBox("EquipamentoTorre", string.Format("{0:n2}", Model.EquipamentoTorre), new { @class = "money" })
                @*@Html.ValidationMessageFor(model => model.EquipamentoTorre)*@
            </div>
        </div>
        <div class="span3">
            <div class="editor-label">
                <label>N. Martelo Principal</label>
            </div>
            <div class="editor-field">
                @Html.TextBoxFor(m => m.EquipamentoMarteloNumero, new { @class = "number span12" })
                @*@Html.ValidationMessageFor(model => model.EquipamentoMarteloNumero)*@
            </div>
        </div>
        <div class="span3">
            <div class="editor-label">
                <label>Peso Martelo (kg)</label>
            </div>
            <div class="editor-field">
                @Html.TextBox("EquipamentoMarteloPeso", string.Format("{0:n}", Model.EquipamentoMarteloPeso).Replace(".",""), new { @class = "decimal" })
                @*@Html.ValidationMessageFor(model => model.EquipamentoMarteloPeso)*@
            </div>
        </div>
    </div>
    <div class="row-fluid">
        <div class="span3">
            <div class="editor-label">
                <label>Guincho (kg)</label>
            </div>
            <div class="editor-field">
                @Html.TextBox("EquipamentoGuincho", string.Format("{0:n}", Model.EquipamentoGuincho).Replace(".",""), new { @class = "decimal" })
                @*@Html.ValidationMessageFor(model => model.EquipamentoGuincho)*@
            </div>
        </div>
        <div class="span9">
            <div class="editor-label">
                @Html.LabelFor(model => model.EquipamentoObservacao)
            </div>
            <div class="editor-field">
                @Html.TextBoxFor(model => model.EquipamentoObservacao, new { @class = "span12" })
                @*@Html.ValidationMessageFor(model => model.EquipamentoObservacao)*@
            </div>
        </div>
    </div>
    
    
    
    <div class="row-fluid">
        
    </div>
    
    
    
    
    <div class="form-actions">
        <input type="submit" value="@acao" class="btn btn-primary  btn-large"  TabIndex=10 />
    </div>
}




<div>
    @Html.ActionLink("Voltar", "Index")
</div>


@section Scripts {



}
