@model Models.TipoAnexo



@{
    

    
    var acao = "Cadastrar";
    if (Model.TipoAnexoID > 0)
    {
        acao = "Alterar";
    }


    ViewBag.Title = acao + " tipo de anexo";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";     
}





@section Breadcrumb{
    <li class="active"><span class="divider">/</span> @Html.ActionLink("Configurações", "Configuracoes", "Principal")</li>
    <li class="active"><span class="divider">/</span> @Html.ActionLink("Tipos de Anexos", "Index", new { id = 0 })</li>
}


<div class="cwell">
    @using (Html.BeginForm("Criar", "TiposAnexos", FormMethod.Post, new { @class = "form-horizontal" }))
    {
        @Html.ValidationSummary(true)

        if (Model.TipoAnexoID > 0)
        {
        @Html.Hidden("TipoAnexoID", Model.TipoAnexoID);
                                                      acao = "Alterar";
        }
       
            
     
        <div class="control-group">
            @Html.LabelFor(model => model.DescricaoAnexo, new { @class = "control-label" })
            <div class="controls">
                @Html.EditorFor(model => model.DescricaoAnexo)
                @Html.ValidationMessageFor(model => model.DescricaoAnexo)
            </div>
        </div>
        
    
      

        <div class="form-actions">


            <input type="submit" value="@acao" class="btn btn-primary  btn-large"  TabIndex=10 />

        </div>
            
    }
    <div>
        @Html.ActionLink("Voltar", "Index")
    </div>
</div>





@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
