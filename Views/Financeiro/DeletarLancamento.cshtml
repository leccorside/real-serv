@model Models.Lancamento


@{
    var vtipo = (string)Model.LancamentoTipo;
    var vname = "";
    switch (vtipo)
    {
        case "D":
            vname = "Despesa";
            break;  // Always break each case
        case "R":
            vname = "Receita";
            break;
        case "T":
            vname = "Transferência";
            break;
        default:
            vname = "Indefinido";
            break;
    }
}

@{
    ViewBag.Title = "Excluir Lançamento de " + vname;
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";  
}




@section Breadcrumb{

  <li class="active"><span class="divider">/</span>  @Html.ActionLink("Financeiro", "Index", "Financeiro")</li>
   <li class="active"><span class="divider">/</span> @Html.ActionLink("Edição de Lançamento de " + vname, "CriarLancamento", new { id = Model.LancamentoId, tipo = Model.LancamentoTipo })</li>
}



<div class="alert">
    <button type="button" class="close" data-dismiss="alert">&times;</button>
    <h2>Atencão!</h2>
    Você tem certeza que deseja excluir o Lançamento?
</div>


<div class="cwell">
        <fieldset>

            <legend>Lançamento</legend>
            <div class="row-fluid">

                <div class="span3">
                    <div class="display-label">
                        @Html.DisplayNameFor(model => model.LancamentoTipo)
                    </div>
                    <div class="display-field">
                        @Html.DisplayFor(model => model.LancamentoTipo)
                    </div>

                </div>
                <div class="span3">

                    <div class="display-label">
                        @Html.DisplayNameFor(model => model.Descricao)
                    </div>
                    <div class="display-field">
                        @Html.DisplayFor(model => model.Descricao)
                    </div>

                </div>
                <div class="span3">
                    <div class="display-label">
                        @Html.DisplayNameFor(model => model.Valor)
                    </div>
                    <div class="display-field">
                        @Html.DisplayFor(model => model.Valor)
                    </div>

                </div>
                <div class="span3">

                    <div class="display-label">
                        @Html.DisplayNameFor(model => model.DataVencimento)
                    </div>
                    <div class="display-field">
                        @Html.DisplayFor(model => model.DataVencimento)
                    </div>

                </div>
            </div>



        </fieldset>
        <br />


     @using (Html.BeginForm())
        {
            
          
            
            <div class="row-fluid">
                <div class="span12">
                    @Html.HiddenFor(model => model.LancamentoId)
                    @Html.HiddenFor(model => model.RecorrenciaGUID)
                    <p class="pull-right">
                        <input type="submit" value="Apagar" class="btn btn-large btn-danger" />
                    </p>

                    @if (Model.RecorrenciaGUID != null)
                    {
                    <p class="pull-left">
                        Ooops! Esse lançamento pertence a um cadastro em lote (recorrência). O que você deseja?<br />
                        <label>@Html.RadioButtonFor(m=>m.ExcluirLote, false, true) - Apagar somente essa ocorrência</label>
                        <label>@Html.RadioButtonFor(m=>m.ExcluirLote, true) - Apagar todas</label>
                    </p>    
                    }
                    

                </div>
            </div>    
            
            <div class="row-fluid">
                <div class="span12">
                    @Html.ActionLink("Voltar", "CriarLancamento", new { id = Model.LancamentoId, tipo = Model.LancamentoTipo })
                </div>

            </div>
          
        }



    </div>



