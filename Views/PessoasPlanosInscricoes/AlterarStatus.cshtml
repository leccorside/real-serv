@model Models.PessoaPlanoInscricaoView
@{
    
    ViewBag.Title = "Inscrição";
    Layout = "~/Views/Shared/_FortunaLayoutModal.cshtml";


    var MyStatus = Model.PessoaPlanoInscricao.PessoaPlanoPagtoStatus.ToEnum<BLL.PessoasPlanosInscricoes.EnumSituacaoPlano>();
}

<div class="content animate-panel">
    <div class="row">
        <div class="col-lg-12" style="">



            <div class="hpanel">
                <div class="panel-heading">
                    <div class="panel-tools">
                        <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                    </div>
                    Alteração de Dados de Pagamento
                </div>
                <div class="panel-body">
                    <!-- dados aqui-->
                    <div class="row">
                        <div class="col-lg-12">

                            @using (Html.BeginForm("AlterarStatus", "PessoasPlanosInscricoes", FormMethod.Post, new { enctype = "multipart/form-data", @id = "form_principal" }))
                            {
                                @Html.HiddenFor(x => x.PessoaPlanoInscricao.PessoaPlanoInscricaoId)
                                @Html.HiddenFor(x => x.PessoaPlanoInscricao.PessoaPlanoGUID)
                                             
                                <div class="row">

                                    
                                    <div class="col-lg-8 col-md-8 col-sm-8">
                                        <label>Plano</label>
                                    @Html.DropDownListFor(model => model.PessoaPlanoInscricao.PessoaPlanoId, (SelectList)ViewBag.ddlPessoasPlanos, null, new { @class = "chosen-select form-control" })    
                                    </div>


                                    <div class="col-lg-4 col-md-4 col-sm-4">
                                        <label>Status</label>
                                        @Html.DropDownListStatusPagto("PessoaPlanoInscricao.PessoaPlanoInscricaoStatusId", Convert.ToInt16(MyStatus).ToString(), true, " form-control")
                                    </div>
                                    </div><br />
                                <div class="row">
                                    <div class="col-lg-2 col-md-2 col-sm-2">
                                        <label>Dt. Inscrição</label>
                                        @Html.TextBox("PessoaPlanoInscricao.RegDtInicio", String.Format("{0:dd/MM/yyyy}", Model.PessoaPlanoInscricao.RegDtInicio), new { @class = "datepicker maskdate form-control", value = DateTime.Now })

                                    </div>
                                    <div class="col-lg-2 col-md-2 col-sm-2">
                                        <label>Dt. Pagamento</label>
                                        @Html.TextBox("PessoaPlanoInscricao.PessoaPlanoInscricaoDtPagto", String.Format("{0:dd/MM/yyyy}", Model.PessoaPlanoInscricao.PessoaPlanoInscricaoDtPagto), new { @class = "datepicker maskdate form-control", value = DateTime.Now })
                                    </div>
                                    
                                    <div class="col-lg-4 col-md-4 col-sm-4">
                                        <label>Tipo Pagamento</label>
                                        @Html.DropDownListPessoasPlanosInscricoesTiposPagtos("PessoaPlanoInscricao.GatewayTipoPagamento", Model.PessoaPlanoInscricao.GatewayTipoPagamento, true, " form-control ")
                                    </div>

                                    <div class="col-lg-4 col-md-4 col-sm-4">
                                        <label>Valor</label>
                                        <div class="input-group m-b">
                                            <span class="input-group-addon">R$</span>
                                            @Html.TextBox("PessoaPlanoInscricao.PessoaPlanoVlrTotal", string.Format("{0:F2}", Model.PessoaPlanoInscricao.PessoaPlanoVlrTotal), new { @class = "moeda form-control select-all" })
                                        </div>
                                    </div>

                                    

                                    

                                    <div class="col-lg-12 col-md-12 col-sm-12">
                                        <label>Observação</label>
                                        @Html.TextBoxFor(x => x.PessoaPlanoInscricao.GatewayDados, new { @class = "form-control" })
                                    </div>


                                </div>
                                <br />
                                <div class="row">
                                    <div class="col-lg-12">
                                        <button type="submit" class="btn btn-primary">
                                            Alterar
                                        </button>
                                    </div>
                                </div>
   
                            }
                        </div>
                    </div>
                    <br />
                    <div class="row">
                        <div class="col-lg-12">
                            @Html.Partial("~/Views/PessoasPlanosInscricoes/_detalheInscricao.cshtml", Model.PessoaPlanoInscricao)
                        </div>
                    </div>

                    <!-- ./ dados aqui-->
                </div>

            </div>
        </div>
    </div>

</div>







@section Styles{
    @Styles.Render("~/bundles/select2/css")
    @Styles.Render("~/bundles/datepicker/css")
    @Styles.Render("~/bundles/fancybox/css")
    <style>
        .permiteedicao
        {
            display: none;
        }

        .form-group-mini .checkbox
        {
            margin-top: -10px !important;
            margin-bottom: 15px !important;
        }
    </style>

}


@section Scripts {
    @Scripts.Render("~/bundles/fancybox/js")
    @Scripts.Render("~/bundles/select2/js")
    @Scripts.Render("~/bundles/datepicker/js")
    @Scripts.Render("~/bundles/mask/js")
    @Scripts.Render("~/bundles/jquery-cep/js")



    <script>


        $("#PessoaPlanoInscricao_PessoaPlanoInscricaoDtPagto").mask("99/99/9999");


    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('.chosen-select').select2();
            $('.datepicker').datepicker({ language: 'pt-BR', format: 'dd/mm/yyyy', todayHighlight: true, todayBtn: true });
            $('.moeda').mask('000000000000000,00', { reverse: true });
        });



        $(".select-all").click(function () {
            $(this).select();
        });
    </script>


}

