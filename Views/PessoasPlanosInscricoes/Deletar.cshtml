@model Models.PessoaPlanoInscricaoView

@{
    ViewBag.Title = "Excluíndo Inscrição";



    Layout = "~/Views/Shared/_FortunaLayout.cshtml";
    
}


@section Breadcrumb{

}



<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">
            <div class="alert alert-warning">
                <i class="fa fa-exclamation-triangle" aria-hidden="true"></i><strong>Atenção</strong> Você tem certeza que deseja apagar esse registro?
            </div>

            <div class="hpanel">
                <div class="panel-body">
                    <!-- conteudo aqui -->
                    <div class="row">
                        <div class="col-lg-12">
                            @Html.Partial("~/Views/PessoasPlanosInscricoes/_detalheInscricao.cshtml", Model.PessoaPlanoInscricao)

                        </div>


                    </div>
                    <!-- ./conteudo aqui -->
                </div>
                <div class="panel-footer">

                    @using (Html.BeginForm())
                    {
                        <div class="row">
                            <div class="col-lg-12">
                                @Html.HiddenFor(model => model.PessoaPlanoInscricao.PessoaPlanoInscricaoId)
                                
                                <input type="submit" value="Apagar" class="btn btn-danger pull-right" />

                                @Html.ActionLink("Voltar", "Index",  new { @class = "btn btn-outline btn-primary " })


                            </div>
                        </div>    
                    }

                </div>
            </div>

        </div>
    </div>
</div>







