@model Models.Notificacao

@{
    ViewBag.Title = "Excluíndo Notificacoes";


    if (Model.Modal)
    {
        Layout = "~/Views/Shared/_FortunaLayoutModal.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_FortunaLayout.cshtml";
    }
    
}


@section Breadcrumb{
    <li class="active">@Html.ActionLink("Configurações", "Configuracoes", "Principal")</li>

    <li class="active">@Html.ActionLink("Notificacoes", "Index", new { id = 0 })</li>
}



<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">
            <div class="alert alert-warning">
                <i class="fa fa-exclamation-triangle" aria-hidden="true"></i><strong>Atenção</strong> Você tem certeza que deseja apagar esse registro?
            </div>

            <div class="hpanel">
                <div class="panel-body">
                    <!-- conteudo aqui -->
                    <div class="row">
                        <div class="col-lg-1 col-md-1 col-sm-1">
                            <div class="display-label">
                                <label>#</label>
                            </div>
                            <div class="display-field">
                                @Html.DisplayFor(model => model.NotificacaoId)
                            </div>

                        </div>
                        <div class="col-lg-3 col-md-3 col-sm-3">
                            <div class="display-label">
                                @Html.DisplayNameFor(model => model.NotificacaoNome)
                            </div>
                            <div class="display-field">
                                @Html.DisplayFor(model => model.NotificacaoNome)
                            </div>
                        </div>
                        <div class="col-lg-8 col-md-8 col-sm-8">
                            <div class="display-label">
                                @Html.DisplayNameFor(model => model.NotificacaoDescricao)
                            </div>
                            <div class="display-field">
                                @Html.DisplayFor(model => model.NotificacaoDescricao)
                            </div>
                        </div>



                    </div>
                    <!-- ./conteudo aqui -->
                </div>
                <div class="panel-footer">
                    @using (Html.BeginForm())
                    {
                        <div class="row">
                            <div class="col-lg-12">
                                @Html.HiddenFor(model => model.NotificacaoId)
                                @Html.HiddenFor(model => model.Entidade)
                                @Html.HiddenFor(m => m.Modal)
                                <input type="submit" value="Apagar" class="btn btn-danger" />
                                @Html.ActionLink("Voltar", "Index", new { id = 0, tipo = Model.Entidade, Modal = Model.Modal }, new { @class = "btn btn-outline btn-primary " })
                            </div>
                        </div>    
                    }
                </div>
            </div>

        </div>
    </div>
</div>







