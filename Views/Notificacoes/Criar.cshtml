@model Models.Notificacao


@{
    ViewBag.Title = " Notificações";

    if (Model.Modal)
    {
        Layout = "~/Views/Shared/_FortunaLayoutModal.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_FortunaLayout.cshtml";
    }

    var _PRCPropostas_Index = BLL.Usuarios.VerificaAcesso("Index", "PRCPropostas");

       
}


@section Breadcrumb{
    <li class="active">@Html.ActionLink("Configurações", "Configuracoes", "Principal")</li>
    <li class="active">@Html.ActionLink("Notificacoes", "Index", new { id = 0, tipo = Model.Entidade })</li>
}

<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">

            <div class="hpanel">

                <div class="panel-body">
                    <!-- conteudo aqui -->


                    @using (Html.BeginForm("Criar", "Notificacoes", FormMethod.Post, new { @id = "form-criar", @class = "alertChanges" }))
                    {
                        @Html.ValidationSummary(true)

                        @Html.HiddenFor(m => m.Entidade)
                        @Html.HiddenFor(m => m.Modal)
                        if (Model.NotificacaoId > 0)
                        {
                        @Html.Hidden("NotificacaoId", Model.NotificacaoId);
                        }

                        
       
                        <div class="row">
                            <div class="form-group col-lg-12 col-md-12 col-sm-12">
                                <label>Nome</label>
                                @Html.TextBoxFor(model => model.NotificacaoNome, new { @class = "form-control" })
                            </div>

                            <div class="form-group col-lg-12 col-md-12 col-sm-12">
                                <label>Descrição</label>
                                @Html.TextAreaFor(model => model.NotificacaoDescricao, new { @class = "form-control" })
                            </div>




                            <div class="form-group col-lg-9 col-md-9 col-sm-9">
                                <label>Status</label>
                                @Html.DropDownListFor(model => model.EntidadeStatusId, (SelectList)ViewBag.ddlEntidadesStatus, null, new { @class = "chosen-select select2 form-control" })
                            </div>



                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>Executar após </label>

                                <div class="input-group m-b">
                                    @Html.TextBoxFor(model => model.EntidadeStatusHoras, new { @class = "form-control input select-all number " })
                                    <span class="input-group-addon">horas</span>

                                </div>
                                

                            </div>


                        </div>
                        
         
                        <!-- email -->
                        <div class="row">
                            <div class="col-lg-12">
                                <div class="checkbox">
                                    <label>@Html.CheckBoxFor(model => model.NotificacaoEmailEnviar) <i class="fa fa-envelope"></i>Enviar EMail</label>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row" id="div_NotificacaoEmail">
                            <div class="col-form col-lg-12 col-md-12 col-sm-12">
                                <label>Assunto</label>
                                @Html.TextBoxFor(model => model.NotificacaoEmailAssunto, new { @class = "form-control" })
                            </div>

                            <div class="col-form col-lg-12 col-md-12 col-sm-12">
                                <label>Texto</label>
                                <select id="variaveis_email" class="form-control" name="variaveis_email">
                                    <option value="">--Variáveis--</option>
                                    <option value="#prcpropostaid#">Cód. Proposta</option>
                                    <option value="#prcpropostaprecatorio#">Número precatório</option>
                                    <option value="#primeironome#">Primeiro Nome @BLL.Usuarios.GetEntidadeCliente()</option>
                                    <option value="#nome#">Nome @BLL.Usuarios.GetEntidadeCliente()</option>

                                       @if (_PRCPropostas_Index)
                                    {
                                    <option value="#primeironegociadornome#">Primeiro Nome Negociador</option>
                                    <option value="#negociadornome#">Nome Negociador</option>    
                                    }
                                    


                                    <option value="#email#">E-Mail @BLL.Usuarios.GetEntidadeCliente()</option>
                                    <option value="#celular#">Celular @BLL.Usuarios.GetEntidadeCliente()</option>
                                    <option value="#optoutemail#">Link OptOut E-Mail</option>
                                    <option value="#optoutsms#">Link OptOut SMS</option>
                                    <option value="#optoutligacao#">Link OptOut Ligação</option>
                                    <option value="#agendar#">Link para Agendamento</option>
                                </select>
                                @Html.TextAreaFor(model => model.NotificacaoEmailTexto, new { @class = "col-lg-12", @rows = 10 })

                            </div>
                        </div>
                        <hr />
                        <!-- ./email -->
                        
                        
                        <!-- sms -->
                        <div class="row">
                            <div class="col-lg-12">
                                <div class="checkbox">
                                    <label>@Html.CheckBoxFor(model => model.NotificacaoSmsEnviar) <i class="fa fa-comment"></i>Enviar SMS</label>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row" id="div_NotificacaoSms">

                            <div class="col-form col-lg-12 col-md-12 col-sm-12">
                                <label>Texto</label>
                                <select id="variaveis_sms" class="form-control" name="variaveis_sms">
                                    <option value="">--Variáveis--</option>
                                    <option value="#prcpropostaid#">Cód. Proposta</option>
                                    <option value="#prcpropostaprecatorio#">Número precatório</option>
                                    <option value="#primeironome#">Primeiro Nome @BLL.Usuarios.GetEntidadeCliente()</option>
                                    <option value="#nome#">Nome @BLL.Usuarios.GetEntidadeCliente()</option>

                                    @if (_PRCPropostas_Index)
                                    {
                                    <option value="#primeironegociadornome#">Primeiro Nome Negociador</option>
                                    <option value="#negociadornome#">Nome Negociador</option>    
                                    }
                                    

                                    <option value="#email#">E-Mail @BLL.Usuarios.GetEntidadeCliente()</option>
                                    <option value="#celular#">Celular @BLL.Usuarios.GetEntidadeCliente()</option>
                                    <option value="#optoutemail#">Link OptOut E-Mail</option>
                                    <option value="#optoutsms#">Link OptOut SMS</option>
                                    <option value="#optoutligacao#">Link OptOut Ligação</option>
                                    <option value="#agendar#">Link para Agendamento</option>
                                </select>
                                @Html.TextAreaFor(model => model.NotificacaoSmsTexto, new { @class = "form-control maxlen", maxlength = "100", rows = 4 })


                            </div>
                        </div>
                        <hr />
                        <!-- ./sms -->
                        
                        
                        <!-- Carta -->
                        <div class="row">
                            <div class="col-lg-12">
                                <div class="checkbox">
                                    <label>@Html.CheckBoxFor(model => model.NotificacaoCartaGerar) <i class="fa fa-file-text-o"></i>Gerar Carta</label>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row" id="div_NotificacaoCarta">
                            <div class="col-form col-lg-12 col-md-12 col-sm-12">
                                <label>Template</label>
                                @Html.DropDownListFor(model => model.DocumentoTemplateId, (SelectList)ViewBag.ddlDocumentosTemplates, null, new { @class = "chosen-select select2 form-control" })
                            </div>
                            <div class="col-form col-lg-12 col-md-12 col-sm-12">
                                <label>Texto</label>
                                <select id="variaveis_carta" class="form-control" name="variaveis_carta">
                                    <option value="">--Variáveis--</option>
                                    <option value="#prcpropostaid#">Cód. Proposta</option>
                                    <option value="#prcpropostaprecatorio#">Número precatório</option>
                                    <option value="#primeironome#">Primeiro Nome @BLL.Usuarios.GetEntidadeCliente()</option>
                                    <option value="#nome#">Nome @BLL.Usuarios.GetEntidadeCliente()</option>

                                       @if (_PRCPropostas_Index)
                                    {
                                    <option value="#primeironegociadornome#">Primeiro Nome Negociador</option>
                                    <option value="#negociadornome#">Nome Negociador</option>    
                                    }
                                    


                                    <option value="#email#">E-Mail @BLL.Usuarios.GetEntidadeCliente()</option>
                                    <option value="#celular#">Celular @BLL.Usuarios.GetEntidadeCliente()</option>
                                </select>
                                @Html.TextAreaFor(model => model.NotificacaoCartaTexto, new { @class = "col-lg-12", @rows = 10 })


                            </div>
                        </div>
                        <hr />
                        <!-- ./sms -->
                        
                        
                        <!-- div_NotificacaoRetornarBase -->
                        <div class="row">
                            <div class="col-lg-12">
                                <div class="checkbox">
                                    <label>@Html.CheckBoxFor(model => model.NotificacaoRetornarBase) <i class="fa fa-database"></i>Retornar para BASE</label>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row" id="div_NotificacaoRetornarBase">
                            
                            <div class="col-form col-lg-6 col-md-6 col-sm-6">
                            <label>Voltar para base propostas sem atualização por</label>    
                                <div class="input-group col-md-3 m-b">
                                    @Html.TextBoxFor(model => model.NotificacaoRetornoBaseDias, new { @class = "form-control number" })
                                    <span class="input-group-addon">dias</span>
                                </div>
                            </div>

                            <div class="col-form col-lg-6 col-md-6 col-sm-6">
                                <label>Alterar para status:</label>
                                @Html.DropDownListFor(model => model.NotificacaoRetornarBaseStatusId, (SelectList)ViewBag.ddlEntidadesStatus, null, new { @class = "chosen-select select2 form-control" })
                            </div>

                        </div>
                        <hr />
                        <!-- ./div_NotificacaoRetornarBase -->
                        
                        
                        <!-- div_NotificacaoRetornarBase -->
                        <div class="row">
                            <div class="col-lg-12">
                                <div class="checkbox">
                                    <label>@Html.CheckBoxFor(model => model.NotificacaoMudarNegociador) <i class="fa fa-retweet"></i>Enviar para outro negociador ou passivo</label>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row" id="div_NotificacaoMudarNegociador">

                            <div class="col-form col-lg-4 col-md-4 col-sm-4">
                                <label>Após passar por</label>
                                <div class="input-group m-b">
                                    @Html.TextBoxFor(model => model.NotificacaoMudarNegociadorDias, new { @class = "form-control number"}) 
                                    <span class="input-group-addon">negociadores</span>
                                </div>

                            </div>
                            <div class="col-form col-lg-4 col-md-4 col-sm-4">
                                <label>Enviar para</label><br />
                                @Html.DropDownListUsuarios("NotificacaoMudarNegociadorId", Model.NotificacaoMudarNegociadorId.ToString(), true, " chosen-select select2  col-lg-12  ", true, "--Base de Propostas--", true, "--Usuário Aleatório--")
                            </div>

                            <div class="col-form col-lg-4 col-md-4 col-sm-4">
                                <label>Alterar para status:</label>
                                @Html.DropDownListFor(model => model.NotificacaoMudarNegociadorStatusId, (SelectList)ViewBag.ddlEntidadesStatus, null, new { @class = "chosen-select select2 form-control" })
                            </div>

                            <div class="col-form col-lg-12 col-md-12 col-sm-12">
                                <label>Caso proposta não possua negociador, alterar para usuário aleatório com perfil:</label>
                                @Html.DropDownListFor(model => model.NotificacaoMudarNegociadorPerfilId, (SelectList)ViewBag.ddlPerfis, null, new { @class = "chosen-select select2 form-control" })
                            </div>

                        </div>
                        <hr />
                        <!-- ./div_NotificacaoRetornarBase -->
                        
                        
                        <br />
                        <div class="row">

                            <div class="col-lg-12">
                                <input type="submit" value="Salvar" class="btn btn-primary btn-large" tabindex="11" />
                                @Html.ActionLink("Voltar", "Index", new { id = 0, tipo = Model.Entidade, Modal = Model.Modal }, new { @class = "btn btn-outline btn-primary " })
                            </div>

                        </div>
            
                    }

                    <!-- ./conteudo aqui -->
                </div>

            </div>
        </div>
    </div>
</div>


@section Styles{
    @Styles.Render("~/bundles/select2/css")
    @Styles.Render("~/bundles/bootstrap-tagsinput/css")
    @Styles.Render("~/redactor/redactor.css")

    <style>
        .my-group .select
        {
            width: 30%;
        }

        .my-group .input
        {
            width: 70%;
        }
    </style>
    <style>
        option:disabled
        {
            background-color: #afafaf !important;
            color: #ffffff !important;
        }

        .bootstrap-tagsinput
        {
            width: 100%;
        }
    </style>
}

@section Scripts {
    @Scripts.Render("~/bundles/maxlenght/js")
    @Scripts.Render("~/bundles/bootstrap-tagsinput/js")

    @Scripts.Render("~/bundles/select2/js")


    @Scripts.Render("~/bundles/fancybox/js")
    @Scripts.Render("~/bundles/datepicker/js")
    @Scripts.Render("~/bundles/mask/js")
    @Scripts.Render("~/redactor/redactor.min.js")
    <script>
        $("#NotificacaoNome").focus();
        $('.number').mask('0000');
        $('.money').mask('000000000000000,00', { reverse: true });

        $(".select-all").click(function () {
            $(this).select();
        });


        $('.select2').select2();

        $('.tags').tagsinput({
            splitOn: ',',
            trimValue: true,
        });
        $('.maxlen').maxlength({
            alwaysShow: true,
            threshold: 10,
            warningClass: "label label-success",
            limitReachedClass: "label label-danger"
        });



    </script>

    <script>
        $('#NotificacaoEmailEnviar').change(function () {
            verificaEmail(this.checked);
        });

        verificaEmail($("#NotificacaoEmailEnviar").is(':checked'));

        function verificaEmail(checado) {
            if (checado) {
                $("#div_NotificacaoEmail").slideDown();
            } else {
                $("#div_NotificacaoEmail").slideUp();
            }
        }

        $('#NotificacaoEmailTexto').redactor({
            focus: true,
            imageUpload: '@Url.Content("~/Redactor/ImageUpload")'
        });
    </script>


    <script>
        $('#NotificacaoSmsEnviar').change(function () {
            verificaSms(this.checked);
        });

        verificaSms($("#NotificacaoSmsEnviar").is(':checked'));

        function verificaSms(checado) {
            if (checado) {
                $("#div_NotificacaoSms").slideDown();
            } else {
                $("#div_NotificacaoSms").slideUp();
            }
        }
    </script>

    <script>
        $('#NotificacaoCartaGerar').change(function () {
            verificaCarta(this.checked);
        });

        verificaCarta($("#NotificacaoCartaGerar").is(':checked'));

        function verificaCarta(checado) {
            if (checado) {
                $("#div_NotificacaoCarta").slideDown();
            } else {
                $("#div_NotificacaoCarta").slideUp();
            }
        }

        $('#NotificacaoCartaTexto').redactor({
            focus: true,
            imageUpload: '@Url.Content("~/Redactor/ImageUpload")'
        });
    </script>

    <script>
        $('#NotificacaoRetornarBase').change(function () {
            verificaNotificacaoRetornarBase(this.checked);
        });

        verificaNotificacaoRetornarBase($("#NotificacaoRetornarBase").is(':checked'));

        function verificaNotificacaoRetornarBase(checado) {
            if (checado) {
                $("#div_NotificacaoRetornarBase").slideDown();
            } else {
                $("#div_NotificacaoRetornarBase").slideUp();
            }
        }
    </script>

    <script>
        $('#NotificacaoMudarNegociador').change(function () {
            verificaNotificacaoMudarNegociador(this.checked);
        });

        verificaNotificacaoMudarNegociador($("#NotificacaoMudarNegociador").is(':checked'));

        function verificaNotificacaoMudarNegociador(checado) {
            if (checado) {
                $("#div_NotificacaoMudarNegociador").slideDown();
            } else {
                $("#div_NotificacaoMudarNegociador").slideUp();
            }
        }
    </script>

    <script>

        
        $('#variaveis_email').on('change', function () {
            var cursorPos = $('#NotificacaoEmailTexto').prop('selectionStart');
            var v = $('#NotificacaoEmailTexto').val();
            var textBefore = v.substring(0, cursorPos);
            var textAfter = v.substring(cursorPos, v.length);
            //$('#NotificacaoEmailTexto').val(textBefore + $(this).val() + textAfter);
            $('#NotificacaoEmailTexto').redactor('set', textBefore + $(this).val() + textAfter);
            $("#variaveis_email").val(""); 
        });

        $('#variaveis_sms').on('change', function () {
            var cursorPos = $('#NotificacaoSmsTexto').prop('selectionStart');
            var v = $('#NotificacaoSmsTexto').val();
            var textBefore = v.substring(0, cursorPos);
            var textAfter = v.substring(cursorPos, v.length);
            $('#NotificacaoSmsTexto').val(textBefore + $(this).val() + textAfter);
            $("#variaveis_sms").val("");
        });

        $('#variaveis_carta').on('change', function () {
            var cursorPos = $('#NotificacaoCartaTexto').prop('selectionStart');
            var v = $('#NotificacaoCartaTexto').val();
            var textBefore = v.substring(0, cursorPos);
            var textAfter = v.substring(cursorPos, v.length);
            //$('#NotificacaoCartaTexto').val(textBefore + $(this).val() + textAfter);
            $('#NotificacaoCartaTexto').redactor('set', textBefore + $(this).val() + textAfter);
            $("#variaveis_carta").val("");
        });


        


    </script>
}
