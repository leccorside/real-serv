@model Models.Configuracao

@{
    ViewBag.Title = "Excluíndo Variável do Sistema";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";  
}


@section Breadcrumb{

    <li class="active"><span class="divider">/</span> @Html.ActionLink("Configurações", "Configuracoes", "Principal")</li>
    <li class="active"><span class="divider">/</span>    @Html.ActionLink("Variáveis do Sistema", "Index", new { id = 0 })</li>
}




<div class="alert">

    <h2>Atencão!</h2>
    Você tem certeza que deseja apagar essa configuração?
</div>

<table class="table table-bordered table-striped table-highlight">
    <thead>
        <tr>

            <th>
                @Html.DisplayNameFor(model => model.Variavel)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Valor)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Descricao)
            </th>

        </tr>
    </thead>
    <tbody>
        <tr>

            <td>
                @Html.DisplayFor(model => model.Variavel)
            </td>
            <td>
                @Html.DisplayFor(model => model.Valor)
            </td>
            <td>
                @Html.DisplayFor(model => model.Descricao)
            </td>

        </tr>
    </tbody>
</table>



@using (Html.BeginForm())
{
    @Html.HiddenFor(model => model.ConfiguracaoId)
    <p class="pull-right">
        <input type="submit" value="Apagar" class="btn btn-large btn-danger" />
    </p>

    <p class="pull-left">
        @Html.ActionLink("Voltar", "Index")
    </p>
         
}


