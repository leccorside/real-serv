@model Models.PessoaEndereco

@{
    
    ViewBag.Title = "Adicionar novo meio de contato";


    Layout = "~/Views/Shared/_FortunaLayoutModal.cshtml";


}



<div class="content animate-panel">


    <div class="row">
        <div class="col-lg-12" style="">
            <div class="hpanel ">
                <div class="panel-heading">
                    <div class="panel-tools">
                        <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                    </div>
                    Cadastro de Endereços
                </div>
                <div class="panel-body">
                    <!-- dados aqui-->
                    <div class="row">
                        <div class="col-lg-2 col-md-2 col-sm-2">
                            <label>CPF</label>
                            @Model.Pessoa.Documento
                        </div>
                        <div class="col-lg-10 col-md-10 col-sm-10">
                            <label>Nome</label><br />
                            @Model.Pessoa.Nome
                        </div>
                    </div>

                    <br />
                    @using (Html.BeginForm("Criar", "PessoasEnderecos", FormMethod.Post))
                    {
                        @Html.ValidationSummary(true)

                        @Html.HiddenFor(m => m.PessoaID)

                        if (Model.PessoaEnderecoId > 0)
                        {
                        @Html.HiddenFor(m => m.PessoaEnderecoId);
                        }
                        @Html.HiddenFor(m=>m.PessoaDependenteId)
                        <div class="row">
                            <div class="form-group col-lg-2 col-md-2 col-sm-2">
                                <label>CEP</label><label id="loading_cep" style="display: none"><i class="fa fa-spinner fa-spin"></i></label>

                                <div class="input-group">
                                    @Html.TextBoxFor(model => model.PessoaEnderecoCep, new { @class = "form-control" })
                                    <span class="input-group-btn">
                                        <button type="button" id="buscar-cep" class="btn btn-default"><i class="fa fa-search"></i></button>
                                    </span>
                                </div>


                            </div>
                            <div class="form-group col-lg-6 col-md-6 col-sm-6">
                                <label>Endereço</label>
                                @Html.TextBoxFor(model => model.PessoaEnderecoEndereco, new { @class = "  form-control " })
                            </div>
                            <div class="form-group col-lg-2 col-md-2 col-sm-2">
                                <label>Número</label>
                                @Html.TextBoxFor(model => model.PessoaEnderecoNumero, new { @class = "  form-control " })
                            </div>
                            <div class="form-group col-lg-2 col-md-2 col-sm-2">
                                <label>Complemento</label>
                                @Html.TextBoxFor(model => model.PessoaEnderecoComplemento, new { @class = "  form-control " })
                            </div>

                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>Bairro</label>
                                @Html.TextBoxFor(model => model.PessoaEnderecoBairro, new { @class = "  form-control " })
                            </div>
                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>Cidade</label>
                                @Html.TextBoxFor(model => model.PessoaEnderecoCidade, new { @class = "  form-control " })
                            </div>
                            <div class="form-group col-lg-2 col-md-2 col-sm-2">
                                <label>Estado</label>
                                @Html.TextBoxFor(model => model.PessoaEnderecoEstado, new { @class = "  form-control " })
                            </div>
                            <div class="form-group col-lg-4 col-md-4 col-sm-4">
                                <label>Observações</label>
                                @Html.TextBoxFor(model => model.PessoaEnderecoTipo, new { @class = "  form-control " })
                            </div>
                        </div>

        
                        
                        <div class="row">
                            <div class="col-lg-12">
                                <button type="submit" class="btn btn-primary">Salvar</button>
                                <a href="@Url.Content("~/PessoasEnderecos/Index/" + Model.Pessoa.PessoaID)" class="btn btn-outline btn-primary ">Voltar</a>
                            </div>
                        </div>
                    }

                    <!-- ./ dados aqui-->
                </div>

            </div>
        </div>
    </div>
</div>





@section Styles{
    @Styles.Render("~/bundles/select2/css")
    @Styles.Render("~/bundles/fancybox/css")
    @Styles.Render("~/bundles/datepicker/css")
}



@section Scripts {
    @Scripts.Render("~/bundles/select2/js")
    @Scripts.Render("~/bundles/fancybox/js")
    @Scripts.Render("~/bundles/clipboard/js")
    @Scripts.Render("~/bundles/datepicker/js")
    @Scripts.Render("~/bundles/mask/js")
    @Scripts.Render("~/bundles/maxlenght/js")
@Scripts.Render("~/bundles/jquery-cep/js")

    <script>
        $("#PessoaEnderecoCep").mask("99999-999");
        $("#PessoaEnderecoCep").focus();

        $('#buscar-cep').click(function () {


            $('#PessoaEnderecoCep').cep({
                load: function () {
                    //Exibe a div loading
                    $('#loading.cep').css('display', 'inline');
                },
                complete: function () {
                    //Esconde a div loading
                    $('#loading.cep').css('display', 'none');
                },
                error: function (msg) {
                    //Exibe em alert a mensagem de erro retornada
                    alert(msg);
                },
                success: function (data) {
                    $('#PessoaEnderecoEndereco').val(data.tipoLogradouro + ' ' + data.logradouro);
                    $('#PessoaEnderecoBairro').val(data.bairro);
                    $('#PessoaEnderecoEstado').val(data.estado);
                    $('#PessoaEnderecoCidade').val(data.cidade);
                    $('#PessoaEnderecoNumero').focus();
                }
            });
        });



        $(document).ready(function () {

            $(".fancybox").fancybox({ fitToView: false, width: '80%', autoSize: true });
            $(".fancybox_full").fancybox({
                fitToView: false,
                width: '100%',
                autoSize: false,
                closeClick: false,
                openEffect: 'none',
                closeEffect: 'none'
            });
        });

    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('.chosen-select').select2();
            $('.datepicker').datepicker({ language: 'pt-BR', format: 'dd/mm/yyyy', todayHighlight: true, todayBtn: true });
            $('.moeda').mask('000000000000000,00', { reverse: true });
        });
    </script>
}

