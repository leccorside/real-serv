@model Models.PessoaPlano


@{
    
    var pathFileman = "/Assets/plugins/fileman/index.html";



    ViewBag.Title = Model.PessoaPlanoGrupo.PessoaPlanoGrupoNome;


    Layout = "~/Views/Shared/_FortunaLayout.cshtml";

    var cubee_empresa_token = BLL.Configuracoes.CarregarPorEmpresaId("cubee.empresa.token", BLL.Usuarios.GetEmpresaId());
    var cubee_url_sistema = BLL.Configuracoes.CarregarPorEmpresaId("cubee.url.sistema", BLL.Usuarios.GetEmpresaId());
}





@section Breadcrumb{
    <li class="active">@Html.ActionLink("Grupo de Planos e Eventos", "Index", "PessoasPlanosGrupos")</li>
    <li class="active">@Html.ActionLink("Planos", "Index", new { id = Model.PessoaPlanoGrupoId })</li>
}



<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">

            <div class="hpanel">

                <div class="panel-body">
                    <!-- conteudo aqui -->


                    @using (Html.BeginForm("Criar", "PessoasPlanos", FormMethod.Post, new { @id = "form-criar", @class = "alertChanges" }))
                    {
                        @Html.ValidationSummary(true)

                        if (Model.PessoaPlanoId > 0)
                        {
                        @Html.Hidden("PessoaPlanoId", Model.PessoaPlanoId);
                        }
                        @Html.HiddenFor(m => m.PessoaPlanoGUID)
                        @Html.HiddenFor(m => m.PessoaPlanoGrupoId)
    
                        
                        
                        <div class="row">
                            <div class="col-lg-12"><legend>Cadastro de @Html.GetLegendaPlanoGrupoTipo(Model.PessoaPlanoGrupo.PessoaPlanoGrupoTipoId) / @Model.PessoaPlanoGrupo.PessoaPlanoGrupoNome</legend></div>
                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>Perfil @BLL.Usuarios.GetEntidadeClienteSingular()</label><br />
                                @Html.DropDownListFor(model => model.PessoaCategoriaSubId, (SelectList)ViewBag.ddlPessoasCategoriasSubs, null, new { @class = "chosen-select form-control" })
                            </div>


                            <div class="form-group col-lg-3 col-md-3 col-sm-3 @(Model.PessoaPlanoGrupo.PessoaPlanoGrupoGratis ? " invisible " : "")">
                                <label>Valor Inscrição</label>
                                <div class="input-group m-b">
                                    <span class="input-group-addon">R$</span>
                                    @Html.TextBox("PessoaPlanoVlrInscricao", string.Format("{0:F2}", Model.PessoaPlanoVlrInscricao), new { @class = "moeda form-control select-all" })
                                </div>
                            </div>

                            <div class="form-group col-lg-3 col-md-3 col-sm-3 @(Model.PessoaPlanoGrupo.PessoaPlanoGrupoGratis ? " invisible " : "")">
                                <label>Valor Inscrição <small>Boleto</small></label>
                                <div class="input-group m-b">
                                    <span class="input-group-addon">R$</span>
                                    @Html.TextBox("PessoaPlanoVlrInscricaoBoleto", string.Format("{0:F2}", Model.PessoaPlanoVlrInscricaoBoleto), new { @class = "moeda form-control select-all" })
                                </div>
                            </div>

                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>Conta </label><br />
                                @Html.DropDownListFor(model => model.ContaId, (SelectList)ViewBag.ddlContas, null, new { @class = "chosen-select form-control" })
                            </div>


                            @if (Model.PessoaPlanoGrupo.PessoaPlanoGrupoTipoId == 0)
                            {
                                <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                    <label>Valor Plano</label>
                                    <div class="input-group m-b">
                                        <span class="input-group-addon">R$</span>
                                        @Html.TextBox("PessoaPlanoVlr", string.Format("{0:F2}", Model.PessoaPlanoVlr), new { @class = "moeda form-control select-all" })
                                    </div>
                                </div>

                                <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                    <label>Valor Plano <small>Boleto</small></label>
                                    <div class="input-group m-b">
                                        <span class="input-group-addon">R$</span>
                                        @Html.TextBox("PessoaPlanoVlrBoleto", string.Format("{0:F2}", Model.PessoaPlanoVlrBoleto), new { @class = "moeda form-control select-all" })
                                    </div>
                                </div>
                                

                                <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                    <label>
                                        <abbr title="Duração do intervalo de cobrança em meses">Validade</abbr></label>
                                    <div class="input-group m-b">
                                        @Html.TextBox("PessoaPlanoValidadeMeses", Model.PessoaPlanoValidadeMeses, new { @class = "number form-control select-all" })
                                        <span class="input-group-addon">meses</span>
                                    </div>
                                </div>

                                <div class="form-group col-lg-6 col-md-6 col-sm-6">
                                    <label>Tipo de Plano</label><br />
                                    @Html.DropDownListFor(model => model.PessoaPlanoTipoId, (SelectList)ViewBag.ddlPessoasPlanosTipos, null, new { @class = "chosen-select form-control" })
                                </div>
                                
                                <div class="form-group col-lg-6 col-md-6 col-sm-6">
                                    <label>Status Inicial</label><br />
                                    @Html.DropDownListFor(model => model.EntidadeStatusId, (SelectList)ViewBag.ddlEntidadesStatus, "--Nenhum--", new { @class = "chosen-select form-control" })
                                </div>
                                
                              

                                
                            }
                            </div>
                        
                        
                        <div class="row">
                            <div class="col-form col-lg-2 col-md-2 col-sm-2">
                                    <label>Ordem</label>
                                    @Html.TextBoxFor(model => model.PessoaPlanoOrdem, new { @class = "form-control" })
                                </div>
                              <div class="col-form col-lg-10 col-md-10 col-sm-10">
                                    <label>Título</label>
                                    @Html.TextBoxFor(model => model.PessoaPlanoTitulo, new { @class = "form-control" })
                                </div>


                            <div class="col-form col-lg-12 col-md-12 col-sm-12">
                                <label>Descrição</label>
                                @Html.TextAreaFor(model => model.PessoaPlanoDescricao, new { @class = "form-control" })
                            </div>

                            

                        </div>
                        <br />
                        
                        
                        if (cubee_empresa_token != "")
                        {
                        <div class="row">
                            <div class="col-form col-lg-12 col-md-12 col-sm-12">
                                <label>Tipo de Vitrine: <label class="badge">Integração CUBEE <i class="fa fa-cube" aria-hidden="true"></i></label></label>
                                <select data-placeholder="Selecione uma vitrine..." class="form-control chosen-select " data-val="true" id="CubeeVitrineId" name="CubeeVitrineId"></select>
                                <small class="text-warning2" >* Essa é a vitrine inicial para integração. Após integração, a vitrine deve ser alterada no CUBEE</small>
                            </div>
                        </div>
                        
                        <br />
                        }

                        
                        <div class="row">
                            <div class="col-lg-12">
                                <div class="checkbox">
                                    <legend>
                                        <label>@Html.CheckBoxFor(model => model.PessoaPlanoEmailEnviar) <i class="fa fa-envelope"></i>Enviar EMail</label></legend>
                                </div>
                            </div>
                        </div>

                            
                        <div class="row" id="div_PlanoEmailEnviar">
                            <div class="col-form col-lg-12 col-md-12 col-sm-12">
                                <label>Assunto</label>
                                @Html.TextBoxFor(model => model.PessoaPlanoEmailAssunto, new { @class = "form-control" })
                            </div>

                            <div class="col-form col-lg-12 col-md-12 col-sm-12">
                                <label>Texto</label>
                                @Html.TextAreaFor(model => model.PessoaPlanoEmailTexto, new { @class = "col-lg-12", @rows = 10 })
                            </div>
                        </div>


                        <br />
                        
                        
                        <div class="row">
                            <div class="col-lg-12">
                                <div class="checkbox">
                                    <legend>
                                        <label>@Html.CheckBoxFor(model => model.RegraDescAtivo) <i class="fa fa-calculator"></i>Regra de Desconto</label></legend>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row"  id="div_RegraDescAtivo">
                            
                            <div class="col-form col-lg-3 col-md-3 col-sm-3">
                                <label>Campo</label>
                                <select name="RegraDescCampo" id="RegraDescCampo" class="form-control chosen-select">
                                    <option value="pessoa.anoconclusao">Data de Conclusão</option>
                                </select>
                            </div>

                            <div class="col-form col-lg-3 col-md-3 col-sm-3">
                                <label>Operador</label>
                                @Html.DropDownListOperadores("RegraDescOperador", Model.RegraDescOperador, true, " form-control ")
                            </div>


                            <div class="col-form col-lg-2 col-md-2 col-sm-2">
                                <label>Valor</label>
                                @Html.TextBoxFor(m => m.RegraDescValor, new { @class = "form-control number select-all" })
                            </div>

                            <div class="col-form col-lg-2 col-md-2 col-sm-2">
                                <label>Tipo</label>
                                <select name="RegraDescValorTipo" id="RegraDescValorTipo" class="form-control chosen-select">
                                    <option value="MESES">MESES</option>
                                </select>
                            </div>



                            <div class="col-form col-lg-2 col-md-2 col-sm-2">
                                <label>Desconto</label>
                                <div class="input-group m-b">
                                    <span class="input-group-addon">%</span>
                                    @Html.TextBox("RegraDescDesconto", string.Format("{0:F3}", Model.RegraDescDesconto), new { @class = "percent form-control select-all" })
                                </div>

                            </div>


                        </div>
                        <br />
                        <div class="row-fluid">
                            <div class="col-lg-12">
                                <input type="submit" value="Salvar" class="btn btn-primary btn-large" tabindex="11" />
                                @Html.ActionLink("Voltar", "Index", new { id = Model.PessoaPlanoGrupoId }, new { @class = "btn btn-outline btn-primary " })
                            </div>

                        </div>
            
                    }

                    <!-- ./conteudo aqui -->
                </div>

            </div>
        </div>
    </div>
</div>


@section Styles{
    @Styles.Render("~/Assets/css/chosen.css")
    @Styles.Render("~/bundles/select2/css")
    @Styles.Render("~/bundles/datepicker/css")
    @Styles.Render("~/bundles/fancybox/css")
    @Styles.Render("~/bundles/ladda/css")
    @Styles.Render("~/redactor/redactor.css")


}


@section Scripts {
    @Scripts.Render("~/bundles/fancybox/js")
    @Scripts.Render("~/bundles/select2/js")
    @Scripts.Render("~/Assets/js/chosen.jquery.js")
    @Scripts.Render("~/Assets/js/chosen.jquery.extend.js")
    @Scripts.Render("~/bundles/datepicker/js")
    @Scripts.Render("~/bundles/mask/js")
    @Scripts.Render("~/bundles/jquery-cep/js")
    @Scripts.Render("~/bundles/maxlenght/js")
    @Scripts.Render("~/bundles/ladda/js")
    @Scripts.Render("~/redactor/redactor.min.js")


    <script type="text/javascript">


        $("#Requerente_Documento").mask("999.999.999-99");
        $('#Requerente_Celular').mask(maskBehavior, options);
        $('#Requerente_Telefone').mask(maskBehavior, options);
        $("#Requerente_DataNascimento").mask("99/99/9999");
        $("#Requerente_Cep").mask("99999-999");

        $('.chosen-select').select2();

        $('.chosen-select-add').chosen().trigger("chosen:updated");


        $('#PessoaPlanoFormasPagtoArray').trigger("chosen:updated");
        $('.datepicker').datepicker({ language: 'pt-BR', format: 'dd/mm/yyyy', todayHighlight: true, todayBtn: true });
        $('.moeda').mask('000000000000000,00', { reverse: true });
        $('.percent').mask('000000000000000,000', { reverse: true });
        $('.max').maxlength({
            alwaysShow: true,
            threshold: 10,
            warningClass: "label label-success",
            limitReachedClass: "label label-danger"
        });
        $('.number').mask('0000', { reverse: true });
        $(".select-all").click(function () {
            $(this).select();
        });
    </script>

    <script>

        function atualiza() {
            var url = "@Url.Content("~/XXXXX/EditarJSON")"; // the script where you handle the form input.
            calculaVlLiq();

            $.ajax({
                type: "POST",
                url: url,
                data: $("#form-criar").serialize(),
                success: function (result) {
                    if (result.NUMERO != 0) {
                        swal({ title: "Atencão!", text: result.MENSAGEM, type: "error", showCancelButton: false, cancelButtonText: "Não", confirmButtonColor: "#DD6B55", confirmButtonText: "Ok", closeOnConfirm: true }, function () { });
                    }

                },
                error: function (result) {
                    swal({ title: "Atencão!", text: "Ocorreu um erro ao tentar salvar os dados da proposta", type: "error", showCancelButton: false, cancelButtonText: "Não", confirmButtonColor: "#DD6B55", confirmButtonText: "Ok", closeOnConfirm: true }, function () { });
                }
            });


        }


        $("input[type=text], textarea, select, :checkbox").change(function () {
            //atualiza();

        });


    </script>


    <script type="text/javascript">
        $(function () {
            $('#PessoaPlanoEmailTexto').redactor({
                focus: true,
                imageUpload: '@Url.Content("~/Redactor/ImageUpload")'
            });

            $('#PessoaPlanoDescricao').redactor({
                focus: true,
                imageUpload: '@Url.Content("~/Redactor/ImageUpload")'
            });

            
        });
    </script>


    <script>
        $('#PessoaPlanoEmailEnviar').change(function () {
            verificaEmail(this.checked);
        });

        verificaEmail($("#PessoaPlanoEmailEnviar").is(':checked'));

        function verificaEmail(checado) {
            if (checado) {
                $("#div_PlanoEmailEnviar").slideDown();
            } else {
                $("#div_PlanoEmailEnviar").slideUp();
            }
        }

    </script>

    <script>
        $('#RegraDescAtivo').change(function () {
            verificaDesconto(this.checked);
        });

        verificaDesconto($("#RegraDescAtivo").is(':checked'));

        function verificaDesconto(checado) {
            if (checado) {
                $("#div_RegraDescAtivo").slideDown();
            } else {
                $("#div_RegraDescAtivo").slideUp();
            }
        }

    </script>

    <script>

        

        function carregaVitrines(CubeeVitrineId) {
            $.getJSON("@Url.Content(cubee_url_sistema + "/ApiIntegracaoV1/GetVitrinesPerfis/")", { token: "@cubee_empresa_token" }, function (result) {

                
                data = $.map(result, function (item, a) {
                    var select = (CubeeVitrineId == item.VitrinePerfilId) ? " selected='selected' " : "";
                    return "<option value=" + item.VitrinePerfilId + " " + select + ">" + item.VitrinePerfilNome + "</option>";
                });
                $("#CubeeVitrineId").empty();
                $('#CubeeVitrineId').append($('<option>', {
                    value: 0,
                    text: '--Selecione--'
                }));
                $("#CubeeVitrineId").append(data.join(""));

                $("#CubeeVitrineId").val(CubeeVitrineId).trigger('chosen:updated');
                $("#CubeeVitrineId").val(CubeeVitrineId).trigger('change.select2');

            });
        }

        carregaVitrines("@Model.CubeeVitrineId");
    </script>

}




