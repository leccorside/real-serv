@model Models.PessoaPlano

@{
    ViewBag.Title = "Excluíndo Planos";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";
}


@section Breadcrumb{
    <li class="active">@Html.ActionLink("Configurações", "Configuracoes", "Principal")</li>
    
 <li class="active">@Html.ActionLink("Planos", "Index", new { id = Model.PessoaPlanoGrupoId })</li>
}



<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">
            <div class="alert alert-warning">
                <i class="fa fa-exclamation-triangle" aria-hidden="true"></i><strong>Atenção</strong> Você tem certeza que deseja apagar esse registro?
            </div>

            <div class="hpanel">
                <div class="panel-body">
                    <!-- conteudo aqui -->
                    <div class="row">
                <div class="col-lg-3 col-md-3 col-sm-3">
                    <div class="display-label">

                        ID



                    </div>
                    <div class="display-field">
                        @Html.DisplayFor(model => model.PessoaPlanoId)
                    </div>

                </div>
                <div class="col-lg-9 col-md-9 col-sm-9">
                    <div class="display-label">

Descrição


                    </div>
                    <div class="display-field">
                        <h5>@Model.PessoaCategoriaSubNome</h5>
                        <small>@Model.PessoaPlanoDescricao</small>
                    </div>

                </div>



            </div>
                    <!-- ./conteudo aqui -->
                </div>
                <div class="panel-footer">

                    @using (Html.BeginForm())
                    {
                        <div class="row">
                            <div class="col-lg-12">
                                @Html.HiddenFor(model => model.PessoaPlanoId)
                                @Html.HiddenFor(model=>model.PessoaPlanoGrupoId)
                                    <input type="submit" value="Apagar" class="btn btn-danger" />
                                
                                @Html.ActionLink("Voltar", "Index",  new { id = Model.PessoaPlanoGrupoId }, new {  @class = "btn btn-outline btn-primary " })
                            </div>
                        </div>    
                    }

                </div>
            </div>

        </div>
    </div>
</div>







