@model Models.UsuarioEmpresa

@{
    ViewBag.Title = "Exclu&iacute;ndo Empresa";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


@section Breadcrumb{

    <li class="active"><span class="divider">/</span>    @Html.ActionLink("Usu&aacute;rios", "Index")</li>
}


<div class="alert">
    
    <h2>Aten&ccedil;&atilde;o!</h2>
    Voc&ecirc; tem certeza que deseja apagar esse registro?
</div>

<table class="table table-bordered table-striped table-highlight">
    <thead>
        <tr>

            <th>Nome
            </th>

            
            <th>Telefone
            </th>


            <th nowrap>Criado em
            </th>

        </tr>
    </thead>
    <tbody>
        <tr>
            <td>@Html.DisplayFor(model => model.UsuarioEmpresaNomeFantasia)</td>

            
            <td nowrap>(@Model.UsuarioEmpresaCttTelDDD) - @Model.UsuarioEmpresaCttTel

            
                <td nowrap>
                    @Model.RegDtInicio
                </td
        </tr>



    </tbody>
</table>



@using (Html.BeginForm())
{
    
    @Html.HiddenFor(model => model.UsuarioEmpresaId)

    <p class="pull-right">
        <input type="submit" value="Apagar" class="btn btn-large btn-danger" />
    </p>

    <p class="pull-left">
        @Html.ActionLink("Voltar", "Index")
    </p>
}


