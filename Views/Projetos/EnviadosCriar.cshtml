@model Models.EnviadoView

@{
    ViewBag.Title = "Alterar Obras";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



@section Styles {

}


@section Breadcrumb{

    <li class="active"><span class="divider">/</span>    @Html.ActionLink("Obras", "Index")</li>

}


@Html.Partial("~/Views/Projetos/_Navtabs.cshtml", Model.DadosProjeto)



@using (Html.BeginForm()) {
    @Html.ValidationSummary(true)

     
    if (Model.Enviado.EnviadoId > 0)
    {
    @Html.Hidden("Enviado.EnviadoId", Model.Enviado.EnviadoId);
    @Html.HiddenFor(m => m.Enviado.ProjetoId);
    }
    
    <div class="row-fluid">
        <div class="span3">
            <div class="editor-label">
            @Html.LabelFor(model => model.Enviado.EnviadoTipo)
        </div>
        <div class="editor-field">
            @Html.DropDownListEnviadoTipo("Enviado.EnviadoTipo",Model.Enviado.EnviadoTipo.ToString())
            @Html.ValidationMessageFor(model => model.Enviado.EnviadoTipo)
        </div>
        </div>
        <div class="span3">
            <div class="editor-label">
            @Html.LabelFor(model => model.Enviado.EnviadoNF)
        </div>
        <div class="editor-field">
            @Html.EditorFor(model => model.Enviado.EnviadoNF)
            @Html.ValidationMessageFor(model => model.Enviado.EnviadoNF)
        </div>
        </div>
        <div class="span3">
            <div class="editor-label">
            @Html.LabelFor(model => model.Enviado.EnviadoData)
        </div>
        <div class="editor-field">
            @Html.TextBox("Enviado.EnviadoData", @String.Format("{0:dd/MM/yyyy}", Model.Enviado.EnviadoData), new { @class = "span12", value = @DateTime.Now })
            @Html.ValidationMessageFor(model => model.Enviado.EnviadoData)
        </div>
        </div>
        <div class="span3">
            <div class="editor-label">
            @Html.LabelFor(model => model.Enviado.EnviadoValorFrete)
        </div>
        <div class="editor-field">
            @Html.TextBox("Enviado.EnviadoValorFrete", string.Format("{0:n2}", Model.Enviado.EnviadoValorFrete), new { @class = "money span12" })
            @Html.ValidationMessageFor(model => model.Enviado.EnviadoValorFrete)
        </div>
        </div>
    </div>
    <div class="row-fluid">
        <div class="span12">
            <div class="editor-label">
            @Html.LabelFor(model => model.Enviado.EnviadoObservacoes)
        </div>
        <div class="editor-field">
            @Html.TextAreaFor(model => model.Enviado.EnviadoObservacoes, new { @class = "span12" })
            @Html.ValidationMessageFor(model => model.Enviado.EnviadoObservacoes)
        </div>
        </div>
    </div>
    
    <legend>Itens</legend>
    <div class="row-fluid">
        <div class="span7">
            <div class="control-group">
                <label><strong>Produto</strong></label>
                <div class="input-append">
                    @Html.DropDownList("EnviadoProduto.ProdutoId", (SelectList)ViewBag.ddlProdutos, new { @class="chosen-select"})
                </div>
            </div>
        </div>
        <div class="span2">
            <div class="control-group">
                <label><strong>Qtd. Enviado (m)</strong></label>
                <div class="input-append">
                    @Html.TextBox("EnviadoProduto.ProdutoQtdEnviado", string.Format("{0:n2}", Model.EnviadoProduto.ProdutoQtdEnviado), new { @class = "money input-small" })
                </div>
            </div>
        </div>
        <div class="span3">
            <div class="control-group">
                <label><strong>Valor Unitário (R$)</strong></label>
                <div class="input-append">
                    @Html.TextBox("EnviadoProduto.ProdutoValorUnitario", string.Format("{0:n2}", Model.EnviadoProduto.ProdutoValorUnitario), new { @class = "money input-small" })
                    <button id="btnAdicionar" value="adicionar" type="submit" class="btn"><i class="icon-plus"></i>Adicionar</button>
                </div>
            </div>
        </div>
    </div>
    
    <table class="table table-bordered table-striped table-highlight">
        <thead>
            <tr>
                <th>Produto</th>
                <th>Qtd.Enviado</th>
                <th>Vlr.Unitário</th>
                <th>Total</th>
                <th></th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model.ListaEnviadoProdutos)
            {
                <tr>
                    <td>@item.ProdutoNome</td>
                    <td>@item.ProdutoQtdEnviado</td>
                    <td>@item.ProdutoValorUnitario</td>
                    <td>@item.ProdutoValorTotal</td>
                    <td nowrap><a href="~/Projetos/EnviadosProdutosDeletar/@item.EnviadoProdutoId?eid=@item.EnviadoId&pid=@Model.Enviado.ProjetoId" class="btn btn-mini" onclick="return confirm('Deseja realmente excluir esse registro?')"><i class="fa fa-times"></i> Excluir</a></td>
                </tr>
            }
        </tbody>
    </table>
    
    <div class="form-actions">
        <input type="submit" name="btnSubmit" value="Registrar" class="btn btn-primary  btn-large"  TabIndex=10 />
        
        <button type="submit" name="btnSubmit" value="RegistrarNova" class="btn  btn-mini pull-right"  TabIndex=10 >Nova NF</button>
    </div>
}
    
    

<div>
    <a href="~/Projetos/Enviados/@Model.Enviado.ProjetoId">Voltar</a>
    
</div>

@section Scripts {
    <script>

        $("#Enviado_EnviadoData").mask("99/99/9999");
        $("#Enviado_EnviadoData").datepicker(
            {
                dateFormat: 'dd/mm/yy',
                dayNames: ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'],
                dayNamesMin: ['D', 'S', 'T', 'Q', 'Q', 'S', 'S', 'D'],
                dayNamesShort: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb', 'Dom'],
                monthNames: ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
                monthNamesShort: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
                changeMonth: true,
            }
            );
    </script>
}
