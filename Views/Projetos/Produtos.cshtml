@model Models.ProjetoProdutoView

@{
    
    
    ViewBag.Title = "Alterar Obras";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



@section Styles {

}


@section Breadcrumb{

    <li class="active"><span class="divider">/</span>    @Html.ActionLink("Obras", "Index")</li>

}

@Html.Partial("~/Views/Projetos/_Navtabs.cshtml", Model.DadosProjeto)


@using (Html.BeginForm("Produtos", "Projetos", FormMethod.Post))
{
    @Html.ValidationSummary(true)
    
    
    @Html.Hidden("ProjetoProduto.ProjetoId", Model.DadosProjeto.ProjetoId);
  
    <div class="row-fluid">
        <div class="span12">
            <div class="control-group">
                <label><strong>Seção</strong></label>
                <div class="input-append">
                    @Html.DropDownList("ProjetoProduto.ProdutoId", (SelectList)ViewBag.ddlProdutos, new { @class = "chosen-select" })
                </div>
            </div>
        </div>
    </div>
    
    <div class="row-fluid">
        <div class="span2">
            <div class="control-group">
                <label><strong>Taxa Solda unit. (R$)</strong></label>
                <div class="input-append">
                    @Html.TextBox("ProjetoProduto.TaxaSolda", string.Format("{0:n2}", Model.ProjetoProduto.TaxaSolda), new { @class = "money span12" })
                </div>
            </div>
        </div>
        
        <div class="span2">
            <div class="control-group">
                <label><strong>Vlr. Serviço (RS)</strong></label>
                <div class="input-append">
                    @Html.TextBox("ProjetoProduto.TaxaServico", string.Format("{0:n2}", Model.ProjetoProduto.TaxaServico), new { @class = "money span12" })
                </div>
            </div>
        </div>

        <div class="span2">
            <div class="control-group">
                <label><strong>Vlr. Material (RS)</strong></label>
                <div class="input-append">
                    @Html.TextBox("ProjetoProduto.TaxaMaterial", string.Format("{0:n2}", Model.ProjetoProduto.TaxaMaterial), new { @class = "money span12" })
                </div>
            </div>
        </div>

        <div class="span2">
            <div class="control-group">
                <label><strong>Qtd.Piquetes</strong></label>
                <div class="input-append">
                    @Html.TextBoxFor(m=>m.ProjetoProduto.ProdutoQtdPiquetes, new { @class="number span12"})
                </div>
            </div>
        </div>

        <div class="span4">
            <div class="control-group">
                <label><strong>Comp.Medido (m)</strong></label>
                <div class="input-append">
                    @Html.TextBoxFor(m => m.ProjetoProduto.ProdutoCompMedio, new { @class = "money span6" })
                    <button id="btnAdicionar" type="submit" class="btn"><i class="icon-plus"></i>Adicionar</button>
                </div>
            </div>
        </div>
    </div>
    
    
}


<table class="table table-bordered table-striped table-highlight">
    <thead>
        <tr>
            <th>Seção</th>
            <th>Solda unit. R$</th>
            <th>Vlr. Serviço</th>
            <th>Vlr. Material</th>
            <th>Qtd.Piquetes</th>
            <th>Comp.Medido (m)</th>
            <th>Total Estimado (m)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.ListaProdutos)
        {
            <tr>
                <td nowrap>@item.ProdutoCodigo - @item.ProdutoSecaoNome - @item.ProdutoNome</td>
                <td nowrap>R$ @item.TaxaSolda</td>
                <td nowrap>R$ @item.TaxaServico</td>
                <td nowrap>R$ @item.TaxaMaterial</td>
                <td nowrap>@item.ProdutoQtdPiquetes</td>
                <td nowrap>@item.ProdutoCompMedio.ToString("N2")</td>
                <td nowrap>@item.ProdutoTotalEstimado.ToString("N2")</td>
                <td nowrap><a href="~/Projetos/ProdutosDeletar/@Model.DadosProjeto.ProjetoId?pid=@item.ProjetoProdutoId" class="btn btn-mini" onclick="return confirm('Deseja realmente excluir esse registro?')"><i class="fa fa-times"></i> Excluir</a></td>
            </tr>
        }
    </tbody>
</table>


<div>
    @Html.ActionLink("Voltar", "Index")
</div>


@section Scripts {

    <script>
        $("#ProjetoProduto\\.ProdutoId").focus();
    </script>
    
}
