@model Models.Perfil

@{
    ViewBag.Title = "Excluíndo Perfis";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";    
}


@section Breadcrumb{
      <li class="active">@Html.ActionLink("Configurações", "Configuracoes", "Principal")</li>
   <li class="active">@Html.ActionLink("Perfis", "Index", new { id = 0 })</li>
}

<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">
            <div class="alert alert-warning">
                <i class="fa fa-exclamation-triangle" aria-hidden="true"></i><strong>Atenção</strong> Você tem certeza que deseja apagar esse registro?
            </div>

            <div class="hpanel">
                <div class="panel-body">
                    <!-- conteudo aqui -->


                    <div class="row">

                        <div class="col-lg-2">
                            <div class="display-label">
                                @Html.DisplayNameFor(model => model.PerfilId)
                            </div>
                            <div class="display-field">
                                @Html.DisplayFor(model => model.PerfilId)
                            </div>

                        </div>
                        <div class="col-lg-10">

                            <div class="display-label">
                                @Html.DisplayNameFor(model => model.PerfilNome)
                            </div>
                            <div class="display-field">
                                @Html.DisplayFor(model => model.PerfilNome)
                            </div>

                        </div>
                        
                    </div>




                    <!-- ./conteudo aqui -->
                </div>
                <div class="panel-footer">

                    @using (Html.BeginForm())
                    {
                        <div class="row">
                            <div class="col-lg-12">
                                @Html.HiddenFor(model => model.PerfilId)
                    @Html.HiddenFor(model => model.EmpresaId)
                                    <input type="submit" value="Apagar" class="btn btn-danger" />
                                
                                    @Html.ActionLink("Voltar", "Index", new { @idEmpresa=Model.EmpresaId }, new { @class = "btn btn-outline btn-primary" })
                                
                            </div>
                        </div>    
                    }

                </div>
            </div>

        </div>
    </div>
</div>





