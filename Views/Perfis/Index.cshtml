@model IEnumerable<Models.Perfil>

@{
    ViewBag.Title = "Perfis";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";
    var idEmpresa = Url.RequestContext.RouteData.Values["id"];
}

@section Breadcrumb{
    <li class="active"><span class="divider">/</span> @Html.ActionLink("Configura&ccedil;&otilde;es", "Configuracoes", "Principal")</li>
}

@section Styles {
@Html.Partial("_TableStyles")
}

<div class="ponto-container">
    <div class="ponto-header">
        <div class="ponto-title"><h2><i class="pe-7s-lock"></i> Perfis de Acesso</h2></div>
        @Html.ActionLink("+ Criar", "Criar", new { id = 0, idEmpresa = idEmpresa }, new { @class = "btn-create" })
    </div>
    <div class="ponto-table-container">
        <table class="ponto-table">
            <thead>
                <tr>
                    <th>N&iacute;vel</th>
                    <th>Perfis</th>
                    <th>Regras</th>
                    <th style="width:230px">A&ccedil;&otilde;es</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td nowrap>@item.Nivel</td>
                        <td width="100%">
                            @Html.DisplayFor(m => item.PerfilNome)
                            @if (item.PRCPropostaRegraRange || item.PRCPropostaRegraMetaFUP > 0 || item.PRCPropostaRegraMetaTeto > 0)
                            {
                                <small>
                                    @if (item.PRCPropostaRegraRange) { <span>R$ @string.Format("{0:N2}", item.PRCPropostaRegraVlrDe) — @string.Format("{0:N2}", item.PRCPropostaRegraVlrAte)</span> }
                                    @if (item.PRCPropostaRegraMetaTeto > 0) { <span>| Teto: @item.PRCPropostaRegraMetaTeto</span> }
                                </small>
                            }
                        </td>
                        <td nowrap>@Html.DisplayFor(m => item.RegDtInicio)</td>
                        <td nowrap>
                            <div class="actions-cell">
                                <a href="@Url.Content("~/Perfis/Acessos/" + item.PerfilId + "?idEmpresa=" + item.EmpresaId)" class="btn-acessos"><i class="fa fa-lock"></i> Acessos</a>
                                @Html.ActionLink("Alterar", "Criar", new { id = item.PerfilId, idEmpresa = item.EmpresaId }, new { @class = "btn-alterar" })
                                @Html.ActionLink("Excluir", "Deletar", new { id = item.PerfilId, idEmpresa = item.EmpresaId }, new { @class = "btn-excluir" })
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
