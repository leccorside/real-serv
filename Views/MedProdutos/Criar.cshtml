@model Models.MedProduto


@{
    

    
    var acao = "Cadastrar";
    if (Model.MedProdutoId > 0)
    {
        acao = "Alterar";
    }


    ViewBag.Title = acao + " Convênio";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";   
}





@section Breadcrumb{
    <li class="active">@Html.ActionLink("Configurações", "Configuracoes", "Principal")</li>
    <li class="active">@Html.ActionLink("Produtos e Exames", "Index", new { id = 0 })</li>
}




<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">

            <div class="hpanel">

                <div class="panel-body">
                    <!-- conteudo aqui -->


         @using (Html.BeginForm("Criar", "MedProdutos", FormMethod.Post, new { @class = "form-horizontal" }))
    {
        @Html.ValidationSummary(true)

        if (Model.MedProdutoId > 0)
        {
        @Html.Hidden("MedProdutoId", Model.MedProdutoId);
                                            acao = "Alterar";
        }
    
       
                        <div class="row">
                            <div class="col-lg-2">
                                @Html.LabelFor(model => model.MedProdutoCod)
                                @Html.TextBoxFor(model => model.MedProdutoCod, new { @class="form-control" })
                            </div>

                             <div class="col-lg-2">
                                <label>Cód.Legado</label>
                                @Html.TextBoxFor(model => model.MedProdutoCodLegado, new { @class="form-control" })
                            </div>

                            <div class="col-lg-8">
                                <label>Categoria</label>
                                @Html.DropDownListFor(model => model.MedProdutoCategoriaId, (SelectList)ViewBag.ddlMedProdutosCategorias, new { @class = "chosen-select form-control " })
                            </div>

                            <div class="col-lg-10">
                                @Html.LabelFor(model => model.MedProdutoNome)
                                @Html.TextBoxFor(model => model.MedProdutoNome, new { @class="form-control" })
                            </div>


                            <div class="col-lg-2">
                                @Html.LabelFor(model => model.MedProdutoPrecoCusto)
                                @Html.TextBox("MedProdutoPrecoCusto", string.Format("{0:F2}", Model.MedProdutoPrecoCusto), new {  @class = "form-control moeda" })
                            </div>

                            <div class="col-lg-12">
                                @Html.LabelFor(model => model.MedProdutoDescricao)
                                @Html.TextAreaFor(model => model.MedProdutoDescricao, new { @class="form-control" })
                            </div>

                        </div>                  
        
            
         
            <br />

                        <div class="row">
                            <div class="col-lg-12">
                                <button name="salvarfechar" value="true" type="submit" class="btn btn-primary  ">Salvar</button>    
                   
                                @Html.ActionLink("Voltar", "Index", null, new {@class="btn btn-outline btn-primary " })
                            </div>

                        </div>
            
                    }

                    <!-- ./conteudo aqui -->
                </div>

            </div>
        </div>
    </div>
</div>




@section Scripts {
@Scripts.Render("~/bundles/mask/js")
    <script>
        $('#MedProdutoNome').keyup(function () {
            console.log(this.value);
            this.value = this.value.toLocaleUpperCase();
        });
        $('#MedProdutoDescricao').keyup(function () {
            console.log(this.value);
            this.value = this.value.toLocaleUpperCase();
        });
    </script>

    <script type="text/javascript">
        $(document).ready(function () {
            $('.moeda').mask('000000000000000,00', { reverse: true });
        });
    </script>
}
