@model Models.Plano


@{
    ViewBag.Title = "Excluindo plano";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";  
}




@section Breadcrumb{
    <li class="active"><span class="divider">/</span> @Html.ActionLink("Planos", "Index", "Planos")</li>
}




<div class="alert">
    <button type="button" class="close" data-dismiss="alert">&times;</button>
    <h2>Atencão!</h2>
    Você tem certeza que deseja apagar esse plano?
</div>


<table class="table table-bordered table-striped">
    <thead>
        <tr>

            <th>
                @Html.DisplayNameFor(model => model.PlanoTipoNome)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Nome)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ServicoNome)
            </th>

            <th>
                @Html.DisplayNameFor(model => model.CreditoInicial)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CreditoAtual)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CreditoAtualData)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.VencimentoPlanoData)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RegDtInicio)
            </th>

        </tr>
    </thead>
    <tbody>

            <tr>

                <td nowrap>
                    @Html.DisplayFor(model => model.PlanoTipoNome)
                </td>
                <td width="100%" nowrap>
                    @Html.DisplayFor(model => model.Nome)
                </td>
                <td width="100%" nowrap>
                    @Html.DisplayFor(model => model.ServicoNome)
                </td>
             
                <td width="100%" nowrap>
                    @Html.DisplayFor(model => model.CreditoInicial)
                </td>
                <td width="100%" nowrap>
                    @Html.DisplayFor(model => model.CreditoAtual)
                </td>
                <td width="100%" nowrap>
                    @Html.DisplayFor(model => model.CreditoAtualData)
                </td>
                <td width="100%" nowrap>

                    @{

            if (Model.VencimentoPlanoData != null)
            {
                @Convert.ToDateTime(Model.VencimentoPlanoData).ToShortDateString();
            }
                    }


                </td>
                <td nowrap>
                    @Html.DisplayFor(model => model.RegDtInicio)
                </td>


            </tr>
     




    </tbody>
</table>





<div class="cwell">


    @using (Html.BeginForm())
    {
        <div class="row-fluid">
            <div class="span2">
                @Html.HiddenFor(model => model.PlanoId)
                <p class="pull-left">
                    <input type="submit" value="Apagar" class="btn btn-danger btn-large" />

                </p>
                <br/>
                <br/>
                <br/>
                <p class="bottom">
                    @Html.ActionLink("Voltar", "Index")
                </p>
            </div>
        </div>



    }


</div>




