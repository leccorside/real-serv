                        @using (Html.BeginForm("DefinirFilial", "Acessos", FormMethod.Post, new { @class = "" }))
                        {
                            <input type="hidden" value="@currentController" name="controle" />
                            <input type="hidden" value="@currentAction" name="acao" />
                            <input type="hidden" value="@currentTipo" name="tipo" />
                            <input type="hidden" value="@currentId" name="currentId" />


                            <!-- controle de filiais-->
                            <div class="input-append input-prepend pull-right">
                                <span class="add-on">@BLL.Usuarios.GetEntidadeFilial():</span>
                                @Html.DropDownList("FilialIDMaster", (SelectList)listaFiliais, null, new { @class = "chosen-select  tip-top", @Value = BLL.Usuarios.GetFilialId(), @title = "Filial" })



                                <button class="btn " type="submit">Ok</button>
                            </div>
                            <!-- ./controle de filiais-->
                        }
                    </div>
                    }
                </div>

            <div class="row-fluid">

                @if (!regras_nobreadcrumb)
                {
                    <h6>@ViewBag.Title</h6>    
                }

                <!-- breadcrumb -->
                <ul class="breadcrumb">
                    <li><a href="@Url.Content("~/Principal")" title="Ir para Home" class="tip-bottom"><i class="icon-home"></i>Home</a></li>

                    @RenderSection("breadcrumb", required: false)

                    @if (currentPage != "principal-index")
                    {
                        <li class="active"><span class="divider">/</span> @ViewBag.Title</li>
                    }

                </ul>
                <!-- ./breadcrumb -->
            </div>





            @if (!@Html.ViewData.ModelState.IsValid)
            {
                <div class="row-fluid">
                    <div class="span12">
                        <div class="alert alert-error" id="alert-error">
                            <h4>Ooops... alguns erros ocorreram</h4>
                            <br />
                            @Html.ValidationSummary("", new { @class = "unstyled" })
                        </div>
                    </div>
                </div>
            }
            @if (TempData["message"] != null)
            { <div class="row-fluid">
                <div class="span12">
                    <div class="alert alert-success" id="alert-success">
                        <button type="button" class="close" data-dismiss="alert">&times;</button>
                        <h4>Sucesso!</h4>
                        @Html.Raw(TempData["message"])
                    </div>
                </div>
            </div>
            }
            @if (TempData["error"] != null)
            { <div class="row-fluid">
                <div class="span12">
                    <div class="alert alert-danger" id="alert-danger">
                        <button type="button" class="close" data-dismiss="alert">&times;</button>
                        <h4>Atenção!</h4>
                        @Html.Raw(TempData["error"])
                    </div>
                </div>
            </div>
            }

            @if (TempData["alert"] != null)
            { <div class="row-fluid">
                <div class="span12">
                    <div class="alert alert-block" id="alert-block">
                        <button type="button" class="close" data-dismiss="alert">&times;</button>
                        <h4>Atenção!</h4>
                        @Html.Raw(TempData["alert"])
                    </div>
                </div>
            </div>
            }


        

            @RenderBody()


            
            <div class="row-fluid" style="margin-top:300px;">
                <div id="footer" class="span12">

                    @if (_copyright == "" || _copyright == "true")
                    {
                        <span class="muted pull-right">@DateTime.Today.ToString("yyyy") &copy; Powered By <a href="http://www.e-bee.com.br" target="_blank" style="color: #ff7518; font-weight: bold">E-Bee</a>    </span>
                    }
                </div>
            </div>
        </div>
    </div>

