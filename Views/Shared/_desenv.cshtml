@{
    var url = Request.Url;
    var baseUrl = url.GetLeftPart(UriPartial.Authority);

    var currentController = ViewContext.RouteData.Values["controller"] as string ?? "Principal";
    var currentAction = ViewContext.RouteData.Values["action"] as string ?? "Index";
    var currentTipo = ViewContext.RouteData.Values["tipo"] as string ?? "";

    var currentId = ViewContext.RouteData.Values["id"] as string ?? "0";

    currentController = currentController.ToLower();
    currentAction = currentAction.ToLower();
    currentTipo = currentTipo.ToLower();
    var currentPage = (currentController + "-" + currentAction + currentTipo).ToLower();

    var user = new BLL.Usuarios();
    var controleAcesso = user.ControleAcesso(currentAction, currentController);

    var dadosUser = user.Carregar(BLL.Usuarios.GetUsuarioId());

    var bllFiliais = new BLL.Filiais();
    var bllUsuariosFiliais = new BLL.UsuariosFiliais();
    SelectList listaFiliais;

    listaFiliais = (SelectList)bllFiliais.ListarTipos(true);
    if (BLL.Usuarios.GetVisualizaOutrasFiliais())
    {
        //filiaisSelecionadas
        listaFiliais = (SelectList)bllUsuariosFiliais.ListarTiposAcessos(BLL.Usuarios.GetUsuarioId());    
    }
    
    SelectListItem selected = listaFiliais.FirstOrDefault(x => x.Value == BLL.Usuarios.GetFilialId().ToString());
    if (selected != null)
    {
        listaFiliais = new SelectList(listaFiliais, "value", "text", selected.Value);
    }

    var _copyright = BLL.Utils.Funcoes.GetWebConfigKey("copyright");
    

    string bg = BLL.Usuarios.GetEmpresaId().ToString();

    if (BLL.Usuarios.GetFilialId() > 0)
    {
        bg += "_" + BLL.Usuarios.GetFilialId().ToString();
    }



    var index_agendamento = user.ControleAcesso("index", "agendamento");
    var pessoas_pesquisarapida = user.ControleAcesso("pesquisarapida", "pessoas");
    var agenda_agendamento = user.ControleAcesso("agenda", "agendamento");
    var calendario_agendamento = user.ControleAcesso("calendario", "agendamento");
    var regras_nobreadcrumb = user.ControleAcesso("nobreadcrumb", "regras");

    var largura = BLL.Utils.Funcoes.GetMaxWidth();

    var urlPesquisa = "~/Pessoas/PesquisaRapida/?lightbox[iframe]=true&lightbox[width]=" + largura + "&lightbox[height]=520";
}
