                        <a href="@Url.Content(urlPesquisa)" class="btn ui-lightbox">Pesquisar <i class="fa fa-search"></i></a>
                    </div>
                }
                    
                    @if (BLL.Usuarios.GetUtilizaFilial() && (BLL.Usuarios.GetFilialIDMaster() == 0 || BLL.Usuarios.GetVisualizaOutrasFiliais()))
                    {
