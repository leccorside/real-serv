    <div id="content">


        <div class="container-fluid">
            <span class="cwell hidden">
                <small>@BLL.Usuarios.GetUtilizaFilial() / GetFilialId: @BLL.Usuarios.GetFilialId() / GetFilialIDMaster: @BLL.Usuarios.GetFilialIDMaster() / GetVisualizaOutrasFiliais: @BLL.Usuarios.GetVisualizaOutrasFiliais()</small>
            </span>
            
            <div class="row-fluid">
                @if (pessoas_pesquisarapida)
                {
