
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
 
    <title>@ViewBag.Title</title>



    <!-- Stylesheets -->
    <link href="~/Assets/themes/metro/style/bootstrap.css" rel="stylesheet" />
    

    <link href="~/Assets/themes/metro/style/style.css" rel="stylesheet">

    <link href="~/Assets/themes/metro/style/bootstrap-responsive.css" rel="stylesheet">



   <link href="~/Assets/themes/metro/css/font-awesome.min.css" rel="stylesheet" />

    <style>
       
html {
    min-height: 100%;
    background: #eaeaea url('@VirtualPathUtility.ToAbsolute("~/Assets/img/bg/" + ViewBag.EmpresaId + "Home.jpg")') 100% 100% no-repeat;
    -webkit-background-size: cover;
    -o-background-size: cover;
    background-size: cover;
}

body {
    min-height: 100%;
    xxxfont: 20px/1.4 'PT Sans', sans-serif;
    color: #000;
    @*text-shadow: 0 1px 1px rgba(0, 0, 0, 0.33);*@
    background: transparent;
}

        table{background:#eaeaea};

        
    </style>
</head>

<body>
    <header></header>
    <div class="container">


        
    <div id="loginbox">

        @RenderBody()

    </div>
        <div class="row-fluid">
            <div class="span4"></div>
            <div class="span4">
                @if (!@Html.ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-error" id="alert-error">
                        <h4>Ooops!</h4>
                        @Html.ValidationSummary("", new { @class = "unstyled" })
                    </div>
                }
                @if (TempData["message"] != null)
                {
                    <div class="alert alert-success">
                        <h2>Sucesso!</h2>
                        @TempData["message"]
                    </div>
                }
                @if (TempData["error"] != null)
                {
                    <div class="alert alert-danger">
                        <h2>Atenção!</h2>
                        @TempData["error"]
                    </div>
                }
            </div>
            <div class="span4"></div>
        </div>
    </div>
    
    <!-- Le javascript
    ================================================== -->
    <!-- Placed at the end of the document so the pages load faster -->
    @Scripts.Render("~/Assets/themes/metro/js/jquery.js")
    @*@Scripts.Render("~/Assets/themes/unicorn/js/jquery.min.js")
    @Scripts.Render("~/Assets/themes/unicorn/js/unicorn.login.js")*@
    @RenderSection("scripts", required: false)
</body>
</html>
