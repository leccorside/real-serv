    <div class="container-fluid">
        <div class="row-fluid">

           @* @if (Bll.Acessos.ListarQtdItensMenu() > 0)
            {
                <div id="menu-left" class="span3">

                    @Html.Partial("~/Views/Foo/_MenuSistema.cshtml")

                </div>    
            }*@



            <div id="content" class="span12 section-body">

                <br />
                
                <blockquote>
                    <h3>@ViewBag.Title</h3>
                </blockquote>

                <ul class="breadcrumb">
                    <li><a href="@Url.Content("~/Principal")" title="Ir para Home" class="tip-bottom"><i class="fa fa-home"></i> Home</a></li>

                    @RenderSection("breadcrumb", required: false)

                    @if (currentPage != "principal-index")
                    {
                        <li class="active"><span class="divider">/</span> @ViewBag.Title</li>
                    }

                </ul>


                @Html.Partial("~/Views/Foo/_RenderErros.cshtml")


                @if (dadosUser == null)
                {
                    <div class="row-fluid">
                        <div class="span12">
                            <div class="alert alert-error" id="alert-error">
                                <h4>Ooops... Parece que sua sessão foi encerrada</h4>


                                <small>Entre novamente com seu login e senha. <a href="@Url.Content("~/Manager/Home/Logoff")">Clique aqui</a></small>
                            </div>
                        </div>
                    </div>
                    <div style="display: none;">
                        @RenderBody()
                    </div>
                }
                else if (dadosUser.AcessoRestrito == true && Request.UserHostAddress.Trim() != dadosUser.AcessoIP.Trim())
                {
                    <div class="row-fluid">
                        <div class="span12">
                            <div class="alert alert-error" id="alert-error">
                                <h4>Ooops... Parece que seu perfil possui restrição de acesso ao sistema</h4>

                                <h6>Qual o motivo para restrição de acesso:</h6>
                                Você não está acessando do IP: @dadosUser.AcessoIP<br />
                                Seu IP atual: @Request.UserHostAddress<br />
                                <small>Se você acha que essa mensagem não se aplica à você, entre em contato.</small>
                            </div>
                        </div>
                    </div>
                    <div style="display: none;">
                        @RenderBody()
                    </div>
               
                }
                else
                {
                    if (controleAcesso)
                    {
                
           
               
                        
                    <div class="row-fluid">
                        <div class="span12">
                            @RenderBody()
                            <div class="clearfix"></div>
                        </div>
                    </div>
                        

            
                    }
                    else
                    {
                    <div class="row-fluid">
                        <div class="span12">
                            <div class="alert alert-error" id="alert-error">
                                <h4>Ooops... Você não possui acesso à este módulo</h4>
                                <br />
                                @currentController / @currentAction
                            </div>
                        </div>
                    </div>
                    <div style="display: none;">
                        @RenderBody()
                    </div>
                    }
                }
                <!-- ./renderBody-->











            </div>

        </div>
        @Html.Partial("~/Views/Foo/_Footer.cshtml")

