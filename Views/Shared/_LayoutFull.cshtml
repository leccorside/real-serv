    <script src="~/Assets/dashboardV3/js/jquery.maskedinput.js"></script>
    <script src="~/Assets/dashboardV3/js/jquery.maskMoney.js"></script>
    <script src="~/Assets/bootstrap/js/chosen.jquery.js"></script>
    <script src="~/Assets/bootstrap/js/angular.min.js"></script>
    <script src="~/Assets/bootstrap/js/bootstrap-tagsinput.js"></script>
    <script src="~/Assets/bootstrap/js/bootstrap-tagsinput-angular.js"></script>
    <script src="~/Assets/bootstrap/js/custom.js"></script>
    
    @*@Scripts.Render("~/bundles/jquery") *@
    
    @RenderSection("scripts", required: false)



    @if (modal != null)
    {

        if (Session["modalView_" + modal.ModalId] != "true")
        {
        <!-- Modal -->
        <div id="myModal" class="modal hide fade" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true">×</button>
                <h3 id="myModalLabel">@modal.Titulo</h3>
            </div>
            <div class="modal-body">
                @Html.Raw(modal.Conteudo)
            </div>
        </div>
        <script>$('#myModal').modal('show')</script>

            Session["modalView_" + modal.ModalId] = "true";
        }
    }

</body>
</html>





