@model Models.ContratoView


@{
    

    
    var acao = "Cadastrar";
    if (Model.Contrato.ContratoId > 0)
    {
        acao = "Alterar";
    }


    ViewBag.Title = acao + " Contrato";

    if (Model.Contrato.Modal)
    {
        Layout = "~/Views/Shared/_FortunaLayoutModal.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_FortunaLayout.cshtml";
    }

   
    
}





@section Breadcrumb{

    <li class="active">@Html.ActionLink("Contratos", "Index", new { id = 0 })</li>
}



<div class="content ">

    <div class="row">
        <div class="col-lg-12">
            <div class="hpanel">
                @Html.Partial("~/Views/Contratos/_tabs.cshtml", Model)
                <div class="panel-body">
                    @Html.Partial("~/Views/Contratos/_resumo.cshtml", Model)
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12">
            <div class="hpanel">
                <div class="panel-body">

                    <ul style="list-style: none; margin: 0px !important; padding: 0px !important;">
                        @foreach (var item in Model.ListPessoaPlano)
                        {
                            var selecionado = (item.PessoaPlanoId == Model.Contrato.PessoaPlanoId);
                            <li class="col-sm-4" style="">

                                <div class="hpanel plan-box @(selecionado ? "hgreen" : "hyellow") @(selecionado ? "active" : "")">
                                    <div class="panel-heading hbuilt text-center">
                                        <h4 class="font-bold">@item.PessoaPlanoTitulo</h4>
                                    </div>
                                    <div class="panel-body">
                                        <p class="text-muted">
                                            @Html.Raw(item.PessoaPlanoDescricao)
                                        </p>

                                        <h3 class="font-bold">
                                            @string.Format("{0:N2}", item.PessoaPlanoVlrInscricao)
                                        </h3>
                                        @if (!selecionado)
                                        {
                                            
                                            <a class="btn btn-warning btn-sm m-t-xs" type="button" aria-expanded="true" href="#" onclick="return cubeeConfirm('Atenção','Deseja realmente alterar esse plano?','@Url.Content("~/Contratos/PlanosUpd/" + Model.Contrato.ContratoId + "/?Modal=false&ppid=" + item.PessoaPlanoId)')">Selecionar esse</a>
                                        }
                                        else
                                        {

                                        }

                                    </div>
                                    @if (selecionado)
                                    {
                                        <div class="panel-footer">
                                            Plano selecionado
                                        </div>
                                    }
                                </div>
                            </li>
                                        
                        }
                    </ul>


                </div>
            </div>
        </div>
    </div>
</div>




@section Styles{


    <style>

        .col-sm-4
        {
            height:300px;
        }
    </style>

}


@section Scripts {
    @Scripts.Render("~/bundles/fancybox/js")
    @Scripts.Render("~/bundles/select2/js")
    @Scripts.Render("~/bundles/datepicker/js")
    @Scripts.Render("~/bundles/mask/js")


}
