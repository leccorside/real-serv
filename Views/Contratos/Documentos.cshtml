@model Models.ContratoView


@{
    

    
    var acao = "Cadastrar";
    if (Model.Contrato.ContratoId > 0)
    {
        acao = "Alterar";
    }


    ViewBag.Title = acao + " Contrato";

    if (Model.Contrato.Modal)
    {
        Layout = "~/Views/Shared/_FortunaLayoutModal.cshtml";
    }
    else
    {
        Layout = "~/Views/Shared/_FortunaLayout.cshtml";
    }

   
    
}





@section Breadcrumb{
    
    <li class="active">@Html.ActionLink("Contratos", "Index", new { id = 0 })</li>
}



<div class="content ">
    
    <div class="row">
        <div class="col-lg-12">
                <div class="hpanel">
                    @Html.Partial("~/Views/Contratos/_tabs.cshtml", Model)
                    <div class="panel-body">
                        @Html.Partial("~/Views/Contratos/_resumo.cshtml", Model)
                    </div>
                </div>
            </div>
    </div>

    <div class="row">
        <div class="col-lg-3" style="">
            <div class="hpanel">
                <div class="panel-body">
                    <ul class="h-list m-t">
                        <li class="active"><a href="@Url.Content("~/DocumentosArquivos/Index/" + Model.Contrato.ContratoId + "/contratos/")" class="fancybox_recarrega fancybox.iframe"><i class="fa fa-folder"></i>Documentos</a></li>
                    </ul>
                </div>

            </div>
        </div>
        <div class="col-lg-9" style="">
            @Html.Partial("~/Views/DocumentosArquivos/_ListDocumentos.cshtml", Model.ListDocumentosArquivos)
        </div>
    </div>
</div>



@section Styles{
    @Styles.Render("~/bundles/fancybox/css")
    @Styles.Render("~/bundles/select2/css")
}





@section Scripts {

    @Scripts.Render("~/bundles/fancybox/js")
    @Scripts.Render("~/bundles/select2/js")

    <script type="text/javascript">


        $(document).ready(function () {
            $('.chosen-select').select2();
            $(".fancybox").fancybox({
                fitToView: false,
                width: '80%',
                autoSize: false
            });
            $(".fancybox_recarrega").fancybox({
                fitToView: false,
                width: '80%',
                autoSize: false,
                beforeClose: function () {
                    RecarregaPagina();
                },
            });
            $(".fancybox_full").fancybox({
                fitToView: false,
                width: '100%',
                autoSize: false,
                closeClick: false,
                openEffect: 'none',
                closeEffect: 'none'
            });
        });



        function RecarregaPagina() {
            window.location.reload(true);
        }

    </script>



}

