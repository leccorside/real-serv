@model Models.MedProdutoFavoritoItemView


@{
    ViewBag.Title = "Excluir Produtos & Exames Favoritos";

    Layout = "~/Views/Shared/_FortunaLayout.cshtml";  
    
}


@section Breadcrumb{
    <li class="active">@Html.ActionLink("Produtos & Exames Favoritos", "Index", new { id = 0 })</li>
}


<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">
            <div class="alert alert-warning">
                <i class="fa fa-exclamation-triangle" aria-hidden="true"></i><strong>Atenção</strong> Você tem certeza que deseja apagar esse registro?
            </div>

            <div class="hpanel">
                <div class="panel-body">
                    <!-- conteudo aqui -->


                    <div class="row">

                        <div class="col-lg-3">
                            <div class="display-label">
                                @Html.DisplayNameFor(model => model.MedProdutoFavoritoId)
                            </div>
                            <div class="display-field">
                                <h4>@Html.DisplayFor(model => model.MedProdutoFavoritoId)</h4>
                            </div>

                        </div>
                        <div class="col-lg-9">

                            <div class="display-label">
                                @Html.DisplayNameFor(model => model.MedProdutoFavorito.MedProdutoFavoritoNome)
                            </div>
                            <div class="display-field">
                                <h4>@Html.DisplayFor(model => model.MedProdutoFavorito.MedProdutoFavoritoNome)</h4>
                            </div>

                        </div>
                        
                        <div class="col-lg-12">
                            <br />
                            <table cellpadding="1" cellspacing="1" class="table" id="table_produtos">
                <thead>
                    <tr>
                        <th>Cód.</th>
                        <th>Produto / Exame</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.ListMedProdutoFavoritoItem)
                    {
                    
                        <tr>
                            <td>@item.MedProdutoCod</td>
                            <td>
                                @item.MedProdutoNome
                            </td>
                        </tr>	 
                    }
                </tbody>
            </table>
                        </div>
                    </div>




                    <!-- ./conteudo aqui -->
                </div>
                <div class="panel-footer">

                    @using (Html.BeginForm())
                    {
                        <div class="row">
                            <div class="col-lg-12">
                                @Html.HiddenFor(model => model.MedProdutoFavorito.MedProdutoFavoritoId)
                                    <input type="submit" value="Apagar" class="btn btn-danger" />
                                
                                    @Html.ActionLink("Voltar", "Index", null, new { @class = "btn btn-outline btn-primary" })
                                
                            </div>
                        </div>    
                    }

                </div>
            </div>

        </div>
    </div>
</div>


