@model Models.MedProdutoFavorito

@{
    ViewBag.Title = "Criar Produtos & Exames Favoritos";

    Layout = "~/Views/Shared/_FortunaLayout.cshtml";  
    
}

@section Breadcrumb{
    <li class="active">@Html.ActionLink("Produtos & Exames Favoritos", "Index", new { id = 0 })</li>
}


<div class="content ">

    <div class="row">
        <div class="col-lg-12">
            <div class="hpanel">


                <ul class="nav nav-tabs">
                    <li class="active"><a href="#">Dados Gerais</a></li>
                    <li><a href="#" id="btn-produtos-exames">Produtos / Exames</a></li>
                </ul>

                <div class="tab-content">
                    <div id="tab-1" class="tab-pane active">
                        <div class="panel-body">
                            <!-- conteuod aqui -->
                            @using (Html.BeginForm("Criar", "MedProdutosFavoritos", FormMethod.Post, new { @id = "form-criar" }))
                            {
                                @Html.ValidationSummary(true)
                                @Html.HiddenFor(m => m.MedProdutoFavoritoId);
                                @Html.HiddenFor(m => m.RegStatus);
                                @Html.HiddenFor(m => m.RegDtInicio);
                                <input type="hidden" value="produtos" id="destino" name="destino" />
                                
                                <div class="row">
                                    <div class="form-group col-lg-2">
                                        <label>Favorito n.</label>
                                        <p class="form-control-static">@Model.MedProdutoFavoritoId</p>
                                    </div>
                                    <div class="form-group col-lg-10">
                                        <label>Favorito</label>
                                        @Html.TextBoxFor(model => model.MedProdutoFavoritoNome, new { @class = "form-control" })
                                    </div>
                                </div>
                                
                                
                                <br />
                                <div class="row">
                                    <div class="col-lg-12">
                                        <button name="salvar" id="btn-salvar" value="true" type="submit" class="btn btn-primary  btn-large ">Próximo <i class="fa fa-chevron-right"></i></button>
                                    </div>
                                </div>
        
                            }

                            <!-- ./conteudo aqui -->
                        </div>
                    </div>
                </div>
            </div>


        </div>
    </div>









</div>


















@section Scripts {

    <script>

        $('#btn-produtos-exames').click(function () {
            console.log('ok');
            $('#destino').val("produtos");
            $('#form-criar').submit();
        });
    </script>
}

