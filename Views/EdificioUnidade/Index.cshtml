@{
    ViewBag.Title = "Edifícios / Unidades";
}



@section Breadcrumb{


}



<div class="row-fluid">
    <div class="span12">
        @Html.ActionLink("+ Criar", "Criar", new { id = 0 }, new { @class = "btn btn-primary" })
    </div>
</div>




<div class="row-fluid">

    <div class="span12">
        <table class="table table-bordered table-striped">
            <thead>
                <tr>

                    <th>Cliente
                    </th>
                    <th>Descrição / Nome
                    </th>
                    <th>Endereço</th>
                    <th>Situação</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>

                @for (int i = 0; i < 10; i++)
                {
                    var classe = "";
                    var situacao = "Mapeado";
                    var tipolabel = "badge-success";
                    if (i == 3 || i == 6)
                    {
                        classe = "info";
                        situacao = "Não mapeado";
                        tipolabel = "badge-important";
                    }
                    <tr class="@classe">
                        <td nowrap><a href="#"><i class="icon-search"></i></a>@(i + 124) - Cliente @i</td>
                        <td width="100%">Edifício Teste @i</td>
                        <td nowrap>Rua Teste, @(i + 23) - Bairro X - São Paulo - SP</td>
                        <td nowrap><span class="badge @tipolabel">@situacao</span></td>
                        <td nowrap>@Html.ActionLink("Alterar", "Criar", new { id = 0 }, new { @class = "btn btn-mini" }) |
            @Html.ActionLink("Excluir", "Deletar", new { id = 0 }, new { @class = "btn btn-mini" })</td>
                    </tr>
                }



            </tbody>



        </table>
    </div>
</div>


