@model Models.EntidadeNome


@{
    

    
    var acao = "Cadastrar";
    if (Model.EntidadeNomeId > 0)
    {
        acao = "Alterar";
    }


    ViewBag.Title = acao + " Entidade";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";   
}





@section Breadcrumb{
    <li class="active">@Html.ActionLink("Configurações", "Configuracoes", "Principal")</li>
    <li class="active">@Html.ActionLink("Entidades", "Index", new { id = 0 })</li>
}
<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">

            <div class="hpanel">

                <div class="panel-body">
                    <!-- conteudo aqui -->
                    @using (Html.BeginForm("Criar", "EntidadesNomes", FormMethod.Post, new { @class = "form-horizontal" }))
    {
        @Html.ValidationSummary(true)

        if (Model.EntidadeNomeId > 0)
        {
        @Html.Hidden("EntidadeNomeId", Model.EntidadeNomeId);
                                            acao = "Alterar";
        }
                        
                        <div class="row">
                            
                            <div class="col-form col-lg-4 col-md-4 col-sm-4">
                                <label>Nomenclatura</label>
                                @Html.TextBoxFor(model => model.EntidadeNomenclatura, new { @class = "form-control" })
                                @Html.ValidationMessageFor(model => model.EntidadeNomenclatura)
                            </div>
                            <div class="col-form col-lg-8 col-md-8 col-sm-8">
                                <label>Descrição</label>
                                @Html.TextBoxFor(model => model.EntidadeDescricao, new { @class = "form-control" })
                                @Html.ValidationMessageFor(model => model.EntidadeDescricao)
                            </div>
                        
                            <div class="col-form col-lg-4 col-md-4 col-sm-4">
                                <label>Tabela Auxiliar</label>
                                @Html.TextBoxFor(model => model.TabelaAux1Nome, new { @class = "form-control" })
                                @Html.ValidationMessageFor(model => model.TabelaAux1Nome)
                            </div>

                            <div class="col-form col-lg-4 col-md-4 col-sm-4">
                                <label>Coluna Identificador</label>
                                @Html.TextBoxFor(model => model.TabelaAux1CampoId, new { @class = "form-control" })
                                @Html.ValidationMessageFor(model => model.TabelaAux1CampoId)
                            </div>

                            <div class="col-form col-lg-4 col-md-4 col-sm-4">
                                <label>Coluna Nome</label>
                                @Html.TextBoxFor(model => model.TabelaAux1CampoValue, new { @class = "form-control" })
                                @Html.ValidationMessageFor(model => model.TabelaAux1CampoValue)
                            </div>
                        </div>
                       
                        
                        <div class="row">
                            <div class="col-lg-12">
                                <input type="submit" value="Salvar" class="btn btn-primary btn-large" tabindex="11" />
                                @Html.ActionLink("Voltar", "Index", new { id = 0 }, new { @class = "btn btn-outline btn-primary"})
                            </div>

                        </div>
            
                    }

                    <!-- ./conteudo aqui -->
                </div>

            </div>
        </div>
    </div>
</div>






















@section Scripts {
    <script>
        $("#EntidadeNome").focus();
    </script>
}
