@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")


    <script src="~/Scripts/jquery.cep-1.0.min.js"></script>
    <script>
        $(function () {

            $('#Pessoa_Nome').focus();
            $("#Pessoa_Telefone").mask("(99)9999-9999?9");
            $("#Pessoa_Celular").mask("(99)9999-9999?9");
            $("#PessoaDadoClinico_PessoaDadoClinicoMedicoTel").mask("(99)9999-9999?9");
            $("#Pessoa_Cep").mask("99999-999");
            $("#Pessoa_DataNascimento").mask("99/99/9999");
            $("#Pessoa_HepatiteData").mask("99/99/9999");
            verificaTermos();
        });



        //$("input[data-val-length-max]").each(function (index, element) {
        //    var length = parseInt($(this).attr("data-val-length-max"));
        //    $(this).prop("maxlength", length);
        //});




        jQuery(function () {

            $('#btnSubmit').click(function () {
                if ($('#PessoaDadoClinico_TermoAceite').is(":checked")) {
                    $("#formName").submit();
                } else {
                    alert("Para avançar você deve aceitar os termos.");
                    return false;

                }
            });

            //$('#buscar-cep').click(function () {
            $('#Pessoa_Cep').change(function () {
                $('#Pessoa_Cep').cep({
                    load: function () {
                        //Exibe a div loading
                        $('#loading').show();
                    },
                    complete: function () {
                        //Esconde a div loading
                        $('#loading').hide();
                    },
                    error: function (msg) {
                        //Exibe em alert a mensagem de erro retornada
                        alert(msg);
                        //$('#Pessoa_Cep').focus();
                    },
                    success: function (data) {
                        $('#Pessoa_Endereco').val(data.tipoLogradouro + ' ' + data.logradouro);
                        $('#Pessoa_Bairro').val(data.bairro);
                        $('#Pessoa_Estado').val(data.estado);
                        $('#Pessoa_Cidade').val(data.cidade);
                        $('#Pessoa_Pais').val('Brasil');
                        $('#Pessoa_Numero').focus();
                    }
                });
            });


            $('#PessoaDadoClinico_ServicoId').click(function () {
                verificaTermos();
                
            });



        });


        function verificaTermos() {
            var vid = $("#PessoaDadoClinico_ServicoId").val();

            if (vid > 0) {
                $.getJSON('@Url.Content("~/ApiIntegracao/GetServico/")', { id: $("#PessoaDadoClinico_ServicoId").val() }, function (data) {
                    console.log(data.Objeto.ServicoTermos);
                    $("#lbltermos").html(data.Objeto.ServicoTermos);
                    });
                }

        }

    </script>
}
