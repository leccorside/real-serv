            <div class="editor-field">
               @Model.PessoaDadoClinico.PressaoArterial
            </div>
        </div>
        <div class="span3">
            <div class="editor-label">
                @Html.LabelFor(model => model.PessoaDadoClinico.Alergia)
            </div>
            <div class="editor-field">
                <i class="@(Model.PessoaDadoClinico.Alergia?"fa fa-check-square-o":"fa fa-square-o")"></i>
            </div>
        </div>
        <div class="span3">
            <div class="editor-label">
                @Html.LabelFor(model => model.PessoaDadoClinico.AlergiaTipos)
            </div>
            <div class="editor-field">
                @Model.PessoaDadoClinico.AlergiaTipos
            </div>
        </div>
    </div>
    <br />
    <div class="row-fluid">
        <div class="span6">
            <div class="editor-label">
                @Html.LabelFor(model => model.PessoaDadoClinico.TratamentoRecente)
            </div>
            <div class="editor-field">
               <i class="@(Model.PessoaDadoClinico.TratamentoRecente?"fa fa-check-square-o":"fa fa-square-o")"></i>
            </div>
        </div>
        <div class="span3">
            <div class="editor-label">
                @Html.LabelFor(model => model.PessoaDadoClinico.TratamentoRecenteTipos)
            </div>
            <div class="editor-field">
            @Model.PessoaDadoClinico.TratamentoRecenteTipos
            </div>
        </div>
        <div class="span3">
            <div class="editor-label">
                @Html.LabelFor(model => model.PessoaDadoClinico.TratamentoRecenteDrugs)
            </div>
            <div class="editor-field">
               @Model.PessoaDadoClinico.TratamentoRecenteDrugs
            </div>
        </div>
    </div>
    <br />
    <div class="row-fluid">
        <div class="span6">
            <div class="editor-label">
                @Html.LabelFor(model => model.PessoaDadoClinico.PessoaDadoClinicoMedico)
            </div>
            <div class="editor-field">
              @Model.PessoaDadoClinico.PessoaDadoClinicoMedico
            </div>
        </div>
        <div class="span6">
            <div class="editor-label">
                @Html.LabelFor(model => model.PessoaDadoClinico.PessoaDadoClinicoMedicoTel)
            </div>
            <div class="editor-field">
             @Model.PessoaDadoClinico.PessoaDadoClinicoMedicoTel
            </div>
        </div>
    </div>
    <br />
    <div class="row-fluid">
        <div class="span3">
            <div class="editor-label">
                @Html.LabelFor(model => model.PessoaDadoClinico.Gestante)
            </div>
            <div class="editor-field">
               <i class="@(Model.PessoaDadoClinico.Gestante?"fa fa-check-square-o":"fa fa-square-o")"></i>
            </div>
        </div>
        <div class="span3">
            <div class="editor-label">
                @Html.LabelFor(model => model.PessoaDadoClinico.ConsumoDrugsUlt4Horas)
            </div>
            <div class="editor-field">
                <i class="@(Model.PessoaDadoClinico.ConsumoDrugsUlt4Horas?"fa fa-check-square-o":"fa fa-square-o")"></i>
            </div>
        </div>
    </div>
    <br />
    <div class="row-fluid">
        <div class="span12">
            <div class="editor-label">
                @Html.LabelFor(model => model.PessoaDadoClinico.ObservacaoMedica)
            </div>
            <div class="editor-field">
                @Model.PessoaDadoClinico.ObservacaoMedica
            </div>
        </div>
    </div>
    <br />
    <div class="row-fluid">
        <div class="span12 cwell">
            <div class="editor-field">
                <label>Serviço</label>
                @Model.PessoaDadoClinico.ServicoNome<br />
                
                @if (Model.PessoaDadoClinico.LocalCorpoServico != "" && Model.PessoaDadoClinico.LocalCorpoServico !=null)
                {
                <label>Local do serviço no corpo</label>
                @Model.PessoaDadoClinico.LocalCorpoServico<br />    
                }
                
                <label>Profissional</label>
                @Model.PessoaDadoClinico.PessoaIDIndicacaoNome<br />

                <label>Termos</label>
                <small>@Model.PessoaDadoClinico.ServicoTermos</small>
                
                    
                
            </div>
        </div>
    </div><br />
     <i class="fa fa-check-square-o"></i> Aceito os termos<br />
    <img alt="@Model.Pessoa.Nome"  onerror="this.src='http://1x1px.me/FFFFFF-0.8.png'" src="@Url.Content("~/Content/Uploads/Signs/"+Model.PessoaDadoClinico.PessoaDadoClinicoId+"_"+Model.PessoaDadoClinico.PessoaId+".png")" style="border:1px solid;background-color:#fff;" />

    @*<img alt="@Model.Pessoa.Nome" onerror="this.src='http://1x1px.me/FFFFFF-0.8.png'" src="data:image/png;base64,@Model.PessoaDadoClinico.PessoaAssinatura" style="border:1px solid;background-color:#fff;" />

    <div class="assinado signed"> <div class="sigWrapper"> <div class="typed" style="display: none;">@Model.Pessoa.Nome</div> <canvas class="pad"  width="400" height="120"></canvas> </div> <p>@Model.Pessoa.Nome<br /><small>@Model.Pessoa.Documento</small><br>@String.Format("{0:d MMMM, yyyy}", Model.PessoaDadoClinico.RegDtInicio)</p> </div>*@

     

    


</div>


<br />



