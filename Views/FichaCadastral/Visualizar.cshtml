@model Models.FichaCadastral
@{
    ViewBag.Title = "Confirme seus dados e assine digitalmente";
    Layout = "~/Views/Shared/_LayoutBranco.cshtml";
    
    //http://thomasjbradley.ca/lab/signature-pad/#regenerate

}
@section Styles {


    <link href="~/Assets/plugins/signature-pad/jquery.signaturepad.css" rel="stylesheet" />
    <style>
        small {
            font-size: 10px;
            line-height: 0px;
    }
    </style>
}

<div class="cwell">
    <legend>Dados Pessoais</legend>
    <div class="row-fluid">
        <div class="span9">
            <label>Nome Completo</label>
            @Model.Pessoa.Nome
            
        </div>
        <div class="span3">
            <label>Como nos conheceu?</label>
            @Model.Pessoa.MidiaNome
            
        </div>
    </div>
    <br />
    <div class="row-fluid">
        <div class="span3">
            <label>Documento</label>
            @Model.Pessoa.Documento
        </div>
        <div class="span3">
            <label>RG</label>
            @Model.Pessoa.Rg
        </div>
        <div class="span3">
            <div class="editor-label">
                Data de Nascimento
            </div>
            <div class="editor-field">
                @String.Format("{0:dd/MM/yyyy}", Model.Pessoa.DataNascimento)
            </div>
        </div>
        <div class="span3">
            <div class="editor-label">
                @Html.LabelFor(model => model.Pessoa.Sexo)
            </div>
            <div class="editor-field">
                @Model.Pessoa.Sexo
                
            </div>
        </div>
    </div>
    <br />
    <div class="row-fluid">
        <div class="span3" id="div_ecivil">
            <div class="editor-label">
                Estado Civil
            </div>
            <div class="editor-field">
               @Model.Pessoa.EstadoCivlNome
            </div>
        </div>
        <div class="span3" id="div_profissao">
            <label>Profissão</label>
            @Model.Pessoa.Profissao
        </div>
        <div class="span3">
            <label>Idade</label>
            @BLL.Utils.Funcoes.CalculaIdade(Model.Pessoa.DataNascimento)
        </div>
    </div>

    <legend>Contato</legend>
    <div class="row-fluid">
        <div class="span4">
            <div class="editor-label">
                @Html.LabelFor(model => model.Pessoa.Email)
            </div>
            <div class="editor-field">
              @Model.Pessoa.Email
            </div>
        </div>
        <div class="span4">
            <div class="editor-label">
                @Html.LabelFor(model => model.Pessoa.Telefone)
            </div>
            <div class="editor-field">
                @Model.Pessoa.Telefone
            </div>
        </div>
        <div class="span4">
            <div class="editor-label">
                @Html.LabelFor(model => model.Pessoa.Celular)
            </div>
            <div class="editor-field">
               @Model.Pessoa.Celular
            </div>
        </div>
    </div>

    <legend>Endereço</legend>
    <div class="row-fluid">
        <div class="span4">
            <div class="editor-label">
                @Html.LabelFor(model => model.Pessoa.Cep)
            </div>
            <div class="editor-field">
                  @Model.Pessoa.Cep
            </div>
        </div>
        <div class="span4">
            <div class="editor-label">
                @Html.LabelFor(model => model.Pessoa.Endereco)
            </div>
            <div class="editor-field">
               @Model.Pessoa.Endereco
            </div>
        </div>
        <div class="span4">
            <div class="editor-label">
                @Html.LabelFor(model => model.Pessoa.Numero)
            </div>
            <div class="editor-field">
               @Model.Pessoa.Numero
            </div>
        </div>
    </div>
    <br />
    <div class="row-fluid">
        <div class="span4">
            <div class="editor-label">
                @Html.LabelFor(model => model.Pessoa.Complemento)
            </div>
            <div class="editor-field">
               @Model.Pessoa.Complemento
            </div>
        </div>
        <div class="span4">
            <div class="editor-label">
                @Html.LabelFor(model => model.Pessoa.Bairro)
            </div>
            <div class="editor-field">
               @Model.Pessoa.Bairro
            </div>
        </div>
        <div class="span4">
            <div class="editor-label">
                @Html.LabelFor(model => model.Pessoa.Cidade)
            </div>
            <div class="editor-field">
              @Model.Pessoa.Cidade
            </div>
        </div>
    </div>
    <div class="row-fluid">
        <div class="span4">
            <div class="editor-label">
                @Html.LabelFor(model => model.Pessoa.Estado)
            </div>
            <div class="editor-field">
              @Model.Pessoa.Estado
            </div>
        </div>
        <div class="span8">
            <div class="editor-label">
                <label>Referência</label>
            </div>
            <div class="editor-field">
              @Model.Pessoa.Observacao
            </div>
        </div>
    </div>



    <legend>Dados Clínicos</legend>
    <div class="row-fluid">
        <div class="span3">
            <div class="editor-label">
                @Html.LabelFor(model => model.PessoaDadoClinico.Diabetes)
            </div>
            <div class="editor-field">
                <i class="@(Model.PessoaDadoClinico.Diabetes?"fa fa-check-square-o":"fa fa-square-o")"></i>
            </div>
        </div>
        <div class="span3">
            <div class="editor-label">
                @Html.LabelFor(model => model.PessoaDadoClinico.Hepatite)
            </div>
            <div class="editor-field">
                <i class="@(Model.PessoaDadoClinico.Hepatite?"fa fa-check-square-o":"fa fa-square-o")"></i>
            </div>
        </div>
        <div class="span3">
            <div class="editor-label">
                @Html.LabelFor(model => model.PessoaDadoClinico.HepatiteTipo)
            </div>
            <div class="editor-field">
                @Model.PessoaDadoClinico.HepatiteTipo
            </div>
        </div>
        <div class="span3">
            <div class="editor-label">
                @Html.LabelFor(model => model.PessoaDadoClinico.HepatiteData)
            </div>
            <div class="editor-field">
                @String.Format("{0:dd/MM/yyyy}", Model.PessoaDadoClinico.HepatiteData)
            </div>
        </div>
    </div>
    <br />
    <div class="row-fluid">
        <div class="span3">
            <div class="editor-label">
                @Html.LabelFor(model => model.PessoaDadoClinico.HIV)
            </div>
            <div class="editor-field">
               <i class="@(Model.PessoaDadoClinico.HIV?"fa fa-check-square-o":"fa fa-square-o")"></i>
            </div>
        </div>
        <div class="span3">
            <div class="editor-label">
                @Html.LabelFor(model => model.PessoaDadoClinico.Cicatrizacao)
            </div>
            <div class="editor-field">
                <i class="@(Model.PessoaDadoClinico.Cicatrizacao?"fa fa-check-square-o":"fa fa-square-o")"></i>
            </div>
        </div>
        <div class="span3">
            <div class="editor-label">
                @Html.LabelFor(model => model.PessoaDadoClinico.Anemia)
            </div>
            <div class="editor-field">
                <i class="@(Model.PessoaDadoClinico.Anemia?"fa fa-check-square-o":"fa fa-square-o")"></i>
            </div>
        </div>
        <div class="span3">
            <div class="editor-label">
                @Html.LabelFor(model => model.PessoaDadoClinico.Desmaios)
            </div>
            <div class="editor-field">
                <i class="@(Model.PessoaDadoClinico.Desmaios?"fa fa-check-square-o":"fa fa-square-o")"></i>
            </div>
        </div>
    </div>
    <br />
    <div class="row-fluid">
        <div class="span3">
            <div class="editor-label">
                @Html.LabelFor(model => model.PessoaDadoClinico.Eplepsia)
