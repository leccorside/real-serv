@{
    DateTime DataConsulta = Convert.ToDateTime(ViewBag.DataConsulta);
    ViewBag.Title = "Aniversariantes";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";  

    int mesAtual = DateTime.Now.Month;
}





@section Breadcrumb{
    <li class="active"><span class="divider">/</span> @Html.ActionLink("Relatórios", "Relatorios", "Principal")</li>
}


<div class="cwell">
    @using (Html.BeginForm())
    {
        @Html.ValidationSummary(true)

        <div class="row-fluid">
            <div class="span4">
                <label>Tipo</label>
                <select onchange="Select(this.value);" id="tipo_report" name="tipo_report">
                    <option value="month">aniversariantes do MÊS </option>
                    <option value="week">aniversariantes da SEMANA </option>
                </select>

                

            </div>

            
        </div>

        
        <div class="row-fluid" id="div_mes">
            <div class="span12">
                <label>Selecione o mês</label>
                <select name="mes" id="mes">
                    @for (int i = 1; i < 13; i++)
                    {
                        string newdate = new DateTime(DateTime.Now.Year, i, 1).ToString("MMMM");
                        <option value="@i"  @(mesAtual == i ? " selected " : "")>@newdate</option>
                    }
                </select>
            </div>
        </div>

        <div class="row-fluid" id="div_mes">
            <div class="span12">
                <label>Tipo de Relatório</label>
                <label class="checkbox">

                                        <input type="checkbox" value="col-visible" id="tipo_info" name="tipo_info" /> Completo (apelido, email, telefone, idade e turma)
                                    </label>
            </div>
        </div>



        <div class="form-actions">

            <input type="submit" value="Gerar" formaction="@Url.Content("~/Relatorios/RelatorioAniversariantes")" class="btn btn-primary  btn-large" onclick="return confirm('Esse processo pode demorar alguns minutos?')" />

            <input type="submit" value="Exportar" formaction="@Url.Content("~/Relatorios/RelatorioAniversariantesExportToXls")" class="btn btn-primary  btn-large" onclick="return confirm('Esse processo pode demorar alguns minutos?')" >


        </div>

    }
    <div>
        @Html.ActionLink("Voltar", "Relatorios", "Principal")
    </div>
</div>






@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")


    <script src="~/Content/themes/base/js/plugins/lightbox/jquery.lightbox.min.js"></script>
    <script src="~/Content/themes/base/js/Application.js"></script>
    @*<script src="~/Content/themes/base/js/Gallery.js"></script>*@

    <script src="~/Scripts/jquery.cep-1.0.min.js"></script>
    <script>



        function Select(jtipo) {

            if (jtipo == "month") {
                
                $("#div_mes").show("slow");
                $("#div_semana").hide("slow");

            } else {
                
                $("#div_mes").hide("slow");
                $("#div_semana").show("slow");
            }


        }



        Select($('#tipo_report').val());


    </script>



}
