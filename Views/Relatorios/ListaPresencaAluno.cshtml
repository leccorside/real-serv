@{
    DateTime DataConsulta = Convert.ToDateTime(ViewBag.DataConsulta);
    ViewBag.Title = "Relatório de Presença - " + BLL.Usuarios.GetEntidadeCliente();
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";  
    
}





@section Breadcrumb{
    <li class="active"><span class="divider">/</span> @Html.ActionLink("Relatórios", "Relatorios", "Principal")</li>
}


<div class="cwell">
    @using (Html.BeginForm())
    {
        @Html.ValidationSummary(true)

        <div class="row-fluid">
            <div class="span4">
                <label>@BLL.Usuarios.GetEntidadeCliente()</label>
                @Html.DropDownList("id", (SelectList)ViewBag.ClientesList, "--Selecione--", new { @class = "chosen-select " })

            </div>

            <div class="span4">

            </div>
        </div>


        <div class="row-fluid">
            <div class="span2">
                <label><br />Data Inicial</label>
                
                <input type="text" name="dataDe" title="Data para consulta da agenda" class="datepicker input-small input-small" value="@String.Format("{0:dd/MM/yyyy}", DataConsulta)" />

            </div>
            <div class="span2">
                <label><br />Data Final</label>

                <input type="text" name="dataAte" title="Data para consulta da agenda" class="datepicker input-small input-small" value="@String.Format("{0:dd/MM/yyyy}", DataConsulta)" />

            </div>

            <div class="span4">

            </div>
        </div>






        <div class="form-actions">


            <input type="submit" value="Gerar" class="btn btn-primary  btn-large" />

        </div>

    }
    <div>
        @Html.ActionLink("Voltar", "Relatorios", "Principal")
    </div>
</div>






@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
