@model IEnumerable<Models.Servico>

@{
    var user = new BLL.Usuarios();
    ViewBag.Title = "Servi&ccedil;os";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";
    var configuracao_servico_valor = user.ControleAcesso("configuracao_servico_valor", "Regras");
}

@section Styles {
@Html.Partial("_TableStyles")
}

<div class="ponto-container">
    <div class="ponto-header">
        <div class="ponto-title">
            <h2><i class="pe-7s-settings"></i> Servi&ccedil;os</h2>
        </div>
        @Html.ActionLink("+ Criar", "Criar", new { id = 0 }, new { @class = "btn-create" })
    </div>

    <div class="ponto-table-container">
        <table class="ponto-table">
            <thead>
                <tr>
                    <th>Servi&ccedil;o</th>
                    @if (configuracao_servico_valor)
                    {
                        <th>Individual</th>
                        <th>Valor</th>
                    }
                    <th>Data de In&iacute;cio</th>
                    <th style="width:140px">A&ccedil;&otilde;es</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td width="100%">
                            @item.ServicoNome
                            @if (!string.IsNullOrEmpty(item.ServicoNomeEN_US))
                            {
                                <small>@item.ServicoNomeEN_US</small>
                            }
                        </td>
                        @if (configuracao_servico_valor)
                        {
                            <td nowrap>
                                @if (item.ServicoIndividual)
                                {
                                    <i class="fa fa-check text-success"></i>
                                }
                            </td>
                            <td nowrap>@Html.DisplayFor(m => item.Valor)</td>
                        }
                        <td nowrap>@Html.DisplayFor(m => item.RegDtInicio)</td>
                        <td nowrap>
                            <div class="actions-cell">
                                @Html.ActionLink("Alterar", "Criar", new { id = item.ServicoId }, new { @class = "btn-alterar" })
                                @Html.ActionLink("Excluir", "Deletar", new { id = item.ServicoId }, new { @class = "btn-excluir" })
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>