@model Models.ChangePasswordModel



@{
    

    

    var acao = "Alterar";


    ViewBag.Title = acao + " Senha";
    Layout = "~/Views/Shared/_FortunaLayout.cshtml";   
}





@section Breadcrumb{
    <li class="active">@Html.ActionLink("Configurações", "Configuracoes", "Principal")</li>
    <li class="active">@Html.ActionLink("Usuários", "Index", "Usuarios")</li>
}

<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">

            <div class="hpanel">

                <div class="panel-body">
                    <!-- conteudo aqui -->


                    @using (Html.BeginForm("RedefinirSenha", "Usuarios", FormMethod.Post))
    {
        @Html.ValidationSummary(true)

      
            @Html.HiddenFor(model => model.UsuarioId);

                                                     @Html.Hidden("oldPassword", Guid.NewGuid());
     
        
       
       
                        <div class="row">

                            <div class="col-form col-lg-6 col-md-6 col-sm-6">
                                @Html.LabelFor(model => model.newPassword)
                                @Html.PasswordFor(model => model.newPassword, new { @class = " form-control" })
                            </div>

                            <div class="col-form col-lg-6 col-md-6 col-sm-6">
                                @Html.LabelFor(model => model.ConfirmPassword)
                                @Html.PasswordFor(model => model.ConfirmPassword, new { @class = " form-control" })
                            </div>


                        </div>

                   
                        
                        <div class="row">
                            <div class="col-lg-12">
                                <input type="submit" value="Salvar" class="btn btn-primary btn-large" tabindex="11" />
                                @Html.ActionLink("Voltar", "Index", null,  new { @class = "btn btn-outline btn-primary " })
                            </div>

                        </div>
            
                    }

                    <!-- ./conteudo aqui -->
                </div>

            </div>
        </div>
    </div>
</div>





@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
