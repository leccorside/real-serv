@model PetaPoco.Page<Models.DocumentoArquivo>

@{
    ViewBag.Title = "Templates";
    Layout = "~/Views/Shared/_FortunaLayoutModal.cshtml";

    var id = Url.RequestContext.RouteData.Values["id"];
    var tipo = Url.RequestContext.RouteData.Values["tipo"];
}




@section Breadcrumb{

    <li> @Html.ActionLink("Configurações", "Configuracoes", "Principal")</li>


}


<div class="content animate-panel">

    <div class="row">
        <div class="col-lg-12">
            @Html.ActionLink("+ Criar", "SelecionarTemplate", new { id = 0, entidade = tipo, entidadeid = id }, new { @class = "btn btn-primary" })
        </div>
    </div>

    <div class="row">
        <div class="col-lg-12" style="">
            <div class="hpanel">
                <div class="panel-heading">
                    <div class="panel-tools">
                        <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                    </div>
                    Documentos
                </div>
                <div class="panel-body">
                    <div class="table-responsive">
                        <table class="table table-hover table-condensed table-striped" >
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nome</th>
                    <th>Criado em</th>
                    <th></th>
                    <th></th>
                    <th></th>
                </tr>
            </thead>
            <tbody>

                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.DocumentoArquivoId</td>
                        <td>@item.DocumentoArquivoNome</td>
                        <td>@item.RegDtInicio</td>
                        <td><a href="@Url.Content("~/DocumentosArquivos/View/" + item.DocumentoArquivoId + "?")" class="fancybox fancybox.iframe btn btn-xs btn-outline btn-primary" data-toggle="tooltip" data-original-title="Imprimir"  title="Imprimir" data-placement="top">Imprimir</a></td>
                        <td>@Html.ActionLink("Alterar", "Criar", new { id = item.DocumentoArquivoId, entidade = tipo, entidadeid = id }, new { @class = "btn btn-xs btn-outline btn-primary" })</td>
                        <td>@Html.ActionLink("Excluir", "Deletar", new { id = item.DocumentoArquivoId , entidade = tipo, entidadeid = id}, new { @class = "btn btn-xs btn-outline btn-primary" })</td>
                    </tr>
                }

            </tbody>



        </table>
                    </div>
                    @Html.FortunaPaginacao(Convert.ToInt16(Model.TotalPages))
                </div>

            </div>
        </div>
    </div>

</div>


@section Styles{
    @Styles.Render("~/bundles/fancybox/css")
}





@section Scripts {
    @Scripts.Render("~/bundles/fancybox/js")

    <script type="text/javascript">


        $(document).ready(function () {
            $(".fancybox").fancybox({ fitToView: false, width: '80%', autoSize: false });
            $(".fancybox_full").fancybox({
                fitToView: false,
                width: '100%',
                autoSize: false,
                closeClick: false,
                openEffect: 'none',
                closeEffect: 'none'
            });
        });





    </script>



}
