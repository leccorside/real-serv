@model Models.DocumentoArquivo




@{
    ViewBag.Title = "SelecionarTemplate";
    Layout = "~/Views/Shared/_FortunaLayoutModal.cshtml";
}


<div class="content animate-panel">


    <div class="row">
        <div class="col-lg-12" style="">
            <div class="hpanel">
                <div class="panel-heading">
                    <div class="panel-tools">
                        <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                    </div>
                    Selecione um Template
                </div>
                <div class="panel-body">
                    <div class="table-responsive">
                        <table class="table table-hover table-condensed table-striped">
                            <thead>
                                <tr>
                                    <th></th>
                                    <th>Nome</th>
                                    <th>Descrição</th>

                                </tr>
                            </thead>
                            <tbody>

                                @foreach (var item in Model.ListDocumentoTemplate)
                                {
                                    <tr>
                                        <td>@Html.ActionLink("Novo Documento", "Criar", "DocumentosArquivos", new { id = Model.DocumentoArquivoId, entidade = Model.Entidade, entidadeid = Model.EntidadeId, templateid = item.DocumentoTemplateId }, new { @class = "btn btn-xs btn-outline btn-primary" })</td>
                                        <td>@item.DocumentoTemplateNome</td>
                                        <td>@item.DocumentoTemplateDescricao</td>

                                    </tr>
                                }

                            </tbody>



                        </table>
                    </div>
                    
                </div>

            </div>
        </div>
    </div>

</div>



