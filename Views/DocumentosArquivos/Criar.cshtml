@model Models.DocumentoArquivo


@{
    var pathFileman = "/Assets/plugins/fileman/index.html";


    var acao = "Cadastrar";
    if (Model.DocumentoArquivoId > 0)
    {
        acao = "Alterar";
    }


    ViewBag.Title = acao + " Template";
    Layout = "~/Views/Shared/_FortunaLayoutModal.cshtml"; 
}






<div class="content animate-panel">


    <div class="row">
        <div class="col-lg-12" style="">
            <div class="hpanel">
                <div class="panel-heading">
                    <div class="panel-tools">
                        <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                    </div>
                    Criar Documento
                </div>
                <div class="panel-body">
                    <!-- inicia aqui-->
                    @using (Html.BeginForm())
                    {
                        @Html.ValidationSummary(true)
                        @Html.HiddenFor(m => m.DocumentoArquivoId);    
                        @Html.HiddenFor(m => m.Entidade);
                        @Html.HiddenFor(m => m.EntidadeId);
                        @Html.HiddenFor(m => m.DocumentoTemplateId);
                        <div class="form-group">
                            <label class="col-sm-12 control-label text-left">Nome do Arquivo</label>
                            <div class="col-sm-12">
                                @Html.TextBoxFor(model => model.DocumentoArquivoNome, new { @class = "form-control" })
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label class="col-sm-12 control-label text-left">Conteúdo</label>
                            <div class="col-sm-12">
                                @Html.TextAreaFor(model => model.DocumentoArquivoConteudo, new { @class = "col-lg-12", @rows = 10 })
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <div class="col-sm-12">
                        <button name="salvarfechar" value="true" type="submit" class="btn btn-primary ">Salvar</button>

                                @Html.ActionLink("Voltar", "Index", new {tipo = Model.Entidade, id = Model.EntidadeId  }, new { @class = "btn btn-outline btn-primary" })

                                </div>
                            </div>
                        
                    }
                    <!-- ./inicia aqui-->
                </div>

            </div>
        </div>
    </div>

</div>

    









