@model Models.TransferenciaAssincrona




@{
    ViewBag.Title = "Detalhes";
    Layout = "~/Views/Shared/_FortunaLayoutModal.cshtml";
}


<div class="content animate-panel">

    <div class="row">

        <div class="col-lg-12 col-md-12 col-sm-12">

            <div class="hpanel">

                <div class="panel-heading">
                    <div class="panel-tools">
                        <a class="showhide"><i class="fa fa-chevron-up"></i></a>
                    </div>
                    Detalhes do Arquivo
                        
                </div>

                <div class="panel-body">


                    <div class="row">
                        <div class="row">
                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>Cód. Upload</label><br />
                                @Model.TransferId
                            </div>

                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>Data</label><br />
                                @Model.RegDtInicio
                            </div>

                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>Situação</label><br />
                                @Model.SituacaoCode
                            </div>

                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>Descrição</label><br />
                                @Model.SituacaoDesc
                            </div>
                            <div class="form-group col-lg-5 col-md-5 col-sm-5">
                                <label>Nome arquivo</label><br />
                                <small>@Model.FileName</small>
                            </div>
                            
                            
                            <div class="form-group col-lg-2 col-md-2 col-sm-2">
                                <label>Extensão</label><br />
                                @Model.FileExtensao
                            </div>

                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>Tipo</label><br />
                                <small>@Model.FileContentType</small>
                            </div>


                            <div class="form-group col-lg-2 col-md-2 col-sm-2">
                                <label>Tamanho</label><br />
                                @Model.FileContentLength
                            </div>

                            <div class="form-group col-lg-12 col-md-12 col-sm-12">
                                <label>Detalhe operação</label><br />
                                @Model.SituacaoLog
                            </div>
                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>Qtd. Registros no arquivo</label><br />
                                @(Model.QtdRegistrosIns + Model.QtdRegistrosUpd)
                            </div>
                            
                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>Qtd. Registros Inseridos</label><br />
                                @Model.QtdRegistrosIns
                            </div>
                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>Qtd. Registros Atualizados</label><br />
                                @Model.QtdRegistrosUpd
                            </div>
                            <div class="form-group col-lg-3 col-md-3 col-sm-3">
                                <label>Qtd. Registros Erro</label><br />
                                @Model.QtdRegistrosErr
                            </div>
                        </div>
                    </div>



                </div>
            </div>

        </div>
    </div>

</div>


@section Scripts {

}
