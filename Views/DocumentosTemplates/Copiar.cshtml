
@{
    
    ViewBag.Title = "Copiar";
    Layout = "~/Views/Shared/_FortunaLayoutModal.cshtml";

    
}



@section Breadcrumb{
    
}



<div class="content ">
    <div class="row">
        <div class="col-md-12" style="">

            <div class="hpanel">

                <div class="panel-body">
                    <!-- conteudo aqui -->
                    <div class="col-lg-12" style="">

                        @using (Html.BeginForm("Copiar", "DocumentosTemplates", FormMethod.Post, new { @class = "form-horizontal" }))
                        {
                            
                            
    
       
                            <div class="row">
                                

                                <div class="form-group col-lg-12">
                                    <label>Copiar todos os templates da @BLL.Usuarios.GetEntidadeFilial()</label>
                                    @Html.DropDownList("id", (SelectList)ViewBag.ddlFiliais, new { @class = "chosen-select form-control " })
                                </div>






                            </div>                  
            
                            
         
                            <div class="row">
                                <div class="col-lg-12">
                                    
                                    <button type="submit" class="btn btn-primary btn-large" >Copiar</button>
                                </div>

                            </div>
            
                        }
                    </div>
                    <!-- ./conteudo aqui -->
                </div>

            </div>
        </div>
    </div>
</div>







@section Styles{
    @Styles.Render("~/bundles/select2/css")

}




@section Scripts {

    @Scripts.Render("~/bundles/select2/js")

    <script>
        $('.chosen-select').select2();
    </script>
    

}
