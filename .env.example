# .env.example
# Copie este arquivo para .env e altere os valores para seus ambientes
# NÃO commite o arquivo .env com senhas reais!

# ==========================================
# Configuração da Aplicação
# ==========================================

# Ambiente (Development, Production, Staging)
ASPNETCORE_ENVIRONMENT=Production

# Debug habilitado (false em produção)
DEBUG=false

# ==========================================
# Configuração de Logs
# ==========================================

# Nível de log (Debug, Information, Warning, Error, Critical)
LOG_LEVEL=Information

# ==========================================
# DESENVOLVIMENTO LOCAL - Use este arquivo para override
# ==========================================

# ASPNETCORE_ENVIRONMENT=Development
# DEBUG=true
